    background: var(--deep-navy) url('/blog/hero-small-vs-large.svg') center/cover no-repeat;
    padding-block: clamp(3rem, 6vw, 5rem) clamp(3rem, 5vw, 4.5rem);
    position: relative;
    overflow: hidden;
  }
  .post-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.62);
    pointer-events: none;
  }

  .post-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }

  .post-hero__meta {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }

  .post-hero__date {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.04em;
  }

  .post-tag-pill {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 999px;
    background: rgba(255,255,255,0.10);
    border: 1px solid rgba(255,255,255,0.16);
    color: rgba(255,255,255,0.75);
    font-size: 0.7rem;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .post-hero__h1 {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: var(--white);
    margin-bottom: var(--sp-6);
  }
  .post-hero__h1 em {
    color: rgba(255,255,255,0.45);
    font-weight: 300;
    font-style: normal;
  }

  .post-hero__deck {
    font-family: var(--font-body);
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.68);
    line-height: 1.75;
    max-width: 600px;
    margin-bottom: var(--sp-8);
  }

  .post-hero__byline {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: rgba(255,255,255,0.40);
    letter-spacing: 0.04em;
  }
  .post-hero__sep { opacity: 0.4; }

  /* ── Layout ── */
  .post-body {
    padding-block: clamp(3rem, 6vw, 5rem);
    background: var(--white);
  }

  .post-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  /* ── TOC ── */
  .post-toc {
    position: sticky;
    top: calc(70px + var(--sp-8));
  }

  .post-toc__label {
    font-size: var(--fs-xs);
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: var(--sp-4);
  }

  .post-toc__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    counter-reset: toc;
    padding: 0;
  }

  .post-toc__list li {
    counter-increment: toc;
  }

  .post-toc__list a {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
