    font-size: var(--fs-md);
    color: rgba(255,255,255,0.85);
    line-height: 1.75;
    margin: 0;
  }

  /* ── Back link ── */
  .post-back {
    padding-block: var(--sp-8);
    background: var(--off-white);
    border-top: 1px solid var(--border);
  }

  .post-back__link {
