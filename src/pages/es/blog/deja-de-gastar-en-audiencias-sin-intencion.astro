    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    counter-reset: toc;
    padding: 0;
  }

  .post-toc__list li {
    counter-increment: toc;
  }

  .post-toc__list a {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    color: var(--text-2);
    line-height: 1.5;
