---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';
import FAQ from '../../../components/FAQ.astro';

/* ── Datos ────────────────────────────────────────────── */

const overviewCards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="7" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.6"/><line x1="9" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="9" y1="16" x2="13" y2="16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Gestión de la página de empresa',
    text: 'Tu primera impresión digital, construida y llevada de principio a fin.',
    href: '#svc-company-page',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Producción editorial',
    text: 'Todos los formatos, cada semana, en tus mercados. Contenido que instala tu credibilidad y la sostiene en el tiempo.',
    href: '#svc-content-production',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Newsletter de LinkedIn',
    text: 'Una relación directa con los profesionales que importan para tu negocio.',
    href: '#svc-newsletter',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.6"/><rect x="7" y="14" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.7"/></svg>`,
    title: 'Eventos de LinkedIn',
    text: 'El formato más fuerte de LinkedIn en interacciones. Y cada inscrito es un contacto identificado.',
    href: '#svc-events',
  },
];

const whatWeDo = [
  { title: 'Toda tu producción de contenido, asumida.', body: 'Estrategia, calendario editorial, producción, publicación, informes. Tú validas, del resto nos encargamos nosotros. Tu equipo puede por fin centrarse en su trabajo de verdad.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/></svg>` },
  { title: 'Tu voz, no la nuestra.', body: 'Nos tomamos el tiempo de entender cómo habla tu equipo, qué interesa a tu mercado y a quién estás intentando llegar. Después, redactamos. Y el resultado tiene que leerse como si lo hubieras escrito tú. Si no es así, lo volvemos a hacer.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>` },
  { title: 'Contenido en cada idioma de tus compradores.', body: 'No traducimos. Redactamos de forma nativa, con redactores que piensan en la lengua de destino. ¿Tus prospectos leen en alemán, en mandarín, en español? Escribimos para ellos desde cero.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M3.5 9h17M3.5 15h17" stroke="currentColor" stroke-width="1.6"/><ellipse cx="12" cy="12" rx="4" ry="9" stroke="currentColor" stroke-width="1.6"/></svg>` },
  { title: 'La IA acelera el ritmo. La calidad, esa no se mueve.', body: 'En la práctica, la inteligencia artificial nos ayuda en la investigación, la redacción, el multilingüe, los visuales y el montaje. Pero nuestro equipo editorial lo revisa todo y tú validas todo antes de publicar. Más contenidos, más rápido, a menor coste unitario, y siempre con un humano que tiene la última palabra.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>` },
  { title: 'Informes que hablan a tu dirección comercial.', body: 'Un informe al mes, vinculado a tus objetivos de negocio. Lo que funcionó, lo que arrancó menos, lo que cambiamos. No te mandamos un cuadro de mando con 45 indicadores que nadie sabe interpretar.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 17V13M12 17V9M17 17V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>` },
];

const whyBlocks = [
  { title: 'Solo hacemos esto.', body: 'No somos una agencia digital que ofrece LinkedIn entre otros quince canales. LinkedIn es todo lo que hacemos. Nuestros métodos, nuestros procesos editoriales, nuestras referencias de rendimiento: todo se ha construido para esto y solo para esto.' },
  { title: 'Multilingüe desde el primer día.', body: 'La mayoría de agencias traducen un contenido en inglés y lo llaman localización. Nosotros redactamos de forma nativa en cada lengua. Tu contenido en alemán se lee como si lo hubiera escrito alguien que piensa en alemán. Y es exactamente lo que pasa.' },
  { title: 'La IA nos da velocidad. El humano fija el listón.', body: 'Usamos inteligencia artificial en cada etapa: investigación, primeros borradores, visuales, cortes de vídeo. Eso sí, nada sale sin haber pasado por nuestro equipo editorial. Es él quien decide si está listo. La máquina no.' },
  { title: 'Todo es tuyo.', body: 'Los contenidos, la lista de suscriptores, los datos de los inscritos, las creatividades. Si te vas mañana, todo se va contigo. Nosotros no nos quedamos con nada.' },
];

const services = [
  {
    id: 'svc-company-page',
    title: 'Gestión de la página de empresa',
    short: 'Tu primera impresión digital, construida y llevada de principio a fin.',
    details: [
      'Auditoría y rediseño completo (banner, sección Acerca de, contenidos destacados, etiquetas de especialidad)',
      'Gestión mensual de las publicaciones, calibrada al algoritmo de LinkedIn y a tus prioridades comerciales',
      'Todos los formatos: texto, carruseles, vídeos, documentos, encuestas',
      'Crecimiento de suscriptores vía la activación de los empleados, campañas segmentadas y contenido que circula',
      'Informe mensual: qué ha pasado, por qué, qué ajustamos',
    ],
    trust: 'Ganamos tiempo gracias a la IA. Pero es el equipo el que garantiza el nivel.',
    footnote: 'Nada sale sin tu visto bueno. Y todo lo que construimos se queda contigo.',
    stat: null,
    image: '/images/content-company-page.webp',
    imageAlt: 'Panel de gestión de la página de empresa',
  },
  {
    id: 'svc-content-production',
    title: 'Producción editorial',
    short: 'Todos los formatos, cada semana, en cada uno de tus mercados.',
    details: [
      'Cada formato de LinkedIn elegido por una razón concreta, nunca por defecto',
      'Redacción para tus directivos: tienen la experiencia, nosotros le ponemos voz',
      'Contenidos multilingües redactados de forma nativa, no traducidos',
      'Calendario editorial cerrado un mes por adelantado: redactado, revisado, validado, publicado en plazo',
    ],
    trust: 'Investigación, redacción, multilingüe: la IA nos acelera en todo eso. El equipo editorial verifica que el resultado se sostenga.',
    footnote: 'Tú validas cada contenido. Si no convence, lo rehacemos.',
    stat: null,
    image: '/images/content-production.webp',
    imageAlt: 'Proceso de producción editorial',
  },
  {
    id: 'svc-newsletter',
    title: 'Newsletter de LinkedIn',
    short: 'Un canal directo hacia los profesionales que más cuentan para tu negocio.',
    details: [
      'Concepto editorial: lo que defiende tu newsletter, a quién le habla, por qué la gente se queda suscrita',
      'Producción completa: investigación, redacción, revisión, asunto, llamadas a la acción',
      'Crecimiento de suscriptores: captación orgánica y de pago vía tu página de empresa, los perfiles de tus directivos, campañas segmentadas',
      'Seguimiento del rendimiento: tasa de apertura, clics, crecimiento de la base, análisis después de cada edición',
    ],
    trust: 'La búsqueda de temas y la redacción multilingüe las acelera la IA. El resto, la pluma y el control final, eso lo hace una persona.',
    footnote: 'La lista de suscriptores es tuya. Siempre.',
    stat: null,
    image: '/images/content-newsletter.webp',
    imageAlt: 'Maqueta de newsletter de LinkedIn',
  },
  {
    id: 'svc-events',
    title: 'Eventos de LinkedIn',
    short: 'El formato más fuerte de LinkedIn en interacciones. Y cada inscrito es un contacto identificado.',
    details: [
      'Concepto y posicionamiento: un ángulo claro, un público bien definido, un formato pensado para llenar la sala',
      'Campaña de promoción en varios canales, lanzada cuatro semanas antes del evento, orgánica y de pago',
      'Preparación de los ponentes: cada participante recibe un briefing, se prepara y pasa la prueba técnica',
      'Gestión en directo: nosotros llevamos la sesión, tú te centras en el contenido',
      'Materiales posevento: grabación, cortes de vídeo, resumen escrito, publicaciones sociales',
      'Plan de recontacto: los datos de los inscritos, más un plan de acción concreto para tu equipo comercial',
    ],
    trust: 'Tratamiento de las grabaciones, generación de cortes, declinación de los momentos clave en todos los formatos de LinkedIn: de eso se encarga la IA.',
    footnote: 'Materiales y datos de los inscritos: todo es tuyo. Y si el concepto no se sostiene, te lo decimos ya en la primera semana.',
    stat: '100 % Propiedad de los datos de los inscritos',
    image: '/images/content-events.webp',
    imageAlt: 'Pieza de promoción de un evento de LinkedIn',
  },
];

const cardIcons = overviewCards.map(c => c.icon);

const stats = [
  { value: '80 %', label: 'de los contactos B2B procedentes de redes sociales vienen de LinkedIn.', context: 'Ninguna otra plataforma se acerca, ni de lejos.', source: 'LinkedIn Marketing Solutions / Cognism' },
  { value: '7x', label: 'más rápido: el crecimiento de suscriptores de las páginas que publican cada semana.', context: 'La regularidad es la primera palanca. Y por mucho.', source: 'LinkedIn' },
  { value: '5x', label: 'más interacciones en los contenidos de vídeo que en las publicaciones estáticas.', context: 'El formato pesa tanto como el fondo.', source: 'LinkedIn' },
  { value: '59 %', label: 'de los responsables de decisión B2B consideran el contenido de expertise más fiable que cualquier otro soporte para evaluar a un proveedor.', context: 'Por delante de la publicidad. Por delante de los whitepapers. Por delante de los casos de estudio.', source: 'LinkedIn / Edelman' },
  { value: '4 de 5', label: 'miembros de LinkedIn participan en las decisiones de compra de su empresa.', context: 'En claro, tu contenido cae bajo los ojos de gente que puede firmar.', source: 'LinkedIn' },
  { value: '2x', label: 'más conversiones en LinkedIn que en las demás redes sociales.', context: 'El público ya está en modo profesional.', source: 'LinkedIn Marketing Solutions' },
  { value: '277 %', label: 'más eficaz que Facebook y X juntos para generar contactos cualificados.', context: 'No juegan en la misma liga.', source: 'HubSpot' },
  { value: '46 %', label: 'del tráfico social hacia los sitios B2B procede de LinkedIn.', context: 'El contenido no solo construye imagen. Trae gente a tu sitio.', source: 'LinkedIn' },
  { value: '28 %', label: 'menos de coste por contacto en LinkedIn frente a Google Ads.', context: 'Y el contenido orgánico todavía rebaja más la factura.', source: 'HubSpot' },
  { value: '61 %', label: 'más de probabilidades de convertir a través de publicidad tras una interacción orgánica.', context: 'Contenido más publicidad, juntos, funcionan mejor que cualquiera por separado.', source: 'Investigación interna de LinkedIn' },
];

const faqs = [
  { q: 'En la práctica, ¿cómo va el primer mes?', a: 'Empezamos con una auditoría de tu presencia en LinkedIn: página de empresa, perfiles de directivos, histórico de publicaciones, base de suscriptores. A partir de ahí construimos la estrategia editorial, te sometemos el primer mes de contenido para que lo valides y arrancamos. En general, nuestros clientes están operativos en dos o tres semanas.' },
  { q: '¿Cuánto dura el compromiso mínimo?', a: 'Tres meses al principio, después mes a mes. El primer trimestre es el tiempo que hace falta para sentar las bases y empezar a medir cosas concretas. Después, te quedas porque funciona, no porque estés atado a un contrato.' },
  { q: '¿Cómo interviene la IA en la producción de contenido?', a: 'En todas las etapas. Investigación, redacción, multilingüe, creación de imágenes, montaje de vídeo. Eso nos permite producir más, más rápido, a menor coste. Pero el equipo editorial revisa cada texto y nuestros diseñadores comprueban cada visual: nada sale sin validación humana y sin tu visto bueno. En este punto no transigimos.' },
  { q: '¿Y si el contenido no me convence?', a: 'Lo rehacemos. Sin discutir, sin facturar de más. Preferimos reescribir un post tres veces antes que publicar algo que no encaja.' },
  { q: '¿Puedo empezar por un solo servicio?', a: 'Sí. Empieza por lo que te parezca más urgente, ya veremos lo demás después.' },
  { q: '¿Cuánto tiempo le quita a mi equipo?', a: 'Bien poco, la verdad. Planificamos los contenidos un mes por adelantado, tu equipo revisa y valida. En general se quedan en veinte o treinta minutos por semana. Algunos clientes lo hacen el lunes por la mañana con el café.' },
  { q: '¿Se puede trabajar con nuestra identidad gráfica?', a: 'Por supuesto. Identidad gráfica, tono, identidad visual, proceso de validación, nos adaptamos. Si tienes plantillas, terminología obligatoria o restricciones regulatorias, también nos ajustamos.' },
  { q: '¿Cómo son los informes mensuales?', a: 'Un informe al mes, ligado a tus objetivos comerciales. Crecimiento de suscriptores, interacciones, rendimiento de los contenidos, indicadores de generación de contactos. Te explicamos qué funcionó, qué arrancó peor y qué ajustamos para el mes siguiente. Sin relleno.' },
  { q: '¿Cuánto tardo en ver resultados?', a: 'Las visitas al perfil, el crecimiento de suscriptores, las interacciones: suelen moverse en los primeros 60 días. Para la generación de contactos comerciales, más bien 90 días. Lo que tarda en acumularse el contenido y en construirse tu audiencia lectora. No prometemos resultados de la noche a la mañana, no sería honesto. LinkedIn premia a quien aguanta la distancia.' },
  { q: '¿Y si quiero parar?', a: 'Pasados los tres primeros meses, 30 días de preaviso y listo. Contenidos, suscriptores, materiales: te llevas todo contigo.' },
];
---

<Layout
  lang="es"
  title="Servicios de contenido en LinkedIn | Genera más contactos B2B"
  description="Producimos todos los contenidos en LinkedIn que tu marca necesita. Estrategia, producción, publicación, informes. Hecho para B2B, hecho para generar contactos."
  abstract="Llevamos tu contenido en LinkedIn de principio a fin. Estrategia, producción, publicación, informes. Cuatro servicios, un objetivo: más contactos cualificados desde LinkedIn."
>
  <NavBar lang="es" />
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="c-hero" aria-labelledby="hero-h">
      <div class="c-hero__bg" aria-hidden="true"></div>
      <div class="c-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="c-hero__content">
          <p class="eyebrow eyebrow--light reveal">Servicios de contenido en LinkedIn</p>
          <h1 id="hero-h" class="c-hero__h1 reveal reveal-delay-1">
            Contenido en LinkedIn que capta la atención y trae <span class="text-gradient">contactos.</span>
          </h1>
          <p class="c-hero__sub reveal reveal-delay-2">
            Producimos todo el contenido que tu presencia en LinkedIn necesita. Estrategia, producción, publicación, informes. Tú, sin gestionar nada.
          </p>
          <div class="c-hero__actions reveal reveal-delay-3">
            <a href="/es/contacto" class="btn btn--primary btn--lg">Reservar una llamada</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ── Service Overview Cards ──────────────────────────── -->
    <section class="section c-overview" aria-label="Resumen de servicios">
      <div class="container">
        <div class="c-ov__grid">
          {overviewCards.map((card, i) => (
            <a href={card.href} class={`c-ov-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="c-ov-card__top">
                <span class="c-ov-card__icon" set:html={card.icon} />
              </div>
              <strong class="c-ov-card__title">{card.title}</strong>
              <p class="c-ov-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ── What We Do ──────────────────────────────────────── -->
    <section class="section c-wwd" aria-labelledby="wwd-h">
      <div class="container">
        <div class="c-wwd__head reveal">
          <p class="eyebrow">Nuestro enfoque</p>
          <h2 id="wwd-h" class="c-wwd__h2">Convertimos tu presencia en LinkedIn en una palanca comercial de verdad.</h2>
          <p class="c-wwd__intro">Tu equipo tiene la expertise. Tu empresa tiene una historia que contar. Pero mientras ese saber hacer se quede dentro de tus paredes, no va a llenar el libro de pedidos.</p>
          <p class="c-wwd__intro">Cogemos lo que da credibilidad a tu marca y lo convertimos en una mecánica editorial que rueda cada semana en LinkedIn. Publicaciones, artículos, newsletters, eventos. Todo calibrado para llegar a quienes compran lo que tú vendes.</p>
        </div>

        <div class="c-wwd__grid">
          {whatWeDo.map((item, i) => (
            <div class={`c-wwd-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="c-wwd-card__top">
                <span class="c-wwd-card__icon" aria-hidden="true" set:html={item.icon} />
              </div>
              <strong class="c-wwd-card__title">{item.title}</strong>
              <p class="c-wwd-card__body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── Why Brands Work With Us ─────────────────────────── -->
    <section class="section c-why" aria-labelledby="why-h">
      <div class="c-why__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="c-why__head reveal">
          <p class="eyebrow eyebrow--light">Por qué nosotros</p>
          <h2 id="why-h" class="c-why__h2">Pensado para B2B. Tallado para lo internacional.</h2>
        </div>

        <div class="c-why__layout">
          <!-- Left: visual column -->
          <div class="c-why__visual reveal">
            <div class="c-why__photo-wrap">
              <img src="/images/content-team.webp" alt="El equipo de Nuvora Studio" class="c-why__photo" width="480" height="560" loading="lazy" />
            </div>
            <div class="c-why__trust-row">
              <div class="c-why__trust-item">
                <span class="c-why__trust-num">100 %</span>
                <span class="c-why__trust-label">Dedicado a LinkedIn</span>
              </div>
              <div class="c-why__trust-divider"></div>
              <div class="c-why__trust-item">
                <span class="c-why__trust-num">B2B</span>
                <span class="c-why__trust-label">En exclusiva</span>
              </div>
              <div class="c-why__trust-divider"></div>
              <div class="c-why__trust-item">
                <span class="c-why__trust-num">Global</span>
                <span class="c-why__trust-label">Multilingüe</span>
              </div>
            </div>
          </div>

          <!-- Right: differentiator cards -->
          <div class="c-why__cards">
            {whyBlocks.map((b, i) => (
              <div class={`c-why-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
                <div class="c-why-card__content">
                  <strong class="c-why-card__title">{b.title}</strong>
                  <p class="c-why-card__body">{b.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ── Our LinkedIn Content Services ───────────────────── -->
    <section class="section c-svc" aria-labelledby="svc-h">
      <div class="container">
        <div class="c-svc__head reveal">
          <p class="eyebrow">Nuestros servicios</p>
          <h2 id="svc-h" class="c-svc__h2">Cuatro servicios. Un objetivo. Más contactos cualificados vía LinkedIn.</h2>
          <p class="c-svc__intro">Cada uno funciona por separado. Pero juntos transforman tu presencia en LinkedIn en un verdadero sistema de generación de contactos, del tipo con el que tu equipo comercial puede contar a diario.</p>
        </div>

        {services.map((s, i) => (
          <div class={`c-svc-block${i % 2 === 1 ? ' c-svc-block--flip' : ''} reveal`} id={s.id}>
            <div class="c-svc-block__text">
              <div class="c-svc-block__label">
                <span class="c-svc-block__icon" set:html={cardIcons[i]} />
              </div>
              <h3 class="c-svc-block__title">{s.title}</h3>
              <p class="c-svc-block__short">{s.short}</p>

              <ul class="c-svc-block__details" role="list">
                {s.details.map(d => (
                  <li>
                    <svg class="c-svc-check" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="8" fill="var(--blue)" opacity="0.10"/><path d="M5 8l2.2 2.2L11.4 6" stroke="var(--blue)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>{d}</span>
                  </li>
                ))}
              </ul>

              <div class="c-svc-block__trust">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1l1.76 3.58L13 5.24l-3 2.88.72 4.12L7 10.36 3.28 12.24 4 8.12 1 5.24l4.24-.66L7 1z" fill="var(--cyan)" opacity="0.85"/></svg>
                <p>{s.trust}</p>
              </div>
              <p class="c-svc-block__footnote"><em>{s.footnote}</em></p>

              {s.stat && (
                <div class="c-svc-block__stat">
                  <span>{s.stat}</span>
                </div>
              )}
            </div>

            <div class="c-svc-block__visual">
