---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';

import ContactCTA from '../../../components/ContactCTA.astro';

/* ── Datos ────────────────────────────────────────────── */

const contentServices = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="7" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.6"/><line x1="9" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Gestión de la página de empresa',
    text: 'La creamos desde cero, o cogemos lo que ya hay y ponemos orden. Luego la llevamos día a día. La identidad visual, los textos, el calendario de publicaciones. En definitiva, todo eso para lo que no tienes tiempo.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Producción editorial',
    text: 'Publicaciones, artículos, carruseles, vídeos. Escribimos todo y lo maquetamos. Cada semana. En tu tono, no en el nuestro. Y a fuerza de publicar con regularidad, la gente acaba leyéndote. De verdad.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Newsletter de LinkedIn',
    text: 'La newsletter aterriza directa en el correo de tus suscriptores. Y también en sus notificaciones de LinkedIn. Ahí el algoritmo no pinta nada.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Eventos de LinkedIn',
    text: 'De lejos, el formato que más interacción genera en LinkedIn. La logística, la promoción, los recordatorios antes y después, eso es cosa nuestra. Tú solo tienes que venir a hablar.',
  },
];

const adFormats = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="3" width="20" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Contenido patrocinado',
    text: 'Tus mejores contenidos aparecen en el feed de quienes tienen presupuesto y autoridad para firmar. Segmentamos por cargo, por antigüedad, por empresa. Es quirúrgico.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.6"/><polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Mensajes patrocinados',
    text: 'InMail y mensajes patrocinados, pensados para B2B puro y duro. Escribimos los mensajes, ajustamos la segmentación, y el objetivo es que la gente responda. Que solo abran el mensaje no nos vale.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="1.6"/><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Anuncios dinámicos',
    text: 'El cliente potencial ve su propio nombre y su foto justo al lado de tu marca. Eso, claro, atrae la mirada. Nos encargamos del montaje y de la optimización, incluso a gran volumen.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 8h8M8 12h6M8 16h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Anuncios de texto',
    text: 'No es el formato más espectacular, pero como complemento de los contenidos patrocinados hace un trabajo de fondo serio. La relación calidad-precio es imbatible.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 11l3 3L22 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Formularios integrados',
    text: 'El prospecto rellena el formulario sin salir de LinkedIn. Un clic, y tienes sus datos. Sin página externa, sin un paso de más. Los construimos, los probamos y los vamos afinando.',
  },
];

const consultingServices = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.6"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Activación de los empleados',
    text: 'A las redes personales de tu equipo, tu página de empresa no va a llegar jamás. Nosotros montamos el programa y preparamos las publicaciones. Tu gente solo tiene que compartirlas.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Posicionamiento de directivos',
    text: 'Antes incluso de mirar tu página de empresa, un prospecto se pasa primero por el perfil de tu director general. Nos aseguramos de que lo que encuentre refleje, por fin, el nivel de expertise que ya existe puertas adentro.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2V3z" stroke="currentColor" stroke-width="1.6"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7V3z" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Formaciones',
    text: 'Talleres presenciales, concretos, nada de teoría en PowerPoint. Cubrimos todo, desde la optimización del perfil hasta la estrategia de contenido y el análisis de las métricas. Tu equipo sale sabiendo exactamente qué hacer el lunes por la mañana.',
  },
];
---

<Layout
  lang="es"
  title="Servicios LinkedIn para B2B"
  description="Contenido, publicidad, consultoría. Tres palancas para que tus próximos clientes te encuentren en LinkedIn."
  abstract="Desarrollamos tu presencia en LinkedIn para que se traduzca en reuniones y en contratos. Contenido, publicidad y acompañamiento."
>
  <NavBar lang="es" />
  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════ -->
    <section class="s-hero" aria-labelledby="s-hero-h">
      <div class="s-hero__bg" aria-hidden="true"></div>
      <div class="s-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="s-hero__content">
          <p class="eyebrow eyebrow--light reveal">Nuestros servicios</p>
          <h1 id="s-hero-h" class="s-hero__h1 reveal reveal-delay-1">
            Tu LinkedIn debería traerte clientes. Hacemos que <span class="text-gradient">así sea de verdad.</span>
          </h1>
          <p class="s-hero__sub reveal reveal-delay-2">
            Sabes que LinkedIn podría rendir mucho más. Pero internamente nadie tiene tiempo de ocuparse en serio, y el método se queda en niebla. Y al final no se mueve nada. Estamos aquí para desatascar eso.
          </p>
          <div class="s-hero__actions reveal reveal-delay-3">
            <a href="/es/contacto" class="btn btn--primary btn--lg">Reservar una cita</a>
            <a href="#s-content" class="btn btn--outline-white btn--lg">Ver nuestros servicios</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         INTRO
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-intro" aria-labelledby="s-intro-h">
      <div class="container">
        <div class="s-intro__inner reveal">
          <h2 id="s-intro-h" class="s-intro__h2">Trabajamos sobre tres ejes. El objetivo es siempre el mismo: que LinkedIn te traiga negocio.</h2>
          <p class="s-intro__body">Tu página de empresa está medio vacía. El perfil de tu director general no se ha tocado desde 2021 (con suerte). Todo el mundo sabe que habría que ponerse, pero nadie lo hace. La película nos la sabemos de memoria, es exactamente lo que venimos a resolver.</p>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         SERVICIOS DE CONTENIDO
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar" id="s-content" aria-labelledby="s-content-h">
      <div class="container">
        <div class="s-pillar__layout">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </div>
            <h2 id="s-content-h" class="s-pillar__h2">Contenido en LinkedIn</h2>
            <a href="/es/servicios/contenido" class="btn btn--primary">¿Lo hablamos?</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap">
              <img src="/services-content.webp" alt="Profesional redactando una publicación de LinkedIn en su ordenador portátil" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-cards">
          {contentServices.map((card, i) => (
            <a href="/es/servicios/contenido" class={`s-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="s-card__top">
                <span class="s-card__icon" set:html={card.icon} />
              </div>
              <strong class="s-card__title">{card.title}</strong>
              <p class="s-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         SERVICIOS DE PUBLICIDAD
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar s-pillar--dark" id="s-advertising" aria-labelledby="s-ads-h">
      <div class="s-pillar__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="s-pillar__layout s-pillar__layout--flip">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap s-pillar__icon-wrap--light">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
            </div>
            <h2 id="s-ads-h" class="s-pillar__h2">Publicidad en LinkedIn</h2>
            <a href="/es/servicios/publicidad" class="btn btn--primary">Saber más</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap s-pillar__img-wrap--dark">
              <img src="/services-advertising.webp" alt="Dos compañeros analizando los resultados de una campaña publicitaria en LinkedIn" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-ad-grid">
          {adFormats.map((card, i) => (
            <a href="/es/servicios/publicidad" class={`s-ad-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 4)}` : ''}`}>
              <span class="s-ad-card__icon" set:html={card.icon} />
              <strong class="s-ad-card__title">{card.title}</strong>
              <p class="s-ad-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         SERVICIOS DE CONSULTORÍA
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar" id="s-consulting" aria-labelledby="s-consult-h">
      <div class="container">
        <div class="s-pillar__layout">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2V3z" stroke="currentColor" stroke-width="1.6"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7V3z" stroke="currentColor" stroke-width="1.6"/></svg>
            </div>
            <h2 id="s-consult-h" class="s-pillar__h2">Consultoría y formación en LinkedIn</h2>
            <a href="/es/servicios/consultoria" class="btn btn--primary">Hablemos</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap">
              <img src="/services-consulting.webp" alt="Formación de LinkedIn en sala con una ponente delante de un grupo de profesionales" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-consult-grid">
          {consultingServices.map((card, i) => (
            <a href="/es/servicios/consultoria" class={`s-consult-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <span class="s-consult-card__icon" set:html={card.icon} />
              <strong class="s-consult-card__title">{card.title}</strong>
              <p class="s-consult-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         EQUIPO
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-team" aria-labelledby="s-team-h">
      <div class="container">
        <div class="s-team__inner reveal">
          <p class="eyebrow">El equipo</p>
          <h2 id="s-team-h" class="s-team__h2">Sin plantillas. Sin recetas de manual.</h2>
          <p class="s-team__body">Lo que hace falta es gente que viva en el B2B, que conozca LinkedIn hasta en sus rincones y que sea un poco obsesiva con la calidad. Ese es nuestro perfil. Hemos trabajado con empresas de industria, tecnología, salud y consultoría. En España y fuera de ella.</p>
          <a href="/es/nosotros" class="btn btn--outline">Conocer al equipo</a>
        </div>
      </div>
    </section>


    <ContactCTA lang="es" />

  </main>
</Layout>


<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>

  /* ╔═══════════════════════════════════════════╗
     ║  HERO                                     ║
     ╚═══════════════════════════════════════════╝ */
  .s-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .s-hero__bg {
    position: absolute;
    inset: 0;
    background: url('/services-hero.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .s-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.92) 0%,
      rgba(15,23,42, 0.75) 50%,
      rgba(15,23,42, 0.45) 100%
    );
    z-index: 1;
  }

  .s-hero__content {
    max-width: 680px;
  }

  .s-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .s-hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .s-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.68);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--sp-10);
  }

  .s-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  @media (max-width: 640px) {
    .s-hero { padding-block: var(--sp-16) var(--sp-12); }
  }


  /* ╔═══════════════════════════════════════════╗
     ║  INTRO                                    ║
     ╚═══════════════════════════════════════════╝ */
  .s-intro {
    background: var(--white);
    padding-block: var(--sp-16);
  }
  .s-intro__inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .s-intro__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: var(--text);
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-6);
  }
  .s-intro__body {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
  }


  /* ╔═══════════════════════════════════════════╗
     ║  PILLAR SECTIONS (Contenu / Pub / Conseil)║
     ╚═══════════════════════════════════════════╝ */
  .s-pillar {
    background: var(--white);
    position: relative;
    overflow: hidden;
  }
  .s-pillar--dark {
    background: var(--deep-navy);
  }
  .s-pillar__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 60% at 0% 100%, rgba(6,182,212,.08) 0%, transparent 60%),
      radial-gradient(ellipse 40% 50% at 100% 0%, rgba(3,105,161,.06) 0%, transparent 60%);
  }

  .s-pillar__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
    margin-bottom: var(--sp-16);
    position: relative;
    z-index: 1;
  }
  .s-pillar__layout--flip { direction: rtl; }
  .s-pillar__layout--flip .s-pillar__text,
  .s-pillar__layout--flip .s-pillar__visual { direction: ltr; }

  .s-pillar__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    border-radius: var(--r-xl);
    background: linear-gradient(135deg, rgba(3,105,161,.08), rgba(6,182,212,.06));
    color: var(--sky);
    margin-bottom: var(--sp-5);
    transition: transform var(--t-base);
  }
  .s-pillar__icon-wrap:hover { transform: scale(1.05); }
  .s-pillar__icon-wrap--light {
    background: linear-gradient(135deg, rgba(6,182,212,.12), rgba(3,105,161,.08));
    color: var(--cyan);
  }

  .s-pillar__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-6);
  }
  .s-pillar--dark .s-pillar__h2 { color: var(--white); }

  .s-pillar__lead {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-4);
    font-weight: 500;
  }
  .s-pillar--dark .s-pillar__lead { color: rgba(255,255,255,0.68); }

  .s-pillar__body {
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-8);
  }
  .s-pillar--dark .s-pillar__body { color: rgba(255,255,255,0.48); }

  /* Visual images */
  .s-pillar__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .s-pillar__img-wrap {
    position: relative;
    border-radius: var(--r-2xl);
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--off-white);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
  }
  .s-pillar__img-wrap--dark {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
    box-shadow: var(--shadow-lg);
  }

  .s-pillar__img-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    height: 100%;
    background: linear-gradient(135deg, var(--off-white) 0%, var(--border) 100%);
  }
  .s-pillar__img-ph--dark {
    background: linear-gradient(135deg, rgba(15,23,42,0.9) 0%, rgba(3,105,161,0.20) 100%);
  }

  .s-ph__icon {
    transition: transform var(--t-base);
  }
