---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import LangBanner from '../../components/LangBanner.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { useTranslations, getAlternateUrl } from '../../i18n/index.ts';

const t = useTranslations('fr');
---

<Layout
  lang="fr"
  title="[FR] Tarifs | Nuvora Studio"
  description="[FR] LinkedIn marketing retainers for B2B companies. Transparent pricing, no lock-in."
  abstract="[FR] Transparent LinkedIn retainer pricing for B2B companies."
>
  <NavBar lang="fr" />
  <LangBanner
    message={t('lang.banner')}
    alternatUrl={getAlternateUrl('/fr/pricing', 'en')}
  />
  <main id="main-content">

    <section class="pricing-hero" aria-labelledby="pricing-heading">
      <div class="pricing-hero__bg" aria-hidden="true"></div>
      <div class="pricing-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="pricing-hero__content">
          <p class="eyebrow eyebrow--light reveal">Tarifs</p>
          <h1 id="pricing-heading" class="pricing-hero__h1 reveal reveal-delay-1">
            Des tarifs transparents. <span class="text-gradient">Sans surprises.</span>
          </h1>
          <p class="pricing-hero__sub reveal reveal-delay-2">
            Trois formules d'accompagnement. Une seule plateforme. Des livrables clairs à chaque niveau.
          </p>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--off-white);">
      <div class="container">
        <div class="placeholder-notice">
          <p>🇫🇷 <strong>Page en cours de traduction.</strong> Le contenu complet de cette page sera disponible prochainement en français.</p>
          <a href="/pricing" class="btn btn--outline btn--sm">Read in English →</a>
        </div>
      </div>
    </section>

    <ContactCTA />
  </main>
</Layout>

<style>
  .pricing-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .pricing-hero__bg {
    position: absolute;
    inset: 0;
    background: url('/hero-network.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .pricing-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.92) 0%,
      rgba(15,23,42, 0.75) 50%,
      rgba(15,23,42, 0.45) 100%
    );
    z-index: 1;
  }

  .pricing-hero__content {
    max-width: 680px;
  }

  .pricing-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .pricing-hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.68);
    max-width: 520px;
    line-height: 1.75;
  }

  @media (max-width: 640px) {
    .pricing-hero { padding-block: var(--sp-16) var(--sp-12); }
  }
  .placeholder-notice {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-10);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    flex-wrap: wrap;
  }
  .placeholder-notice p { font-size: var(--fs-md); color: var(--text-2); }
</style>
