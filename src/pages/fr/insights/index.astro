---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';
import ContactCTA from '../../../components/ContactCTA.astro';

const posts = [
  // ── 29 March 2026 ──
  {
    slug: 'why-your-reach-dropped',
    category: 'Stratégie LinkedIn',
    tags: ['Algorithme'],
    title: "Pourquoi votre portée a chuté de 50\u00a0% en 2026 (et c'est pas votre contenu)",
    excerpt: "LinkedIn a remplacé tout son algorithme par 360Brew. La portée a chuté de 50\u00a0%, les pages entreprises ont perdu 60\u00a0%. Votre contenu n'est pas en cause. C'est le système qui a changé.",
    date: '2026-03-29',
    readTime: '8 min de lecture',
    featured: true,
    image: '/blog/hero-reach-dropped.svg',
  },
  {
    slug: 'content-to-inbound-leads',
    category: 'Stratégie LinkedIn',
    tags: ['Prospects'],
    title: "Comment transformer son contenu LinkedIn en vrais prospects (et pas juste en vues)",
    excerpt: "Du contenu LinkedIn qui fait des vues mais zéro prospect, c'est de l'énergie perdue. La prospection entrante convertit à 14,6% contre 1,7% pour la sortante. Voici comment revoir votre approche.",
    date: '2026-03-29',
    readTime: '9 min de lecture',
    featured: false,
    image: '/blog/hero-content-to-leads.webp',
  },
  {
    slug: 'profile-mistakes-killing-conversions',
    category: 'Stratégie LinkedIn',
    tags: ['Profil'],
    title: "Les erreurs de profil qui plombent vos résultats sans que vous le sachiez",
    excerpt: "Chaque publication renvoie des visiteurs vers votre profil. Et la plupart des profils ne les retiennent pas. Accroche banale, section Sélection vide, résumé façon CV — ça vous coûte des prospects tous les jours.",
    date: '2026-03-29',
    readTime: '9 min de lecture',
    featured: false,
    image: '/blog/hero-profile-mistakes.webp',
  },
  {
    slug: 'linkedin-headline-costing-opportunities',
    category: 'Stratégie LinkedIn',
    tags: ['Profil'],
    title: "Votre titre LinkedIn vous fait perdre des opportunités. Voici comment le corriger.",
    excerpt: "Votre titre LinkedIn apparaît partout où on vous voit sur la plateforme. La plupart des gens le gaspillent avec un intitulé de poste. Il y a une meilleure formule.",
    date: '2026-03-29',
    readTime: '7 min de lecture',
    featured: false,
    image: '/blog/hero-headline-fix.webp',
  },
  {
    slug: 'algorithm-change-small-vs-large-accounts',
    category: 'Stratégie LinkedIn',
    tags: ['Algorithme'],
    title: "Nouvel algorithme LinkedIn : ce que ça change pour les petits comptes face aux gros",
    excerpt: "Le nouvel algorithme de LinkedIn récompense la qualité des échanges plutôt que le nombre d'abonnés. Un petit compte avec un réseau actif fait désormais mieux qu'un gros compte suivi par des gens qui ne réagissent jamais.",
    date: '2026-03-29',
    readTime: '9 min de lecture',
    featured: false,
    image: '/blog/hero-small-vs-large.svg',
  },
  {
    slug: 'how-to-grow-on-linkedin',
    category: 'Stratégie LinkedIn',
    tags: ['Croissance'],
    title: "Se développer sur LinkedIn quand la concurrence a été multipliée par cinq",
    excerpt: "LinkedIn compte cinq fois plus de gens qui publient qu'en 2023. Deux millions de publications par jour. Mais moins de 3% des membres publient chaque semaine. Ceux qui s'en sortent ont compris un truc : il faut être précis.",
    date: '2026-03-29',
    readTime: '10 min de lecture',
    featured: false,
    image: '/blog/hero-grow-linkedin.svg',
  },
  {
    slug: 'why-linkedin-ads-cost-more',
    category: 'Publicité LinkedIn',
    tags: ['Publicité'],
    title: "Pourquoi les publicités LinkedIn coûtent 4 à 6x plus par clic, et quand ça vaut quand même le coup",
    excerpt: "LinkedIn facture entre 5 et 12\u00a0$ par clic. Meta facture 0,50\u00a0$. Mais les clics ne concluent pas d'affaires. Les prospects LinkedIn convertissent 2 à 3 fois mieux que sur les autres plateformes.",
    date: '2026-03-29',
    readTime: '8 min de lecture',
    featured: false,
    image: '/blog/hero-ads-cost.svg',
  },
  {
    slug: 'linkedin-ads-vs-organic-content',
    category: 'Stratégie LinkedIn',
    tags: ['Budget'],
    title: "Publicité LinkedIn ou contenu naturel : où mettre votre budget en 2026",
    excerpt: "Le contenu naturel génère des prospects à moitié prix par rapport à la publicité. Mais la pub comble les trous plus vite. Le bon dosage dépend de votre maturité et de la taille de vos contrats.",
    date: '2026-03-29',
    readTime: '9 min de lecture',
    featured: false,
    image: '/blog/hero-ads-vs-organic.svg',
  },
  {
    slug: 'stop-wasting-money-low-intent-audiences',
    category: 'Publicité LinkedIn',
    tags: ['Ciblage'],
    title: "Publicités LinkedIn : arrêtez de viser des gens qui n'ont aucune intention d'acheter",
    excerpt: "La plupart des campagnes LinkedIn ciblent des publics trop larges et trop froids. Seulement 3 à 6% de votre marché est en phase d'achat. Commencez par revoir votre ciblage.",
    date: '2026-03-29',
    readTime: '10 min de lecture',
    featured: false,
    image: '/blog/hero-targeting-waste.webp',
  },
  {
    slug: 'linkedin-ad-roi-measurement-problem',
    category: 'Publicité LinkedIn',
    tags: ['Mesure'],
    title: "Pourquoi le rendement de vos publicités LinkedIn a l'air catastrophique (c'est un problème de mesure)",
    excerpt: "LinkedIn génère un retour sur investissement publicitaire de 121% en B2B. Mais le parcours d'achat moyen dure 272 jours. Si vous mesurez le rendement à 30 jours, vos chiffres vous racontent n'importe quoi.",
    date: '2026-03-29',
    readTime: '10 min de lecture',
    featured: false,
    image: '/blog/hero-roi-measurement.webp',
  },
  {
    slug: 'minimum-viable-linkedin-ads-budget',
    category: 'Publicité LinkedIn',
    tags: ['Budget'],
    title: "Quel budget publicitaire minimum pour obtenir de vrais résultats sur LinkedIn",
    excerpt: "LinkedIn impose un plancher de 10 $ par jour. Autant dire que ça ne donnera rien. Le vrai budget minimum dépend de votre cible, de votre offre et de la longueur de votre cycle commercial.",
    date: '2026-03-29',
    readTime: '10 min de lecture',
    featured: false,
    image: '/blog/hero-ads-budget.webp',
  },
  // ── 23 March 2026 ──
  {
    slug: 'your-linkedin-post-is-already-dead',
    category: 'Stratégie LinkedIn',
    tags: ['Contenu'],
    title: "Votre publication LinkedIn est déjà morte. Voici comment la sauver.",
    excerpt: "Le fil d'actualité croule sous le contenu généré par l'IA. Votre fenêtre de visibilité, c'est deux heures. Les entreprises qui s'en sortent ont compris un truc que les autres ignorent encore.",
    date: '2026-03-23',
    readTime: '5 min de lecture',
    featured: false,
    image: '/blog/hero-post-already-dead.svg',
  },
  {
    slug: 'the-real-linkedin-problem',
    category: 'Stratégie LinkedIn',
    tags: ['Stratégie'],
    title: "Le vrai problème sur LinkedIn c'est pas d'écrire. C'est de savoir quoi dire.",
    excerpt: "L'IA peut polir vos phrases. Elle peut pas décider de quoi vous allez parler. C'est sur ce point que la majorité des entreprises B2B se plantent sans s'en rendre compte.",
    date: '2026-03-23',
    readTime: '5 min de lecture',
    featured: false,
    image: '/blog/hero-thinking-not-writing.svg',
  },
];

// Collect all unique tags across posts
const allTags = [...new Set(posts.flatMap(p => p.tags))].sort();
---

<Layout
  lang="fr"
  title="Publications | Stratégie LinkedIn, contenu B2B & publicité | Nuvora Studio"
  description="Réflexions pointues sur la stratégie LinkedIn, le contenu B2B, la publicité et les mises à jour de la plateforme. Rédigé par des praticiens, pas des usines à textes."
  abstract="Stratégie LinkedIn, contenu B2B et analyses publicitaires par Nuvora Studio. Rédigé par des praticiens."
>
  <NavBar lang="fr" />
  <main id="main-content">

    <!-- Hero -->
    <section class="insights-hero" aria-labelledby="insights-heading">
      <div class="container">
        <p class="eyebrow eyebrow--light reveal">Publications</p>
        <h1 id="insights-heading" class="insights-hero__h1 reveal reveal-delay-1">
          L'intelligence LinkedIn,<br /><em>par écrit.</em>
        </h1>
        <p class="insights-hero__sub reveal reveal-delay-2">
          Réflexions pointues sur la stratégie LinkedIn, le contenu B2B, la publicité et les évolutions de la plateforme.
          Rédigé par des praticiens, pas des usines à textes.
        </p>
      </div>
    </section>

    <!-- Posts -->
    <section class="section" style="background: var(--off-white);" aria-label="Tous les articles">
      <div class="container">

        <!-- Tag filters -->
        <div class="tag-filters" role="group" aria-label="Filtrer par étiquette">
          <button class="tag-btn tag-btn--active" data-tag="all">Tous</button>
          {allTags.map(tag => (
            <button class="tag-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>

        <!-- Posts grid -->
        <div class="posts-grid" id="posts-grid">
          {posts.map((post, i) => (
            <article
              class="post-card"
              data-tags={post.tags.join(',')}
              style={`transition-delay: ${i * 0.07}s`}
            >
              {post.image ? (
                <div class="post-card__thumb" style={`background-image: url('${post.image}')`}></div>
              ) : (
                <div class="post-card__thumb post-card__thumb--empty">
                  <span>Visuel à venir</span>
                </div>
              )}
              <div class="post-card__top">
                <div class="post-card__tags">
                  {post.featured && <span class="post-tag post-tag--featured">À la une</span>}
                  {post.tags.map(tag => (
                    <span class="post-tag">{tag}</span>
                  ))}
                </div>
                <span class="post-card__category">{post.category}</span>
              </div>
              <h2 class="post-card__title">
                <a href={`/fr/insights/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="post-card__excerpt">{post.excerpt}</p>
              <div class="post-card__footer">
                <span class="post-card__read-time">{post.readTime}</span>
                <a href={`/fr/insights/${post.slug}`} class="post-card__cta">Lire l'article →</a>
              </div>
            </article>
          ))}
        </div>

        <!-- Empty state -->
        <p class="posts-empty" id="posts-empty" style="display:none">
          Aucun article trouvé pour cette étiquette.
        </p>

      </div>
    </section>

    <ContactCTA lang="fr" />
  </main>
</Layout>

<style>
  /* ── Hero ── */
  .insights-hero {
    background: var(--deep-navy) url('/blog/hero-insights.svg') center/cover no-repeat;
    padding-block: clamp(3rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }
  .insights-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 75% 40%, rgba(6,182,212,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .insights-hero .container { position: relative; z-index: 1; }

  .insights-hero__h1 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.12;
    letter-spacing: -0.015em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .insights-hero__h1 em {
    color: rgba(255,255,255,0.38);
    font-weight: 300;
    font-style: normal;
  }
  .insights-hero__sub {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.58);
    max-width: 540px;
    line-height: 1.7;
  }

  /* ── Tag filters ── */
  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-8);
  }

  .tag-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--white);
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--text-2);
    cursor: pointer;
    transition: all var(--t-base) ease;
    letter-spacing: 0.02em;
  }
  .tag-btn:hover {
    border-color: var(--sky);
    color: var(--sky);
    box-shadow: 0 2px 8px rgba(14,165,233,0.1);
  }
  .tag-btn--active {
    background: var(--deep-navy);
    border-color: var(--deep-navy);
    color: var(--white);
  }

  /* ── Grid ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  /* ── Card ── */
  .post-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-10);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    transition:
      box-shadow var(--t-base) ease,
      border-color var(--t-base) ease,
      transform var(--t-base) ease,
      opacity var(--t-base) ease;
  }
  .post-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-2);
    transform: translateY(-3px);
  }
  .post-card.is-hidden {
    display: none;
  }

  .post-card__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--r-lg);
    background-color: var(--deep-navy);
    background-size: cover;
    background-position: center;
    margin-bottom: var(--sp-2);
  }

  .post-card__thumb--empty {
    background: linear-gradient(135deg, rgba(14,165,233,0.04) 0%, rgba(6,182,212,0.06) 100%);
    border: 1.5px dashed rgba(14,165,233,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-card__thumb--empty span {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(14,165,233,0.2);
  }


  .post-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .post-tag {
    display: inline-block;
    padding: 2px var(--sp-3);
    border-radius: var(--r-sm);
    background: rgba(14,165,233,0.07);
    color: var(--sky);
    font-family: var(--font-body), sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .post-tag--featured {
    background: rgba(234,179,8,0.12);
    color: #b45309;
  }

  .post-card__category {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .post-card__title {
    font-family: var(--font-display), sans-serif;
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .post-card__title a { color: inherit; transition: color var(--t-fast) ease; }
  .post-card__title a:hover { color: var(--sky); }

  .post-card__excerpt {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.8;
    flex: 1;
  }

  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .post-card__read-time {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    color: var(--text-3);
  }

  .post-card__cta {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sky);
    transition: color var(--t-fast) ease;
  }
  .post-card__cta:hover { color: var(--cyan); }

  .posts-empty {
    text-align: center;
    color: var(--text-3);
    padding-block: var(--sp-20);
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-md);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
    .post-card { padding: var(--sp-7); }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards   = document.querySelectorAll<HTMLElement>('.post-card');
  const empty   = document.getElementById('posts-empty');

  function filter(tag: string) {
    let visible = 0;

    cards.forEach(card => {
      const tags = (card.dataset.tags ?? '').split(',');
      const show = tag === 'all' || tags.includes(tag);
      card.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });

    if (empty) empty.style.display = visible === 0 ? 'block' : 'none';

    buttons.forEach(btn => {
      btn.classList.toggle('tag-btn--active', btn.dataset.tag === tag);
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => filter(btn.dataset.tag ?? 'all'));
  });
</script>
