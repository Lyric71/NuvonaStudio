  }

  /* ═══════════════════════════════════════════════════════════
     PROBLEM STATEMENT
     ═══════════════════════════════════════════════════════════ */
  .problem {
    background: var(--deep-navy);
  }

  /* ── Hero row ── */
  .problem__hero {
