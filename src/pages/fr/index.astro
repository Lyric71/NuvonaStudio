---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import FAQ from '../../components/FAQ.astro';
import Testimonials from '../../components/Testimonials.astro';

const painPoints = [
  {
    stat: '3%',
    label: 'des entreprises B2B publient régulièrement sur LinkedIn',
    detail: 'Les autres publient une fois, disparaissent, et s\'étonnent que rien ne se passe.',
  },
  {
    stat: '0',
    label: 'dirigeants avec une vraie présence',
    detail: 'La majorité des profils de direction ont l\'air de CV. Ça n\'inspire pas confiance, ça n\'inspire rien du tout.',
  },
  {
    stat: '72%',
    label: 'du budget publicitaire LinkedIn est gaspillé',
    detail: 'Mauvaise cible, mauvais format, mauvais parcours. Le budget fond vite quand il n\'y a pas de structure.',
  },
];

const services = [
  {
    title: 'Contenu',
    tag: 'Organique',
    body: 'Nous gérons votre page entreprise, on produit tous les formats que LinkedIn propose, et on publie avec régularité pour que votre marque reste visible pendant que votre équipe se concentre sur son métier.',
    href: '/fr/services/content',
    subs: [
      'Gestion de la page entreprise',
      'Production de contenu & ligne éditoriale',
      'Newsletter LinkedIn',
      'Événements LinkedIn',
    ],
  },
  {
    title: 'Publicité',
    tag: 'Payant',
    body: 'Du contenu sponsorisé aux formulaires de captation, on construit et pilote des campagnes qui touchent les bons décideurs et les transforment en prospects. C\'est la partie de LinkedIn que la plupart des entreprises sous-exploitent.',
    href: '/fr/services/advertising',
    subs: [
      'Architecture de campagne',
      'Ciblage d\'audience',
      'Création publicitaire & rédaction',
      'Suivi relié à votre outil commercial',
    ],
  },
  {
    title: 'Conseil',
    tag: 'Stratégie',
    body: 'Formation, visibilité du dirigeant et programmes de mobilisation des collaborateurs qui transforment vos équipes en votre meilleur canal sur LinkedIn.',
    href: '/fr/services/consulting',
    subs: [
      'Mobilisation des collaborateurs',
      'Visibilité du dirigeant',
      'Ateliers de formation',
      'Audit de stratégie LinkedIn',
    ],
  },
];

const steps = [
  {
    title: 'Audit & Stratégie',
    body: 'On analyse votre présence LinkedIn, vos concurrents et votre audience. Vous repartez avec une feuille de route claire, des actions concrètes — pas un document générique.',
    detail: 'Semaine 1–2',
  },
  {
    title: 'Construction & Lancement',
    body: 'On optimise les profils, on met en place la production de contenu et on lance les campagnes. Rien ne sort sans votre feu vert.',
    detail: 'Semaine 3–4',
  },
  {
    title: 'Croissance & Suivi',
    body: 'Suivi mensuel sur les indicateurs fixés ensemble. On ajuste ce qui marche, on accélère ce qui convertit. Pas de chiffres pour faire joli.',
    detail: 'En continu',
  },
];

const pillars = [
  {
    title: 'Spécialistes, pas généralistes',
    body: 'Tout ce qu\'on propose est construit autour de LinkedIn. L\'algorithme, les formats, le ciblage, le contenu qui génère des résultats — on connait.',
    metric: '100%',
    metricLabel: 'consacré à LinkedIn',
  },
  {
    title: 'Du contenu qui capte l\'attention',
    body: 'On écrit pour vos acheteurs, pas pour vous faire plaisir. Du contenu B2B clair, direct, qui se lit et qui pousse à l\'action.',
    metric: '3.2x',
    metricLabel: 'de hausse d\'interaction en moyenne',
  },
  {
    title: 'Transparents par défaut',
    body: 'Pas de rapports vagues, pas de marges cachées. Vous savez ce qu\'on fait et pourquoi on le fait.',
    metric: '0',
    metricLabel: 'frais cachés',
  },
  {
    title: 'Assistés par l\'IA. Pilotés par des humains.',
    body: 'On utilise l\'IA pour aller plus vite et produire davantage. Mais chaque contenu passe entre les mains de l\'équipe avant de sortir, sans exception.',
    metric: '100%',
    metricLabel: 'validé par un humain',
  },
];

const industries = [
  { label: 'Technologie & SaaS' },
  { label: 'Industrie et fabrication' },
  { label: 'Services professionnels' },
  { label: 'Santé & Sciences de la vie' },
  { label: 'Services financiers' },
  { label: 'Logistique et chaîne d\'approvisionnement' },
];

const posts = [
  {
    category: 'Stratégie LinkedIn',
    tags: ['Algorithme', 'Portée'],
    title: "Pourquoi votre portée a chuté de 50 % en 2026 (et ce n'est pas votre contenu)",
    excerpt: "LinkedIn a remplacé tout son algorithme par 360Brew. La portée a chuté de 50%, les pages entreprise ont perdu 60%. C'est pas votre contenu le problème — c'est le système qui a changé.",
    date: '2026-03-29',
    slug: 'why-your-reach-dropped',
    image: '/blog/hero-reach-dropped.svg',
  },
  {
    category: 'Stratégie LinkedIn',
    tags: ['Contenu', 'Prospects'],
    title: "Comment transformer votre contenu LinkedIn en prospects (et pas juste en vues)",
    excerpt: "Du contenu LinkedIn qui fait des vues mais aucun prospect, c'est de l'énergie perdue. La prospection entrante convertit à 14,6% contre 1,7% pour la sortante. Voici comment revoir votre approche.",
    date: '2026-03-29',
    slug: 'content-to-inbound-leads',
    image: '/blog/hero-ads-vs-organic.svg',
  },
  {
    category: 'Publicité LinkedIn',
    tags: ['Publicité', 'Mesure'],
    title: "Pourquoi le rendement de vos publicités LinkedIn a l'air catastrophique (c'est un problème de mesure)",
    excerpt: "LinkedIn génère un retour sur investissement publicitaire de 121% en B2B. Mais le parcours d'achat moyen dure 272 jours. Mesurez le rendement à 30 jours et vos données vous mentent.",
    date: '2026-03-29',
    slug: 'linkedin-ad-roi-measurement-problem',
    image: '/blog/hero-ads-cost.svg',
  },
];

const faqs = [
  { q: "Vos clients sont où ?", a: "Un peu partout. Europe, Amérique du Nord, Asie, et d'autres régions. LinkedIn est une plateforme mondiale et on fonctionne pareil." },
  { q: "Vous ne faites vraiment que LinkedIn ?", a: "Oui. Pas de référencement, pas d'Instagram, pas de formule « agence à tout faire ». LinkedIn uniquement. C'est cette spécialisation qui fait la différence." },
  { q: "Combien ça coûte pour démarrer ?", a: "Notre formule Foundation démarre à 1 500 €/mois. Ça inclut la stratégie, le contenu et le suivi. La plupart des clients commencent par là et montent en gamme ensuite.", link: { text: 'Voir tous les tarifs →', href: '/fr/pricing' } },
  { q: "C'est que pour les grandes boîtes ?", a: "Non. 1 500 €/mois vous donne une présence LinkedIn entièrement gérée, c'est accessible à beaucoup d'entreprises. Et si un accompagnement complet c'est pas encore le bon moment, on propose aussi de la formation et de la gestion publicitaire à la carte." },
  { q: "La publicité est incluse ?", a: "La publicité est une ligne à part. Certains clients font du contenu organique uniquement, d'autres que de la pub. La plupart font les deux. Le budget publicitaire va toujours directement sur votre compte LinkedIn, jamais par chez nous." },
  { q: "Et les résultats, vous les mesurez comment ?", a: "On fixe les indicateurs ensemble au démarrage : nombre de prospects, croissance de l'audience, coût par prospect, contribution au chiffre d'affaires. Chaque mois on vous envoie un rapport la dessus. Pas un document rempli de vues et de chiffres qui veulent rien dire." },
];

---

<Layout
  lang="fr"
  title="Nuvora Studio | L'agence B2B 100 % LinkedIn"
  description="Conseil LinkedIn exclusif pour les entreprises B2B. Contenu, publicité, visibilité des dirigeants et formation. Une seule plateforme. Une expertise totale."
  abstract="L'agence B2B spécialisée LinkedIn. On construit des présences qui génèrent des prospects et installent la crédibilité. Une seule plateforme."
>
  <NavBar lang="fr" />
  <main id="main-content">

    <!-- ═══════════════════════════ 1. HERO ═══════════════════════════ -->
    <section class="hero" aria-labelledby="hero-heading">
      <div class="hero__bg" aria-hidden="true"></div>
      <div class="hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="hero__content">
          <p class="eyebrow eyebrow--light reveal">L'agence B2B 100 % LinkedIn</p>
          <h1 id="hero-heading" class="hero__h1 reveal reveal-delay-1">
            On transforme LinkedIn en votre <span class="text-gradient">meilleur canal de prospection.</span>
          </h1>
          <p class="hero__sub reveal reveal-delay-2">
            Stratégie, contenu et publicité. Exclusivement sur LinkedIn.
            On aide les entreprises B2B à se rendre visibles, installer leur crédibilité et générer des prospects.
          </p>
          <div class="hero__actions reveal reveal-delay-3">
            <a href="/fr/contact?intent=call" class="btn btn--primary btn--lg">Réserver un appel stratégique</a>
            <a href="/fr/services" class="btn btn--outline-white btn--lg">Découvrir nos services</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ 2. PROBLEM STATEMENT ═══════════════════════════ -->
    <section class="section problem" aria-labelledby="problem-heading">
      <div class="container">

        <div class="problem__hero reveal">
          <div class="problem__head">
            <p class="eyebrow eyebrow--light">Le problème</p>
            <h2 id="problem-heading">
              La plupart des entreprises B2B sont<br />invisibles sur LinkedIn.
            </h2>
            <p class="problem__sub">
              Elles publient quand elles y pensent. Leur page entreprise date d'il y a deux ans. Leurs dirigeants n'ont aucune présence.
              Leurs pubs touchent les mauvaises personnes. LinkedIn récompense la régularité et l'expertise — sans les deux
              vous gaspillez le meilleur canal B2B qui existe.
            </p>
          </div>

          <div class="problem__visual">
            <img
              src="/problem-linkedin.png"
              alt="Comparaison côte à côte de deux écrans : à gauche des notifications LinkedIn vides avec zéro impression et des statistiques plates, à droite un flux de demandes de connexion, de nouveaux prospects et 12 400 de portée"
              class="problem__img"
              width="1024"
              height="1024"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <div class="problem__grid">
          {painPoints.map((p, i) => (
            <div class="problem__card reveal" style={`transition-delay: ${i * 0.1}s`}>
              <p class="problem__stat">{p.stat}</p>
              <p class="problem__label">{p.label}</p>
              <p class="problem__detail">{p.detail}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════ 3. SERVICES GRID ═══════════════════════════ -->
    <section id="services" class="section" style="background: var(--off-white);" aria-labelledby="services-heading">
      <div class="container">

        <div class="services__head reveal">
          <div>
            <p class="eyebrow">Ce qu'on fait</p>
            <h2 id="services-heading">Tout ce dont votre présence<br />LinkedIn a besoin.</h2>
          </div>
          <p class="services__intro">
            En toute transparence. Stratégie, audit et suivi sont inclus dans chaque mission, pas en supplément.
          </p>
        </div>

        <div class="services__grid">
          {services.map((s, i) => (
            <a href={s.href} class="services__card reveal" style={`transition-delay: ${i * 0.08}s`}>
              <div class="services__card-top">
                <span class="tag tag--cyan">{s.tag}</span>
                <span class="services__arrow" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M4.5 15.5L15.5 4.5M15.5 4.5H7.5M15.5 4.5V12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              {s.title === 'Contenu' ? (
                <div class="services__vis services__vis--content" aria-hidden="true">
                  <img src="/content-calendar-v2.png" alt="" width="600" height="338" loading="lazy" />
                </div>
              ) : s.title === 'Publicité' ? (
                <div class="services__vis services__vis--content" aria-hidden="true">
                  <img src="/ad-creative-stack.png" alt="" width="600" height="338" loading="lazy" />
                </div>
              ) : s.title === 'Conseil' ? (
                <div class="services__vis services__vis--content" aria-hidden="true">
                  <img src="/consulting-workshop.png" alt="" width="600" height="338" loading="lazy" />
                </div>
              ) : (
                <div class="vis-placeholder services__vis" aria-hidden="true">
                  <span>Visuel provisoire</span>
                </div>
              )}
              <h3 class="services__card-title">{s.title}</h3>
              <p class="services__card-desc">{s.body}</p>
              <ul class="services__subs">
                {s.subs.map(sub => (
                  <li class="services__sub">{sub}</li>
                ))}
              </ul>
            </a>
          ))}
        </div>

        <div class="services__foot reveal">
          <a href="/fr/services" class="btn btn--outline btn--lg">Voir tous les services</a>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════ 4. HOW WE WORK ═══════════════════════════ -->
    <section class="section" style="background: var(--deep-navy);" aria-labelledby="process-heading">
      <div class="container">

        <div class="process__head reveal">
          <p class="eyebrow eyebrow--light">Comment ça marche</p>
          <h2 id="process-heading" style="color: var(--white);">
            De l'audit à la prospection<br /><em style="color: rgba(255,255,255,0.35); font-weight: 300;">en trois étapes.</em>
          </h2>
        </div>

        <div class="process__grid">
          {steps.map((s, i) => (
            <div class="process__step reveal" style={`transition-delay: ${i * 0.1}s`}>
              <div class="process__line-horizontal" aria-hidden="true"></div>
              <div class="process__content">
                <span class="process__detail">{s.detail}</span>
                <h3 class="process__title">{s.title}</h3>
                <p class="process__body">{s.body}</p>
              </div>
              {s.title === 'Audit & Stratégie' ? (
                <div class="process__vis process__vis--img" aria-hidden="true">
                  <img src="/audit-strategy.png" alt="" width="600" height="375" loading="lazy" />
                </div>
              ) : s.title === 'Construction & Lancement' ? (
                <div class="process__vis process__vis--img" aria-hidden="true">
                  <img src="/build-launch.png" alt="" width="600" height="375" loading="lazy" />
                </div>
              ) : s.title === 'Croissance & Suivi' ? (
                <div class="process__vis process__vis--img" aria-hidden="true">
                  <img src="/grow-report.png" alt="" width="600" height="375" loading="lazy" />
                </div>
              ) : (
                <div class="vis-placeholder process__vis" aria-hidden="true">
                  <span>Visuel provisoire</span>
                </div>
              )}
            </div>
          ))}
        </div>

        <div class="process__cta reveal" style="transition-delay: 0.3s">
          <a href="/fr/pricing" class="btn btn--outline-white btn--lg">Voir les tarifs</a>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════ 5. WHAT SETS US APART ═══════════════════════════ -->
    <section class="section" aria-labelledby="apart-heading">
      <div class="container">
        <div class="apart__layout">

          <div class="apart__left">
            <div class="apart__head reveal">
              <p class="eyebrow">Pourquoi nous</p>
              <h2 id="apart-heading">On fait une seule chose.<br />LinkedIn.</h2>
              <div class="accent-bar"></div>
              <p class="apart__lead">
                On est pas une agence numérique généraliste qui fait « aussi » du LinkedIn.
                LinkedIn c'est tout ce qu'on fait. Et c'est ça qui change tout.
              </p>
            </div>

            <!-- Visual: comparison graphic -->
            <div class="apart__visual reveal reveal-delay-1" aria-hidden="true">
              <div class="apart__visual-inner">
                <div class="apart__vis-compare">
                  <div class="apart__vis-col apart__vis-col--them">
                    <span class="apart__vis-label">Agences généralistes</span>
                    <div class="apart__vis-bars">
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 30%"></div></div>
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 25%"></div></div>
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 20%"></div></div>
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 35%"></div></div>
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 15%"></div></div>
                    </div>
                  </div>
                  <div class="apart__vis-divider"></div>
                  <div class="apart__vis-col apart__vis-col--us">
                    <span class="apart__vis-label">Nuvora Studio</span>
                    <div class="apart__vis-bars">
                      <div class="apart__vis-item"><span class="apart__vis-dot"></span><div class="apart__vis-bar" style="width: 100%"></div></div>
                    </div>
                    <span class="apart__vis-tag">100 % LinkedIn</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="apart__right">
            <div class="apart__grid">
              {pillars.map((p, i) => (
                <div class="apart__card reveal" style={`transition-delay: ${i * 0.08}s`}>
                  <div class="apart__card-metric">
                    <span class="apart__metric-value">{p.metric}</span>
                    <span class="apart__metric-label">{p.metricLabel}</span>
                  </div>
                  <div class="apart__card-body">
                    <div class="apart__card-header">
                      <h3 class="apart__title">{p.title}</h3>
                    </div>
                    <p class="apart__body">{p.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ 6. TESTIMONIALS ═══════════════════════════ -->
    <Testimonials
      eyebrow="Ils nous font confiance"
      heading="Ce que disent nos clients"
      sub="Des collaborations orientées résultats, avec des équipes B2B de tous secteurs."
      items={[
        { text: "Nuvora a transformé notre présence LinkedIn. En six mois, 40% de nos prospects venaient de LinkedIn. Avant c'était un canal qu'on négligeait complètement.", image: "https://randomuser.me/api/portraits/women/32.jpg", name: "Sophie Laurent", role: "Directrice marketing, Éditeur SaaS" },
        { text: "Ils ne se contentent pas de publier. Ils comprennent les cycles d'achat B2B. Les profils de nos dirigeants sont passés de dormants à générateurs de conversations entrantes.", image: "https://randomuser.me/api/portraits/men/45.jpg", name: "Marcus Webb", role: "Directeur commercial, Industrie tech" },
        { text: "La transparence, c'est ce qui change tout. Chaque mois on voit exactement ce qui marche, ce qui marche pas, et où va le budget. Aucune autre agence nous avait donné ça.", image: "https://randomuser.me/api/portraits/women/28.jpg", name: "Priya Sharma", role: "Responsable marketing, Fintech" },
        { text: "On a testé trois agences avant Nuvora. La différence ? Ils comprennent vraiment l'algorithme LinkedIn et comment les décideurs B2B se comportent sur la plateforme.", image: "https://randomuser.me/api/portraits/men/22.jpg", name: "David Chen", role: "PDG, Cabinet de conseil" },
        { text: "Notre budget pub LinkedIn est passé de l'argent brûlé à des prospects qualifiés à moitié prix. L'architecture de campagne qu'ils ont construite est redoutablement efficace.", image: "https://randomuser.me/api/portraits/women/44.jpg", name: "Emma Bergström", role: "Responsable numérique, Industrie" },
        { text: "Ce qui les distingue c'est la qualité du contenu. Chaque publication sonne comme nous, pas comme une agence. C'est rare quand on externalise du contenu B2B.", image: "https://randomuser.me/api/portraits/men/36.jpg", name: "James Okafor", role: "Fondateur, Services professionnels" },
        { text: "De la stratégie à l'exécution, tout est pris en charge. On est passés d'une publication par mois à une vraie présence. Page entreprise, profils dirigeants, publicité. Et tout fonctionne.", image: "https://randomuser.me/api/portraits/women/51.jpg", name: "Ana Rodriguez", role: "Directrice marketing, Santé" },
        { text: "Nuvora nous a aidés à monter un programme de mobilisation qui a transformé nos commerciaux en voix de référence. L'impact sur la prospection a été mesurable, et significatif.", image: "https://randomuser.me/api/portraits/men/53.jpg", name: "Ravi Patel", role: "Directeur de la croissance, Éditeur logiciel" },
        { text: "Ce qui m'a le plus impressionné c'est le suivi. De vrais indicateurs, de vrais chiffres de prospection. Pas des vues et des mentions j'aime. On sait enfin ce que LinkedIn apporte concrètement à notre activité.", image: "https://randomuser.me/api/portraits/women/19.jpg", name: "Laura Koenig", role: "Directrice des opérations, Logistique" },
      ]}
    />

    <!-- ═══════════════════════════ 7. INDUSTRIES ═══════════════════════════ -->
    <section class="section" aria-labelledby="industries-heading">
      <div class="container">
        <div class="industries__layout">

          <div class="industries__text reveal">
            <p class="eyebrow">Avec qui on travaille</p>
            <h2 id="industries-heading">Conçu pour le B2B,<br /><em>tous secteurs confondus.</em></h2>
            <div class="accent-bar"></div>
            <p class="industries__body">
              On travaille avec des entreprises de toutes tailles — des multinationales établies aux boîtes en forte croissance, dans des secteurs et des marchés très différents.
            </p>
            <p class="industries__body">
              Si vos acheteurs sont sur LinkedIn et que vous les atteignez pas, on devrait en parler.
            </p>
            <a href="/fr/contact" class="btn btn--primary" style="margin-top: var(--sp-6);">
              Parlons-en
            </a>
          </div>

          <div class="industries__right reveal reveal-delay-2">
            <div class="industries__visual" aria-hidden="true">
              <img src="/global-connections.png" alt="" width="600" height="338" loading="lazy" />
            </div>
            <div class="industries__grid" aria-label="Secteurs que nous servons">
              {industries.map(ind => (
                <div class="industries__item">
                  <span class="industries__dot" aria-hidden="true"></span>
                  <span class="industries__label">{ind.label}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ 8. INSIGHTS PREVIEW ═══════════════════════════ -->
    <section class="section" style="background: var(--off-white);" aria-labelledby="insights-heading">
      <div class="container">

        <div class="insights__head reveal">
          <div>
            <p class="eyebrow">Depuis le blog</p>
            <h2 id="insights-heading">L'intelligence LinkedIn,<br /><em>par écrit.</em></h2>
          </div>
          <p class="insights__sub">
            Des analyses de fond sur la stratégie LinkedIn, le contenu B2B, la publicité et les évolutions de la plateforme.
            Ecrites par des praticiens, pas par des usines à textes.
          </p>
        </div>

        <div class="insights__grid">
          {posts.map((post, i) => (
            <article class="insights__card reveal" style={`transition-delay: ${i * 0.08}s`}>
              {post.image ? (
                <div class="insights__thumb insights__thumb--img" style={`background-image: url('${post.image}')`} aria-hidden="true"></div>
              ) : (
                <div class="vis-placeholder insights__thumb" aria-hidden="true">
                  <span>Visuel provisoire</span>
                </div>
              )}
              <div class="insights__card-top">
                <div class="insights__tags">
                  {post.tags.map(t => <span class="insights__tag">{t}</span>)}
                </div>
              </div>
              <h3 class="insights__title">
                <a href={`/insights/${post.slug}`}>{post.title}</a>
              </h3>
              <p class="insights__excerpt">{post.excerpt}</p>
              <a href={`/insights/${post.slug}`} class="insights__read">
                Lire l'article
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M3 7h8m0 0L7.5 3.5M11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </article>
          ))}
        </div>

        <div class="text-center reveal" style="margin-top: var(--sp-10);">
          <a href="/fr/insights" class="btn btn--outline btn--lg">Lire tous les articles</a>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════ 9. FAQ ═══════════════════════════ -->
    <FAQ heading="Ce qu'on nous demande le plus souvent." faqs={faqs} footer="D'autres questions ?" footerLink={{ text: 'Écrivez-nous', href: '/fr/contact' }} id="faq-fr" />

    <!-- ═══════════════════════════ 10. CONTACT CTA ═══════════════════════════ -->
    <section class="section cta" aria-labelledby="cta-heading" style="background: var(--deep-navy);">
      <div class="container">
        <div class="cta__layout">

          <div class="cta__left reveal">
            <p class="eyebrow eyebrow--light">Par où commencer</p>
            <h2 id="cta-heading" class="cta__headline">
              Construisons votre présence LinkedIn<br />
              <em>pour de bon.</em>
            </h2>
          </div>

          <div class="cta__right reveal reveal-delay-2">
            <p class="cta__sub">
              Que vous partiez de zéro ou que vous vouliez développer ce qui existe déjà — on préfère d'abord comprendre votre situation. Pas de discours commercial, pas de slides. Juste une conversation.
            </p>
            <div class="cta__actions">
              <a href="/fr/contact?intent=call" class="btn btn--primary btn--lg">Réserver un appel de 30 minutes</a>
              <a href="/fr/contact" class="btn btn--outline-white btn--lg">Nous envoyer un message</a>
            </div>
            <p class="cta__note">30 minutes. Pas de baratin. Des réponses directes.</p>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════ */
  .hero {
