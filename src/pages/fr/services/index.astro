---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';

import ContactCTA from '../../../components/ContactCTA.astro';

/* ── Données ──────────────────────────────────────────── */

const contentServices = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="7" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.6"/><line x1="9" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Gestion de page entreprise',
    text: 'On la crée de zéro, ou alors on reprend ce qui existe et on remet de l\u2019ordre. Après c\u2019est nous qui gérons au quotidien. La charte, les textes, le planning de publication, bref tout ce que vous n\u2019avez pas le temps de faire.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Production éditoriale',
    text: 'Posts, articles, carrousels, vidéos - on écrit tout et on met en page. Toutes les semaines. Dans votre ton, pas le nôtre. Et à force de publier régulièrement, les gens finissent par vous lire. Vraiment.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Infolettre LinkedIn',
    text: 'L\u2019infolettre arrive directement dans la boîte mail de vos abonnés. Et dans leurs notifications LinkedIn, aussi. Là-dessus l\u2019algorithme n\u2019a aucune prise.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Événements LinkedIn',
    text: 'De loin le format qui génère le plus d\u2019engagement sur LinkedIn. Tout le côté logistique, la promotion, les relances avant et après, c\u2019est pour nous. Vous, vous avez juste à venir parler.',
  },
];

const adFormats = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="3" width="20" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Contenus sponsorisés',
    text: 'Vos meilleurs contenus apparaissent dans le fil des gens qui ont le budget et l\u2019autorité pour signer. On cible par fonction, par séniorité, par entreprise - c\u2019est chirurgical.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.6"/><polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Messages sponsorisés',
    text: 'InMail et messages sponsorisés, conçus pour du B2B pur. On écrit les messages, on règle le ciblage, et l\u2019objectif c\u2019est que les gens répondent. Qu\u2019ils ouvrent juste le message ça ne nous intéresse pas.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="1.6"/><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Annonces dynamiques',
    text: 'Le prospect voit son propre nom et sa photo juste à côté de votre marque - forcément ça attire l\u2019oeil. On gère la mise en place et l\u2019optimisation, y compris sur des gros volumes.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 8h8M8 12h6M8 16h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Annonces textuelles',
    text: 'C\u2019est pas le format le plus spectaculaire, mais en complément des contenus sponsorisés elles font un vrai travail de fond. Le rapport qualité-prix est imbattable.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 11l3 3L22 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Formulaires intégrés',
    text: 'Le prospect remplit le formulaire sans quitter LinkedIn. Un clic, et vous avez ses coordonnées. Pas de page externe, pas d\u2019étape en plus. On les construit, on les teste, on les fait évoluer.',
  },
];

const consultingServices = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.6"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Prise de parole des collaborateurs',
    text: 'Les réseaux personnels de vos collaborateurs, votre page entreprise n\u2019y aura jamais accès. Nous on construit le programme et on prépare les publications. Vos équipes n\u2019ont qu\u2019à partager.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Rayonnement des dirigeants',
    text: 'Avant même de regarder votre page entreprise, un prospect va d\u2019abord checker le profil de votre DG. On s\u2019assure que ce qu\u2019il y trouve reflète enfin le niveau d\u2019expertise qui existe déjà en interne.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2V3z" stroke="currentColor" stroke-width="1.6"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7V3z" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Formations',
    text: 'Ateliers en présentiel, concrets, pas de la théorie PowerPoint. On couvre tout depuis l\u2019optimisation du profil jusqu\u2019à la stratégie de contenu et l\u2019analyse des stats. Votre équipe repart en sachant exactement quoi faire lundi matin.',
  },
];
---

<Layout
  lang="fr"
  title="Nos services LinkedIn pour le B2B"
  description="Contenu, publicité, conseil. Trois leviers pour que vos prochains clients vous trouvent sur LinkedIn."
  abstract="On développe votre présence LinkedIn pour que ça se transforme en rendez-vous et en contrats. Contenu, publicité, accompagnement."
>
  <NavBar lang="fr" />
  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════ -->
    <section class="s-hero" aria-labelledby="s-hero-h">
      <div class="s-hero__bg" aria-hidden="true"></div>
      <div class="s-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="s-hero__content">
          <p class="eyebrow eyebrow--light reveal">Nos services</p>
          <h1 id="s-hero-h" class="s-hero__h1 reveal reveal-delay-1">
            Votre LinkedIn devrait vous ramener des clients. On fait en sorte que <span class="text-gradient">ça arrive vraiment.</span>
          </h1>
          <p class="s-hero__sub reveal reveal-delay-2">
            Vous savez que LinkedIn pourrait rapporter plus. Mais personne en interne n'a le temps de s'en occuper sérieusement, et la méthode reste floue. Du coup rien ne bouge. Nous on est là pour débloquer ça.
          </p>
          <div class="s-hero__actions reveal reveal-delay-3">
            <a href="/fr/contact" class="btn btn--primary btn--lg">Prendre rendez-vous</a>
            <a href="#s-content" class="btn btn--outline-white btn--lg">Voir nos offres</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         INTRO
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-intro" aria-labelledby="s-intro-h">
      <div class="container">
        <div class="s-intro__inner reveal">
          <h2 id="s-intro-h" class="s-intro__h2">On intervient sur trois axes. L'objectif est toujours le même : que LinkedIn vous rapporte des affaires.</h2>
          <p class="s-intro__body">Votre page entreprise est à moitié vide. Le profil de votre dirigeant n'a pas bougé depuis 2021 (au mieux). Tout le monde sait qu'il faudrait s'en occuper mais personne ne le fait. On connaît le scénario par coeur, c'est exactement ce qu'on traite.</p>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         SERVICES DE CONTENU
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar" id="s-content" aria-labelledby="s-content-h">
      <div class="container">
        <div class="s-pillar__layout">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </div>
            <h2 id="s-content-h" class="s-pillar__h2">Contenu LinkedIn</h2>
            <a href="/fr/services/contenu" class="btn btn--primary">On en parle ?</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap">
              <img src="/services-content.webp" alt="Professionnelle rédigeant une publication LinkedIn sur son ordinateur portable" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-cards">
          {contentServices.map((card, i) => (
            <a href="/fr/services/contenu" class={`s-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="s-card__top">
                <span class="s-card__icon" set:html={card.icon} />
              </div>
              <strong class="s-card__title">{card.title}</strong>
              <p class="s-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         SERVICES PUBLICITAIRES
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar s-pillar--dark" id="s-advertising" aria-labelledby="s-ads-h">
      <div class="s-pillar__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="s-pillar__layout s-pillar__layout--flip">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap s-pillar__icon-wrap--light">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
            </div>
            <h2 id="s-ads-h" class="s-pillar__h2">Publicité LinkedIn</h2>
            <a href="/fr/services/publicite" class="btn btn--primary">En savoir plus</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap s-pillar__img-wrap--dark">
              <img src="/services-advertising.webp" alt="Deux collègues analysant les résultats d'une campagne publicitaire LinkedIn" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-ad-grid">
          {adFormats.map((card, i) => (
            <a href="/fr/services/publicite" class={`s-ad-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 4)}` : ''}`}>
              <span class="s-ad-card__icon" set:html={card.icon} />
              <strong class="s-ad-card__title">{card.title}</strong>
              <p class="s-ad-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         SERVICES DE CONSEIL
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar" id="s-consulting" aria-labelledby="s-consult-h">
      <div class="container">
        <div class="s-pillar__layout">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2V3z" stroke="currentColor" stroke-width="1.6"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7V3z" stroke="currentColor" stroke-width="1.6"/></svg>
            </div>
            <h2 id="s-consult-h" class="s-pillar__h2">Conseil et formation LinkedIn</h2>
            <a href="/fr/services/conseil" class="btn btn--primary">Discutons-en</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap">
              <img src="/services-consulting.webp" alt="Formation LinkedIn en salle avec une intervenante devant un groupe de professionnels" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-consult-grid">
          {consultingServices.map((card, i) => (
            <a href="/fr/services/conseil" class={`s-consult-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <span class="s-consult-card__icon" set:html={card.icon} />
              <strong class="s-consult-card__title">{card.title}</strong>
              <p class="s-consult-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         ÉQUIPE
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-team" aria-labelledby="s-team-h">
      <div class="container">
        <div class="s-team__inner reveal">
          <p class="eyebrow">L'équipe</p>
          <h2 id="s-team-h" class="s-team__h2">Pas de templates. Pas de recettes toutes faites.</h2>
          <p class="s-team__body">Ce qu'il faut, c'est des gens qui baignent dans le B2B, qui connaissent LinkedIn jusque dans ses recoins et qui sont un peu obsessionnels sur la qualité. C'est notre profil. On a travaillé avec des boîtes dans l'industrie, la tech, la santé, le conseil. En France et à l'international.</p>
          <a href="/fr/a-propos" class="btn btn--outline">Découvrir l'équipe</a>
        </div>
      </div>
    </section>


    <ContactCTA lang="fr" />

  </main>
</Layout>


<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>

  /* ╔═══════════════════════════════════════════╗
     ║  HERO                                     ║
     ╚═══════════════════════════════════════════╝ */
  .s-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .s-hero__bg {
    position: absolute;
    inset: 0;
    background: url('/services-hero.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .s-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.92) 0%,
      rgba(15,23,42, 0.75) 50%,
      rgba(15,23,42, 0.45) 100%
    );
    z-index: 1;
  }

  .s-hero__content {
    max-width: 680px;
  }

  .s-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .s-hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .s-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.68);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--sp-10);
  }

  .s-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  @media (max-width: 640px) {
    .s-hero { padding-block: var(--sp-16) var(--sp-12); }
  }


  /* ╔═══════════════════════════════════════════╗
     ║  INTRO                                    ║
     ╚═══════════════════════════════════════════╝ */
  .s-intro {
    background: var(--white);
    padding-block: var(--sp-16);
  }
  .s-intro__inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .s-intro__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: var(--text);
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-6);
  }
  .s-intro__body {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
  }


  /* ╔═══════════════════════════════════════════╗
     ║  PILLAR SECTIONS (Contenu / Pub / Conseil)║
     ╚═══════════════════════════════════════════╝ */
  .s-pillar {
    background: var(--white);
    position: relative;
    overflow: hidden;
  }
  .s-pillar--dark {
    background: var(--deep-navy);
  }
  .s-pillar__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 60% at 0% 100%, rgba(6,182,212,.08) 0%, transparent 60%),
      radial-gradient(ellipse 40% 50% at 100% 0%, rgba(3,105,161,.06) 0%, transparent 60%);
  }

  .s-pillar__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
    margin-bottom: var(--sp-16);
    position: relative;
    z-index: 1;
  }
  .s-pillar__layout--flip { direction: rtl; }
  .s-pillar__layout--flip .s-pillar__text,
  .s-pillar__layout--flip .s-pillar__visual { direction: ltr; }

  .s-pillar__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    border-radius: var(--r-xl);
    background: linear-gradient(135deg, rgba(3,105,161,.08), rgba(6,182,212,.06));
    color: var(--sky);
    margin-bottom: var(--sp-5);
    transition: transform var(--t-base);
  }
  .s-pillar__icon-wrap:hover { transform: scale(1.05); }
  .s-pillar__icon-wrap--light {
    background: linear-gradient(135deg, rgba(6,182,212,.12), rgba(3,105,161,.08));
    color: var(--cyan);
  }

  .s-pillar__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-6);
  }
  .s-pillar--dark .s-pillar__h2 { color: var(--white); }

  .s-pillar__lead {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-4);
    font-weight: 500;
  }
  .s-pillar--dark .s-pillar__lead { color: rgba(255,255,255,0.68); }

  .s-pillar__body {
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-8);
  }
  .s-pillar--dark .s-pillar__body { color: rgba(255,255,255,0.48); }

  /* Visual images */
  .s-pillar__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .s-pillar__img-wrap {
    position: relative;
    border-radius: var(--r-2xl);
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--off-white);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
  }
  .s-pillar__img-wrap--dark {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
    box-shadow: var(--shadow-lg);
  }

  .s-pillar__img-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    height: 100%;
    background: linear-gradient(135deg, var(--off-white) 0%, var(--border) 100%);
  }
  .s-pillar__img-ph--dark {
