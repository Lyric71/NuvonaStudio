---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import LangBanner from '../../components/LangBanner.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations, getAlternateUrl } from '../../i18n/index.ts';

const t = useTranslations('fr');
---

<Layout
  lang="fr"
  title="[FR] Contactez Nuvora Studio | Réservez un appel découverte"
  description="[FR] Prenez contact avec Nuvora Studio. Réservez un appel de 30 minutes ou envoyez-nous un message."
  abstract="[FR] Réservez un appel ou envoyez un message. Réponse sous un jour ouvrable."
>
  <NavBar lang="fr" />
  <LangBanner
    message={t('lang.banner')}
    alternatUrl={getAlternateUrl('/fr/contact', 'en')}
  />
  <main id="main-content">

    <section class="contact-hero" aria-labelledby="contact-heading">
      <div class="container">
        <div class="contact-hero__inner">
          <div class="contact-hero__text">
            <p class="eyebrow eyebrow--light reveal">Nous contacter</p>
            <h1 id="contact-heading" class="contact-hero__h1 reveal reveal-delay-1">
              Parlons<br /><em>LinkedIn.</em>
            </h1>
            <p class="contact-hero__sub reveal reveal-delay-2">
              [FR] Tell us about your project. We read every message and reply within one business day.
            </p>
          </div>
          <div class="contact-hero__info reveal reveal-delay-2">
            <div class="contact-info-item">
              <span class="contact-info-item__label">Délai de réponse</span>
              <span class="contact-info-item__value">1 jour ouvrable</span>
            </div>
            <div class="contact-info-item">
              <span class="contact-info-item__label">[FR] We work with</span>
              <span class="contact-info-item__value">[FR] B2B companies worldwide</span>
            </div>
            <div class="contact-info-item">
              <span class="contact-info-item__label">[FR] Engagements from</span>
              <span class="contact-info-item__value">$1,800 / mois</span>
              <a href="/fr/pricing" class="contact-info-item__link">[FR] See full pricing →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--off-white);">
      <div class="container container--contact">
        <div class="contact-card" id="contact-card">
          <div class="contact-card__header">
            <h2 class="contact-card__title">[FR] Send us a message</h2>
            <p class="contact-card__note">[FR] Fields marked * are required.</p>
          </div>

          <form id="contact-form" class="contact-form" novalidate aria-label="Formulaire de contact">
            <div class="contact-form__grid">
              <div class="form-group">
                <label class="form-label" for="name">Votre nom <span aria-hidden="true">*</span></label>
                <input class="form-input" type="text" id="name" name="name" autocomplete="name" required placeholder="Jean Dupont" />
                <span class="form-error" id="name-error" role="alert"></span>
              </div>
              <div class="form-group">
                <label class="form-label" for="email">Votre e-mail <span aria-hidden="true">*</span></label>
                <input class="form-input" type="email" id="email" name="email" autocomplete="email" required placeholder="jean@entreprise.com" />
                <span class="form-error" id="email-error" role="alert"></span>
              </div>
              <div class="form-group">
                <label class="form-label" for="phone">Téléphone <span class="form-optional">(facultatif)</span></label>
                <input class="form-input" type="tel" id="phone" name="phone" autocomplete="tel" placeholder="+33 6 00 00 00 00" />
              </div>
              <div class="form-group">
                <label class="form-label" for="website">Site web <span aria-hidden="true">*</span></label>
                <input class="form-input" type="url" id="website" name="website" autocomplete="url" required placeholder="https://votreentreprise.com" />
                <span class="form-error" id="website-error" role="alert"></span>
              </div>
              <div class="form-group contact-form__full">
                <label class="form-label" for="company">Entreprise <span aria-hidden="true">*</span></label>
                <input class="form-input" type="text" id="company" name="company" autocomplete="organization" required placeholder="Acme Corp" />
                <span class="form-error" id="company-error" role="alert"></span>
              </div>
              <div class="form-group contact-form__full">
                <label class="form-label" for="project">Votre projet <span aria-hidden="true">*</span></label>
                <textarea class="form-textarea" id="project" name="project" required rows="5" placeholder="[FR] Tell us what you're working on..."></textarea>
                <span class="form-error" id="project-error" role="alert"></span>
              </div>
            </div>

            <div class="form-banner" id="form-error-banner" role="alert">
              <span id="form-error-message"></span>
            </div>

            <div class="contact-form__actions">
              <button type="submit" class="btn btn--primary btn--lg" id="submit-btn">
                <span id="submit-label">{t('form.send')}</span>
                <span id="submit-spinner" class="submit-spinner" style="display:none" aria-hidden="true"></span>
              </button>
              <p class="contact-form__privacy">[FR] We never share your data with third parties.</p>
            </div>
          </form>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .contact-hero {
    background: var(--deep-navy);
    padding-block: var(--sp-24) var(--sp-20);
    position: relative;
    overflow: hidden;
  }
  .contact-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 90% 50%, rgba(0,168,220,0.10) 0%, transparent 60%);
    pointer-events: none;
  }
  .contact-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--sp-16);
    align-items: center;
  }
  .contact-hero__h1 {
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .contact-hero__h1 em { color: rgba(255,255,255,0.48); font-weight: 300; font-style: normal; }
  .contact-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.65);
    max-width: 480px;
    line-height: 1.75;
  }
  .contact-hero__info {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    flex-shrink: 0;
  }
  .contact-info-item {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-5) var(--sp-7);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: var(--r-xl);
    min-width: 200px;
  }
  .contact-info-item__label {
    font-size: var(--fs-xs);
    color: var(--cyan);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .contact-info-item__value {
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--white);
  }
  .contact-info-item__link {
    font-size: var(--fs-xs);
    color: rgba(255,255,255,0.45);
    margin-top: var(--sp-1);
    transition: color var(--t-fast);
  }
  .contact-info-item__link:hover { color: var(--cyan); }
  .container--contact { max-width: 760px; }
  .contact-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-2xl);
    overflow: hidden;
  }
  .contact-card__header {
    padding: var(--sp-8) var(--sp-10) var(--sp-6);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .contact-card__title {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 600;
    color: var(--deep-navy);
  }
  .contact-card__note { font-size: var(--fs-xs); color: var(--text-3); }
  .contact-form {
    padding: var(--sp-8) var(--sp-10);
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }
  .contact-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-5);
  }
  .contact-form__full { grid-column: 1 / -1; }
  .form-optional { color: var(--text-3); font-weight: 400; font-size: var(--fs-xs); }
  .form-error { font-size: var(--fs-xs); color: #c0392b; min-height: 16px; display: block; }
  .form-input.is-invalid, .form-textarea.is-invalid {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192,57,43,0.10);
  }
  .form-banner {
    display: none;
    padding: var(--sp-4);
    background: #FEF2F2;
    border: 1px solid rgba(192,57,43,0.20);
    border-radius: var(--r-md);
    font-size: var(--fs-sm);
    color: #c0392b;
  }
  .form-banner.is-visible { display: block; }
  .contact-form__actions {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
    flex-wrap: wrap;
  }
  .contact-form__privacy { font-size: var(--fs-xs); color: var(--text-3); }
  .submit-spinner {
    display: inline-block;
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,0.30);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-left: var(--sp-2);
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @media (max-width: 1024px) {
    .contact-hero__inner { grid-template-columns: 1fr; }
    .contact-hero__info { flex-direction: row; flex-wrap: wrap; }
    .contact-info-item { flex: 1; min-width: 160px; }
  }
  @media (max-width: 640px) {
    .contact-hero { padding-block: var(--sp-16) var(--sp-12); }
    .contact-form { padding: var(--sp-6); }
    .contact-card__header { padding: var(--sp-6); }
    .contact-form__grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline src="https://www.google.com/recaptcha/api.js?render=6LfeTpQsAAAAAH-_V7o9bJuu4PO_kfgGcGMCuSiE"></script>
<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const card    = document.getElementById('contact-card') as HTMLElement | null;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label') as HTMLElement | null;
  const submitSpinner = document.getElementById('submit-spinner') as HTMLElement | null;
  const errorBanner  = document.getElementById('form-error-banner') as HTMLElement | null;
  const errorMessage = document.getElementById('form-error-message') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    if (submitBtn)     submitBtn.disabled = true;
    if (submitLabel)   submitLabel.textContent = 'Envoi en cours…';
    if (submitSpinner) submitSpinner.style.display = 'inline-block';

    try {
      const token = await new Promise<string>((resolve, reject) => {
        (window as any).grecaptcha.ready(() => {
          (window as any).grecaptcha.execute('6LfeTpQsAAAAAH-_V7o9bJuu4PO_kfgGcGMCuSiE', { action: 'contact' }).then(resolve).catch(reject);
        });
      });
      data.append('recaptcha_token', token);

      const res  = await fetch('/api/contact', { method: 'POST', body: data });
      const json = await res.json();
      if (res.ok) {
        if (card) card.innerHTML = '<div style="padding:4rem 2rem;text-align:center"><h2>Message envoyé.</h2><p>Nous vous répondrons dans un jour ouvrable.</p><a href="/fr/" class="btn btn--primary" style="margin-top:1.5rem">Retour à l\'accueil</a></div>';
      } else {
        if (errorBanner)  errorBanner.classList.add('is-visible');
        if (errorMessage) errorMessage.textContent = json.error ?? 'Une erreur est survenue.';
      }
    } catch {
      if (errorBanner)  errorBanner.classList.add('is-visible');
      if (errorMessage) errorMessage.textContent = 'Erreur réseau. Veuillez réessayer.';
    } finally {
      if (submitBtn)     submitBtn.disabled = false;
      if (submitLabel)   submitLabel.textContent = 'Envoyer le message';
      if (submitSpinner) submitSpinner.style.display = 'none';
    }
  });
</script>
