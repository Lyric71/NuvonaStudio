---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import FAQ from '../components/FAQ.astro';

/* ── Data ───────────────────────────────────────────────── */

const values = [
  {
    title: 'Do the work. Don\'t just advise on it.',
    body: 'The strategist who builds your plan is the same person running your campaigns. We don\'t separate thinking from doing. That\'s where most agencies fall apart.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Say what\'s true. Skip what sounds good.',
    body: 'We won\'t inflate metrics to make a report look pretty. If something isn\'t working, you\'ll hear it from us first.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Earn attention. Never rent it.',
    body: 'Every post, every ad, every executive profile we build has to be worth someone\'s time. If the content won\'t stop the scroll, it doesn\'t ship.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.6"/></svg>`,
  },
];

const whyWorkWithUs = [
  {
    title: 'LinkedIn is all we do.',
    body: 'We don\'t juggle ten platforms. Everyone on our team works on LinkedIn strategy, content, and ads. Nothing else. That depth shows up in the results.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Senior people. No handoffs.',
    body: 'The people you brief are the people who do the work. Your strategist, your writer, your campaign manager. You\'ll know them by name.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Global team. Local fluency.',
    body: 'We operate from Hong Kong, France, the Philippines, and China. A core group of LinkedIn strategists and campaign managers, backed by bilingual writers, designers, and data analysts. We produce content in 10+ languages without losing tone or nuance.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M3.5 9h17M3.5 15h17" stroke="currentColor" stroke-width="1.6"/><ellipse cx="12" cy="12" rx="4" ry="9" stroke="currentColor" stroke-width="1.6"/></svg>`,
  },
  {
    title: 'AI where it speeds things up. Humans where it counts.',
    body: 'We use AIGC workflows to draft and translate content faster. Every piece is reviewed and shaped by a real editor before it goes live. The technology keeps costs down. The people keep quality up.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Certified by LinkedIn.',
    body: 'Our team holds official LinkedIn Marketing certifications. It\'s a hiring standard, not a marketing badge.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l3 6h6l-5 4 2 6-6-4-6 4 2-6-5-4h6l3-6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
  },
];

const faqs = [
  { q: 'What kind of companies do you work with?', a: 'B2B companies across manufacturing, healthcare, tech, FMCG, retail, and professional services. If your buyers are on LinkedIn, we can help.' },
  { q: 'How long before we see results?', a: 'It depends on where you\'re starting. Companies with an existing LinkedIn presence tend to see traction faster than those building from zero. We set specific benchmarks in our first strategy session and report against them monthly.' },
  { q: 'What does onboarding look like?', a: 'We start with a strategy sprint: audit your current LinkedIn presence, define your target audience, and build a content and campaign plan. From there, we move into production.' },
  { q: 'We already have a marketing team. How does Nuvora fit in?', a: 'We work alongside internal teams regularly. Some clients hand LinkedIn to us entirely. Others use us for content production and ads while their team handles community engagement. We adapt to your setup.' },
  { q: 'Do you only work with large companies?', a: 'No. We work with mid-market and enterprise B2B companies. What matters is that LinkedIn is a meaningful channel for your sales pipeline.' },
  { q: 'How do you handle content in multiple languages?', a: 'Our team and AI-assisted workflows produce content in 10+ languages. Every piece is reviewed by a native speaker before publishing. We don\'t translate word for word. We localize for tone, context, and platform norms.' },
  { q: 'Can you manage executive profiles alongside the company page?', a: 'Yes. We offer ghostwriting and positioning for C-suite leaders as a standalone service or bundled with company page management. Executive branding is one of the fastest ways to generate inbound interest on LinkedIn.' },
  { q: 'What reporting do we get?', a: 'Monthly performance reports covering engagement, follower growth, ad metrics, and lead attribution. Clear numbers. No vanity metrics dressed up to look impressive.' },
  { q: 'What\'s the minimum commitment?', a: 'We recommend a three-month minimum to start. LinkedIn requires consistency to perform. A one-month test rarely tells you anything useful.' },
  { q: 'How do we get started?', a: 'Book a call. We\'ll review your current LinkedIn presence, talk through your goals, and tell you if we\'re the right fit.' },
];
---

<Layout
  title="About Nuvora Studio | LinkedIn Agency for B2B Leads"
  description="Nuvora Studio grows LinkedIn presence for B2B companies worldwide. Certified team. Strategic content. LinkedIn ads. Executive branding. More leads."
  abstract="We grow LinkedIn presence for B2B companies around the world. One platform. Certified team. Strategic content. The result: more leads."
>
  <NavBar />
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="ab-hero" aria-labelledby="ab-hero-h">
      <div class="ab-hero__bg" aria-hidden="true"></div>
      <div class="ab-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="ab-hero__content">
          <p class="eyebrow eyebrow--light reveal">About Nuvora Studio</p>
          <h1 id="ab-hero-h" class="ab-hero__h1 reveal reveal-delay-1">
            The B2B network is crowded. We make sure you are <span class="text-gradient">heard.</span>
          </h1>
          <p class="ab-hero__sub reveal reveal-delay-2">
            We grow LinkedIn presence for B2B companies around the world. One platform. Certified team. Strategic content. The result: more leads.
          </p>
        </div>
      </div>
    </section>


    <!-- ── Why We Exist ────────────────────────────────────── -->
    <section class="section ab-exist" aria-labelledby="exist-h">
      <div class="container">
        <div class="ab-exist__layout">

          <div class="ab-exist__text reveal">
            <p class="eyebrow">Our Story</p>
            <h2 id="exist-h">Why We Exist</h2>
            <p>We started Nuvora Studio because we kept seeing the same problem.</p>
            <p>Companies know LinkedIn matters for B2B. But they don't have the team, the time, or the platform expertise to make it work. So they post without a plan. They run ads without a strategy. And the leads don't come.</p>
            <p>We built an agency that does one thing and does it well. We grow your LinkedIn presence so you get more leads. Not more impressions. Not more followers for the sake of it. More conversations with the right buyers.</p>
            <p class="ab-exist__closing"><strong>That's why we're here.</strong></p>
          </div>

          <div class="ab-exist__visual reveal reveal-delay-1">
            <div class="ab-exist__sig-card">
              <div class="ab-exist__sig-visual">
                <img src="/signal-vs-noise.webp" alt="From noise to clarity, signal vs noise on LinkedIn" class="ab-exist__sig-hero" width="600" height="600" loading="lazy" />
              </div>
              <div class="ab-exist__sig-footer">
                <div class="ab-exist__sig-photo">
                  <img src="/Cyril-Drouin.webp" alt="Cyril Drouin, CEO" class="ab-exist__sig-img" width="80" height="80" loading="lazy" />
                </div>
                <div class="ab-exist__sig-info">
                  <strong class="ab-exist__sig-name">Cyril Drouin</strong>
                  <span class="ab-exist__sig-title">CEO & Chief Strategy Officer</span>
                </div>
              </div>
              <img src="https://beyondbordergroup.com/wp-content/compressx-nextgen/uploads/2026/02/Cyril-Drouin-Signature-Transparent.webp.avif" alt="Cyril Drouin signature" class="ab-exist__sig-mark" width="180" height="60" loading="lazy" />
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ── Our Values ──────────────────────────────────────── -->
    <section class="section ab-values" aria-labelledby="values-h">
      <div class="ab-values__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="ab-values__head reveal">
          <p class="eyebrow eyebrow--light">What Drives Us</p>
          <h2 id="values-h">Our Values</h2>
        </div>

        <div class="ab-values__grid">
          {values.map((v, i) => (
            <div class={`ab-val-card reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
              <div class="ab-val-card__icon" aria-hidden="true" set:html={v.icon} />
              <strong class="ab-val-card__title">{v.title}</strong>
              <p class="ab-val-card__body">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── Why Work With Us ────────────────────────────────── -->
    <section class="section ab-why" aria-labelledby="why-h">
      <div class="container">
        <div class="ab-why__head reveal">
          <p class="eyebrow">Why Us</p>
          <h2 id="why-h">Why Work With Us</h2>
        </div>

        <div class="ab-why__grid">
          {whyWorkWithUs.map((item, i) => (
            <div class={`ab-why-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="ab-why-card__icon" aria-hidden="true" set:html={item.icon} />
              <strong class="ab-why-card__title">{item.title}</strong>
              <p class="ab-why-card__body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── Our Leadership ──────────────────────────────────── -->
    <section class="section ab-team" aria-labelledby="team-h">
      <div class="container">
        <div class="ab-team__head reveal">
          <p class="eyebrow">Our Leadership</p>
          <h2 id="team-h">Our Leadership</h2>
          <p class="ab-team__sub">Built by practitioners. Proven at scale.</p>
        </div>

        <!-- Cyril Drouin -->
        <div class="ab-leader reveal">
          <div class="ab-leader__visual">
            <div class="ab-leader__photo-wrap">
              <img src="/Cyril-Drouin.webp" alt="Cyril Drouin" class="ab-leader__photo" width="400" height="480" loading="lazy" />
            </div>
          </div>

          <div class="ab-leader__content">
            <h3 class="ab-leader__name">Cyril Drouin</h3>
            <span class="ab-leader__title">CEO & Chief Strategy Officer</span>

            <div class="ab-leader__bio">
              <p>Cyril has spent 20+ years building marketing and commerce operations across China, Europe, and global markets.</p>
              <p>As CEO of Publicis Commerce China, he ran a 250-person team that generated $35M in revenue with 25%+ year-over-year growth. The agency was named eCommerce Agency of the Year, Greater China (Gold 2022). His client portfolio included Apple, L'Oréal, Nike, Nestlé, Heineken, and Kering.</p>
              <p>He is triple-certified by LinkedIn Marketing Labs: Marketing Strategy, Advertising Fundamentals, and Content & Creative Design.</p>
              <p>Cyril also founded HubStudio, an AIGC content studio, and teaches at HEC Paris, ESCP, and Shanghai Jiaotong University.</p>
            </div>

            <div class="ab-leader__certs">
              <a href="https://verify.skilljar.com/c/o4g7hsuokjyp" target="_blank" rel="noopener noreferrer" class="ab-leader__cert-card">
                <svg class="ab-leader__cert-li" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <div class="ab-leader__cert-info">
                  <strong>Content and Creative Design</strong>
                  <span>Issued Aug 2024</span>
                </div>
              </a>
              <a href="https://verify.skilljar.com/c/owpjectbjz4m" target="_blank" rel="noopener noreferrer" class="ab-leader__cert-card">
                <svg class="ab-leader__cert-li" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <div class="ab-leader__cert-info">
                  <strong>Marketing Strategy</strong>
                  <span>Issued Aug 2024</span>
                </div>
              </a>
              <a href="https://verify.skilljar.com/c/44sf7pp965dk" target="_blank" rel="noopener noreferrer" class="ab-leader__cert-card">
                <svg class="ab-leader__cert-li" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <div class="ab-leader__cert-info">
                  <strong>Marketing Solutions Fundamentals</strong>
                  <span>Issued Aug 2024</span>
                </div>
              </a>
            </div>
          </div>
        </div>

        <hr class="ab-team__divider" />

        <!-- LiYan Ye -->
        <div class="ab-leader ab-leader--flip reveal">
          <div class="ab-leader__visual">
            <div class="ab-leader__photo-wrap">
              <img src="https://beyondbordergroup.com/wp-content/uploads/elementor/thumbs/Liyan-Ye-rjaieqnzssadxaepw8m116yt79e5qhu51d5tgiyybk.webp" alt="LiYan Ye" class="ab-leader__photo" width="400" height="480" loading="lazy" />
              <div class="ab-leader__photo-ph" aria-hidden="true" style="display:none;">
                <svg width="64" height="64" viewBox="0 0 64 64" fill="none"><circle cx="32" cy="22" r="12" fill="rgba(10,102,194,0.15)"/><ellipse cx="32" cy="52" rx="20" ry="12" fill="rgba(10,102,194,0.10)"/></svg>
                <span>Photo coming soon</span>
              </div>
            </div>
          </div>

          <div class="ab-leader__content">
            <h3 class="ab-leader__name">LiYan Ye</h3>
            <span class="ab-leader__title">General Manager</span>

            <div class="ab-leader__bio">
              <p>LiYan brings 20 years of marketing experience with Fortune 500 brands including Beiersdorf, Reckitt Benckiser, Yum! Brands, and Valio.</p>
              <p>As Digital Marketing Director at Yum! China, she delivered the brand's first positive quarterly same-store sales growth in Q1 2017, reversing 11 consecutive quarters of decline. She was also a founding team member of Valio APAC, where she built the company's China B2B digital presence from scratch.</p>
              <p>At Nuvora Studio, LiYan runs day-to-day operations and oversees content quality, campaign performance, and client delivery across every account. Her focus areas are LinkedIn content strategy, social selling, and B2B audience engagement.</p>
              <p>Fluent in Mandarin and English.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <FAQ heading="Frequently Asked Questions" faqs={faqs} background="var(--off-white)" id="ab-faq" />


    <!-- ── Bottom CTA ──────────────────────────────────────── -->
    <section class="section ab-cta" aria-labelledby="ab-cta-h">
      <div class="ab-cta__orb ab-cta__orb--1" aria-hidden="true"></div>
      <div class="ab-cta__orb ab-cta__orb--2" aria-hidden="true"></div>
      <div class="container">
        <div class="ab-cta__layout">
          <div class="ab-cta__left reveal">
            <p class="eyebrow eyebrow--light">Start here</p>
            <h2 id="ab-cta-h" class="ab-cta__headline">
              Your buyers are on LinkedIn.<br />
              <em>Let's make sure they find you.</em>
            </h2>
          </div>
          <div class="ab-cta__right reveal reveal-delay-2">
            <p class="ab-cta__sub">Book a call. We'll review your current LinkedIn presence and tell you where the opportunity is.</p>
            <div class="ab-cta__actions">
              <a href="/contact?intent=call" class="btn btn--primary btn--lg">Book a call</a>
            </div>
            <p class="ab-cta__note">30 minutes. No pitch. Straight answers.</p>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>



<style>
  /* ────────────────────────────────────────────────────────────
     HERO
     ──────────────────────────────────────────────────────────── */
  .ab-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .ab-hero__bg {
    position: absolute;
    inset: 0;
    background: url('/about-hero-office.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .ab-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.92) 0%,
      rgba(15,23,42, 0.75) 50%,
      rgba(15,23,42, 0.45) 100%
    );
    z-index: 1;
  }

  .ab-hero__content {
    max-width: 680px;
  }

  .ab-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .ab-hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ab-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.68);
    max-width: 520px;
    line-height: 1.75;
  }

  @media (max-width: 640px) {
    .ab-hero { padding-block: var(--sp-16) var(--sp-12); }
  }


  /* ────────────────────────────────────────────────────────────
     WHY WE EXIST
     ──────────────────────────────────────────────────────────── */
  .ab-exist {
    background: var(--white);
  }

  .ab-exist__layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--sp-16);
    align-items: center;
  }

  .ab-exist__text h2 {
    margin-bottom: var(--sp-6);
  }
  .ab-exist__text p {
    font-family: var(--font-body);
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.8;
    margin-bottom: var(--sp-4);
  }
  .ab-exist__text p:last-child { margin-bottom: 0; }
  .ab-exist__closing {
    margin-top: var(--sp-4);
  }
  .ab-exist__closing strong {
    color: var(--text);
    font-size: var(--fs-lg);
  }

  /* Signature card */
  .ab-exist__sig-card {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--r-2xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--t-base), transform var(--t-base);
  }
  .ab-exist__sig-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }
  .ab-exist__sig-visual {
    width: 100%;
    overflow: hidden;
  }
  .ab-exist__sig-hero {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .ab-exist__sig-footer {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-5) var(--sp-6);
    width: 100%;
    text-align: left;
  }
  .ab-exist__sig-photo {
    width: 56px; height: 56px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--border-2);
    flex-shrink: 0;
  }
  .ab-exist__sig-img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .ab-exist__sig-name {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--text);
    display: block;
  }
  .ab-exist__sig-title {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--text-2);
    display: block;
    margin-top: var(--sp-1);
  }
  .ab-exist__sig-mark {
    max-width: 180px;
    height: auto;
    opacity: 0.7;
    padding-bottom: var(--sp-6);
  }


  /* ────────────────────────────────────────────────────────────
     OUR VALUES
     ──────────────────────────────────────────────────────────── */
  .ab-values {
    background: var(--deep-navy);
    position: relative;
    overflow: hidden;
  }
  .ab-values__bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 80% at 20% 50%, rgba(6, 182, 212, 0.06) 0%, transparent 60%),
                radial-gradient(ellipse 50% 60% at 80% 30%, rgba(3, 105, 161, 0.05) 0%, transparent 50%);
