<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards   = document.querySelectorAll<HTMLElement>('.case-card');
  const empty   = document.getElementById('cases-empty');

  function filter(service: string) {
    let visible = 0;

    cards.forEach(card => {
      const services = (card.dataset.services ?? '').split('||');
      const show = service === 'all' || services.includes(service);
      card.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });

    if (empty) empty.style.display = visible === 0 ? 'block' : 'none';

    buttons.forEach(btn => {
      btn.classList.toggle('filter-btn--active', btn.dataset.service === service);
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => filter(btn.dataset.service ?? 'all'));
  });
</script>
