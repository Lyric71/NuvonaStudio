---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Pricing1 from '../components/ui/Pricing.astro';
import FAQ from '../components/FAQ.astro';

/* ── Core retainer data ── */
const plans = [
  { name: 'Foundation', popular: false, price: '$1,800', href: '/contact?intent=retainer&tier=foundation' },
  { name: 'Growth', popular: true, price: '$3,500', href: '/contact?intent=retainer&tier=growth' },
  { name: 'Scale', popular: false, price: '$6,000', href: '/contact?intent=retainer&tier=scale' },
];

const features = [
  { label: 'Monthly price',          foundation: '$1,800', growth: '$3,500', scale: '$6,000' },
  { label: 'Page audit + setup',     foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Content strategy',       foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Posts per month',        foundation: '4', growth: '8', scale: '16' },
  { label: 'AI-generated visuals',   foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Community management',   foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'LinkedIn Ads management',foundation: '—', growth: '✓', scale: '✓' },
  { label: 'ICP + targeting',        foundation: '—', growth: '✓', scale: '✓' },
  { label: 'Competitor reports',     foundation: '—', growth: '✓', scale: '✓' },
  { label: 'Performance report',     foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Weekly strategy call',   foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Dedicated account',      foundation: 'Manager', growth: 'Manager', scale: 'Lead' },
  { label: 'Chat support M–F',      foundation: '✓', growth: '✓', scale: '✓' },
];

/* ── Ads comparison ── */
const adsFeatures = [
  { label: 'Monthly fee',                foundation: '$1,500/month', growth: '6%–10% of spend' },
  { label: 'Full-funnel Ads strategy',   foundation: '✓', growth: '✓' },
  { label: 'Unlimited campaigns & ads',  foundation: '✓', growth: '✓' },
  { label: 'Unlimited expert support',   foundation: '✓', growth: '✓' },
  { label: 'Customized reporting',       foundation: '✓', growth: '✓' },
  { label: 'Ad content guidance',        foundation: '✓', growth: '✓' },
  { label: 'Weekly check-in calls',      foundation: '—', growth: '✓' },
  { label: 'Performance analysis',       foundation: '—', growth: '✓' },
  { label: 'Microsegmentation strategy', foundation: '—', growth: '✓' },
  { label: 'Volume discounts',           foundation: '—', growth: '✓' },
];

/* ── Simple table data ── */
const execServices = [
  { service: 'Executive profile optimization (one-time)', price: '$500 per profile' },
  { service: 'Executive ghostwriting (4 posts/month + profile maintenance)', price: '$1,200/month per leader' },
];

const contentServices = [
  { service: 'AI-generated video (5s–30s)', price: '$200–$5,000 per video' },
  { service: 'Professional video shooting', price: 'Custom quote per project' },
  { service: 'Multilingual content', price: 'Custom quote per language' },
];

const trainingServices = [
  { service: 'LinkedIn training workshop (2 hours)', price: '$2,500 per session' },
  { service: 'Team training program (4 sessions)', price: '$8,000 one-time' },
  { service: 'Employee advocacy program', price: '$2,500/month' },
];

const bonusServices = [
  { model: 'Lead milestone bonus', percent: '+15%', structure: 'of monthly retainer when agreed lead targets are met. Requires active LinkedIn ad spend.' },
  { model: 'Follower growth bonus', percent: '+10%', structure: 'of monthly retainer when quarterly growth targets are exceeded. Requires active LinkedIn ad spend.' },
];

/* ── FAQ ── */
const faqs = [
  {
    q: "What's included in the retainer price?",
    a: "Everything listed under your tier. Strategy, content, visuals, community management, reporting, weekly call, and a dedicated contact. LinkedIn ad spend is the only cost billed separately, and that goes straight to your LinkedIn account, not ours.",
  },
  {
    q: 'Why a 3-month minimum?',
    a: "LinkedIn doesn't produce results overnight. We need time to audit your page, build a strategy, publish consistently, and let the algorithm catch up. Three months is what it takes to see real movement.",
  },
  {
    q: 'Can I switch tiers after I start?',
    a: 'Yes. After your initial 3-month commitment, you can move up or down at the start of any billing cycle.',
  },
  {
    q: 'Do you guarantee a specific number of leads?',
    a: "No. And honestly, be wary of anyone who does. We commit to doing the work right: strategy, content, targeting, week after week. Our performance bonus option means we earn more only when we deliver on the targets we agreed to together.",
  },
  {
    q: 'What does "ICP + targeting" mean?',
    a: "ICP is your ideal customer profile. We figure out who your best buyers are, by title, industry, company size, and location, then shape your content and ads around them. Included in Growth and Scale.",
  },
  {
    q: 'How does ad spend billing work?',
    a: "You pay LinkedIn directly from your own account. We run the campaigns. Your media budget never touches our books. Full transparency.",
  },
  {
    q: 'Can I buy ghostwriting without a retainer?',
    a: "Yes. Executive personal branding is a standalone service. Profile optimization, ghostwriting, or both. No retainer required.",
  },
  {
    q: 'What does the performance bonus cost if you miss the target?',
    a: "Nothing. The bonus only applies when we hit or beat the targets we set together. Miss the mark, and you pay your standard retainer. That's it.",
  },
  {
    q: "What's the real difference between Foundation and Growth?",
    a: "Foundation gives you presence: consistent content and community management. Growth gives you a lead engine with ads, audience targeting, competitor tracking, and twice the content. If your goal is lead generation, Growth is where it starts.",
  },
  {
    q: 'What happens after the 3-month minimum?',
    a: "You move to month-to-month. Stay, change tiers, or cancel with 30 days' notice. No penalties.",
  },
];
---

<Layout
  title="LinkedIn Services Pricing & Plans | Nuvora Studio"
  description="See our LinkedIn services pricing. Three retainer tiers, ads management, executive branding, and training. Clear plans built to get you more leads."
  abstract="LinkedIn services pricing for B2B companies. Three retainer tiers from $1,800 to $6,000/month. Plus ads management, executive branding, and training."
>
  <NavBar />
  <main id="main-content">

    <!-- ═══ HERO ═══ -->
    <section class="section section--dark pricing-hero" aria-labelledby="pricing-heading">
      <div class="pricing-hero__orb pricing-hero__orb--1" aria-hidden="true"></div>
      <div class="pricing-hero__orb pricing-hero__orb--2" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <div class="pricing-hero__grid">
          <div class="pricing-hero__text">
            <p class="eyebrow eyebrow--light anim-fade-up">Pricing</p>
            <h1 id="pricing-heading" class="pricing-hero__title anim-fade-up anim-delay-1">
              One goal: get you more leads<br />on LinkedIn.
            </h1>
            <p class="pricing-hero__sub anim-fade-up anim-delay-2">
              Pick the plan that fits where you are today. Every tier includes strategy, content,
              reporting, and a dedicated point of contact. No hidden fees. No long-term lock-in
              after the first three months.
            </p>
            <div class="pricing-hero__actions anim-fade-up anim-delay-3">
              <a href="#retainer" class="btn btn--primary btn--lg">See plans</a>
              <a href="/contact?intent=call" class="btn btn--outline-white btn--lg">Book a call</a>
            </div>
          </div>

          <div class="pricing-hero__visual anim-fade-up anim-delay-2">
            <div class="hero-placeholder">
              <span class="hero-placeholder__label">Visual placeholder</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CORE RETAINER TIERS ═══ -->
    <section class="section" id="retainer" aria-labelledby="retainer-heading">
      <div class="container">
        <div class="s-head reveal">
          <p class="eyebrow">Core retainer tiers</p>
          <h2 id="retainer-heading">Monthly LinkedIn management</h2>
          <p class="s-head__sub">All plans require a 3-month minimum commitment.</p>
        </div>

        <div class="reveal reveal-delay-1">
          <Pricing1 plans={plans} features={features} />
        </div>

        <div class="tier-cards reveal reveal-delay-2">
          <div class="tier-card">
            <strong>Foundation</strong> is for companies that need a consistent LinkedIn presence, the right foundation before scaling.
          </div>
          <div class="tier-card tier-card--pop">
            <strong>Growth</strong> is where lead generation starts. Ads, targeting, and double the content. This is our most popular tier for a reason.
          </div>
          <div class="tier-card">
            <strong>Scale</strong> is for companies going all-in with 16 posts a month, a senior lead running your account, and every service we offer working in lockstep.
          </div>
        </div>

        <p class="s-footnote reveal">
          Not sure which tier fits? <a href="/contact?intent=call">Book a call</a> and we'll walk through it with you.
        </p>
      </div>
    </section>

    <!-- ═══ EXECUTIVE PERSONAL BRANDING ═══ -->
    <section class="section" style="background: var(--off-white);" aria-labelledby="exec-heading">
      <div class="container">
        <div class="exec-split">
          <div class="exec-split__text reveal">
            <p class="eyebrow">Add-on or standalone</p>
            <h2 id="exec-heading">Executive Personal Branding</h2>
            <p class="s-head__sub">
              Your company page tells one story. Your leaders tell another. Buyers check both before they reach out.
            </p>
            <p class="s-head__note">
              This is a standalone service for senior leaders building their own LinkedIn presence.
              It works on its own or combined with any retainer tier.
            </p>
          </div>
          <div class="exec-split__cards reveal reveal-delay-1">
            {execServices.map(row => (
              <div class="exec-card">
                <p class="exec-card__label">{row.service}</p>
                <p class="exec-card__price">{row.price}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ LINKEDIN ADS MANAGEMENT ═══ -->
    <section class="section" aria-labelledby="ads-heading">
      <div class="container">
        <div class="s-head reveal">
          <p class="eyebrow">Standalone offer</p>
          <h2 id="ads-heading">LinkedIn Ads Management</h2>
          <p class="s-head__sub">
            For companies that want expert ad management without a full retainer.
            Ad spend is billed separately, directly to your LinkedIn account.
          </p>
          <p class="s-head__note">Both tiers require a 3-month contract and a $1,500 one-time setup fee.</p>
        </div>

        <div class="ads-table reveal">
          <div class="ads-table__scroll">
            <table aria-label="LinkedIn Ads management pricing comparison">
              <thead>
                <tr>
                  <th class="ads-table__corner"></th>
                  <th class="ads-table__col-head">Under $15K/mo<br />ad spend</th>
                  <th class="ads-table__col-head">Over $15K/mo<br />ad spend</th>
                </tr>
              </thead>
              <tbody>
                {adsFeatures.map((row, i) => (
                  <tr class={i === 0 ? 'ads-table__row--price' : ''}>
                    <td class="ads-table__label">{row.label}</td>
                    <td class="ads-table__val">
                      {row.foundation === '✓' ? (
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-label="Included"><path d="M4 9.5l3.5 3.5L14 6" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      ) : row.foundation === '—' ? (
                        <span class="ads-table__dash">—</span>
                      ) : (
                        <strong>{row.foundation}</strong>
                      )}
                    </td>
                    <td class="ads-table__val">
                      {row.growth === '✓' ? (
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-label="Included"><path d="M4 9.5l3.5 3.5L14 6" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      ) : row.growth === '—' ? (
                        <span class="ads-table__dash">—</span>
                      ) : (
                        <strong>{row.growth}</strong>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ ENTERPRISE ═══ -->
    <section class="section section--dark enterprise" aria-labelledby="enterprise-heading">
      <div class="enterprise__orb enterprise__orb--1" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 1;">

        <div class="ent-top reveal">
          <p class="eyebrow eyebrow--light">Custom engagement</p>
          <h2 id="enterprise-heading" class="ent-top__title">Enterprise</h2>
          <p class="ent-top__lead">
            For global companies that need LinkedIn working across markets, teams, and languages.
          </p>
        </div>

        <div class="ent-intro reveal">
          <p>
            Our standard tiers work for most B2B companies. But some organizations need more. Multiple regions.
            Dozens of executive profiles. Content in four languages. Ad campaigns running in parallel across
            APAC, EMEA, and the Americas.
          </p>
          <p>That's what Enterprise is for.</p>
          <p>
            We build a custom scope around your structure. Not a one-size package with your logo on it.
            Every Enterprise engagement starts with a discovery call to map your goals, markets, stakeholders,
            and internal workflows.
          </p>
        </div>

        <div class="ent-grid">
          <!-- What Enterprise clients typically need -->
          <div class="ent-block reveal">
            <h3 class="ent-block__title">What Enterprise clients typically need</h3>
            <ul class="ent-list" role="list">
              <li>Multi-market LinkedIn strategy spanning several regions and languages</li>
              <li>Coordinated content calendars across company pages and executive profiles</li>
              <li>Large-scale employee advocacy programs for global teams</li>
              <li>Dedicated senior strategist as your single point of contact</li>
              <li>LinkedIn Ads management across multiple ad accounts and currencies</li>
              <li>Multilingual content production, written by people who understand the market, not just the language</li>
              <li>Custom reporting dashboards aligned to your internal KPIs</li>
              <li>Quarterly business reviews with senior leadership</li>
            </ul>
          </div>

          <!-- How pricing works + Who this is built for -->
          <div class="ent-block reveal reveal-delay-1">
            <h3 class="ent-block__title">How pricing works</h3>
            <div class="ent-block__text">
              <p>
                Enterprise is scoped and quoted per engagement. There is no fixed price because no two programs look the same.
                Pricing is based on the number of markets, profiles, content volume, ad accounts, and languages in scope.
              </p>
              <p class="ent-price-range">
                Most Enterprise engagements start between <strong>$10,000 and $25,000 per month.</strong>
                Some are larger. We'll give you a clear, line-item proposal before anything starts. No surprises.
              </p>
            </div>

            <h3 class="ent-block__title" style="margin-top: var(--sp-10);">Who this is built for</h3>
            <ul class="ent-list" role="list">
              <li>Global companies with teams in multiple countries</li>
              <li>Organizations expanding into new markets, across any industry</li>
              <li>Companies where LinkedIn is a strategic channel, not a side project</li>
            </ul>
          </div>
        </div>

        <div class="ent-cta reveal">
          <p class="ent-cta__text">If your company has outgrown a single retainer tier, this is the conversation to have.</p>
          <a href="/contact?intent=enterprise" class="btn btn--primary btn--lg">Book an Enterprise call</a>
        </div>

      </div>
    </section>

    <!-- ═══ CONTENT + TRAINING ═══ -->
    <section class="section" style="background: var(--off-white);" aria-labelledby="addons-heading">
      <div class="container">
        <div class="s-head reveal" style="text-align: center; max-width: 640px; margin-inline: auto;">
          <p class="eyebrow">Additional services</p>
          <h2 id="addons-heading">Content, training, and advocacy</h2>
          <p class="s-head__sub" style="margin-inline: auto;">
            Written posts, AI-generated images, and visual assets are included in all retainer tiers.
            These services are available separately.
          </p>
        </div>

        <div class="addon-grid">
          <!-- Content production -->
          <div class="addon-col reveal">
            <h3 class="addon-col__title">Content Production</h3>
            {contentServices.map(row => (
              <div class="addon-item">
                <p class="addon-item__name">{row.service}</p>
                <p class="addon-item__price">{row.price}</p>
              </div>
            ))}
          </div>

          <!-- Divider -->
          <div class="addon-divider" aria-hidden="true"></div>

          <!-- Training -->
          <div class="addon-col reveal reveal-delay-1">
            <h3 class="addon-col__title">Training & Employee Advocacy</h3>
            {trainingServices.map(row => (
              <div class="addon-item">
                <p class="addon-item__name">{row.service}</p>
                <p class="addon-item__price">{row.price}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PERFORMANCE BONUS ═══ -->
    <section class="section section--dark" aria-labelledby="bonus-heading">
      <div class="container container--md">
        <div class="s-head reveal" style="text-align: center;">
          <p class="eyebrow eyebrow--light">Optional</p>
          <h2 id="bonus-heading" style="color: var(--white);">Performance Bonus</h2>
          <p class="s-head__sub" style="color: var(--navy-text-2); margin-inline: auto;">
            Available on Growth and Scale tiers. We tie part of our fee to results.
            When we hit the targets we agree on, we earn a bonus.
            When we miss, you pay only your retainer.
          </p>
        </div>

        <div class="bonus-grid">
          {bonusServices.map((b, i) => (
            <div class={`bonus-card reveal reveal-delay-${i + 1}`}>
              <span class="bonus-card__pct">{b.percent}</span>
              <p class="bonus-card__title">{b.model}</p>
              <p class="bonus-card__desc">{b.structure}</p>
              <span class="bonus-card__tag">Growth & Scale</span>
            </div>
          ))}
        </div>

        <p class="s-footnote reveal" style="color: var(--navy-text-3); text-align: center; margin-top: var(--sp-8);">
          Targets are set together at onboarding and reviewed every quarter.
        </p>
      </div>
    </section>

    <!-- ═══ DISCLAIMER ═══ -->
    <div style="padding: var(--sp-10) 0; background: var(--off-white);">
      <div class="container">
        <p class="s-disclaimer reveal">
          All prices in USD. LinkedIn ad spend is billed separately to your account.
          Custom enterprise packages available on request.
        </p>
      </div>
    </div>

    <ContactCTA />

    <FAQ heading="Pricing questions, answered." faqs={faqs} id="pfaq" />

  </main>
  <Footer />
</Layout>

<style>
  /* ═══════════ HERO ═══════════ */
  .pricing-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
  }

  .pricing-hero__orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
  }

  .pricing-hero__orb--1 {
    width: 500px; height: 500px;
    background: rgba(0, 168, 220, 0.12);
    top: -20%; right: -8%;
  }

  .pricing-hero__orb--2 {
    width: 350px; height: 350px;
    background: rgba(10, 102, 194, 0.10);
    bottom: -15%; left: -5%;
  }

  .pricing-hero__title {
    font-size: clamp(var(--fs-2xl), 5vw, var(--fs-4xl));
    font-weight: 700;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.02em;
    max-width: 680px;
    margin-block: var(--sp-5) var(--sp-6);
  }

  .pricing-hero__sub {
    font-size: var(--fs-md);
    color: var(--navy-text-2);
    max-width: 580px;
    line-height: 1.75;
  }

  .pricing-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
  }

  .pricing-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-top: var(--sp-10);
  }

  /* ── Hero visual placeholder ── */
  .pricing-hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--r-xl);
    border: 1.5px dashed rgba(0, 168, 220, 0.25);
    background: linear-gradient(135deg, rgba(10, 102, 194, 0.08) 0%, rgba(0, 168, 220, 0.12) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-placeholder__label {
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
  }

  /* ═══════════ SECTION HEADS ═══════════ */
  .s-head {
    margin-bottom: var(--sp-12);
  }

  .s-head h2 {
    font-size: clamp(var(--fs-xl), 3vw, var(--fs-2xl));
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin-top: var(--sp-4);
  }

  .s-head__sub {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
    margin-top: var(--sp-5);
    max-width: 640px;
  }

  .s-head__note {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.7;
    margin-top: var(--sp-3);
    max-width: 640px;
  }

  /* ═══════════ TIER CARDS ═══════════ */
  .tier-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
    margin-top: var(--sp-12);
  }

  .tier-card {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.7;
    padding: var(--sp-6);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    background: var(--white);
    transition: box-shadow var(--t-base), border-color var(--t-base);
  }

  .tier-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-2);
  }

  .tier-card--pop {
    border-color: var(--blue);
    background: rgba(10, 102, 194, 0.02);
  }

  .tier-card strong {
    color: var(--text);
    font-weight: 600;
  }

  .s-footnote {
    font-size: var(--fs-sm);
    color: var(--text-2);
    text-align: center;
    margin-top: var(--sp-8);
  }

  .s-footnote a {
    color: var(--blue);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--t-fast);
  }

  .s-footnote a:hover { color: var(--mid-blue); }

  /* ═══════════ EXEC SPLIT ═══════════ */
  .exec-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
  }

  .exec-split__text h2 {
    font-size: clamp(var(--fs-xl), 3vw, var(--fs-2xl));
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin-top: var(--sp-4);
  }

  .exec-split__cards {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .exec-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-6) var(--sp-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    transition: box-shadow var(--t-base), border-color var(--t-base);
  }

