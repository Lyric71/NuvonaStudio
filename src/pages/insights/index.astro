---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import ContactCTA from '../../components/ContactCTA.astro';

const posts = [
  // ── 29 March 2026 ──
  {
    slug: 'why-your-reach-dropped',
    category: 'LinkedIn Strategy',
    tags: ['Algorithm'],
    title: "Why your reach dropped 50%+ in 2026 (and it's not your content)",
    excerpt: "LinkedIn replaced its entire algorithm with 360Brew. Reach dropped 50%, company pages lost 60%. Your content isn't the problem. The system changed.",
    date: '2026-03-29',
    readTime: '8 min read',
    featured: true,
    image: '/blog/hero-reach-dropped.svg',
  },
  {
    slug: 'content-to-inbound-leads',
    category: 'LinkedIn Strategy',
    tags: ['Leads'],
    title: "How to turn LinkedIn content into inbound leads (not just impressions)",
    excerpt: "LinkedIn content that generates impressions but no leads is wasted effort. Inbound converts at 14.6% vs 1.7% outbound. Here's how to fix your content system.",
    date: '2026-03-29',
    readTime: '9 min read',
    featured: false,
    image: '/blog/hero-content-to-leads.webp',
  },
  {
    slug: 'profile-mistakes-killing-conversions',
    category: 'LinkedIn Strategy',
    tags: ['Profile'],
    title: "The profile mistakes that silently kill your conversions",
    excerpt: "Every post sends visitors to your profile. Most profiles fail to convert them. Generic headlines, empty Featured sections, and resume-style Abouts cost you leads daily.",
    date: '2026-03-29',
    readTime: '9 min read',
    featured: false,
    image: '/blog/hero-profile-mistakes.webp',
  },
  {
    slug: 'linkedin-headline-costing-opportunities',
    category: 'LinkedIn Strategy',
    tags: ['Profile'],
    title: "Your LinkedIn headline is costing you opportunities. Here's how to fix it.",
    excerpt: "Your LinkedIn headline shows up everywhere you appear on the platform. Most people waste it on a job title. Here's a better formula.",
    date: '2026-03-29',
    readTime: '7 min read',
    featured: false,
    image: '/blog/hero-headline-fix.webp',
  },
  {
    slug: 'algorithm-change-small-vs-large-accounts',
    category: 'LinkedIn Strategy',
    tags: ['Algorithm'],
    title: "What LinkedIn's algorithm change means for small accounts vs. large ones",
    excerpt: "LinkedIn's new algorithm rewards engagement quality over follower count. Small accounts with active networks now outperform large accounts with passive audiences.",
    date: '2026-03-29',
    readTime: '9 min read',
    featured: false,
    image: '/blog/hero-small-vs-large.svg',
  },
  {
    slug: 'how-to-grow-on-linkedin',
    category: 'LinkedIn Strategy',
    tags: ['Growth'],
    title: "How to grow on LinkedIn when there are 5x more creators than three years ago",
    excerpt: "LinkedIn has 5x more creators than 2023. Two million posts go live daily. But less than 3% of members post weekly. Specificity wins the attention war.",
    date: '2026-03-29',
    readTime: '10 min read',
    featured: false,
    image: '/blog/hero-grow-linkedin.svg',
  },
  {
    slug: 'why-linkedin-ads-cost-more',
    category: 'LinkedIn Advertising',
    tags: ['Ads'],
    title: "Why LinkedIn ads cost 4 to 6x more per click, and when it's still worth it",
    excerpt: "LinkedIn charges $5 to $12 per click. Meta charges $0.50. But clicks don't close deals. LinkedIn leads convert at 2 to 3x the rate of other platforms.",
    date: '2026-03-29',
    readTime: '8 min read',
    featured: false,
    image: '/blog/hero-ads-cost.svg',
  },
  {
    slug: 'linkedin-ads-vs-organic-content',
    category: 'LinkedIn Strategy',
    tags: ['Budget'],
    title: "LinkedIn ads vs. organic content: where to put your budget in 2026",
    excerpt: "Organic LinkedIn content generates leads at half the cost of ads. But ads close gaps fast. The right split depends on your stage and deal size.",
    date: '2026-03-29',
    readTime: '9 min read',
    featured: false,
    image: '/blog/hero-ads-vs-organic.svg',
  },
  {
    slug: 'stop-wasting-money-low-intent-audiences',
    category: 'LinkedIn Advertising',
    tags: ['Targeting'],
    title: "How to stop wasting money on LinkedIn ads that target low-intent audiences",
    excerpt: "Most LinkedIn Ads target audiences too large and too cold to convert. Only 3 to 6% of your market is actively buying. Fix your targeting first.",
    date: '2026-03-29',
    readTime: '10 min read',
    featured: false,
    image: '/blog/hero-targeting-waste.webp',
  },
  {
    slug: 'linkedin-ad-roi-measurement-problem',
    category: 'LinkedIn Advertising',
    tags: ['Measurement'],
    title: "Why your LinkedIn ad ROI looks terrible (it's a measurement problem)",
    excerpt: "LinkedIn delivers 121% ROAS for B2B. But the average buyer journey is 272 days. If you measure ROI at 30 days, your data is lying to you.",
    date: '2026-03-29',
    readTime: '10 min read',
    featured: false,
    image: '/blog/hero-roi-measurement.webp',
  },
  {
    slug: 'minimum-viable-linkedin-ads-budget',
    category: 'LinkedIn Advertising',
    tags: ['Budget'],
    title: "The minimum viable LinkedIn ads budget that actually generates pipeline",
    excerpt: "LinkedIn requires $10 per day minimum. That won't generate pipeline. The real minimum depends on your audience, your offer, and your sales cycle length.",
    date: '2026-03-29',
    readTime: '10 min read',
    featured: false,
    image: '/blog/hero-ads-budget.webp',
  },
  // ── 23 March 2026 ──
  {
    slug: 'your-linkedin-post-is-already-dead',
    category: 'LinkedIn Strategy',
    tags: ['Content'],
    title: "Your LinkedIn post is already dead. Here is how to bring it back to life.",
    excerpt: "The feed is drowning in AI-generated content. Your window to be seen is two hours. The companies that survive this know something most brands don't.",
    date: '2026-03-23',
    readTime: '5 min read',
    featured: false,
    image: '/blog/hero-post-already-dead.svg',
  },
  {
    slug: 'the-real-linkedin-problem',
    category: 'LinkedIn Strategy',
    tags: ['Strategy'],
    title: "The real LinkedIn problem isn't writing. It's thinking.",
    excerpt: "AI can clean up your sentences. It cannot tell you what to say. That gap is where most B2B companies quietly fail.",
    date: '2026-03-23',
    readTime: '5 min read',
    featured: false,
    image: '/blog/hero-thinking-not-writing.svg',
  },
];

// Collect all unique tags across posts
const allTags = [...new Set(posts.flatMap(p => p.tags))].sort();
---

<Layout
  title="Insights | LinkedIn for B2B | Nuvora Studio"
  description="Sharp thinking on LinkedIn strategy, B2B content, advertising, and platform updates. Written by practitioners, not content mills."
  abstract="LinkedIn strategy, B2B content, and advertising insights from Nuvora Studio. Written by practitioners."
>
  <NavBar />
  <main id="main-content">

    <!-- Hero -->
    <section class="insights-hero" aria-labelledby="insights-heading">
      <div class="container">
        <p class="eyebrow eyebrow--light reveal">From the blog</p>
        <h1 id="insights-heading" class="insights-hero__h1 reveal reveal-delay-1">
          LinkedIn intelligence,<br /><em>in writing.</em>
        </h1>
        <p class="insights-hero__sub reveal reveal-delay-2">
          Sharp thinking on LinkedIn strategy, B2B content, advertising, and platform updates.
          Written by practitioners. Not content mills.
        </p>
      </div>
    </section>

    <!-- Posts -->
    <section class="section" style="background: var(--off-white);" aria-label="All articles">
      <div class="container">

        <!-- Tag filters -->
        <div class="tag-filters" role="group" aria-label="Filter by tag">
          <button class="tag-btn tag-btn--active" data-tag="all">All</button>
          {allTags.map(tag => (
            <button class="tag-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>

        <!-- Posts grid -->
        <div class="posts-grid" id="posts-grid">
          {posts.map((post, i) => (
            <article
              class="post-card"
              data-tags={post.tags.join(',')}
              style={`transition-delay: ${i * 0.07}s`}
            >
              {post.image ? (
                <div class="post-card__thumb" style={`background-image: url('${post.image}')`}></div>
              ) : (
                <div class="post-card__thumb post-card__thumb--empty">
                  <span>Visual placeholder</span>
                </div>
              )}
              <div class="post-card__top">
                <div class="post-card__tags">
                  {post.tags.map(tag => (
                    <span class="post-tag">{tag}</span>
                  ))}
                </div>
                <span class="post-card__category">{post.category}</span>
              </div>
              <h2 class="post-card__title">
                <a href={`/insights/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="post-card__excerpt">{post.excerpt}</p>
              <div class="post-card__footer">
                <span class="post-card__read-time">{post.readTime}</span>
                <a href={`/insights/${post.slug}`} class="post-card__cta">Read article →</a>
              </div>
            </article>
          ))}
        </div>

        <!-- Empty state -->
        <p class="posts-empty" id="posts-empty" style="display:none">
          No articles found for this tag.
        </p>

      </div>
    </section>

    <ContactCTA />
  </main>
</Layout>

<style>
  /* ── Hero ── */
  .insights-hero {
    background: var(--deep-navy) url('/blog/hero-insights.svg') center/cover no-repeat;
    padding-block: clamp(3rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }
  .insights-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 75% 40%, rgba(6,182,212,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .insights-hero .container { position: relative; z-index: 1; }

  .insights-hero__h1 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.12;
    letter-spacing: -0.015em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .insights-hero__h1 em {
    color: rgba(255,255,255,0.38);
    font-weight: 300;
    font-style: normal;
  }
  .insights-hero__sub {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.58);
    max-width: 540px;
    line-height: 1.7;
  }

  /* ── Tag filters ── */
  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-8);
  }

  .tag-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--white);
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--text-2);
    cursor: pointer;
    transition: all var(--t-base) ease;
    letter-spacing: 0.02em;
  }
  .tag-btn:hover {
    border-color: var(--sky);
    color: var(--sky);
    box-shadow: 0 2px 8px rgba(14,165,233,0.1);
  }
  .tag-btn--active {
    background: var(--deep-navy);
    border-color: var(--deep-navy);
    color: var(--white);
  }

  /* ── Grid ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  /* ── Card ── */
  .post-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-10);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    transition:
      box-shadow var(--t-base) ease,
      border-color var(--t-base) ease,
      transform var(--t-base) ease,
      opacity var(--t-base) ease;
  }
  .post-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-2);
    transform: translateY(-3px);
  }
  .post-card.is-hidden {
    display: none;
  }

  .post-card__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--r-lg);
    background-color: var(--deep-navy);
    background-size: cover;
    background-position: center;
    margin-bottom: var(--sp-2);
  }

  .post-card__thumb--empty {
    background: linear-gradient(135deg, rgba(14,165,233,0.04) 0%, rgba(6,182,212,0.06) 100%);
    border: 1.5px dashed rgba(14,165,233,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-card__thumb--empty span {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(14,165,233,0.2);
  }


  .post-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .post-tag {
    display: inline-block;
    padding: 2px var(--sp-3);
    border-radius: var(--r-sm);
    background: rgba(14,165,233,0.07);
    color: var(--sky);
    font-family: var(--font-body), sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .post-card__category {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .post-card__title {
    font-family: var(--font-display), sans-serif;
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .post-card__title a { color: inherit; transition: color var(--t-fast) ease; }
  .post-card__title a:hover { color: var(--sky); }

  .post-card__excerpt {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.8;
    flex: 1;
  }

  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .post-card__read-time {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    color: var(--text-3);
  }

  .post-card__cta {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sky);
    transition: color var(--t-fast) ease;
  }
  .post-card__cta:hover { color: var(--cyan); }

  .posts-empty {
    text-align: center;
    color: var(--text-3);
    padding-block: var(--sp-20);
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-md);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
    .post-card { padding: var(--sp-7); }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards   = document.querySelectorAll<HTMLElement>('.post-card');
  const empty   = document.getElementById('posts-empty');

  function filter(tag: string) {
    let visible = 0;

    cards.forEach(card => {
      const tags = (card.dataset.tags ?? '').split(',');
      const show = tag === 'all' || tags.includes(tag);
      card.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });

    if (empty) empty.style.display = visible === 0 ? 'block' : 'none';

    buttons.forEach(btn => {
      btn.classList.toggle('tag-btn--active', btn.dataset.tag === tag);
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => filter(btn.dataset.tag ?? 'all'));
  });
</script>
