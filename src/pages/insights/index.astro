---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import ContactCTA from '../../components/ContactCTA.astro';

const posts = [
  {
    slug: 'the-real-linkedin-problem',
    category: 'LinkedIn Strategy',
    title: "The Real LinkedIn Problem Isn't Writing. It's Thinking.",
    excerpt: "AI can clean up your sentences. It cannot tell you what to say. That gap is where most B2B companies quietly fail.",
    date: '2026-03-23',
    readTime: '5 min read',
    featured: true,
  },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}
---

<Layout
  title="Insights — LinkedIn Strategy, B2B Content & Advertising — Nuvora Studio"
  description="Sharp thinking on LinkedIn strategy, B2B content, advertising, and platform updates — written by practitioners, not content mills."
  abstract="LinkedIn strategy, B2B content, and advertising insights from Nuvora Studio — written by practitioners."
>
  <NavBar />
  <main id="main-content">

    <!-- Hero -->
    <section class="insights-hero" aria-labelledby="insights-heading">
      <div class="container">
        <p class="eyebrow eyebrow--light reveal">From the blog</p>
        <h1 id="insights-heading" class="insights-hero__h1 reveal reveal-delay-1">
          LinkedIn intelligence,<br /><em>in writing.</em>
        </h1>
        <p class="insights-hero__sub reveal reveal-delay-2">
          Sharp thinking on LinkedIn strategy, B2B content, advertising, and platform updates —
          written by practitioners, not content mills.
        </p>
      </div>
    </section>

    <!-- Posts -->
    <section class="section" style="background: var(--off-white);" aria-label="All articles">
      <div class="container">

        {posts.length > 0 ? (
          <div class="posts-grid">
            {posts.map((post, i) => (
              <article
                class={`post-card reveal ${post.featured ? 'post-card--featured' : ''}`}
                style={`transition-delay: ${i * 0.07}s`}
              >
                <div class="post-card__top">
                  <span class="tag">{post.category}</span>
                </div>
                <h2 class="post-card__title">
                  <a href={`/insights/${post.slug}`}>{post.title}</a>
                </h2>
                <p class="post-card__excerpt">{post.excerpt}</p>
                <div class="post-card__footer">
                  <span class="post-card__read-time">{post.readTime}</span>
                  <a href={`/insights/${post.slug}`} class="post-card__cta">Read article →</a>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="posts-empty">No articles yet — check back soon.</p>
        )}

      </div>
    </section>

    <ContactCTA />
  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .insights-hero {
    background: var(--deep-navy);
    padding-block: clamp(3rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }
  .insights-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 75% 40%, rgba(0,168,220,0.10) 0%, transparent 60%);
    pointer-events: none;
  }

  .insights-hero .container { position: relative; z-index: 1; }

  .insights-hero__h1 {
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.12;
    letter-spacing: -0.01em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .insights-hero__h1 em {
    color: rgba(255,255,255,0.42);
    font-weight: 300;
    font-style: normal;
  }

  .insights-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.65);
    max-width: 540px;
    line-height: 1.75;
  }

  /* ── Grid ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  /* ── Card ── */
  .post-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-10);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    transition: box-shadow var(--t-base), border-color var(--t-base), transform var(--t-base);
  }
  .post-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  /* Featured card spans full width */
  .post-card--featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr auto;
    gap: var(--sp-6) var(--sp-16);
  }

  .post-card--featured .post-card__top { grid-column: 1; }
  .post-card--featured .post-card__title { grid-column: 1; font-size: clamp(1.25rem, 2.5vw, 1.875rem); }
  .post-card--featured .post-card__excerpt { grid-column: 2; grid-row: 1 / 4; align-self: center; font-size: var(--fs-md); }
  .post-card--featured .post-card__footer { grid-column: 1; }

  .post-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .post-card__date {
    font-size: var(--fs-xs);
    color: var(--text-3);
    letter-spacing: 0.03em;
  }

  .post-card__title {
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .post-card__title a { color: inherit; transition: color var(--t-fast); }
  .post-card__title a:hover { color: var(--blue); }

  .post-card__excerpt {
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.85;
    flex: 1;
  }

  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .post-card__read-time {
    font-size: var(--fs-xs);
    color: var(--text-3);
  }

  .post-card__cta {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue);
    transition: color var(--t-fast);
  }
  .post-card__cta:hover { color: var(--mid-blue); }

  .posts-empty {
    text-align: center;
    color: var(--text-3);
    padding-block: var(--sp-20);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
    .post-card--featured { grid-template-columns: 1fr; }
    .post-card--featured .post-card__excerpt { grid-column: 1; grid-row: auto; }
  }

  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
