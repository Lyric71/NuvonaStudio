---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact Nuvora Studio — Book a LinkedIn Discovery Call"
  description="Get in touch with Nuvora Studio. Book a 30-minute discovery call or send a message about your LinkedIn marketing goals. We reply within one business day."
  abstract="Book a 30-minute discovery call or send a message. We reply within one business day. No pitch — just a straight conversation."
>
  <NavBar />
  <main id="main-content">

    <!-- Hero -->
    <section class="contact-hero" aria-labelledby="contact-heading">
      <div class="container">
        <div class="contact-hero__inner">
          <div class="contact-hero__text">
            <p class="eyebrow eyebrow--light reveal">Get in touch</p>
            <h1 id="contact-heading" class="contact-hero__h1 reveal reveal-delay-1">
              Let's talk<br /><em>LinkedIn.</em>
            </h1>
            <p class="contact-hero__sub reveal reveal-delay-2">
              Tell us about your project. We read every message and reply within one business day.
            </p>
          </div>
          <div class="contact-hero__info reveal reveal-delay-2">
            <div class="contact-info-item">
              <span class="contact-info-item__label">Response time</span>
              <span class="contact-info-item__value">1 business day</span>
            </div>
            <div class="contact-info-item">
              <span class="contact-info-item__label">We work with</span>
              <span class="contact-info-item__value">B2B companies worldwide</span>
            </div>
            <div class="contact-info-item">
              <span class="contact-info-item__label">Engagements from</span>
              <span class="contact-info-item__value">$1,800 / month</span>
              <a href="/pricing" class="contact-info-item__link">See full pricing →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Form section -->
    <section class="section" style="background: var(--off-white);">
      <div class="container container--contact">

        <!-- Success state -->
        <div class="contact-success" id="contact-success" aria-live="polite">
          <div class="contact-success__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <path d="M5 14l6.5 6.5L23 8" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h2 class="contact-success__title">Message sent.</h2>
          <p class="contact-success__body">
            Thanks for reaching out. We will get back to you within one business day.
          </p>
          <a href="/" class="btn btn--primary" style="margin-top: var(--sp-6)">Back to home</a>
        </div>

        <!-- Form card -->
        <div class="contact-card" id="contact-card">
          <div class="contact-card__header">
            <h2 class="contact-card__title">Send us a message</h2>
            <p class="contact-card__note">
              Fields marked <span aria-hidden="true">*</span><span class="sr-only">with an asterisk</span> are required.
            </p>
          </div>

          <form id="contact-form" class="contact-form" novalidate aria-label="Contact form">

            <div class="contact-form__grid">
              <!-- Name -->
              <div class="form-group">
                <label class="form-label" for="name">
                  Your Name <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input class="form-input" type="text" id="name" name="name"
                  autocomplete="name" required placeholder="Jane Smith" />
                <span class="form-error" id="name-error" role="alert"></span>
              </div>

              <!-- Email -->
              <div class="form-group">
                <label class="form-label" for="email">
                  Your Email <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input class="form-input" type="email" id="email" name="email"
                  autocomplete="email" required placeholder="jane@company.com" />
                <span class="form-error" id="email-error" role="alert"></span>
              </div>

              <!-- Phone -->
              <div class="form-group">
                <label class="form-label" for="phone">
                  Your Phone <span class="form-optional">(optional)</span>
                </label>
                <input class="form-input" type="tel" id="phone" name="phone"
                  autocomplete="tel" placeholder="+1 555 000 0000" />
              </div>

              <!-- Website -->
              <div class="form-group">
                <label class="form-label" for="website">
                  Your Website <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input class="form-input" type="url" id="website" name="website"
                  autocomplete="url" required placeholder="https://yourcompany.com" />
                <span class="form-error" id="website-error" role="alert"></span>
              </div>

              <!-- Company -->
              <div class="form-group contact-form__full">
                <label class="form-label" for="company">
                  Your Company Name <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input class="form-input" type="text" id="company" name="company"
                  autocomplete="organization" required placeholder="Acme Corp" />
                <span class="form-error" id="company-error" role="alert"></span>
              </div>

              <!-- Project -->
              <div class="form-group contact-form__full">
                <label class="form-label" for="project">
                  Your Project <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <textarea class="form-textarea" id="project" name="project"
                  required rows="5"
                  placeholder="Tell us what you're working on, what you need, and any context that would help us respond well."
                ></textarea>
                <span class="form-error" id="project-error" role="alert"></span>
              </div>
            </div>

            <!-- Error banner -->
            <div class="form-banner" id="form-error-banner" role="alert">
              <span id="form-error-message"></span>
            </div>

            <div class="contact-form__actions">
              <button type="submit" class="btn btn--primary btn--lg" id="submit-btn">
                <span id="submit-label">Send message</span>
                <span id="submit-spinner" class="submit-spinner" style="display:none" aria-hidden="true"></span>
              </button>
              <p class="contact-form__privacy">We never share your data with third parties.</p>
            </div>
          </form>
        </div>


      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .contact-hero {
    background: var(--deep-navy);
    padding-block: var(--sp-24) var(--sp-20);
    position: relative;
    overflow: hidden;
  }
  .contact-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 90% 50%, rgba(0,168,220,0.10) 0%, transparent 60%);
    pointer-events: none;
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--sp-16);
    align-items: center;
  }

  .contact-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .contact-hero__h1 em { color: rgba(255,255,255,0.48); font-weight: 300; font-style: normal; }

  .contact-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.65);
    max-width: 480px;
    line-height: 1.75;
  }

  /* Info cards in hero */
  .contact-hero__info {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    flex-shrink: 0;
  }

  .contact-info-item {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding: var(--sp-5) var(--sp-7);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: var(--r-xl);
    min-width: 200px;
  }

  .contact-info-item__label {
    font-size: var(--fs-xs);
    color: var(--cyan);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-info-item__value {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--white);
    line-height: 1.2;
  }

  .contact-info-item__link {
    font-size: var(--fs-xs);
    color: rgba(255,255,255,0.45);
    margin-top: var(--sp-1);
    transition: color var(--t-fast);
  }
  .contact-info-item__link:hover { color: var(--cyan); }

  /* ── Form section layout ── */
  .container--contact {
    max-width: 760px;
  }

  /* Success state spans full width */
  .contact-success {
    display: none;
    grid-column: 1 / -1;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--sp-20) var(--sp-10);
    background: var(--white);
    border-radius: var(--r-2xl);
    border: 1px solid var(--border);
  }
  .contact-success.is-visible { display: flex; }

  .contact-success__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--blue);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--sp-6);
  }

  .contact-success__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--deep-navy);
    margin-bottom: var(--sp-3);
    letter-spacing: -0.02em;
  }

  .contact-success__body {
    font-size: var(--fs-md);
    color: var(--text-2);
    max-width: 360px;
    line-height: 1.75;
  }

  /* ── Card ── */
  .contact-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-2xl);
    overflow: hidden;
  }

  .contact-card__header {
    padding: var(--sp-8) var(--sp-10) var(--sp-6);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }

  .contact-card__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 600;
    color: var(--deep-navy);
    letter-spacing: -0.01em;
  }

  .contact-card__note {
    font-size: var(--fs-xs);
    color: var(--text-3);
  }

  /* ── Form ── */
  .contact-form {
    padding: var(--sp-8) var(--sp-10);
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .contact-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-5);
  }

  .contact-form__full { grid-column: 1 / -1; }

  .required-mark { color: var(--blue); margin-left: 2px; }

  .form-optional {
    color: var(--text-3);
    font-weight: 400;
    font-size: var(--fs-xs);
  }

  .form-error {
    font-size: var(--fs-xs);
    color: #c0392b;
    min-height: 16px;
    display: block;
  }

  .form-input.is-invalid,
  .form-textarea.is-invalid {
    border-color: #c0392b;
    box-shadow: 0 0 0 3px rgba(192,57,43,0.10);
  }

  .form-banner {
    display: none;
    padding: var(--sp-4);
    background: #FEF2F2;
    border: 1px solid rgba(192,57,43,0.20);
    border-radius: var(--r-md);
    font-size: var(--fs-sm);
    color: #c0392b;
  }
  .form-banner.is-visible { display: block; }

  .contact-form__actions {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
    flex-wrap: wrap;
  }

  .contact-form__privacy {
    font-size: var(--fs-xs);
    color: var(--text-3);
  }

  .submit-spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.30);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-left: var(--sp-2);
  }
  @keyframes spin { to { transform: rotate(360deg); } }


  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .contact-hero__inner { grid-template-columns: 1fr; }
    .contact-hero__info { flex-direction: row; flex-wrap: wrap; }
    .contact-info-item { flex: 1; min-width: 160px; }
  }

  @media (max-width: 640px) {
    .contact-hero { padding-block: var(--sp-16) var(--sp-12); }
    .contact-form { padding: var(--sp-6); }
    .contact-card__header { padding: var(--sp-6); }
    .contact-form__grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline src="https://www.google.com/recaptcha/api.js?render=6LfeTpQsAAAAAH-_V7o9bJuu4PO_kfgGcGMCuSiE"></script>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const card    = document.getElementById('contact-card') as HTMLElement | null;
  const success = document.getElementById('contact-success') as HTMLElement | null;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label') as HTMLElement | null;
  const submitSpinner = document.getElementById('submit-spinner') as HTMLElement | null;
  const errorBanner  = document.getElementById('form-error-banner') as HTMLElement | null;
  const errorMessage = document.getElementById('form-error-message') as HTMLElement | null;

  function setFieldError(fieldId: string, message: string) {
    const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement | null;
    const error = document.getElementById(`${fieldId}-error`);
    field?.classList.toggle('is-invalid', !!message);
    if (error) error.textContent = message;
  }

  function clearErrors() {
    ['name', 'email', 'website', 'company', 'project'].forEach(id => setFieldError(id, ''));
    if (errorBanner) errorBanner.classList.remove('is-visible');
  }

  function validate(data: FormData): boolean {
    let valid = true;

    const required: { id: string; label: string }[] = [
      { id: 'name',    label: 'Name is required.' },
      { id: 'company', label: 'Company name is required.' },
      { id: 'project', label: 'Please describe your project.' },
    ];

    required.forEach(({ id, label }) => {
      if (!(data.get(id) as string)?.trim()) {
        setFieldError(id, label);
        valid = false;
      }
    });

    // Email: required + format
    const email = (data.get('email') as string)?.trim();
    if (!email) {
      setFieldError('email', 'Email is required.');
      valid = false;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) {
      setFieldError('email', 'Please enter a valid email address (e.g. jane@company.com).');
      valid = false;
    }

    // Website: required + must be a valid URL with http/https
    const website = (data.get('website') as string)?.trim();
    if (!website) {
      setFieldError('website', 'Website is required.');
      valid = false;
    } else {
      try {
        const url = new URL(website);
        if (url.protocol !== 'http:' && url.protocol !== 'https:') {
          setFieldError('website', 'Website must start with https:// or http://');
          valid = false;
        }
      } catch {
        setFieldError('website', 'Please enter a valid URL (e.g. https://yourcompany.com).');
        valid = false;
      }
    }

    return valid;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();

    const data = new FormData(form);
    if (!validate(data)) return;

    if (submitBtn)     submitBtn.disabled = true;
    if (submitLabel)   submitLabel.textContent = 'Sending…';
    if (submitSpinner) submitSpinner.style.display = 'inline-block';

    try {
      // Get reCAPTCHA v3 token
      const token = await new Promise<string>((resolve, reject) => {
        (window as any).grecaptcha.ready(() => {
          (window as any).grecaptcha
            .execute('6LfeTpQsAAAAAH-_V7o9bJuu4PO_kfgGcGMCuSiE', { action: 'contact' })
            .then(resolve)
            .catch(reject);
        });
      });
      data.append('recaptcha_token', token);

      const res = await fetch('/api/contact', { method: 'POST', body: data });
      const json = await res.json();

      if (res.ok) {
        if (card)    card.style.display = 'none';
        if (success) success.classList.add('is-visible');
      } else {
        if (errorBanner)  errorBanner.classList.add('is-visible');
        if (errorMessage) errorMessage.textContent = json.error ?? 'Something went wrong. Please try again.';
      }
    } catch {
      if (errorBanner)  errorBanner.classList.add('is-visible');
      if (errorMessage) errorMessage.textContent = 'Network error. Please check your connection and try again.';
    } finally {
      if (submitBtn)     submitBtn.disabled = false;
      if (submitLabel)   submitLabel.textContent = 'Send message';
      if (submitSpinner) submitSpinner.style.display = 'none';
    }
  });
</script>
