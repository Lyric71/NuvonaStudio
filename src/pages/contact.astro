  .pricing-anchor__value {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .pricing-anchor__value span {
    font-size: var(--fs-lg);
    font-weight: 400;
