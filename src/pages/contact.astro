---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact Us — Nuvora Studio"
  description="Get in touch with Nuvora Studio. Tell us about your project and we'll get back to you within one business day."
>
  <NavBar />
  <main id="main-content">

    <!-- Hero -->
    <section class="contact-hero section--dark">
      <div class="container">
        <p class="eyebrow" style="color: var(--color-cyan)">Get in touch</p>
        <h1>Let's talk LinkedIn.</h1>
        <p class="contact-hero__sub">
          Tell us about your project. We read every message and reply within one business day.
        </p>
      </div>
    </section>

    <!-- Form section -->
    <section class="section section--ice">
      <div class="container container--md">

        <div class="contact-card">
          <!-- Success state (hidden until form submits successfully) -->
          <div class="contact-success" id="contact-success" aria-live="polite">
            <div class="contact-success__icon" aria-hidden="true">✓</div>
            <h2 class="contact-success__title">Message sent.</h2>
            <p class="contact-success__body">
              Thanks for reaching out. We'll get back to you within one business day.
            </p>
            <a href="/" class="btn btn--outline" style="margin-top: var(--space-6)">Back to home</a>
          </div>

          <!-- Form -->
          <form
            id="contact-form"
            class="contact-form"
            novalidate
            aria-label="Contact form"
          >
            <div class="contact-form__header">
              <h2 class="contact-form__title">Send us a message</h2>
              <p class="contact-form__note">
                Fields marked <span aria-hidden="true">*</span><span class="sr-only">with an asterisk</span> are required.
              </p>
            </div>

            <div class="contact-form__grid">
              <!-- Name -->
              <div class="form-group">
                <label class="form-label" for="name">
                  Your Name <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input
                  class="form-input"
                  type="text"
                  id="name"
                  name="name"
                  autocomplete="name"
                  required
                  placeholder="Jane Smith"
                />
                <span class="form-error" id="name-error" role="alert"></span>
              </div>

              <!-- Email -->
              <div class="form-group">
                <label class="form-label" for="email">
                  Your Email <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input
                  class="form-input"
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  required
                  placeholder="jane@company.com"
                />
                <span class="form-error" id="email-error" role="alert"></span>
              </div>

              <!-- Phone -->
              <div class="form-group">
                <label class="form-label" for="phone">
                  Your Phone <span class="form-optional">(optional)</span>
                </label>
                <input
                  class="form-input"
                  type="tel"
                  id="phone"
                  name="phone"
                  autocomplete="tel"
                  placeholder="+1 555 000 0000"
                />
              </div>

              <!-- Website -->
              <div class="form-group">
                <label class="form-label" for="website">
                  Your Website <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input
                  class="form-input"
                  type="url"
                  id="website"
                  name="website"
                  autocomplete="url"
                  required
                  placeholder="https://yourcompany.com"
                />
                <span class="form-error" id="website-error" role="alert"></span>
              </div>

              <!-- Company -->
              <div class="form-group contact-form__full">
                <label class="form-label" for="company">
                  Your Company Name <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <input
                  class="form-input"
                  type="text"
                  id="company"
                  name="company"
                  autocomplete="organization"
                  required
                  placeholder="Acme Corp"
                />
                <span class="form-error" id="company-error" role="alert"></span>
              </div>

              <!-- Project -->
              <div class="form-group contact-form__full">
                <label class="form-label" for="project">
                  Your Project <span class="required-mark" aria-hidden="true">*</span>
                </label>
                <textarea
                  class="form-textarea"
                  id="project"
                  name="project"
                  required
                  rows="5"
                  placeholder="Tell us what you're working on, what you need, and any context that would help us respond well."
                ></textarea>
                <span class="form-error" id="project-error" role="alert"></span>
              </div>
            </div>

            <!-- Form error banner -->
            <div class="form-banner" id="form-error-banner" role="alert">
              <span id="form-error-message"></span>
            </div>

            <div class="contact-form__actions">
              <button type="submit" class="btn btn--primary btn--lg" id="submit-btn">
                <span id="submit-label">Send message</span>
                <span id="submit-spinner" class="submit-spinner" style="display:none" aria-hidden="true"></span>
              </button>
              <p class="contact-form__privacy">
                We never share your data with third parties.
              </p>
            </div>
          </form>
        </div>

        <!-- Aside info -->
        <div class="contact-aside">
          <div class="contact-info-card">
            <p class="eyebrow">Response time</p>
            <p class="contact-info-card__value">1 business day</p>
          </div>
          <div class="contact-info-card">
            <p class="eyebrow">We work with</p>
            <p class="contact-info-card__value">B2B companies worldwide</p>
          </div>
          <div class="contact-info-card">
            <p class="eyebrow">Engagements start from</p>
            <p class="contact-info-card__value">$1,800 / month</p>
            <a href="/pricing" class="btn btn--ghost btn--sm" style="margin-top: var(--space-3); padding-left: 0">
              See full pricing →
            </a>
          </div>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* Hero */
  .contact-hero {
    padding-block: var(--space-20) var(--space-16);
  }

  .contact-hero h1 {
    color: var(--color-white);
    margin-block: var(--space-4) var(--space-6);
  }

  .contact-hero__sub {
    font-size: var(--font-size-md);
    color: rgba(255, 255, 255, 0.7);
    max-width: 480px;
    line-height: var(--line-height-relaxed);
  }

  /* Layout */
  .container--md {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: var(--space-10);
    align-items: start;
  }

  /* Card */
  .contact-card {
    background: var(--color-white);
    border: var(--border-thin);
    border-radius: var(--radius-2xl);
    overflow: hidden;
  }

  /* Form */
  .contact-form {
    padding: var(--space-10);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .contact-form__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .contact-form__title {
    font-size: var(--font-size-xl);
    color: var(--color-deep-navy);
  }

  .contact-form__note {
    font-size: var(--font-size-xs);
    color: var(--color-slate);
  }

  .contact-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .contact-form__full {
    grid-column: 1 / -1;
  }

  .required-mark {
    color: var(--color-error);
    margin-left: 2px;
  }

  .form-optional {
    color: var(--color-slate);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-xs);
  }

  .form-error {
    font-size: var(--font-size-xs);
    color: var(--color-error);
    min-height: 16px;
    display: block;
  }

  .form-input.is-invalid,
  .form-textarea.is-invalid {
    border-color: var(--color-error);
    box-shadow: 0 0 0 3px rgba(163, 45, 45, 0.1);
  }

  /* Error banner */
  .form-banner {
    display: none;
    padding: var(--space-4);
    background: #FEF2F2;
    border: 1px solid rgba(163, 45, 45, 0.2);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    color: var(--color-error);
  }

  .form-banner.is-visible {
    display: block;
  }

  /* Submit */
  .contact-form__actions {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .contact-form__privacy {
    font-size: var(--font-size-xs);
    color: var(--color-slate);
  }

  .submit-spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Success — hidden by default, shown via .is-visible */
  .contact-success {
    display: none;
    padding: var(--space-16) var(--space-10);
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contact-success.is-visible {
    display: flex;
  }

  .contact-success__icon {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-full);
    background: var(--gradient-button);
    color: var(--color-white);
    font-size: var(--font-size-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-6);
  }

  .contact-success__title {
    font-size: var(--font-size-2xl);
    color: var(--color-deep-navy);
    margin-bottom: var(--space-3);
  }

  .contact-success__body {
    color: var(--color-slate);
    max-width: 360px;
    line-height: var(--line-height-relaxed);
  }

  /* Aside */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: calc(64px + var(--space-6));
  }

  .contact-info-card {
    background: var(--color-white);
    border: var(--border-thin);
    border-radius: var(--radius-xl);
    padding: var(--space-5) var(--space-6);
  }

  .contact-info-card .eyebrow {
    margin-bottom: var(--space-2);
  }

  .contact-info-card__value {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-deep-navy);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container--md {
      grid-template-columns: 1fr;
    }

    .contact-aside {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
    }

    .contact-info-card {
      flex: 1;
      min-width: 140px;
    }

    .contact-form {
      padding: var(--space-6);
    }

    .contact-form__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success') as HTMLElement | null;
  const submitBtn   = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label') as HTMLElement | null;
  const submitSpinner = document.getElementById('submit-spinner') as HTMLElement | null;
  const errorBanner  = document.getElementById('form-error-banner') as HTMLElement | null;
  const errorMessage = document.getElementById('form-error-message') as HTMLElement | null;

  function setFieldError(fieldId: string, message: string) {
    const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement | null;
    const error = document.getElementById(`${fieldId}-error`);
    field?.classList.toggle('is-invalid', !!message);
    if (error) error.textContent = message;
  }

  function clearErrors() {
    ['name', 'email', 'website', 'company', 'project'].forEach(id => setFieldError(id, ''));
    if (errorBanner) errorBanner.classList.remove('is-visible');
  }

  function validate(data: FormData): boolean {
    let valid = true;

    const required: { id: string; label: string }[] = [
      { id: 'name',    label: 'Name is required.' },
      { id: 'website', label: 'Website is required.' },
      { id: 'company', label: 'Company name is required.' },
      { id: 'project', label: 'Please describe your project.' },
    ];

    required.forEach(({ id, label }) => {
      if (!(data.get(id) as string)?.trim()) {
        setFieldError(id, label);
        valid = false;
      }
    });

    const email = (data.get('email') as string)?.trim();
    if (!email) {
      setFieldError('email', 'Email is required.');
      valid = false;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setFieldError('email', 'Please enter a valid email address.');
      valid = false;
    }

    return valid;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();

    const data = new FormData(form);
    if (!validate(data)) return;

    // Loading state
    if (submitBtn)     submitBtn.disabled = true;
    if (submitLabel)   submitLabel.textContent = 'Sending…';
    if (submitSpinner) submitSpinner.style.display = 'inline-block';

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: data });
      const json = await res.json();

      if (res.ok) {
        form.style.display = 'none';
        if (success) success.classList.add('is-visible');
      } else {
        if (errorBanner)  errorBanner.classList.add('is-visible');
        if (errorMessage) errorMessage.textContent = json.error ?? 'Something went wrong. Please try again.';
      }
    } catch {
      if (errorBanner)  errorBanner.classList.add('is-visible');
      if (errorMessage) errorMessage.textContent = 'Network error. Please check your connection and try again.';
    } finally {
      if (submitBtn)     submitBtn.disabled = false;
      if (submitLabel)   submitLabel.textContent = 'Send message';
      if (submitSpinner) submitSpinner.style.display = 'none';
    }
  });
</script>
