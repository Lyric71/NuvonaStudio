---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import FAQ from '../../components/FAQ.astro';

const capabilities = [
  {
    title: 'Campaign architecture',
    body: 'We design your campaign structure around your funnel. Every format, audience, and message has a job. Nothing overlaps. Nothing leaks.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
    </svg>`,
  },
  {
    title: 'Audience targeting',
    body: 'We build audiences by job title, seniority, company name, company size, industry, and skills. We run account-based campaigns that reach the exact people who sign contracts.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
    </svg>`,
  },
  {
    title: 'Ad creative',
    body: "We write and design every ad. Copy that speaks to your buyer's problem. Creative built for how LinkedIn's feed actually works. Tested across segments before budget scales.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    title: 'Full-format execution',
    body: 'We run every LinkedIn ad format as one connected system. Not in isolation. Not as one-off campaigns. As a full-funnel engine built to generate leads.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 6h16M4 10h16M4 14h16M4 18h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
  },
  {
    title: 'AI-powered optimization',
    body: 'We use AI to generate and test ad copy, message variants, and creative across audience segments. We find what works by role and seniority before your full budget is deployed. Campaigns get smarter every week.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    title: 'CRM-connected reporting',
    body: "We report against pipeline, not impressions. Every report shows what we spent, what we tested, what converted, and what we're changing next. No jargon. No vanity metrics.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M7 17V13M12 17V9M17 17V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
  },
];

const adFormats = [
  {
    title: 'Sponsored content',
    body: 'The workhorse of LinkedIn advertising. Eight sub-formats: single image, carousel, video, document, event, thought leader, article, and connected TV ads. We use Sponsored Content to build awareness, drive engagement, and feed the top of your funnel with qualified traffic.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
    image: '/images/advertising-sponsored-content.webp',
    imageAlt: 'Sponsored content campaign visual',
  },
  {
    title: 'Sponsored messaging',
    body: "Message Ads and Conversation Ads delivered directly to your prospect's LinkedIn inbox. Message Ads are single-focus with one CTA. Conversation Ads let prospects choose their own path through multiple offers. Both are delivered when your audience is active and ready to engage.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
    image: '/images/advertising-sponsored-messaging.webp',
    imageAlt: 'Sponsored messaging campaign visual',
  },
  {
    title: 'Dynamic ads',
    body: "Ads that personalize automatically using each member's LinkedIn profile data. Follower Ads grow your Page audience. Spotlight Ads drive traffic to your site. Content Ads capture leads when someone downloads your asset. No manual creative production for every individual.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
    image: '/images/advertising-dynamic-ads.webp',
    imageAlt: 'Dynamic ads campaign visual',
  },
  {
    title: 'Text ads',
    body: 'Self-serve PPC in the desktop sidebar. Lowest cost, lowest barrier to entry. No contracts. We use Text Ads as a precision tool inside your broader campaign, not as a standalone tactic.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 6h16M4 10h16M4 14h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <rect x="16" y="14" width="5" height="7" rx="1" stroke="currentColor" stroke-width="1.6"/>
    </svg>`,
    image: '/images/advertising-text-ads.webp',
    imageAlt: 'Text ads campaign visual',
  },
  {
    title: 'Lead Gen forms',
    body: 'Pre-filled forms inside LinkedIn. Your prospect taps twice and the lead lands in your CRM. No landing page. No re-entry. We pair Lead Gen Forms with Sponsored Content and Messaging campaigns to lift conversion at every stage of the funnel.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="5" y="3" width="14" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M9 7h6M9 11h6M9 15h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
    image: '/images/advertising-lead-gen-forms.webp',
    imageAlt: 'Lead gen forms visual',
  },
];

const differentiators = [
  {
    title: "We're LinkedIn advertising certified.",
    body: "This isn't a badge we put on a website and forget about. Certification means our team has passed LinkedIn's own assessment on campaign strategy, ad formats, targeting, measurement, and optimization. You get a team that operates at the platform's highest standard.",
  },
  {
    title: 'We think in funnels, not formats.',
    body: 'Most agencies run Sponsored Content or Lead Gen Forms as standalone tactics. We build a full-funnel system where each format plays a role, from awareness to conversion. That\'s how you lower cost per lead and raise lead quality at the same time.',
  },
  {
    title: 'We report against revenue, not reach.',
    body: "Impressions don't pay invoices. We connect your LinkedIn campaigns to your CRM so you can see exactly which ads generate pipeline. Every week, we optimize toward the metrics that matter to your sales team.",
  },
  {
    title: 'We test before we spend.',
    body: 'AI lets us generate and test dozens of ad copy, headline, and CTA variations before committing your budget at scale. By the time we scale a campaign, we already know what works for your audience.',
  },
  {
    title: 'We manage everything.',
    body: "Strategy. Creative. Targeting. Launch. Optimization. Reporting. You don't need a separate strategist, designer, and media buyer. One team. One system. One point of accountability.",
  },
  {
    title: 'We know B2B.',
    body: "We don't run e-commerce ads on the side. LinkedIn B2B advertising is all we do. We understand long sales cycles, multiple decision-makers, and why a $200 lead can be worth $200,000 in contract value.",
  },
];

const steps = [
  {
    num: '01',
    title: 'Discovery',
    body: "We learn your business, your buyers, and your pipeline goals. We audit your current LinkedIn presence and ad history. We identify what's working, what's not, and where the opportunity is.",
  },
  {
    num: '02',
    title: 'Build',
    body: 'We design your campaign architecture, build your audiences, write your ad copy, and create your visuals. Everything is structured around your funnel and your sales cycle.',
  },
  {
    num: '03',
    title: 'Launch and test',
    body: 'We launch your campaigns and start testing on day one. Ad copy, creative, audiences, formats, and CTAs all run in parallel. AI speeds the process so winners surface faster.',
  },
  {
    num: '04',
    title: 'Optimize and scale',
    body: "We optimize weekly based on what's driving pipeline, not just clicks. As campaigns mature, we scale what works and cut what doesn't. You get a monthly report that connects ad spend to revenue.",
  },
];

const stats = [
  { number: '121%', label: 'ROAS', note: "LinkedIn's return on ad spend for B2B, vs. 67% for Google Search and 51% for Meta.", source: 'Source: Dreamdata 2026 Benchmarks Report' },
  { number: '6.1%', label: 'Conversion rate', note: 'Average U.S. LinkedIn conversion rate, vs. 3.75% for Google Search and 0.77% for Google Display.' },
  { number: '80%', label: 'B2B leads', note: 'Share of all B2B social media leads that come from LinkedIn.' },
  { number: '41%', label: 'Ad budget share', note: 'LinkedIn\'s share of total B2B ad budgets. The largest single platform investment in B2B.' },
  { number: '10–13%', label: 'Lead Gen Form CVR', note: 'Lead Gen Form conversion rate, vs. 2.35% for standard B2B landing pages.' },
  { number: '4 in 5', label: 'Decision-makers', note: 'LinkedIn members involved in business decisions at their company.' },
  { number: '211', label: 'Days to close', note: "Average B2B buying journey from first touch to closed deal. That's why you need a full-funnel system." },
  { number: '33%', label: 'Purchase intent', note: 'Increase in purchase intent for brands advertising on LinkedIn.' },
];

const faqs = [
  {
    q: 'What does "LinkedIn Advertising Certified" mean?',
    a: "It means our team has completed and passed LinkedIn's official certification program covering campaign strategy, ad formats, audience targeting, measurement, and optimization. It's LinkedIn's own standard for advertising expertise. Not every agency has it. We do.",
  },
  {
    q: 'What LinkedIn ad formats do you manage?',
    a: 'All five: Sponsored Content (all 8 sub-formats), Sponsored Messaging (Message Ads and Conversation Ads), Dynamic Ads, Text Ads, and Lead Gen Forms. We run them as one connected system, not as isolated campaigns.',
  },
  {
    q: 'Do you handle strategy and creative, or just media buying?',
    a: 'Everything. We start with your audience, funnel, and pipeline goals. Then we build the architecture, write the copy, design the creative, launch, test, and optimize. One team owns the entire process.',
  },
  {
    q: 'How do you report on results?',
    a: "We report against pipeline. You get weekly optimization updates and a monthly performance report. Every report shows what we spent, what we tested, what worked, and what we're changing. No jargon. No vanity metrics.",
  },
  {
    q: 'How do you use AI?',
    a: 'We use AI to generate and test ad copy, message variants, and creative across audience segments. We find what performs best by role and seniority before your full budget is deployed. The result is faster optimization and lower cost per lead.',
  },
  {
    q: 'What is the minimum ad spend you work with?',
    a: "We work with B2B companies that are serious about LinkedIn as a lead generation channel. If your monthly ad budget is under $5,000, LinkedIn may not be the right fit yet. We'll tell you that upfront.",
  },
  {
    q: 'How long before I see results?',
    a: 'Most clients see qualified leads within the first 30 days. But LinkedIn is a full-funnel channel. The average B2B buying journey is 211 days. The real value compounds over months as your campaigns build data, your targeting sharpens, and your pipeline fills.',
  },
  {
    q: 'Do I need a strong LinkedIn company page before running ads?',
    a: "It helps, but it's not a blocker. Prospects who see your ad often check your company page before engaging. We can advise on page setup or handle it as part of onboarding so your page is ready before the first ad runs.",
  },
  {
    q: 'Can you target specific companies or job titles?',
    a: "Yes. LinkedIn's targeting is the most precise in B2B. We target by job title, seniority, company name, company size, industry, skills, and more. You reach the exact people who make buying decisions.",
  },
  {
    q: 'What industries do you work with?',
    a: "B2B companies across technology, manufacturing, professional services, SaaS, healthcare, and others. If your buyers are on LinkedIn and your deals are worth $20,000 or more, we can build a campaign that pays for itself.",
  },
  {
    q: 'How do I get started?',
    a: "Book a call. We'll review your current LinkedIn presence, discuss your pipeline goals, and tell you whether LinkedIn advertising is the right channel for your business. No pitch deck. No pressure.",
  },
];
---

<Layout
  title="LinkedIn Advertising Services | Get More B2B Leads"
  description="We run every LinkedIn ad format as one system built for B2B lead generation. Precision targeting, AI-powered optimization, and pipeline-first reporting."
  abstract="We run every LinkedIn ad format to get you more B2B leads. Precision targeting, full-funnel campaigns, and reporting against pipeline, not impressions."
>
  <NavBar />
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="ads-hero" aria-labelledby="ads-heading">
      <div class="ads-hero__bg" aria-hidden="true"></div>
      <div class="ads-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="ads-hero__content">
          <p class="eyebrow eyebrow--light reveal">LinkedIn advertising</p>
          <h1 id="ads-heading" class="ads-hero__h1 reveal reveal-delay-1">
            LinkedIn ads that turn clicks into <span class="text-gradient">pipeline.</span>
          </h1>
          <p class="ads-hero__sub reveal reveal-delay-2">
            You already know LinkedIn is where your buyers are. We make sure your ads reach the right ones, at the right time, with the right message. Then we turn that into leads you can close.
          </p>
          <div class="ads-hero__actions reveal reveal-delay-3">
            <a href="/contact?intent=call" class="btn btn--primary btn--lg">Book a call</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── The Problem ─────────────────────────────────────── -->
    <section class="section problem" aria-labelledby="problem-heading">
      <div class="container">
        <div class="problem__inner">
          <div class="problem__text">
            <h2 id="problem-heading" class="problem__h2 reveal">Most B2B companies waste money on LinkedIn ads</h2>
            <div class="problem__body">
              <p class="problem__p reveal">They boost a post. Pick a broad audience. Hope for the best.</p>
              <p class="problem__p reveal">The result? High cost per click. Low-quality leads. No clear line from ad spend to revenue.</p>
              <p class="problem__p reveal">LinkedIn ads work. But only when they're built as a system, not a set of disconnected campaigns.</p>
              <p class="problem__p problem__p--highlight reveal">That's what we do.</p>
            </div>
          </div>
          <div class="problem__visual reveal reveal-delay-2" aria-hidden="true">
            <div class="problem__graphic">
              <div class="problem__bar problem__bar--1"><span>Wasted spend</span></div>
              <div class="problem__bar problem__bar--2"><span>Low-quality leads</span></div>
              <div class="problem__bar problem__bar--3"><span>No attribution</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── What We Do ──────────────────────────────────────── -->
    <section class="section what-we-do" aria-labelledby="wwd-heading">
      <div class="container">
        <div class="wwd__head reveal">
          <p class="eyebrow">What we do</p>
          <h2 id="wwd-heading" class="wwd__h2">We build and run your entire LinkedIn ads engine</h2>
          <p class="wwd__intro">We don't hand you a strategy deck and wish you luck. We own the full process, from audience to pipeline. Our team is LinkedIn Advertising Certified, which means we meet LinkedIn's own standard for campaign strategy, targeting, and optimization.</p>
        </div>

        <div class="wwd__grid">
          {capabilities.map((cap, i) => (
            <div class={`wwd-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="wwd-card__top">
                <span class="wwd-card__icon" aria-hidden="true" set:html={cap.icon} />
              </div>
              <strong class="wwd-card__title">{cap.title}</strong>
              <p class="wwd-card__body">{cap.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Ad Formats We Run ───────────────────────────────── -->
    <section class="section formats-section" aria-labelledby="formats-heading">
      <div class="container">
        <div class="formats__head reveal">
          <p class="eyebrow">Ad formats</p>
          <h2 id="formats-heading" class="formats__h2">Every LinkedIn ad format. One certified team.</h2>
          <p class="formats__intro">LinkedIn offers five core ad formats. Each does a different job in your funnel. Most agencies run one or two. We run all five as one connected system, because that is how you move prospects from first impression to closed deal. Our LinkedIn Advertising Certified team knows when and how to deploy each one.</p>
        </div>

        {adFormats.map((fmt, i) => (
          <div class={`fmt-block${i % 2 === 1 ? ' fmt-block--flip' : ''} reveal`} id={`fmt-${i}`}>
            <div class="fmt-block__text">
              <div class="fmt-block__label">
                <span class="fmt-block__icon" aria-hidden="true" set:html={fmt.icon} />
              </div>
              <h3 class="fmt-block__title">{fmt.title}</h3>
              <p class="fmt-block__body">{fmt.body}</p>
            </div>
            <div class="fmt-block__visual">
              <div class="fmt-block__img-wrap">
                <img
                  src={fmt.image}
                  alt={fmt.imageAlt}
                  class="fmt-block__img"
                  width="560"
                  height="380"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Why Work With Us ────────────────────────────────── -->
    <section class="section why-us" aria-labelledby="why-heading">
      <div class="why-us__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="why__head reveal">
          <p class="eyebrow eyebrow--light">Why us</p>
          <h2 id="why-heading" class="why__h2">What makes us different</h2>
        </div>

        <div class="why__layout">

          <!-- Left: Visual column -->
          <div class="why__visual reveal">
            <!-- Team photo placeholder -->
            <div class="why__photo-wrap">
              <img
                src="/images/advertising-team.webp"
                alt="Nuvora Studio team"
                class="why__photo"
                width="480"
                height="560"
                loading="lazy"
              />
            </div>

            <!-- Certification badge -->
            <div class="why__cert">
              <div class="why__cert-badge">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                  <path d="M14 2l3.09 6.26L24 10l-6.91 2.74L14 22l-3.09-9.26L4 10l6.91-1.74L14 2z" fill="var(--cyan)"/>
                  <circle cx="14" cy="12" r="5" fill="var(--deep-navy)" stroke="var(--cyan)" stroke-width="1.5"/>
                  <path d="M11.5 12l1.75 1.75L16.5 10" stroke="var(--cyan)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="why__cert-text">
                <strong>LinkedIn Advertising Certified</strong>
                <span>Campaign strategy, targeting, measurement & optimization</span>
              </div>
            </div>

            <!-- Trust indicators -->
            <div class="why__trust-row">
              <div class="why__trust-item">
                <span class="why__trust-num">100%</span>
                <span class="why__trust-label">LinkedIn-focused</span>
              </div>
              <div class="why__trust-divider"></div>
              <div class="why__trust-item">
                <span class="why__trust-num">B2B</span>
                <span class="why__trust-label">Only</span>
              </div>
              <div class="why__trust-divider"></div>
              <div class="why__trust-item">
                <span class="why__trust-num">Full</span>
                <span class="why__trust-label">Funnel</span>
              </div>
            </div>
          </div>

          <!-- Right: Differentiator cards -->
          <div class="why__cards">
            {differentiators.map((d, i) => (
              <div class={`why-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
                <div class="why-card__content">
                  <strong class="why-card__title">{d.title}</strong>
                  <p class="why-card__body">{d.body}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- ── How It Works ────────────────────────────────────── -->
    <section class="section steps-section" aria-labelledby="steps-heading">
      <div class="container">
        <div class="steps__head reveal">
          <p class="eyebrow">Process</p>
          <h2 id="steps-heading" class="steps__h2">From kickoff to pipeline in four steps</h2>
        </div>

        <div class="steps__track">
          <div class="steps__line" aria-hidden="true"></div>
          {steps.map((step, i) => (
            <div class={`step-card reveal reveal-delay-${Math.min(i + 1, 4)}`}>
              <div class="step-card__dot" aria-hidden="true">
                <span>{step.num}</span>
              </div>
              <strong class="step-card__title">{step.title}</strong>
              <p class="step-card__body">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── LinkedIn Ads by the Numbers ────────────────────── -->
    <section class="section stats-section" aria-labelledby="stats-heading">
      <div class="container">
        <div class="stats__head reveal">
          <p class="eyebrow eyebrow--light">By the numbers</p>
          <h2 id="stats-heading" class="stats__h2">The platform performs. The numbers prove it.</h2>
        </div>

        <div class="stats__grid">
          {stats.map((s, i) => (
            <div class={`stat-card${i === 0 ? ' stat-card--featured' : ''} reveal${i > 0 ? ` reveal-delay-${(i % 3) === 0 ? '' : i % 3}` : ''}`}>
              <span class="stat-card__number">{s.number}</span>
              <span class="stat-card__label">{s.label}</span>
              <p class="stat-card__note">{s.note}</p>
              {s.source && <p class="stat-card__source">{s.source}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Who This Is For ─────────────────────────────────── -->
    <section class="section fit-section" aria-labelledby="fit-heading">
      <div class="container">
        <div class="fit__layout">
          <div class="fit__text">
            <p class="eyebrow reveal">Is this for you?</p>
            <h2 id="fit-heading" class="fit__h2 reveal">Is this right for your business?</h2>
            <p class="fit__intro reveal">Our LinkedIn advertising services are built for B2B companies that meet three conditions:</p>
          </div>

          <div class="fit__items">
            <div class="fit-item reveal">
              <div class="fit-item__check" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10.5l4 4 8-8" stroke="var(--cyan)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <strong class="fit-item__title">Your buyers are on LinkedIn.</strong>
                <p class="fit-item__body">If your clients are professionals, executives, or business owners, they're on the platform. 4 in 5 LinkedIn members drive business decisions.</p>
              </div>
            </div>
            <div class="fit-item reveal reveal-delay-1">
              <div class="fit-item__check" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10.5l4 4 8-8" stroke="var(--cyan)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div>
                <strong class="fit-item__title">Your deal sizes justify the investment.</strong>
                <p class="fit-item__body">LinkedIn's cost per lead is higher than Meta or Google Display. But for companies with deal sizes above $20,000, the math works. A $200 lead at a 5% close rate means $4,000 to acquire a client worth multiples of that.</p>
              </div>
            </div>
            <div class="fit-item reveal reveal-delay-2">
