---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import FAQ from '../../components/FAQ.astro';

/* ── Data ───────────────────────────────────────────────── */

const advocacyCards = [
  { title: 'Advocacy Program Design & Management', description: 'Structure, content calendar, and day-to-day management. We make participation easy so your team actually does it.' },
  { title: 'Employee Profile Optimization', description: 'Profiles rewritten to win buyers, not recruiters. Every employee profile becomes a landing page for your brand.' },
  { title: 'New Employee Onboarding', description: 'A strong LinkedIn presence from day one. New hires get set up, optimized, and plugged into the program before their first week ends.' },
];

const brandingCards = [
  { title: 'Executive Profile Optimization', description: 'We rewrite profiles so they build credibility with prospects, investors, and future hires, not just old colleagues.' },
  { title: 'Executive Ghostwriting', description: 'Their voice. Their expertise. Published on a schedule that keeps them relevant. We handle drafts, approvals, posting, and comment engagement.' },
  { title: 'LinkedIn Live & Follower Growth', description: 'LinkedIn Live pulls 24× more comments than standard video. We build structured Live programs that grow a real audience around your executives\' expertise.' },
];

const workshops = [
  { tag: 'Half-day', title: 'LinkedIn Fundamentals', description: 'How the platform actually works in 2026. Algorithm mechanics, feed behavior, and what drives results. Built for teams starting from scratch or starting over.' },
  { tag: 'Full-day', title: 'Content Masterclass', description: 'A repeatable production system that builds authority without burning out your team. AI-assisted workflows included. Everyone leaves with a 30-day content plan.' },
  { tag: 'Full-day', title: 'LinkedIn Ads Deep Dive', description: 'Targeting, campaign architecture, budgeting, and attribution. For marketing teams spending money on LinkedIn who need to know exactly where it goes.' },
  { tag: 'Half-day', title: 'Executive Personal Brand', description: 'A focused session for senior leaders. Profile structure, posting rhythm, and the frameworks that earn trust before a first meeting happens.' },
];

const stats = [
  { value: '80%', caption: 'of all B2B social media leads come from LinkedIn. Facebook, X, and Instagram split the rest.' },
  { value: '277%', caption: 'higher lead generation rate than Facebook and X combined.' },
  { value: '2.74%', caption: 'visitor-to-lead conversion rate. Facebook\u2019s is 0.77%.' },
  { value: '4 in 5', caption: 'LinkedIn members are involved in business decisions at their company.' },
  { value: '561%', caption: 'more reach when employees share content vs. the company page posting it.' },
  { value: '10\u201315%', caption: 'conversion rate on LinkedIn Lead Gen Forms. Standard landing pages convert at 2\u20135%.' },
  { value: '85%', caption: 'of B2B marketers say LinkedIn delivers the best value of any social platform.' },
  { value: '28%', caption: 'lower cost per lead than Google Ads for B2B.' },
  { value: '7\u00d7', caption: 'faster follower growth for pages that post weekly.' },
  { value: '89%', caption: 'of B2B marketers already use LinkedIn for lead generation. The rest are catching up.' },
];

const faqs = [
  { q: 'What does "employee advocacy" mean in practice?', a: 'Your employees share curated content from their personal LinkedIn profiles. We build the program, create the content, and handle the logistics. They share. That\u2019s it.' },
  { q: 'How fast will we see results?', a: 'Reach and engagement typically increase within the first month. Leads follow in 60\u201390 days. It depends on your industry, your team\u2019s size, and how active they are. We set expectations clearly on the first call.' },
  { q: 'Do you write everything for executive ghostwriting?', a: 'Every word. We interview your executives, write in their voice, and send drafts for approval. Nothing goes live without their sign-off.' },
  { q: 'We\u2019re not based in the US. Can you still work with us?', a: 'Yes. We work with B2B companies across time zones. Workshops run online or in-person. Content services are remote by default.' },
  { q: 'What size companies do you work with?', a: 'Anywhere from 20 to 20,000 employees. Advocacy scales well for mid-size and enterprise B2B companies. Training fits any size.' },
  { q: 'Do you run LinkedIn Ads for clients?', a: 'Our consulting covers organic growth: advocacy, personal branding, and training. We teach ads strategy in the Deep Dive workshop. For ongoing ads management, ask us what\u2019s available.' },
  { q: 'How is your training different from what\u2019s free online?', a: 'It\u2019s built on data from real B2B campaigns, not recycled tips. Your team leaves with work product: optimized profiles, a content calendar, or a campaign blueprint. Not a slide deck.' },
  { q: 'What do you actually report on?', a: 'Follower growth, engagement rate, profile views, website traffic from LinkedIn, and inbound leads. If a number doesn\u2019t connect to pipeline, we don\u2019t waste your time with it.' },
  { q: 'Can you share pricing?', a: 'Advocacy, ghostwriting, and training are each priced on scope. We\u2019ll walk through the numbers on a call and give you a clear proposal. No ambiguity.' },
  { q: 'We\u2019ve done nothing on LinkedIn. Is that a problem?', a: 'No. Many of our clients started at zero. The Fundamentals workshop exists for exactly this. We meet you where you are and build from there.' },
];
---

<Layout
  title="LinkedIn Consulting Services for B2B Lead Gen"
  description="Employee advocacy, executive branding, and LinkedIn training for B2B companies. We grow your LinkedIn presence so your team generates more leads."
  abstract="We help B2B companies get more leads from LinkedIn through employee advocacy programs, executive personal branding, and hands-on team training."
>
  <NavBar />
  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════ -->
    <section class="c-hero" aria-labelledby="c-hero-h">
      <div class="c-hero__bg" aria-hidden="true"></div>
      <div class="c-hero__orb c-hero__orb--1" aria-hidden="true"></div>
      <div class="c-hero__orb c-hero__orb--2" aria-hidden="true"></div>
      <div class="container">
        <div class="c-hero__inner">
          <p class="eyebrow eyebrow--light reveal">LinkedIn Consulting</p>
          <h1 id="c-hero-h" class="c-hero__h1 reveal reveal-delay-1">
            Get more leads from LinkedIn. <em>Not more noise.</em>
          </h1>
          <p class="c-hero__sub reveal reveal-delay-2">
            Your company page posts reach a fraction of your audience. Your employees' profiles reach everyone else. We build the programs that close that gap.
          </p>
          <div class="c-hero__actions reveal reveal-delay-3">
            <a href="/contact?intent=call" class="btn btn--primary btn--lg">Book a call</a>
          </div>
        </div>
      </div>
      <div class="c-hero__shape" aria-hidden="true">
        <svg viewBox="0 0 1440 72" fill="none" preserveAspectRatio="none"><path d="M0 72V36C240 4 480 0 720 12s480 20 720 0v60H0z" fill="var(--white)"/></svg>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         EMPLOYEE ADVOCACY
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-svc" aria-labelledby="c-advocacy-h">
      <div class="container">
        <div class="c-svc__layout">
          <div class="c-svc__text reveal">
            <span class="c-svc__label">Employee Advocacy</span>
            <h2 id="c-advocacy-h" class="c-svc__h2">Your people reach further than your brand ever will.</h2>
            <div class="c-svc__body">
              <p>LinkedIn's algorithm has a preference. It favors people over company pages. That's not a bug. It's the platform's design.</p>
              <p>Content shared by employees gets 8× more engagement than the same post from a brand page. Their combined networks are 10× larger than your company's follower count. And 92% of B2B buyers trust what employees say over what a company advertises.</p>
              <p>Most companies know this. Very few act on it. The ones that do see 4.3× more impressions and a direct pipeline impact within 90 days.</p>
              <p>We design and run the program. Your team shows up, shares, and gets back to work.</p>
            </div>
          </div>
          <div class="c-svc__visual reveal reveal-delay-2">
            <div class="c-svc__img-wrap">
              <img src="/generated-1774795193053.png" alt="Diverse employees actively sharing content on LinkedIn from a modern open-plan office" class="c-svc__img" width="560" height="420" loading="lazy" />
            </div>
          </div>
        </div>

        <div class="c-cards">
          {advocacyCards.map((card, i) => (
            <div class={`c-card reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
              <span class="c-card__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <strong class="c-card__title">{card.title}</strong>
              <p class="c-card__desc">{card.description}</p>
            </div>
          ))}
        </div>

        <div class="c-svc__cta reveal">
          <a href="/contact?intent=call" class="btn btn--primary btn--lg">Start generating leads through your team</a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         PERSONAL BRANDING
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-svc c-svc--alt" aria-labelledby="c-branding-h">
      <div class="container">
        <div class="c-svc__layout c-svc__layout--flip">
          <div class="c-svc__text reveal">
            <span class="c-svc__label">Personal Branding</span>
            <h2 id="c-branding-h" class="c-svc__h2">Buyers check your executives on LinkedIn before they check your website.</h2>
            <div class="c-svc__body">
              <p>82% of B2B buyers trust a company more when its leadership is active on LinkedIn. 64% would rather read a thoughtful post from your CEO than a product pitch from your company page.</p>
              <p>That's the opportunity. And most executive teams miss it because nobody has time to write three posts a week.</p>
              <p>We take it off their plate. We interview your leaders, write in their voice, and keep them visible to the people who matter, all without stealing an hour from their calendar.</p>
            </div>
          </div>
          <div class="c-svc__visual reveal reveal-delay-2">
            <div class="c-svc__img-wrap">
              <img src="/generated-1774795266442.png" alt="Executive checking LinkedIn engagement on phone in modern corner office at golden hour" class="c-svc__img" width="560" height="420" loading="lazy" />
            </div>
          </div>
        </div>

        <div class="c-cards">
          {brandingCards.map((card, i) => (
            <div class={`c-card reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
              <span class="c-card__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <strong class="c-card__title">{card.title}</strong>
              <p class="c-card__desc">{card.description}</p>
            </div>
          ))}
        </div>

        <div class="c-svc__cta reveal">
          <a href="/contact?intent=call" class="btn btn--primary btn--lg">Put your leadership in front of buyers</a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         TRAINING
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-training" aria-labelledby="c-training-h">
      <div class="c-training__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="c-training__head reveal">
          <span class="c-training__label">Training</span>
          <h2 id="c-training-h" class="c-training__h2">Your team uses LinkedIn every day. Do they know how to use it well?</h2>
          <div class="c-training__intro">
            <p>68% of B2B marketers increased their LinkedIn activity last year. Most did it without any formal training.</p>
            <p>That shows up in the results: generic posts, empty profiles, ad spend with no clear return. Meanwhile, trained professionals are 51% more likely to hit their sales quotas.</p>
            <p>Our workshops are not webinars. They're working sessions. Your team walks out with optimized profiles, a content plan, or an ads strategy they can run the following Monday.</p>
          </div>
        </div>

        <div class="c-workshop-grid">
          {workshops.map((w, i) => (
            <div class={`c-workshop reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <span class={`c-workshop__tag ${w.tag === 'Half-day' ? 'c-workshop__tag--cyan' : 'c-workshop__tag--blue'}`}>{w.tag}</span>
              <strong class="c-workshop__title">{w.title}</strong>
              <p class="c-workshop__desc">{w.description}</p>
            </div>
          ))}
        </div>

        <div class="c-training__cta reveal">
          <a href="/contact?intent=call" class="btn btn--primary btn--lg">Book a workshop</a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         LINKEDIN BY THE NUMBERS
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-num" aria-labelledby="c-num-h">
      <div class="c-num__glow" aria-hidden="true"></div>
      <div class="container">
        <div class="c-num__head reveal">
          <p class="eyebrow eyebrow--light">By the Numbers</p>
          <h2 id="c-num-h" class="c-num__h2">The case for LinkedIn. In numbers.</h2>
          <p class="c-num__intro">These are not our numbers. They come from LinkedIn, HubSpot, Edelman, and independent B2B research. We include them because clients ask us "why LinkedIn?", and the answer is always the same.</p>
        </div>

        <div class="c-num__grid">
          {stats.map((s, i) => (
            <div class={`c-num-card reveal${i > 0 ? ` reveal-delay-${(i % 4) + 1}` : ''}`}>
              <span class="c-num-card__value">{s.value}</span>
              <p class="c-num-card__caption">{s.caption}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <FAQ heading="Common questions" faqs={faqs} background="var(--off-white)" cta={{ text: 'Book a call', href: '/contact' }} id="c-faq" />


    <!-- ═══════════════════════════════════════════════════════
         BOTTOM CTA
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-bcta" aria-labelledby="c-bcta-h">
      <div class="c-bcta__orb c-bcta__orb--1" aria-hidden="true"></div>
      <div class="c-bcta__orb c-bcta__orb--2" aria-hidden="true"></div>
      <div class="container">
        <div class="c-bcta__inner reveal">
          <h2 id="c-bcta-h" class="c-bcta__h2">Your competitors are already on LinkedIn. <em>Make sure you show up better.</em></h2>
          <a href="/contact?intent=call" class="btn btn--primary btn--lg">Book a call</a>
        </div>
      </div>
    </section>

  </main>
</Layout>


<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>
  /* ── shared placeholder ── */
  .ph{display:none;position:absolute;inset:0;flex-direction:column;align-items:center;justify-content:center;gap:var(--sp-3);background:linear-gradient(135deg,var(--off-white),var(--border));border-radius:var(--r-xl)}
  .ph span{font-size:var(--fs-xs);color:var(--text-3);letter-spacing:.06em;text-transform:uppercase;font-weight:500}


  /* ╔═══════════════════════════════════════════╗
     ║  HERO                                     ║
     ╚═══════════════════════════════════════════╝ */
  .c-hero{
    background:var(--deep-navy);
    padding-block:var(--sp-32) var(--sp-24);
    position:relative;overflow:hidden;
    text-align:center;
  }
  .c-hero__bg{
    position:absolute;inset:0;
    background:url('/generated-1774794901935.png') center/cover no-repeat;
    opacity:0.18;
    pointer-events:none;
  }
  .c-hero::before{
    content:'';position:absolute;inset:0;z-index:1;
    background:
      linear-gradient(to bottom,rgba(3,7,18,.55) 0%,rgba(3,7,18,.35) 40%,rgba(3,7,18,.70) 100%),
      radial-gradient(ellipse 55% 60% at 50% 30%,rgba(6,182,212,.12) 0%,transparent 60%),
      radial-gradient(ellipse 40% 50% at 80% 80%,rgba(3,105,161,.08) 0%,transparent 60%);
    pointer-events:none;
  }

  .c-hero__orb{position:absolute;border-radius:50%;pointer-events:none;filter:blur(90px)}
  .c-hero__orb--1{width:600px;height:600px;top:-200px;left:-100px;background:radial-gradient(circle,rgba(6,182,212,.14) 0%,transparent 70%)}
  .c-hero__orb--2{width:400px;height:400px;bottom:-100px;right:-60px;background:radial-gradient(circle,rgba(3,105,161,.10) 0%,transparent 70%)}

  .c-hero__inner{position:relative;z-index:1;max-width:820px;margin-inline:auto}

  .c-hero__h1{
    font-family:var(--font-display);font-size:clamp(2.5rem,5vw,4rem);
    font-weight:700;color:var(--white);line-height:1.10;
    letter-spacing:-.02em;margin-block:var(--sp-5) var(--sp-6);
  }
  .c-hero__h1 em{font-style:normal;display:block;color:rgba(255,255,255,.40);font-weight:300}

  .c-hero__sub{
    font-size:var(--fs-md);color:rgba(255,255,255,.62);
    max-width:620px;margin-inline:auto;line-height:1.75;margin-bottom:var(--sp-10);
  }
  .c-hero__actions{display:flex;justify-content:center;gap:var(--sp-4)}

  .c-hero__shape{position:absolute;bottom:-1px;left:0;right:0;line-height:0}
  .c-hero__shape svg{width:100%;height:72px;display:block}


  /* ╔═══════════════════════════════════════════╗
     ║  SERVICE SECTIONS (Advocacy + Branding)   ║
     ╚═══════════════════════════════════════════╝ */
  .c-svc{background:var(--white)}
  .c-svc--alt{background:var(--off-white)}

  .c-svc__layout{
    display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-16);
    align-items:center;margin-bottom:var(--sp-12);
  }
  .c-svc__layout--flip{direction:rtl}
  .c-svc__layout--flip .c-svc__text,
  .c-svc__layout--flip .c-svc__visual{direction:ltr}

  .c-svc__label{
    display:inline-block;
    font-family:var(--font-display);font-size:var(--fs-xl);font-weight:600;
    color:var(--blue);letter-spacing:-.01em;
    margin-bottom:var(--sp-3);
    padding-bottom:var(--sp-2);
    border-bottom:3px solid var(--cyan);
  }

  .c-svc__h2{
    font-family:var(--font-display);font-size:clamp(1.75rem,3.5vw,2.5rem);
    font-weight:700;color:var(--text);line-height:1.18;letter-spacing:-.01em;
    margin-top:var(--sp-4);margin-bottom:var(--sp-8);
  }

  .c-svc__body{display:flex;flex-direction:column;gap:var(--sp-4)}
  .c-svc__body p{font-size:var(--fs-md);color:var(--text-2);line-height:1.75}

  .c-svc__img-wrap{
    position:relative;border-radius:var(--r-xl);overflow:hidden;
    aspect-ratio:4/3;background:var(--off-white);border:1px solid var(--border);
    box-shadow:var(--shadow-lg);
  }
  .c-svc__img{width:100%;height:100%;object-fit:cover;display:none}
  .c-svc__img-wrap .ph{display:flex}

  /* Service cards */
  .c-cards{
    display:grid;grid-template-columns:repeat(3,1fr);gap:var(--sp-5);
    margin-bottom:var(--sp-8);
  }

  .c-card{
    position:relative;padding:var(--sp-8) var(--sp-6);
    background:var(--white);border:1px solid var(--border);
    border-radius:var(--r-xl);overflow:hidden;
    transition:border-color var(--t-fast),box-shadow var(--t-fast),transform var(--t-base);
  }
  .c-svc--alt .c-card{background:var(--white)}
  .c-card:hover{border-color:var(--border-2);box-shadow:var(--shadow-md);transform:translateY(-3px)}

  .c-card__num{
    position:absolute;top:var(--sp-3);right:var(--sp-5);
    font-family:var(--font-display);font-size:var(--fs-5xl);font-weight:700;
    color:rgba(3,105,161,.05);line-height:1;pointer-events:none;
  }
  .c-card__title{display:block;font-size:var(--fs-base);font-weight:600;color:var(--text);margin-bottom:var(--sp-3);position:relative;z-index:1}
  .c-card__desc{font-size:var(--fs-sm);color:var(--text-2);line-height:1.7;position:relative;z-index:1}

  .c-svc__cta{display:flex;justify-content:center;padding-top:var(--sp-4)}


  /* ╔═══════════════════════════════════════════╗
     ║  TRAINING                                 ║
     ╚═══════════════════════════════════════════╝ */
  .c-training{background:var(--deep-navy);position:relative;overflow:hidden}
  .c-training__bg{
    position:absolute;inset:0;pointer-events:none;
    background:
      radial-gradient(ellipse 50% 60% at 0% 100%,rgba(6,182,212,.12) 0%,transparent 60%),
      radial-gradient(ellipse 40% 50% at 100% 0%,rgba(3,105,161,.10) 0%,transparent 60%);
  }

  .c-training__head{position:relative;z-index:1;max-width:720px;margin-bottom:var(--sp-12)}
  .c-training__label{
    display:inline-block;
    font-family:var(--font-display);font-size:var(--fs-xl);font-weight:600;
    color:var(--cyan);letter-spacing:-.01em;
    margin-bottom:var(--sp-3);
    padding-bottom:var(--sp-2);
    border-bottom:3px solid rgba(6,182,212,.40);
  }

  .c-training__h2{
    font-family:var(--font-display);font-size:clamp(1.75rem,3.5vw,2.5rem);
    font-weight:700;color:var(--white);line-height:1.18;letter-spacing:-.01em;
    margin-top:var(--sp-4);margin-bottom:var(--sp-6);
  }
  .c-training__intro{display:flex;flex-direction:column;gap:var(--sp-4)}
  .c-training__intro p{font-size:var(--fs-md);color:rgba(255,255,255,.58);line-height:1.75}

  .c-workshop-grid{
    position:relative;z-index:1;
    display:grid;grid-template-columns:repeat(2,1fr);gap:var(--sp-5);
    margin-bottom:var(--sp-10);
  }

  .c-workshop{
    padding:var(--sp-8) var(--sp-6);
    background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
    border-radius:var(--r-xl);
    transition:background var(--t-fast),border-color var(--t-fast),transform var(--t-base);
  }
  .c-workshop:hover{background:rgba(255,255,255,.08);border-color:rgba(6,182,212,.30);transform:translateY(-3px)}

  .c-workshop__tag{
    display:inline-flex;align-items:center;
    padding:0.25rem 0.75rem;
    font-size:var(--fs-xs);font-weight:500;
    letter-spacing:0.10em;text-transform:uppercase;
    border-radius:var(--r-full);margin-bottom:var(--sp-4);
  }
  .c-workshop__tag--cyan{background:rgba(6,182,212,.15);color:var(--cyan)}
  .c-workshop__tag--blue{background:rgba(3,105,161,.15);color:rgba(255,255,255,.80)}

  .c-workshop__title{display:block;font-size:var(--fs-lg);font-weight:600;color:var(--white);margin-bottom:var(--sp-3)}
  .c-workshop__desc{font-size:var(--fs-sm);color:rgba(255,255,255,.58);line-height:1.7}

  .c-training__cta{position:relative;z-index:1;display:flex;justify-content:center}


  /* ╔═══════════════════════════════════════════╗
     ║  LINKEDIN BY THE NUMBERS                  ║
     ╚═══════════════════════════════════════════╝ */
  .c-num{background:var(--white);position:relative;overflow:hidden}

  .c-num__glow{
    position:absolute;inset:0;pointer-events:none;
    background:radial-gradient(ellipse 60% 50% at 50% 0%,rgba(3,105,161,.04) 0%,transparent 60%);
  }

  .c-num__head{position:relative;z-index:1;text-align:center;max-width:680px;margin-inline:auto;margin-bottom:var(--sp-12)}
  .c-num__h2{
    font-family:var(--font-display);font-size:clamp(1.75rem,3.5vw,2.5rem);
    font-weight:700;color:var(--text);line-height:1.18;letter-spacing:-.01em;
    margin-top:var(--sp-4);margin-bottom:var(--sp-4);
