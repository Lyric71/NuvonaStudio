---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import ContactCTA from '../../components/ContactCTA.astro';

const workshops = [
  {
    id: 'fundamentals',
    tag: 'Half-day · Up to 15 participants',
    title: 'LinkedIn Fundamentals Workshop',
    hook: 'Most companies are on LinkedIn. Very few are using it right.',
    stats: [
      { number: '50%', label: 'drop in organic reach for teams that have not adapted to the current algorithm' },
      { number: '40%', label: 'less distribution for posts with external links' },
    ],
    intro: 'Organic reach has dropped by up to 50% for teams that have not adapted to the current algorithm. Posts with external links receive 40% less distribution. The platform is no longer forgiving of guesswork.',
    body: 'This half-day workshop gives your team the foundation to operate on LinkedIn with intent and results.',
    modules: [
      'How the LinkedIn algorithm works in 2026',
      'Profile architecture that drives inbound',
      'Content formats and when to use them',
      'Analytics that connect to business objectives',
    ],
    format: 'Half-day. Online or in-person. Up to 15 participants.',
    note: 'Every framework comes from active LinkedIn management. We teach what we apply every day for clients.',
  },
  {
    id: 'content',
    tag: 'Full-day · Content & marketing teams',
    title: 'Content Masterclass',
    hook: 'Good LinkedIn content is not about posting more. It is about posting smarter.',
    stats: [
      { number: '3.7×', label: 'more reach for content built on real expertise vs generalised posts' },
      { number: '81%', label: 'of B2B campaigns fail to capture attention or drive brand recall' },
    ],
    intro: 'Content built on real expertise generates 3.7 times more reach than generalised posts. Yet 81% of B2B campaigns fail to capture attention or drive brand recall. Most companies produce content for the wrong reasons and get nothing back.',
    body: 'This full-day masterclass builds the strategy, the formats, and the production system your team needs to change that.',
    modules: [
      'Content pillars and editorial strategy',
      'Format selection: carousel, video, document, text',
      'Writing for the LinkedIn feed',
      'Building a production system that holds',
    ],
    format: 'Full day. Online or in-person. For content and marketing teams.',
    note: 'The frameworks we teach are the ones we use every week for B2B clients.',
  },
  {
    id: 'ads',
    tag: 'Full-day · Includes live campaign audit',
    title: 'LinkedIn Ads Deep Dive',
    hook: 'LinkedIn Ads is the most precise B2B targeting tool available. Most campaigns waste that precision.',
    stats: [
      { number: '41%', label: 'of total B2B ad budgets go to LinkedIn' },
      { number: '121%', label: 'ROAS — but only with the right campaign structure' },
    ],
    intro: 'LinkedIn commands 41% of total B2B ad budgets and delivers 121% ROAS. But at CPCs of €5 to €9 and CPMs of €20 to €35, a poorly structured campaign burns budget fast. The most common failures are structural, not creative.',
    body: '58% of B2B marketers say LinkedIn Ads is their best-performing paid channel. The gap between them and the rest is almost always a knowledge gap.',
    modules: [
      'Campaign architecture and objective setting',
      'Targeting: audiences, matched lists, lookalikes',
      'Format selection by funnel stage',
      'Creative performance and testing',
      'Attribution and reporting beyond last click',
    ],
    format: 'Full day. Online or in-person. Includes a live audit of your active campaigns.',
    note: 'We cover what the official documentation does not: the judgment calls that turn budget into pipeline.',
  },
  {
    id: 'executive',
    tag: 'Half-day · Groups of 4–8 leaders',
    title: 'Executive Personal Brand Workshop',
    hook: 'Decision-makers research you before they respond to you. What do they find?',
    stats: [
      { number: '8×', label: 'more engagement on personal profiles vs company pages' },
      { number: '82%', label: 'of B2B buyers trust a company more when its leaders are credibly present on LinkedIn' },
    ],
    intro: 'Personal profiles generate 8 times more engagement than company pages. 82% of B2B buyers trust a company more when its senior leaders are credibly present on LinkedIn.',
    body: 'Most executives have either a neglected profile or one that bears no resemblance to their actual voice. Both fail for the same reason: they build no trust. This half-day workshop gives your leadership team a clear point of view, a consistent voice, and a system they can maintain.',
    modules: [
      'Profile positioning for the right audience',
      'Defining your content themes',
      'Writing in your own voice',
      'A publishing cadence that fits an executive schedule',
    ],
    format: 'Half-day. Online or in-person. For groups of 4 to 8 leaders. Individual profile reviews included.',
    note: 'We do not teach executives to become influencers. We teach them to show up where their buyers are already making judgements.',
  },
];
---

<Layout
  title="LinkedIn Training Workshops for B2B Teams — Nuvora Studio"
  description="Expert LinkedIn training workshops for B2B marketing teams, leadership, and commercial functions. Algorithm mechanics, content strategy, advertising, and employee advocacy — taught by active practitioners."
  abstract="Expert LinkedIn training for B2B teams. Algorithm, content strategy, ads, and employee advocacy — taught by practitioners, not theorists."
>
  <NavBar />
  <main id="main-content">

    <!-- Hero -->
    <section class="training-hero" aria-labelledby="training-heading">
      <div class="container">
        <div class="training-hero__inner">
          <div class="training-hero__text">
            <p class="eyebrow eyebrow--light reveal">Services / Training</p>
            <h1 id="training-heading" class="training-hero__h1 reveal reveal-delay-1">
              LinkedIn training that transfers<br /><em>real capability.</em>
            </h1>
            <p class="training-hero__sub reveal reveal-delay-2">
              Four specialist workshops for teams and leaders who want to own their LinkedIn performance
              — not just outsource it. Online or in-person. Led by practitioners.
            </p>
            <div class="training-hero__actions reveal reveal-delay-3">
              <a href="/contact?intent=training" class="btn btn--primary btn--lg">Book a workshop</a>
              <a href="#workshops" class="btn btn--outline-white btn--lg">See all workshops</a>
            </div>
          </div>
          <div class="training-hero__stats reveal reveal-delay-2">
            <div class="training-stat">
              <span class="training-stat__number">4</span>
              <span class="training-stat__label">Specialist workshops</span>
            </div>
            <div class="training-stat">
              <span class="training-stat__number">½–1</span>
              <span class="training-stat__label">Day formats</span>
            </div>
            <div class="training-stat">
              <span class="training-stat__number">100%</span>
              <span class="training-stat__label">Practitioner-led</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Workshops -->
    <section class="section" id="workshops" style="background: var(--white);" aria-label="Training workshops">
      <div class="container">

        <div class="workshops-header reveal">
          <p class="eyebrow">Our workshops</p>
          <h2>Four programmes.<br />One platform mastered.</h2>
        </div>

        <div class="workshops">
          {workshops.map((w, i) => (
            <article class="workshop reveal" id={w.id} aria-labelledby={`workshop-${w.id}`}>

              <div class="workshop__top">
                <div class="workshop__meta">
                  <span class="workshop__num" aria-hidden="true">0{i + 1}</span>
                  <span class="tag">{w.tag}</span>
                </div>
                <div class="workshop__rule"></div>
                <h2 id={`workshop-${w.id}`} class="workshop__title">{w.title}</h2>
                <p class="workshop__hook">{w.hook}</p>
              </div>

              <div class="workshop__body">
                <div class="workshop__stats-col">
                  {w.stats.map(s => (
                    <div class="workshop__stat">
                      <span class="workshop__stat-num">{s.number}</span>
                      <span class="workshop__stat-label">{s.label}</span>
                    </div>
                  ))}
                </div>

                <div class="workshop__content">
                  <p class="workshop__intro">{w.intro}</p>
                  <p class="workshop__desc">{w.body}</p>

                  <div class="workshop__modules">
                    <p class="workshop__modules-label">What we cover</p>
                    <ul class="workshop__module-list" role="list">
                      {w.modules.map(m => (
                        <li class="workshop__module-item">
                          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="workshop__check">
                            <circle cx="7" cy="7" r="7" fill="var(--blue)" opacity="0.12"/>
                            <path d="M4 7l2.2 2.2L10 5" stroke="var(--blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                          {m}
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="workshop__footer">
                    <p class="workshop__format">{w.format}</p>
                    <p class="workshop__note"><em>{w.note}</em></p>
                    <a href={`/contact?intent=training&workshop=${w.id}`} class="btn btn--primary">
                      Book this workshop →
                    </a>
                  </div>
                </div>
              </div>

            </article>
          ))}
        </div>
      </div>
    </section>

    <ContactCTA />
  </main>
  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .training-hero {
    background: var(--deep-navy);
    padding-block: var(--sp-24) var(--sp-20);
    position: relative;
    overflow: hidden;
  }
  .training-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 80% at 80% 40%, rgba(0,168,220,0.10) 0%, transparent 60%);
    pointer-events: none;
  }

  .training-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--sp-16);
    align-items: center;
  }

  .training-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .training-hero__h1 em { color: rgba(255,255,255,0.48); font-weight: 300; font-style: normal; }

  .training-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.68);
    max-width: 560px;
    line-height: 1.75;
    margin-bottom: var(--sp-10);
  }

  .training-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  /* Stats sidebar */
  .training-hero__stats {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    flex-shrink: 0;
  }

  .training-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--sp-6) var(--sp-8);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: var(--r-xl);
    min-width: 140px;
  }

  .training-stat__number {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1;
  }

  .training-stat__label {
    font-size: var(--fs-xs);
    color: var(--cyan);
    margin-top: var(--sp-2);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ── Workshops header ── */
  .workshops-header {
    margin-bottom: var(--sp-12);
  }
  .workshops-header h2 {
    margin-top: var(--sp-4);
  }

  /* ── Workshop list ── */
  .workshops {
    display: flex;
    flex-direction: column;
  }

  .workshop {
    border-top: 1px solid var(--border);
    padding-block: var(--sp-12);
  }
  .workshop:last-child { border-bottom: 1px solid var(--border); }

  .workshop__top {
    margin-bottom: var(--sp-8);
  }

  .workshop__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-5);
  }

  .workshop__num {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--border-2);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .workshop__rule {
    height: 1px;
    background: var(--border);
    margin-bottom: var(--sp-6);
  }

  .workshop__title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-bottom: var(--sp-3);
  }

  .workshop__hook {
    font-size: var(--fs-md);
    color: var(--text-2);
    font-style: italic;
    max-width: 680px;
    line-height: 1.65;
  }

  /* Body: stats + content */
  .workshop__body {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--sp-12);
    align-items: start;
  }

  .workshop__stats-col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
    padding: var(--sp-6);
    background: var(--off-white);
    border-radius: var(--r-xl);
    border: 1px solid var(--border);
  }

  .workshop__stat {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .workshop__stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2vw, 1.875rem);
    font-weight: 700;
    color: var(--blue);
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .workshop__stat-label {
    font-size: var(--fs-xs);
    color: var(--text-3);
    line-height: 1.5;
  }

  .workshop__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .workshop__intro {
    font-size: var(--fs-md);
    color: var(--text);
    line-height: 1.75;
  }

  .workshop__desc {
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.75;
  }

  /* Modules */
  .workshop__modules { padding-top: var(--sp-2); }

  .workshop__modules-label {
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: var(--sp-4);
  }

  .workshop__module-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .workshop__module-item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--text);
    line-height: 1.55;
  }

  .workshop__check { flex-shrink: 0; margin-top: 2px; }

  /* Footer */
  .workshop__footer {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
    margin-top: var(--sp-2);
  }

  .workshop__format {
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--deep-navy);
  }

  .workshop__note {
    font-size: var(--fs-sm);
    color: var(--text-3);
    line-height: 1.65;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .training-hero__inner { grid-template-columns: 1fr; }
    .training-hero__stats {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .training-stat { flex: 1; min-width: 120px; }
  }

  @media (max-width: 768px) {
    .training-hero { padding-block: var(--sp-16) var(--sp-12); }
    .workshop__body { grid-template-columns: 1fr; }
    .workshop__stats-col {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--sp-6);
    }
    .workshop__stat { flex: 1; min-width: 120px; }
  }
</style>
