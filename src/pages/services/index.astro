---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';

/* ── Data ───────────────────────────────────────────────── */

const contentServices = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="7" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.6"/><line x1="9" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Company Page Management',
    text: 'We build it from scratch or overhaul what\u2019s there \u2014 then keep it running end to end. Consistent branding, optimized copy, and a publishing rhythm your audience can count on.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Content Production & Editorial',
    text: 'Posts, articles, carousels, video. We write and design all of it, every week, on brand and on time. Consistency until your audience starts paying attention.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'LinkedIn Newsletter',
    text: 'Newsletters land directly in your subscribers\u2019 inboxes and LinkedIn notifications. No algorithm in the way. A direct line to the professionals who matter most.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'LinkedIn Events',
    text: 'The highest-engagement format on LinkedIn. We handle everything \u2014 setup, promotion, reminders, follow-up. You show up and lead the room.',
  },
];

const adFormats = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="3" width="20" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Sponsored Content',
    text: 'Put your best content in the feed of the people who can actually buy from you. Targeted by role, seniority, and company.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.6"/><polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Sponsored Messaging',
    text: 'InMail campaigns built for B2B. We write the messages, set the targeting, and optimize for replies. Not just opens.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="1.6"/><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Dynamic Ads',
    text: 'Your prospect sees their own name and photo next to your brand. Hard to ignore. We build and manage these campaigns at scale.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 8h8M8 12h6M8 16h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Text Ads',
    text: 'Simple, cheap, easy to scale. Paired with sponsored content, text ads quietly do a lot of heavy lifting.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 11l3 3L22 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Lead Gen Forms',
    text: 'One tap. Their info flows straight to you. No landing page, no friction. We build, test, and optimize these forms.',
  },
];

const consultingServices = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.6"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Employee Advocacy',
    text: 'Your employees have networks your company page will never reach. We build the program and create share-ready content your team can post in seconds.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Personal Branding',
    text: 'Before a prospect visits your company page, they\u2019ve already looked up your CEO. We position your leaders as the experts they are.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2V3z" stroke="currentColor" stroke-width="1.6"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7V3z" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'Training',
    text: 'Hands-on sessions from profile fundamentals to content strategy and analytics. Your team walks out knowing what to do and how to keep doing it.',
  },
];
---

<Layout
  title="LinkedIn Services for B2B Lead Generation"
  description="Three service lines built to turn LinkedIn into the place where your next clients find you. Content, advertising, and consulting for B2B companies."
  abstract="We grow LinkedIn presence. Our clients get more leads. Content services, advertising campaigns, and consulting programs built for B2B."
>
  <NavBar />
  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════ -->
    <section class="s-hero" aria-labelledby="s-hero-h">
      <div class="s-hero__bg" aria-hidden="true"></div>
      <div class="s-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="s-hero__content">
          <p class="eyebrow eyebrow--light reveal">Our Services</p>
          <h1 id="s-hero-h" class="s-hero__h1 reveal reveal-delay-1">
            We grow LinkedIn presence and generate <span class="text-gradient">more leads.</span>
          </h1>
          <p class="s-hero__sub reveal reveal-delay-2">
            Most B2B companies know they should be doing more on LinkedIn. Few have the time, the team, or the know-how to do it well. We fix that.
          </p>
          <div class="s-hero__actions reveal reveal-delay-3">
            <a href="/contact" class="btn btn--primary btn--lg">Book a call</a>
            <a href="#s-content" class="btn btn--outline-white btn--lg">Explore services</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         INTRO
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-intro" aria-labelledby="s-intro-h">
      <div class="container">
        <div class="s-intro__inner reveal">
          <h2 id="s-intro-h" class="s-intro__h2">Three service lines, built to turn LinkedIn into the place where your next clients find you.</h2>
          <p class="s-intro__body">So it sits there. A half-built company page. A profile last updated in 2021. Potential that never converts. We fix that.</p>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         CONTENT SERVICES
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar" id="s-content" aria-labelledby="s-content-h">
      <div class="container">
        <div class="s-pillar__layout">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </div>
            <h2 id="s-content-h" class="s-pillar__h2">LinkedIn Content Services</h2>
            <a href="/services/content" class="btn btn--primary">Talk to us about your content</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap">
              <div class="s-pillar__img-ph" aria-hidden="true">
                <div class="s-ph__icon">
                  <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><rect width="56" height="56" rx="14" fill="rgba(6,182,212,.08)"/><path d="M16 40l10-14 8 10 6-8 10 12H16z" fill="rgba(6,182,212,.16)"/><circle cx="40" cy="20" r="5" fill="rgba(6,182,212,.20)"/></svg>
                </div>
                <span class="s-ph__label">Content Services</span>
              </div>
            </div>
          </div>
        </div>

        <div class="s-cards">
          {contentServices.map((card, i) => (
            <a href="/services/content" class={`s-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="s-card__top">
                <span class="s-card__icon" set:html={card.icon} />
                <span class="s-card__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <strong class="s-card__title">{card.title}</strong>
              <p class="s-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         ADVERTISING SERVICES
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar s-pillar--dark" id="s-advertising" aria-labelledby="s-ads-h">
      <div class="s-pillar__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="s-pillar__layout s-pillar__layout--flip">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap s-pillar__icon-wrap--light">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
            </div>
            <h2 id="s-ads-h" class="s-pillar__h2">LinkedIn Advertising Services</h2>
            <a href="/services/advertising" class="btn btn--primary">Start generating leads</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap s-pillar__img-wrap--dark">
              <div class="s-pillar__img-ph s-pillar__img-ph--dark" aria-hidden="true">
                <div class="s-ph__icon">
                  <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><rect width="56" height="56" rx="14" fill="rgba(6,182,212,.10)"/><circle cx="28" cy="28" r="12" stroke="rgba(6,182,212,.30)" stroke-width="2"/><circle cx="28" cy="28" r="6" fill="rgba(6,182,212,.22)"/><circle cx="28" cy="28" r="2" fill="rgba(6,182,212,.45)"/></svg>
                </div>
                <span class="s-ph__label s-ph__label--dark">Advertising Services</span>
              </div>
            </div>
          </div>
        </div>

        <div class="s-ad-grid">
          {adFormats.map((card, i) => (
            <a href="/services/advertising" class={`s-ad-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 4)}` : ''}`}>
              <span class="s-ad-card__icon" set:html={card.icon} />
              <strong class="s-ad-card__title">{card.title}</strong>
              <p class="s-ad-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         CONSULTING SERVICES
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar" id="s-consulting" aria-labelledby="s-consult-h">
      <div class="container">
        <div class="s-pillar__layout">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2V3z" stroke="currentColor" stroke-width="1.6"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7V3z" stroke="currentColor" stroke-width="1.6"/></svg>
            </div>
            <h2 id="s-consult-h" class="s-pillar__h2">LinkedIn Consulting Services</h2>
            <a href="/services/consulting" class="btn btn--primary">Let's talk about what your team needs</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap">
              <div class="s-pillar__img-ph" aria-hidden="true">
                <div class="s-ph__icon">
                  <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><rect width="56" height="56" rx="14" fill="rgba(6,182,212,.08)"/><path d="M14 18h10a4 4 0 0 1 4 4v16a3 3 0 0 0-3-3H14V18z" fill="rgba(6,182,212,.12)"/><path d="M42 18H32a4 4 0 0 0-4 4v16a3 3 0 0 1 3-3h11V18z" fill="rgba(6,182,212,.18)"/></svg>
                </div>
                <span class="s-ph__label">Consulting Services</span>
              </div>
            </div>
          </div>
        </div>

        <div class="s-consult-grid">
          {consultingServices.map((card, i) => (
            <a href="/services/consulting" class={`s-consult-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <span class="s-consult-card__icon" set:html={card.icon} />
              <strong class="s-consult-card__title">{card.title}</strong>
              <p class="s-consult-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         TEAM
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-team" aria-labelledby="s-team-h">
      <div class="container">
        <div class="s-team__inner reveal">
          <p class="eyebrow">Behind the Work</p>
          <h2 id="s-team-h" class="s-team__h2">Great LinkedIn doesn't come from templates or automation.</h2>
          <p class="s-team__body">It comes from people who understand B2B, know the platform inside out, and care enough to get the details right. Our team has built LinkedIn presences for companies across manufacturing, tech, healthcare, and professional services. In every time zone that matters.</p>
          <a href="/about" class="btn btn--outline">Meet the team</a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         BOTTOM CTA
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-cta" aria-labelledby="s-cta-h">
      <div class="s-cta__orb s-cta__orb--1" aria-hidden="true"></div>
      <div class="s-cta__orb s-cta__orb--2" aria-hidden="true"></div>
      <div class="container">
        <div class="s-cta__inner reveal">
          <h2 id="s-cta-h" class="s-cta__h2">Ready to get more leads from LinkedIn?</h2>
          <p class="s-cta__sub">Every engagement starts with a conversation. No pitch deck. No pressure. Just a clear look at where you are on LinkedIn and what it would take to grow.</p>
          <a href="/contact" class="btn btn--primary btn--lg">Book a call</a>
        </div>
      </div>
    </section>

  </main>
</Layout>


<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>

  /* ╔═══════════════════════════════════════════╗
     ║  HERO                                     ║
     ╚═══════════════════════════════════════════╝ */
  .s-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .s-hero__bg {
    position: absolute;
    inset: 0;
    background: url('/hero-network.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .s-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.92) 0%,
      rgba(15,23,42, 0.75) 50%,
      rgba(15,23,42, 0.45) 100%
    );
    z-index: 1;
  }

  .s-hero__content {
    max-width: 680px;
  }

  .s-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .s-hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .s-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.68);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--sp-10);
  }

  .s-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  @media (max-width: 640px) {
    .s-hero { padding-block: var(--sp-16) var(--sp-12); }
  }


  /* ╔═══════════════════════════════════════════╗
     ║  INTRO                                    ║
     ╚═══════════════════════════════════════════╝ */
  .s-intro {
    background: var(--white);
    padding-block: var(--sp-16);
  }
  .s-intro__inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .s-intro__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: var(--text);
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-6);
  }
  .s-intro__body {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
  }


  /* ╔═══════════════════════════════════════════╗
     ║  PILLAR SECTIONS (Content / Ads / Consult)║
     ╚═══════════════════════════════════════════╝ */
  .s-pillar {
    background: var(--white);
    position: relative;
    overflow: hidden;
  }
  .s-pillar--dark {
    background: var(--deep-navy);
  }
  .s-pillar__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 60% at 0% 100%, rgba(6,182,212,.08) 0%, transparent 60%),
      radial-gradient(ellipse 40% 50% at 100% 0%, rgba(3,105,161,.06) 0%, transparent 60%);
  }

  .s-pillar__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
    margin-bottom: var(--sp-16);
    position: relative;
    z-index: 1;
  }
  .s-pillar__layout--flip { direction: rtl; }
  .s-pillar__layout--flip .s-pillar__text,
  .s-pillar__layout--flip .s-pillar__visual { direction: ltr; }

  .s-pillar__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    border-radius: var(--r-xl);
    background: linear-gradient(135deg, rgba(3,105,161,.08), rgba(6,182,212,.06));
    color: var(--sky);
    margin-bottom: var(--sp-5);
    transition: transform var(--t-base);
  }
  .s-pillar__icon-wrap:hover { transform: scale(1.05); }
  .s-pillar__icon-wrap--light {
    background: linear-gradient(135deg, rgba(6,182,212,.12), rgba(3,105,161,.08));
    color: var(--cyan);
  }

  .s-pillar__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-6);
  }
  .s-pillar--dark .s-pillar__h2 { color: var(--white); }

  .s-pillar__lead {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-4);
    font-weight: 500;
  }
  .s-pillar--dark .s-pillar__lead { color: rgba(255,255,255,0.68); }

  .s-pillar__body {
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-8);
  }
  .s-pillar--dark .s-pillar__body { color: rgba(255,255,255,0.48); }

  /* Visual placeholder */
  .s-pillar__img-wrap {
    position: relative;
    border-radius: var(--r-2xl);
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--off-white);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
  }
  .s-pillar__img-wrap--dark {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
    box-shadow: var(--shadow-lg);
  }

  .s-pillar__img-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    height: 100%;
