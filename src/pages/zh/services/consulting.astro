---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';
import FAQ from '../../../components/FAQ.astro';
import ContactCTA from '../../../components/ContactCTA.astro';

/* ── Data ───────────────────────────────────────────────── */

const advocacyCards = [
  { title: '员工影响力项目设计与管理', description: '从体系搭建、内容规划到日常运营，全流程都有支持，让参与变得简单可执行。' },
  { title: '员工主页优化', description: '为"赢得客户"而写，不是为"找工作"而写。每个员工的主页其实都是品牌的一个入口。' },
  { title: '新员工入职体系', description: '从第一天起，就把专业的 LinkedIn 形象立起来。' },
];

const brandingCards = [
  { title: '高管主页优化', description: '重新打磨个人资料，把在客户、投资人、潜在人才面前的专业可信度建立起来。不是那种只有老同事才会去点的个人简历。' },
  { title: '高管代运营（Ghostwriting）', description: '用他们自己的声音说他们的专业，按节奏持续输出，保持长期影响力。' },
  { title: 'LinkedIn Live & 粉丝增长', description: 'LinkedIn Live 的互动量可达普通视频的 24 倍。我们按高管各自的专业方向去规划直播内容，帮他们攒起一批有质量的观众。' },
];

const workshops = [
  { tag: '半天', title: 'LinkedIn 基础训练', description: '2026 年了，LinkedIn 到底怎么玩？算法逻辑、信息流规则、什么内容能起量。给从零开始的团队准备，也适合想重新来过的。' },
  { tag: '全天', title: '内容策略与创作大师课', description: '一套能反复用的内容生产流程，团队一直出内容也不会被拖垮。AI 工具怎么用到也会讲。每人带走一份 30 天排期表。' },
  { tag: '全天', title: 'LinkedIn 广告深度课程', description: '受众定向、账户结构、预算怎么分、效果怎么归因。适合那种钱已经在花、但不太清楚花在哪的市场部门。' },
  { tag: '半天', title: '高管个人品牌打造', description: '专门给高管开的小班课。主页怎么搭、多久发一次，还有怎么让人在见你之前就觉得你值得信。' },
];

const stats = [
  { value: '80%', caption: '80% 的 B2B 社交媒体线索来自 LinkedIn' },
  { value: '277%', caption: '获客效率高出 277%（对比 Facebook 和 X 总和）' },
  { value: '2.74%', caption: '2.74% 访客转化率（Facebook 仅 0.77%）' },
  { value: '4/5', caption: '5 位用户中有 4 位参与商业决策' },
  { value: '561%', caption: '员工转发内容带来 +561% 触达增长' },
  { value: '10-15%', caption: 'Lead Gen 表单转化率达 10-15%' },
  { value: '85%', caption: '85% 的 B2B 营销人员认为 LinkedIn ROI 最佳' },
  { value: '28%', caption: '获客成本比 Google Ads 低 28%' },
  { value: '7×', caption: '每周发布可实现 7 倍粉丝增长' },
  { value: '89%', caption: '89% 的 B2B 营销人员正在使用 LinkedIn 做获客' },
];

const faqs = [
  { q: '"员工影响力"到底是什么意思？', a: '就是让你的员工拿自己的 LinkedIn 账号去分享我们策划好的内容。我们负责搭体系、出内容、管流程，员工就一件事：分享。' },
  { q: '多久可以看到效果？', a: '曝光和互动一般一个月就能看到变化。线索转化要久一些，大概 60 到 90 天。具体快慢跟行业有关，也跟团队人数、大家有多积极有关系。第一通电话我们就会聊到这块。' },
  { q: '高管代运营（Ghostwriting）真的是你们全写？', a: '对，全是我们写。先访谈高管，按他们的语气来，初稿发给他们看。没有他们点头的内容，不会发出去。' },
  { q: '我们公司不在美国，也能合作吗？', a: '可以。我们合作的 B2B 公司分布在好几个时区。工作坊线上线下都行，内容服务本来就是远程做的。' },
  { q: '你们服务多大规模的公司？', a: '20 人到 2 万人的都有。员工影响力比较适合中大型 B2B 企业。培训不挑，什么规模都可以做。' },
  { q: '你们帮客户跑 LinkedIn 广告吗？', a: '我们这边的咨询主要围绕自然增长：员工影响力、个人品牌、团队培训这几块。广告打法在"深度拆解"那个工作坊里会讲到。如果你需要有人长期帮你管广告，也可以问问我们。' },
  { q: '你们的培训跟网上免费内容有什么区别？', a: '我们的内容是从真实的 B2B 项目里积累下来的，不是网上随便搜搜就能看到的那种东西。团队带走的是实际成果：改好的主页、一份内容排期表，或者一套能直接跑的投放计划，不是 PPT。' },
  { q: '你们跟踪哪些指标？', a: '粉丝增长、互动率、主页浏览量、从 LinkedIn 过来的网站流量，还有实际的线索数。跟最后签不签单没直接关系的指标，我们不放。' },
  { q: '能先说一下价格吗？', a: '员工影响力、高管代运营（Ghostwriting）、培训三块各有各的报价方式，看你具体要做多少。电话里我们会把费用说清楚，给你出一份明细。不搞那种模模糊糊的报价。' },
  { q: '我们在 LinkedIn 上完全没基础，这有影响吗？', a: '不影响。我们有好几个客户一开始就啥都没有。"入门实操"那个工作坊就是给这种情况准备的，你现在在哪我们就从哪开始。' },
];
---

<Layout
  title="B2B 企业 LinkedIn 咨询：员工影响力 · 高管品牌 · 实战培训"
  description="帮 B2B 企业搞定 LinkedIn 上的获客：员工影响力体系、高管个人品牌运营、团队实战培训。把 LinkedIn 真正用起来。"
  abstract="员工影响力、高管品牌、团队培训，帮 B2B 公司在 LinkedIn 上拿到更多线索。"
  lang="zh"
>
  <NavBar lang="zh" />
  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════ -->
    <section class="c-hero" aria-labelledby="c-hero-h">
      <div class="c-hero__bg" aria-hidden="true"></div>
      <div class="c-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="c-hero__content">
          <p class="eyebrow eyebrow--light reveal">LinkedIn 咨询服务</p>
          <h1 id="c-hero-h" class="c-hero__h1 reveal reveal-delay-1">
            从 LinkedIn 获取更多客户，<span class="text-gradient">而不是更多噪音。</span>
          </h1>
          <p class="c-hero__sub reveal reveal-delay-2">
            公司主页能触达的，只占你真实受众的一小部分。员工的个人账号，才是覆盖市场的关键入口。
          </p>
          <div class="c-hero__actions reveal reveal-delay-3">
            <a href="/zh/contact?intent=call" class="btn btn--primary btn--lg">预约咨询</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         EMPLOYEE ADVOCACY
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-svc" aria-labelledby="c-advocacy-h">
      <div class="container">
        <div class="c-svc__layout">
          <div class="c-svc__text reveal">
            <span class="c-svc__label">员工影响力</span>
            <h2 id="c-advocacy-h" class="c-svc__h2">你的员工，触达范围远超品牌本身。</h2>
            <div class="c-svc__body">
              <p>LinkedIn 这个平台的算法天生就偏心，它把流量往个人号上倾斜，企业主页天然就排在后面。这不是什么 BUG，人家一开始就是这么设计的。</p>
              <p>同一条内容从员工号发出去，互动量是公司主页发的 8 倍。他们的关系网加在一起，比公司的粉丝数大十倍都不止。还有个数字挺有意思，92% 的 B2B 决策者说他们更信员工讲的东西，企业广告反而不太买账。</p>
              <p>这道理讲出来谁都懂。可是真正去做的公司没几个。那些做了的呢？90 天曝光翻了 4.3 倍，管线那边的反馈也是明显在好起来。</p>
              <p>我们负责搭体系、跑流程。你的团队做好分享就行，其他事情不用去想。</p>
            </div>
          </div>
          <div class="c-svc__visual reveal reveal-delay-2">
            <div class="c-svc__img-wrap">
              <img src="/consulting-employee-advocacy.webp" alt="员工在现代办公室里通过 LinkedIn 分享专业内容" class="c-svc__img" width="560" height="420" loading="lazy" />
            </div>
          </div>
        </div>

        <div class="c-cards">
          {advocacyCards.map((card, i) => (
            <div class={`c-card reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
              <span class="c-card__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <strong class="c-card__title">{card.title}</strong>
              <p class="c-card__desc">{card.description}</p>
            </div>
          ))}
        </div>

        <div class="c-svc__cta reveal">
          <a href="/zh/contact?intent=call" class="btn btn--primary btn--lg">启动员工影响力项目</a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         PERSONAL BRANDING
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-svc c-svc--alt" aria-labelledby="c-branding-h">
      <div class="container">
        <div class="c-svc__layout c-svc__layout--flip">
          <div class="c-svc__text reveal">
            <span class="c-svc__label">高管个人品牌</span>
            <h2 id="c-branding-h" class="c-svc__h2">客户会先看你这个人，再看你的网站。</h2>
            <div class="c-svc__body">
              <p>82% 的 B2B 买家说过，如果一家公司的高管经常在 LinkedIn 上发东西，他们对这家公司的好感度会高出不少。64% 的人也提到过，他们宁可花时间看 CEO 自己写的一篇有想法的内容，也不想看公司主页推过来的产品广告。</p>
              <p>机会就在那摆着，可大多数高管团队接不住这个球。原因其实就一个：谁有空每个礼拜写三条？</p>
              <p>所以这事我们来。和你的高管聊，用他们的方式来写，保证他们一直出现在该出现的人的 feed 里。整个过程不需要他们花哪怕一个小时。</p>
            </div>
          </div>
          <div class="c-svc__visual reveal reveal-delay-2">
            <div class="c-svc__img-wrap">
              <img src="/consulting-personal-branding.webp" alt="企业高管在办公室查看 LinkedIn 互动数据" class="c-svc__img" width="560" height="420" loading="lazy" />
            </div>
          </div>
        </div>

        <div class="c-cards">
          {brandingCards.map((card, i) => (
            <div class={`c-card reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
              <span class="c-card__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <strong class="c-card__title">{card.title}</strong>
              <p class="c-card__desc">{card.description}</p>
            </div>
          ))}
        </div>

        <div class="c-svc__cta reveal">
          <a href="/zh/contact?intent=call" class="btn btn--primary btn--lg">打造高管影响力</a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         TRAINING
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-training" aria-labelledby="c-training-h">
      <div class="c-training__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="c-training__head reveal">
          <span class="c-training__label">团队培训</span>
          <h2 id="c-training-h" class="c-training__h2">你的团队每天都在用 LinkedIn，但他们真的用对了吗？</h2>
          <div class="c-training__intro">
            <p>去年有 68% 的 B2B 营销人加大了在 LinkedIn 上的投入。但问题在于，这里面绝大部分人根本就没经过什么像样的培训。</p>
            <p>效果嘛，一看就知道：帖子全长一个样，主页空得跟没有一样，广告预算花了一堆，回报却讲不出来。另一边，经过专业培训的销售人员完成指标的可能性高出 51%。</p>
            <p>我们的工作坊跟那种看完就忘的网课不是一回事，进来就是干活的。结束的时候团队手里是有东西带走的：改好的主页、一份内容排期表，或者一套礼拜一就能直接跑的广告策略。</p>
          </div>
        </div>

        <div class="c-workshop-grid">
          {workshops.map((w, i) => (
            <div class={`c-workshop reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <span class={`c-workshop__tag ${w.tag === '半天' ? 'c-workshop__tag--cyan' : 'c-workshop__tag--blue'}`}>{w.tag}</span>
              <strong class="c-workshop__title">{w.title}</strong>
              <p class="c-workshop__desc">{w.description}</p>
            </div>
          ))}
        </div>

        <div class="c-training__cta reveal">
          <a href="/zh/contact?intent=call" class="btn btn--primary btn--lg">预约培训工作坊</a>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         LINKEDIN BY THE NUMBERS
         ═══════════════════════════════════════════════════════ -->
    <section class="section c-num" aria-labelledby="c-num-h">
      <div class="c-num__glow" aria-hidden="true"></div>
      <div class="container">
        <div class="c-num__head reveal">
          <p class="eyebrow eyebrow--light">看看数据</p>
          <h2 id="c-num-h" class="c-num__h2">为什么非得是 LinkedIn？数字会说话。</h2>
          <p class="c-num__intro">这些数据不是我们攒的，出处是 LinkedIn 官方、HubSpot、爱德曼和一些独立 B2B 研究机构。放在这是因为总有客户问"为什么一定要做 LinkedIn"，答案说来说去每次就那几句话。</p>
        </div>

        <div class="c-num__grid">
          {stats.map((s, i) => (
            <div class={`c-num-card reveal${i > 0 ? ` reveal-delay-${(i % 4) + 1}` : ''}`}>
              <span class="c-num-card__value">{s.value}</span>
              <p class="c-num-card__caption">{s.caption}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <FAQ heading="常见问题" faqs={faqs} background="var(--off-white)" cta={{ text: '预约咨询', href: '/zh/contact' }} id="c-faq" />


    <ContactCTA lang="zh" />

  </main>
</Layout>


<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>
  /* ── shared placeholder ── */
  .ph{display:none;position:absolute;inset:0;flex-direction:column;align-items:center;justify-content:center;gap:var(--sp-3);background:linear-gradient(135deg,var(--off-white),var(--border));border-radius:var(--r-xl)}
  .ph span{font-size:var(--fs-xs);color:var(--text-3);letter-spacing:.06em;text-transform:uppercase;font-weight:500}


  /* ╔═══════════════════════════════════════════╗
     ║  HERO                                     ║
     ╚═══════════════════════════════════════════╝ */
  .c-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .c-hero__bg {
    position: absolute;
    inset: 0;
    background: url('/consulting-hero.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .c-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.92) 0%,
      rgba(15,23,42, 0.75) 50%,
      rgba(15,23,42, 0.45) 100%
    );
    z-index: 1;
  }

  .c-hero__content {
    max-width: 680px;
  }

  .c-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .c-hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .c-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.68);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--sp-10);
  }

  .c-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  @media (max-width: 640px) {
    .c-hero { padding-block: var(--sp-16) var(--sp-12); }
  }


  /* ╔═══════════════════════════════════════════╗
     ║  SERVICE SECTIONS (Advocacy + Branding)   ║
     ╚═══════════════════════════════════════════╝ */
  .c-svc{background:var(--white)}
  .c-svc--alt{background:var(--off-white)}

  .c-svc__layout{
    display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-16);
    align-items:center;margin-bottom:var(--sp-12);
  }
  .c-svc__layout--flip{direction:rtl}
  .c-svc__layout--flip .c-svc__text,
  .c-svc__layout--flip .c-svc__visual{direction:ltr}

  .c-svc__label{
    display:inline-block;
    font-family:var(--font-display);font-size:var(--fs-xl);font-weight:600;
    color:var(--blue);letter-spacing:-.01em;
    margin-bottom:var(--sp-3);
    padding-bottom:var(--sp-2);
    border-bottom:3px solid var(--cyan);
  }

  .c-svc__h2{
    font-family:var(--font-display);font-size:clamp(1.75rem,3.5vw,2.5rem);
    font-weight:700;color:var(--text);line-height:1.18;letter-spacing:-.01em;
    margin-top:var(--sp-4);margin-bottom:var(--sp-8);
  }

  .c-svc__body{display:flex;flex-direction:column;gap:var(--sp-4)}
  .c-svc__body p{font-size:var(--fs-md);color:var(--text-2);line-height:1.75}

  .c-svc__img-wrap{
    position:relative;border-radius:var(--r-xl);overflow:hidden;
    aspect-ratio:4/3;background:var(--off-white);border:1px solid var(--border);
    box-shadow:var(--shadow-lg);
  }
  .c-svc__img{width:100%;height:100%;object-fit:cover;display:block}

  /* Service cards */
  .c-cards{
    display:grid;grid-template-columns:repeat(3,1fr);gap:var(--sp-5);
    margin-bottom:var(--sp-8);
  }

  .c-card{
    position:relative;padding:var(--sp-8) var(--sp-6);
    background:var(--white);border:1px solid var(--border);
    border-radius:var(--r-xl);overflow:hidden;
    transition:border-color var(--t-fast),box-shadow var(--t-fast),transform var(--t-base);
  }
  .c-svc--alt .c-card{background:var(--white)}
  .c-card:hover{border-color:var(--border-2);box-shadow:var(--shadow-md);transform:translateY(-3px)}

  .c-card__num{
    position:absolute;top:var(--sp-3);right:var(--sp-5);
    font-family:var(--font-display);font-size:var(--fs-5xl);font-weight:700;
    color:rgba(3,105,161,.05);line-height:1;pointer-events:none;
  }
  .c-card__title{display:block;font-size:var(--fs-base);font-weight:600;color:var(--text);margin-bottom:var(--sp-3);position:relative;z-index:1}
  .c-card__desc{font-size:var(--fs-sm);color:var(--text-2);line-height:1.7;position:relative;z-index:1}

  .c-svc__cta{display:flex;justify-content:center;padding-top:var(--sp-4)}


  /* ╔═══════════════════════════════════════════╗
     ║  TRAINING                                 ║
     ╚═══════════════════════════════════════════╝ */
  .c-training{background:var(--deep-navy);position:relative;overflow:hidden}
  .c-training__bg{
    position:absolute;inset:0;pointer-events:none;
    background:
