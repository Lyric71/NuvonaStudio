---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';
import FAQ from '../../../components/FAQ.astro';

const capabilities = [
  {
    title: '广告架构设计（Campaign Architecture）',
    body: `围绕你的转化漏斗搭建广告结构。
每一种形式、每一类受众、每一条信息，都有明确角色。`,
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
    </svg>`,
  },
  {
    title: '受众定向',
    body: '基于职位、资历、公司名称、公司规模、行业和技能，精准构建目标人群。你特别想拿下的那几家客户，直接上 ABM 按名单投就行，广告只出现在能拍板那个人面前。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
    </svg>`,
  },
  {
    title: '广告创意',
    body: `从文案到设计全部负责。
每一条广告，都直击你的目标客户的痛点。`,
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    title: '全格式执行',
    body: '所有 LinkedIn 广告形式整合到一个统一系统里，协同运行。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 6h16M4 10h16M4 14h16M4 18h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
  },
  {
    title: 'AI 优化',
    body: '用 AI 生成并测试不同文案、信息组合和创意，在不同受众之间持续优化表现。预算还没怎么花，基本就能看出哪套东西对哪类职位最管用，效果一周比一周好。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    title: 'CRM 打通的数据报告',
    body: `我们关注的是销售管道，不是曝光量。
所有数据直接对应你的业务增长。每周报告会写清楚钱花去了哪里、试了哪些方向、转化情况怎么样，不堆术语，也不拿曝光量来充数。`,
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M7 17V13M12 17V9M17 17V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
  },
];

const adFormats = [
  {
    title: '信息流广告 (Sponsored Content)',
    body: 'LinkedIn 广告的核心形式，包含多种子格式，覆盖不同内容与目标场景。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
    image: '/images/advertising-sponsored-content.webp',
    imageAlt: '信息流 LinkedIn 广告服务示意',
  },
  {
    title: '站内私信广告 (Sponsored Messaging)',
    body: '通过 Message Ads 和 Conversation Ads，把信息直接送到目标客户的 LinkedIn 收件箱里。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
    image: '/images/advertising-sponsored-messaging.webp',
    imageAlt: '站内私信 LinkedIn 广告服务示意',
  },
  {
    title: '动态广告 (Dynamic Ads)',
    body: '基于用户的 LinkedIn 资料数据自动个性化展示，提升相关性和点击率。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
    image: '/images/advertising-dynamic-ads.webp',
    imageAlt: '动态 LinkedIn 广告服务示意',
  },
  {
    title: '文字广告 (Text Ads)',
    body: '桌面侧边栏的自助式点击付费广告。成本低、门槛低，适合规模化测试。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 6h16M4 10h16M4 14h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <rect x="16" y="14" width="5" height="7" rx="1" stroke="currentColor" stroke-width="1.6"/>
    </svg>`,
    image: '/images/advertising-text-ads.webp',
    imageAlt: '文字 LinkedIn 广告服务示意',
  },
  {
    title: '站内获客表单 (Lead Gen Forms)',
    body: '内嵌在 LinkedIn 里的预填表单。用户只需两步就能提交信息，最大限度降低转化阻力。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="5" y="3" width="14" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M9 7h6M9 11h6M9 15h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
    image: '/images/advertising-lead-gen-forms.webp',
    imageAlt: '站内获客表单示意',
  },
];

const differentiators = [
  {
    title: '我们拿到了 LinkedIn 广告官方认证',
    body: `不是挂在网站上充门面的。意思是我们团队通过了 LinkedIn 官方在
广告策略、广告形式、受众定向、数据衡量和优化方面的严格评估。说白了，你对接的团队是被 LinkedIn 自己认可过的。`,
  },
  {
    title: '我们按"漏斗"做投放，不是按"广告形式"',
    body: `从认知、兴趣到转化，
我们搭建完整的全漏斗体系，让每一种广告形式各司其职。`,
  },
  {
    title: '我们关注收入，而不是曝光',
    body: `展示次数再高也不能帮你回款。把 LinkedIn 广告跟你的 CRM 打通之后，
每一条广告怎么转化为销售线索和业务机会，看得一清二楚。每周做优化调整时，团队只盯一件事：你销售那边最关心的那几个指标。`,
  },
  {
    title: '先测试，再放量',
    body: `借助 AI，我们在正式投放前生成并测试多版本文案、标题和 CTA，
把预算压在已经验证有效的方案上。等你想放量的时候，哪些内容对目标人群管用，数据早就告诉我们了。`,
  },
  {
    title: '从策略到执行，一体化管理',
    body: `策略、创意、定向、上线、优化、报告，
一个团队、一个系统、全流程负责。`,
  },
  {
    title: '我们专注 B2B',
    body: `不做电商广告，也不做"顺带服务"。
LinkedIn B2B 广告就是我们的全部。销售周期长、采购决策要过好几个人、一条线索 200 美金但合同可能值 20 万美金，这种项目我们做得太多了。`,
  },
];

const steps = [
  {
    num: '01',
    title: '需求洞察',
    body: '把你的业务、目标客户和销售管道目标摸清楚。',
  },
  {
    num: '02',
    title: '策略搭建',
    body: '设计广告结构，构建目标受众，写高转化的广告文案。',
  },
  {
    num: '03',
    title: '上线与测试',
    body: '启动广告投放，立刻展开多维度的测试和验证。',
  },
  {
    num: '04',
    title: '优化与放大',
    body: '盯着真正带来销售线索和管道增长的数据，每周持续优化、放大效果。',
  },
];

const stats = [
  { number: '121%', label: '投资回报率（ROAS）', note: '高于 Google 搜索（67%）和 Meta（51%）', source: '来源：Dreamdata 2026 年基准报告' },
  { number: '6.1%', label: '转化率', note: '美国 LinkedIn 平均转化率，对比 Google 搜索 3.75%' },
  { number: '80%', label: 'B2B 社交媒体线索', note: '来自 LinkedIn' },
  { number: '41%', label: '广告预算占比', note: 'LinkedIn 在 B2B 广告总预算中的份额' },
  { number: '10–13%', label: '表单转化率', note: 'Lead Gen 表单转化率，远高于传统落地页（2.35%）' },
  { number: '4/5', label: '位用户中 4 位参与决策', note: 'LinkedIn 用户高度集中于决策层' },
  { number: '211', label: '天', note: '平均成交周期 211 天。典型 B2B 从首次接触到成交的时间。' },
  { number: '+33%', label: '购买意向提升', note: '在 LinkedIn 投放广告的品牌，购买意向显著提高。' },
];

const faqs = [
  {
    q: '"LinkedIn 广告认证"是什么？',
    a: '就是团队通过了 LinkedIn 官方出的专业考核，内容涵盖投放策略、广告格式、受众定向、效果衡量、优化方法五个方面。注意这不是什么第三方认证，是 LinkedIn 自己定的标准。市面上拿到这个的代理机构其实不算特别多。',
  },
  {
    q: '能投哪几种广告格式？',
    a: '五种都投：信息流广告（八个子格式全覆盖）、私信广告、动态广告、文字广告、Lead Gen Forms。是当成一个整体来投的，不是拆开来各跑各。',
  },
  {
    q: '策略和创意也管吗？',
    a: '管。从受众分析、目标确认，到出架构、写文案、做素材、上线、测试、优化，全部一个团队做完。',
  },
  {
    q: '怎么看投放效果？',
    a: '看商机数据。每周出一份优化进展的简报，每月一份完整的绩效报告。钱花到了哪里、试了什么方向、哪些打法的效果比较好、下个月怎么调整，报告里面都有。我们比较反感堆术语、拿展示量凑数这种做法。',
  },
  {
    q: 'AI 用在哪？',
    a: '主要是创意测试这块。AI 帮我们快速生成大批量的文案和素材变体，然后分群跑测试。这样预算还没怎么花，数据就出来了，知道什么内容对什么职位管用。正式大规模投放的时候效率高很多。',
  },
  {
    q: '最低预算要求是多少？',
    a: '月度广告预算 5,000 美元起。说实话低于这个数，LinkedIn 不一定是最划算的渠道。我们不会为了签单不跟你讲这些。',
  },
  {
    q: '多久能看到效果？',
    a: '一般头 30 天就开始有合格线索了。但你要知道，LinkedIn 本质上是个长线渠道，B2B 平均成交周期是 211 天，指望一两个月就大量签约不现实。好在数据会越跑越准，后面的投产比跟前面比完全不是一回事。',
  },
  {
    q: '公司主页还没怎么做，能投吗？',
    a: '能投。不过效果多少会打一些折扣，因为看完广告的人经常会顺手点进公司主页再决定下一步。需要的话，启动投放之前我们可以帮你把主页先整理一下。',
  },
  {
    q: '能定向到具体某几家公司或某个职位吗？',
    a: '可以。LinkedIn 的定向精度在 B2B 平台里是最高的，职位、层级、公司名、规模、行业、技能标签都可以圈。把预算花在真正有采购权的那些人身上，这是我们比较擅长的事。',
  },
  {
    q: '一般服务哪些行业的客户？',
    a: '科技、制造、专业服务、SaaS、医疗健康都做过。其实行业不是最关键的因素，关键看两条：你的目标客户在 LinkedIn 上活不活跃，单笔合同能不能到 2 万美元以上。这两条满足的话，投放基本都能回本。',
  },
  {
    q: '怎么开始？',
    a: '约个 30 分钟通话就可以了。了解一下你目前在 LinkedIn 上的状况和你的目标，然后我们直接告诉你适不适合投。不做 PPT 演示，不搞推销那套。',
  },
];
---

<Layout
  title="LinkedIn 广告服务 | B2B 企业获客"
  description="LinkedIn 五种广告格式统一管理，面向 B2B 企业的获客体系。精准定向目标决策者，AI 辅助测试优化，按商机数据衡量投放效果。"
  abstract="整合 LinkedIn 全部广告格式，为 B2B 企业搭建系统化的获客投放体系。按商机和营收衡量每一分钱的效果。"
  lang="zh"
>
  <NavBar lang="zh" />
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="ads-hero" aria-labelledby="ads-heading">
      <div class="ads-hero__bg" aria-hidden="true"></div>
      <div class="ads-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="ads-hero__content">
          <p class="eyebrow eyebrow--light reveal">LinkedIn 广告服务</p>
          <h1 id="ads-heading" class="ads-hero__h1 reveal reveal-delay-1">
            每一次点击，离签单更近<span class="text-gradient">一步。</span>
          </h1>
          <p class="ads-hero__sub reveal reveal-delay-2">
            你的买家在 LinkedIn 上，这点不用多说。问题是怎么让广告出现在该出现的人面前，在他愿意听的时候说他在意的事，然后把这份注意力转成你销售团队能跟得下去的单子。
          </p>
          <div class="ads-hero__actions reveal reveal-delay-3">
            <a href="/zh/contact?intent=call" class="btn btn--primary btn--lg">预约咨询</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── The Problem ─────────────────────────────────────── -->
    <section class="section problem" aria-labelledby="problem-heading">
      <div class="container">
        <div class="problem__inner">
          <div class="problem__text">
            <h2 id="problem-heading" class="problem__h2 reveal">多数 B2B 公司的 LinkedIn 广告费，花得不值</h2>
            <div class="problem__body">
              <p class="problem__p reveal">随手推一条帖子，受众选个大概，然后等着看运气好不好。</p>
              <p class="problem__p reveal">然后呢？点击成本很高，进来的线索质量一般，最后也说不清到底哪笔钱带来了哪笔生意。</p>
              <p class="problem__p reveal">LinkedIn 广告本身肯定是有用的。但它得当成一套体系来经营才行，东拼西凑投几组广告想碰出效果，说难听点，就是在赌。</p>
              <p class="problem__p problem__p--highlight reveal">搭这套体系，就是我们每天在做的事。</p>
            </div>
          </div>
          <div class="problem__visual reveal reveal-delay-2" aria-hidden="true">
            <div class="problem__graphic">
              <div class="problem__bar problem__bar--1"><span>预算浪费</span></div>
              <div class="problem__bar problem__bar--2"><span>低质量线索</span></div>
              <div class="problem__bar problem__bar--3"><span>效果无法追踪</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── What We Do ──────────────────────────────────────── -->
    <section class="section what-we-do" aria-labelledby="wwd-heading">
      <div class="container">
        <div class="wwd__head reveal">
          <p class="eyebrow">服务内容</p>
          <h2 id="wwd-heading" class="wwd__h2">整套 LinkedIn 广告体系，由我们来建、来跑</h2>
          <p class="wwd__intro">不是给你一份策略 PPT 就完事的。从受众分析、广告搭建到日常优化、最后出商机，整个流程团队一手包办。我们持有<strong>LinkedIn 广告官方认证</strong>，投放策略、定向、优化都通过了 LinkedIn 自己的专业考核。</p>
        </div>

        <div class="wwd__grid">
          {capabilities.map((cap, i) => (
            <div class={`wwd-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="wwd-card__top">
                <span class="wwd-card__icon" aria-hidden="true" set:html={cap.icon} />
              </div>
              <strong class="wwd-card__title">{cap.title}</strong>
              <p class="wwd-card__body">{cap.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Ad Formats We Run ───────────────────────────────── -->
    <section class="section formats-section" aria-labelledby="formats-heading">
      <div class="container">
        <div class="formats__head reveal">
          <p class="eyebrow">广告格式</p>
          <h2 id="formats-heading" class="formats__h2">五种格式，一支认证团队，一个体系</h2>
          <p class="formats__intro">LinkedIn 一共五种核心广告格式，在销售漏斗的不同阶段各有各的用处。多数代理投一两种就差不多了。我们是五种一起上的，当成一个联动整体来跑，因为想让一个完全不认识你的人最后掏钱签合同，光靠一种广告格式做不到。团队持有 LinkedIn 广告认证，哪个阶段该上哪种格式我们心里清楚。</p>
        </div>

        {adFormats.map((fmt, i) => (
          <div class={`fmt-block${i % 2 === 1 ? ' fmt-block--flip' : ''} reveal`} id={`fmt-${i}`}>
            <div class="fmt-block__text">
              <div class="fmt-block__label">
                <span class="fmt-block__icon" aria-hidden="true" set:html={fmt.icon} />
              </div>
              <h3 class="fmt-block__title">{fmt.title}</h3>
              <p class="fmt-block__body">{fmt.body}</p>
            </div>
            <div class="fmt-block__visual">
              <div class="fmt-block__img-wrap">
                <img
                  src={fmt.image}
                  alt={fmt.imageAlt}
                  class="fmt-block__img"
                  width="560"
                  height="380"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Why Work With Us ────────────────────────────────── -->
    <section class="section why-us" aria-labelledby="why-heading">
      <div class="why-us__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="why__head reveal">
          <p class="eyebrow eyebrow--light">为什么选我们</p>
          <h2 id="why-heading" class="why__h2">跟别家比，差别在哪</h2>
        </div>

        <div class="why__layout">

          <!-- Left: Visual column -->
          <div class="why__visual reveal">
            <div class="why__photo-wrap">
              <img
                src="/images/advertising-team.webp"
                alt="Nuvora Studio 团队"
                class="why__photo"
                width="480"
                height="560"
                loading="lazy"
              />
            </div>

            <!-- Certification badge -->
            <div class="why__cert">
