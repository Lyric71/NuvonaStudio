---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';

import ContactCTA from '../../../components/ContactCTA.astro';

/* ── 数据 ──────────────────────────────────────────── */

const contentServices = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="7" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.6"/><line x1="9" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: '企业主页全托管',
    text: '公司主页管理，打造并全程管理你的全球第一印象',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: '内容生产与编辑',
    text: '覆盖所有形式、每周持续输出、面向全球市场。',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'LinkedIn通讯（Newsletter）',
    text: '与最关键的专业人群建立直接联系。',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: 'LinkedIn活动（Events）',
    text: 'LinkedIn上互动率最高的形式，帮你稳妥落地执行。',
  },
];

const adFormats = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="3" width="20" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: '赞助内容（Sponsored Content）',
    text: '把你最优质的内容，精准投放到真正有购买决策权的人面前',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="1.6"/><polyline points="22,6 12,13 2,6" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: '赞助消息（Sponsored Messaging）',
    text: '专为B2B打造的InMail营销活动',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="1.6"/><path d="M3 21v-2a7 7 0 0 1 7-7h4a7 7 0 0 1 7 7v2" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: '动态广告（Dynamic Ads）',
    text: '让潜在客户看到自己的姓名和头像，与您的品牌同框出现',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 8h8M8 12h6M8 16h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: '文字广告（Text Ads）',
    text: '简单、低成本、易于规模化投放。',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 11l3 3L22 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: '线索收集表单（Lead Gen Forms）',
    text: '一键提交，客户信息直接进入你的系统。无需跳转页面，零摩擦转化',
  },
];

const consultingServices = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.6"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: '员工影响力（Employee Advocacy）',
    text: '员工拥有公司主页永远无法触达的人脉网络。',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: '个人品牌（Personal Branding）',
    text: '在潜在客户访问公司主页之前，他们早已搜索过您的 CEO',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2V3z" stroke="currentColor" stroke-width="1.6"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7V3z" stroke="currentColor" stroke-width="1.6"/></svg>`,
    title: '培训（Training）',
    text: '从个人资料优化到内容策略与数据分析，提供实操型培训',
  },
];
---

<Layout
  lang="zh"
  title="LinkedIn获客我们的服务 | LinkedIn内容服务、LinkedIn广告服务、策略咨询"
  description="帮B2B企业把LinkedIn这块做起来。LinkedIn内容服务、LinkedIn广告服务、策略咨询三条线，别的平台不碰，就做LinkedIn。"
  abstract="只做LinkedIn的B2B获客我们的服务。LinkedIn内容服务、LinkedIn广告服务、策略咨询，帮你在LinkedIn上拿到更多商机。"
>
  <NavBar lang="zh" />
  <main id="main-content">

    <!-- ═══════════════════════════════════════════════════════
         首屏
         ═══════════════════════════════════════════════════════ -->
    <section class="s-hero" aria-labelledby="s-hero-h">
      <div class="s-hero__bg" aria-hidden="true"></div>
      <div class="s-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="s-hero__content">
          <p class="eyebrow eyebrow--light reveal">我们的服务</p>
          <h1 id="s-hero-h" class="s-hero__h1 reveal reveal-delay-1">
            我们帮你做大LinkedIn影响力，<span class="text-gradient">并转化为客户线索。</span>
          </h1>
          <p class="s-hero__sub reveal reveal-delay-2">
            大多数B2B公司都知道，应该在LinkedIn上投入更多精力。但他们缺少时间、团队，或真正做好的能力。我们来解决
          </p>
          <div class="s-hero__actions reveal reveal-delay-3">
            <a href="/zh/contact" class="btn btn--primary btn--lg">预约通话</a>
            <a href="#s-content" class="btn btn--outline-white btn--lg">查看服务</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         导语
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-intro" aria-labelledby="s-intro-h">
      <div class="container">
        <div class="s-intro__inner reveal">
          <h2 id="s-intro-h" class="s-intro__h2">三大服务模块，让LinkedIn成为你获取客户的核心渠道</h2>
          <p class="s-intro__body">一个半成品的公司主页。一个停留在2021年的个人资料。本该转化，却始终沉睡的潜力来找我们的客户，一开始差不多都是这样一个状态。</p>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         内容我们的服务
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar" id="s-content" aria-labelledby="s-content-h">
      <div class="container">
        <div class="s-pillar__layout">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            </div>
            <h2 id="s-content-h" class="s-pillar__h2">LinkedIn内容服务</h2>
            <a href="/zh/services/content" class="btn btn--primary">和我们聊聊你的内容策略</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap">
              <img src="/services-content.webp" alt="LinkedIn上的轮播帖子、长文和Newsletter内容示例" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-cards">
          {contentServices.map((card, i) => (
            <a href="/zh/services/content" class={`s-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="s-card__top">
                <span class="s-card__icon" set:html={card.icon} />
              </div>
              <strong class="s-card__title">{card.title}</strong>
              <p class="s-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         广告我们的服务
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar s-pillar--dark" id="s-advertising" aria-labelledby="s-ads-h">
      <div class="s-pillar__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="s-pillar__layout s-pillar__layout--flip">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap s-pillar__icon-wrap--light">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/></svg>
            </div>
            <h2 id="s-ads-h" class="s-pillar__h2">LinkedIn广告服务</h2>
            <a href="/zh/services/advertising" class="btn btn--primary">开始获取高质量客户线索</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap s-pillar__img-wrap--dark">
              <img src="/services-advertising.webp" alt="团队在分析LinkedIn广告后台的投放数据" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-ad-grid">
          {adFormats.map((card, i) => (
            <a href="/zh/services/advertising" class={`s-ad-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 4)}` : ''}`}>
              <span class="s-ad-card__icon" set:html={card.icon} />
              <strong class="s-ad-card__title">{card.title}</strong>
              <p class="s-ad-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         咨询与培训
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-pillar" id="s-consulting" aria-labelledby="s-consult-h">
      <div class="container">
        <div class="s-pillar__layout">
          <div class="s-pillar__text reveal">
            <div class="s-pillar__icon-wrap">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2V3z" stroke="currentColor" stroke-width="1.6"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7V3z" stroke="currentColor" stroke-width="1.6"/></svg>
            </div>
            <h2 id="s-consult-h" class="s-pillar__h2">LinkedIn 咨询服务
让我们一起探讨，您的团队真正需要什么</h2>
            <a href="/zh/services/consulting" class="btn btn--primary">说说你们的情况</a>
          </div>
          <div class="s-pillar__visual reveal reveal-delay-2">
            <div class="s-pillar__img-wrap">
              <img src="/services-consulting.webp" alt="LinkedIn培训现场，讲师在给一群管理者做实操演示" width="1024" height="1024" loading="lazy" class="s-pillar__img" />
            </div>
          </div>
        </div>

        <div class="s-consult-grid">
          {consultingServices.map((card, i) => (
            <a href="/zh/services/consulting" class={`s-consult-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <span class="s-consult-card__icon" set:html={card.icon} />
              <strong class="s-consult-card__title">{card.title}</strong>
              <p class="s-consult-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         团队
         ═══════════════════════════════════════════════════════ -->
    <section class="section s-team" aria-labelledby="s-team-h">
      <div class="container">
        <div class="s-team__inner reveal">
          <p class="eyebrow">团队</p>
          <h2 id="s-team-h" class="s-team__h2">优秀的 LinkedIn 运营，不来自模板或自动化工具</h2>
          <p class="s-team__body">而是来自真正理解 B2B、深谙平台机制，并且注重每一个细节的人。</p>
          <a href="/zh/about" class="btn btn--outline">认识我们的团队</a>
        </div>
      </div>
    </section>


    <ContactCTA lang="zh" />

  </main>
</Layout>


<!-- ═══════════════════════════════════════════════════════════
     STYLES
     ═══════════════════════════════════════════════════════════ -->
<style>

  /* ╔═══════════════════════════════════════════╗
     ║  HERO                                     ║
     ╚═══════════════════════════════════════════╝ */
  .s-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .s-hero__bg {
    position: absolute;
    inset: 0;
    background: url('/services-hero.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .s-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.92) 0%,
      rgba(15,23,42, 0.75) 50%,
      rgba(15,23,42, 0.45) 100%
    );
    z-index: 1;
  }

  .s-hero__content {
    max-width: 680px;
  }

  .s-hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .s-hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .s-hero__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.68);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--sp-10);
  }

  .s-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  @media (max-width: 640px) {
    .s-hero { padding-block: var(--sp-16) var(--sp-12); }
  }


  /* ╔═══════════════════════════════════════════╗
     ║  INTRO                                    ║
     ╚═══════════════════════════════════════════╝ */
  .s-intro {
    background: var(--white);
    padding-block: var(--sp-16);
  }
  .s-intro__inner {
    max-width: 780px;
    margin-inline: auto;
    text-align: center;
  }
  .s-intro__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 600;
    color: var(--text);
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-6);
  }
  .s-intro__body {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
  }


  /* ╔═══════════════════════════════════════════╗
     ║  PILLAR SECTIONS (内容 / 广告 / 咨询)      ║
     ╚═══════════════════════════════════════════╝ */
  .s-pillar {
    background: var(--white);
    position: relative;
    overflow: hidden;
  }
  .s-pillar--dark {
    background: var(--deep-navy);
  }
  .s-pillar__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 60% at 0% 100%, rgba(6,182,212,.08) 0%, transparent 60%),
      radial-gradient(ellipse 40% 50% at 100% 0%, rgba(3,105,161,.06) 0%, transparent 60%);
  }

  .s-pillar__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
    margin-bottom: var(--sp-16);
    position: relative;
    z-index: 1;
  }
  .s-pillar__layout--flip { direction: rtl; }
  .s-pillar__layout--flip .s-pillar__text,
  .s-pillar__layout--flip .s-pillar__visual { direction: ltr; }

  .s-pillar__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px; height: 56px;
    border-radius: var(--r-xl);
    background: linear-gradient(135deg, rgba(3,105,161,.08), rgba(6,182,212,.06));
    color: var(--sky);
    margin-bottom: var(--sp-5);
    transition: transform var(--t-base);
  }
  .s-pillar__icon-wrap:hover { transform: scale(1.05); }
  .s-pillar__icon-wrap--light {
    background: linear-gradient(135deg, rgba(6,182,212,.12), rgba(3,105,161,.08));
    color: var(--cyan);
  }

  .s-pillar__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.01em;
    margin-bottom: var(--sp-6);
  }
  .s-pillar--dark .s-pillar__h2 { color: var(--white); }

  .s-pillar__lead {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-4);
    font-weight: 500;
  }
  .s-pillar--dark .s-pillar__lead { color: rgba(255,255,255,0.68); }

  .s-pillar__body {
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-8);
  }
  .s-pillar--dark .s-pillar__body { color: rgba(255,255,255,0.48); }

  /* Visual images */
  .s-pillar__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .s-pillar__img-wrap {
    position: relative;
    border-radius: var(--r-2xl);
    overflow: hidden;
    aspect-ratio: 4/3;
    background: var(--off-white);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
  }
  .s-pillar__img-wrap--dark {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
    box-shadow: var(--shadow-lg);
  }

  .s-pillar__img-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    height: 100%;
    background: linear-gradient(135deg, var(--off-white) 0%, var(--border) 100%);
  }
  .s-pillar__img-ph--dark {
    background: linear-gradient(135deg, rgba(15,23,42,0.9) 0%, rgba(3,105,161,0.20) 100%);
  }

  .s-ph__icon {
    transition: transform var(--t-base);
  }
  .s-pillar__img-wrap:hover .s-ph__icon {
    transform: scale(1.05);
  }

  .s-ph__label {
    font-size: var(--fs-xs);
    color: var(--text-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .s-ph__label--dark {
    color: rgba(255,255,255,0.30);
