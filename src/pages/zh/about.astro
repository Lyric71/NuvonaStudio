---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import FAQ from '../../components/FAQ.astro';

/* ── Data ───────────────────────────────────────────────── */

const values = [
  {
    title: '谁出的方案谁来干',
    body: '帮你写策略的人，后面也是他来盯项目。策略和执行分成两拨人那种搞法我们不用，在别的agency见过太多翻车的了。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
  },
  {
    title: '数据不好看也照说',
    body: '我们不会为了月报好看去凑数字的。投放效果不行就是不行，你会比你老板更早知道这件事。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="currentColor" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: '内容本身得值得看',
    body: '不管是帖子还是广告素材，发之前我们内部会先过一遍，就问一个事：别人看到这个会不会愿意停下来？如果自己都觉得一般，那就不发。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.6"/></svg>`,
  },
];

const whyWorkWithUs = [
  {
    title: '这里只做LinkedIn',
    body: '抖音不做，小红书不做，微信也不做。团队所有人就扎在LinkedIn这一个平台上面，策略内容投放全在这。我们就是比较偏科的那种团队，但偏的这一科确实比较深。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M8 12h8M12 8v8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
  },
  {
    title: '对接你的人就是干活的人',
    body: '中间不加人。跟你聊需求的那位，后面写东西、盯投放的也是他，不存在brief传了三手然后出来的东西跟你当初说的完全是两码事。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.6"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
  },
  {
    title: '全球都有人，写出来不像翻译',
    body: '香港、法国、菲律宾、中国大陆都有团队成员。做LinkedIn策略和投放的是核心，后面还有双语写手、设计和做数据分析的。10多种语言的内容出过了，到目前还没有客户跟我们说过语感有问题的。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M3.5 9h17M3.5 15h17" stroke="currentColor" stroke-width="1.6"/><ellipse cx="12" cy="12" rx="4" ry="9" stroke="currentColor" stroke-width="1.6"/></svg>`,
  },
  {
    title: '该用AI的环节我们会用',
    body: '起草和翻译这些比较重复的活，确实在用AIGC提速。但是上线之前必须经过人工编辑，这步我们不会省。说白了工具就是帮我们压成本的，真正决定内容好不好的还是人。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'LinkedIn认证是入职条件',
    body: '我们招人的硬性要求里包括LinkedIn Marketing官方认证。不是什么荣誉展示，考不过就是不录用。',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l3 6h6l-5 4 2 6-6-4-6 4 2-6-5-4h6l3-6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
  },
];

const faqs = [
  { q: '你们一般接什么类型的客户？', a: 'B2B为主。制造、医疗、科技、快消、零售都有，专业服务类的也做过不少。其实我们看的就是一点：你的目标客户用不用LinkedIn。用的话基本都能帮到。' },
  { q: '多久能见到效果？', a: '得看基础。有些公司LinkedIn上已经有点内容积累了，这种起来比较快。完全从零开始就要有耐心，怎么也得两三个月。我们一开始会跟你把阶段目标对清楚，后面按月做数据复盘。' },
  { q: '刚开始合作的时候流程是怎样的？', a: '先集中做策略。把你现在的LinkedIn翻一遍，看看目标人群到底长什么样，然后出一套内容加投放的方案。审完没什么大问题就直接进入执行了。' },
  { q: '我们自己有市场团队，Nuvora怎么嵌进来？', a: '这种情况遇到很多了。有的客户LinkedIn这块完全让我们来，也有的只让我们管内容生产和广告，互动留给自己的团队。怎么分工我们都能配合，关键是前面要把边界说清楚。' },
  { q: '公司规模不大也能合作吗？', a: '可以的，我们客户里面中型企业其实蛮多的。规模不是我们特别在意的事情，主要还是看LinkedIn对你们获客有没有实际价值，有的话就可以聊。' },
  { q: '多语种内容怎么弄？', a: '团队加AI辅助流程，10多个语种都能出。发之前肯定有母语的人审过，这个不用担心。我们也不是一句一句对着翻译那种，基本上都是按当地人的习惯重新写的。' },
  { q: '高管个人号也帮做吗？', a: '做。代写和个人品牌定位都可以，单独签也行打包也行。其实很多人没意识到，高管号才是LinkedIn上最容易带来询盘的渠道。' },
  { q: '报告长什么样？', a: '月报一份，互动、粉丝、广告、线索归因都在里面。只放跟你生意直接相关的指标，播放量那种好看但没用的东西我们不放。' },
  { q: '最少签多久？', a: '三个月起签。LinkedIn要出效果就是需要时间的，一个月测试说实话看不出什么。' },
  { q: '想了解一下怎么开始？', a: '约个电话就行，30分钟左右。我们看看你LinkedIn现在什么样，你聊聊想做到什么程度，然后双方判断合不合适。不合适的项目我们也不会硬做。' },
];
---

<Layout
  title="关于Nuvora Studio | 专注LinkedIn的B2B获客agency"
  description="Nuvora Studio只做一件事：帮B2B企业把LinkedIn做好。团队持有LinkedIn官方认证，负责策略内容、广告投放和高管品牌。从LinkedIn上帮你拿到真实的业务线索。"
  abstract="只做LinkedIn，只服务B2B企业。认证团队，策略驱动，线索导向。"
>
  <NavBar lang="zh" />
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="ab-hero" aria-labelledby="ab-hero-h">
      <div class="ab-hero__bg" aria-hidden="true"></div>
      <div class="ab-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="ab-hero__content">
          <p class="eyebrow eyebrow--light reveal">关于Nuvora Studio</p>
          <h1 id="ab-hero-h" class="ab-hero__h1 reveal reveal-delay-1">
            B2B圈子里谁都在发声。<br/>但能被听到的没几个<span class="text-gradient">。</span>
          </h1>
          <p class="ab-hero__sub reveal reveal-delay-2">
            我们只接B2B的单子，平台也只做LinkedIn。团队有LinkedIn官方认证，内容从策略出发，投放盯着数据走。归根结底就是帮你从LinkedIn上面拿到实在的商业线索。
          </p>
        </div>
      </div>
    </section>


    <!-- ── Why We Exist ────────────────────────────────────── -->
    <section class="section ab-exist" aria-labelledby="exist-h">
      <div class="container">
        <div class="ab-exist__layout">

          <div class="ab-exist__text reveal">
            <p class="eyebrow">我们的故事</p>
            <h2 id="exist-h">为什么做这件事</h2>
            <p>原因也没什么特别的。就是同样的问题见的太多了，但一直没谁在认真解决。</p>
            <p>B2B企业都知道LinkedIn重要，这又不是什么新鲜的认知。但问题是谁来做？内部懂这个平台的人几乎没有，大家手上都有自己一堆事。最后就变成了想起来发一条，想起来投一笔，钱花了效果没有，慢慢的就觉得LinkedIn不行。</p>
            <p>我们觉得这事有人该认真的去做。所以搞了Nuvora，就专门干这一件事 - 帮B2B企业在LinkedIn上跟对的买家把关系建起来。</p>
            <p class="ab-exist__closing"><strong>虚的数字我们不碰，做的每一件事都要能跟生意挂上钩。</strong></p>
          </div>

          <div class="ab-exist__visual reveal reveal-delay-1">
            <div class="ab-exist__sig-card">
              <div class="ab-exist__sig-visual">
                <img src="/signal-vs-noise.png" alt="从噪音到清晰信号 - LinkedIn上的信噪比" class="ab-exist__sig-hero" width="600" height="600" loading="lazy" />
              </div>
              <div class="ab-exist__sig-footer">
                <div class="ab-exist__sig-photo">
                  <img src="/Cyril-Drouin.jpg" alt="Cyril Drouin，CEO" class="ab-exist__sig-img" width="80" height="80" loading="lazy" />
                </div>
                <div class="ab-exist__sig-info">
                  <strong class="ab-exist__sig-name">Cyril Drouin</strong>
                  <span class="ab-exist__sig-title">CEO & 首席策略官</span>
                </div>
              </div>
              <img src="https://beyondbordergroup.com/wp-content/compressx-nextgen/uploads/2026/02/Cyril-Drouin-Signature-Transparent.png.avif" alt="Cyril Drouin签名" class="ab-exist__sig-mark" width="180" height="60" loading="lazy" />
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ── Our Values ──────────────────────────────────────── -->
    <section class="section ab-values" aria-labelledby="values-h">
      <div class="ab-values__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="ab-values__head reveal">
          <p class="eyebrow eyebrow--light">我们信什么</p>
          <h2 id="values-h">做事的几条底线</h2>
        </div>

        <div class="ab-values__grid">
          {values.map((v, i) => (
            <div class={`ab-val-card reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
              <div class="ab-val-card__icon" aria-hidden="true" set:html={v.icon} />
              <strong class="ab-val-card__title">{v.title}</strong>
              <p class="ab-val-card__body">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── Why Work With Us ────────────────────────────────── -->
    <section class="section ab-why" aria-labelledby="why-h">
      <div class="container">
        <div class="ab-why__head reveal">
          <p class="eyebrow">为什么找我们</p>
          <h2 id="why-h">选Nuvora的几个理由</h2>
        </div>

        <div class="ab-why__grid">
          {whyWorkWithUs.map((item, i) => (
            <div class={`ab-why-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="ab-why-card__icon" aria-hidden="true" set:html={item.icon} />
              <strong class="ab-why-card__title">{item.title}</strong>
              <p class="ab-why-card__body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── Our Leadership ──────────────────────────────────── -->
    <section class="section ab-team" aria-labelledby="team-h">
      <div class="container">
        <div class="ab-team__head reveal">
          <p class="eyebrow">核心团队</p>
          <h2 id="team-h">带队的人</h2>
          <p class="ab-team__sub">一线业务打出来的人，不是从咨询公司过来的。</p>
        </div>

        <!-- Cyril Drouin -->
        <div class="ab-leader reveal">
          <div class="ab-leader__visual">
            <div class="ab-leader__photo-wrap">
              <img src="/Cyril-Drouin.jpg" alt="Cyril Drouin" class="ab-leader__photo" width="400" height="480" loading="lazy" />
            </div>
          </div>

          <div class="ab-leader__content">
            <h3 class="ab-leader__name">Cyril Drouin</h3>
            <span class="ab-leader__title">CEO & 首席策略官</span>

            <div class="ab-leader__bio">
              <p>营销和电商做了二十多年了，中国、欧洲、全球各个市场基本都跑过。</p>
              <p>之前在阳狮集团（Publicis）负责中国区商务，带了大概250人的团队，年营收3500万美金，同比增长25%以上。2022年团队还拿了大中华区电商代理商金奖。合作过的品牌有苹果、欧莱雅、耐克、雀巢喜力和开云这些。</p>
              <p>LinkedIn Marketing Labs三项官方认证都考过了，营销策略、广告基础、内容与创意设计。</p>
              <p>另外他自己还创办了HubStudio，做AIGC内容的。教学方面目前在巴黎HEC商学院、ESCP还有上海交大几个地方有课。</p>
            </div>

            <div class="ab-leader__certs">
              <a href="https://verify.skilljar.com/c/o4g7hsuokjyp" target="_blank" rel="noopener noreferrer" class="ab-leader__cert-card">
                <svg class="ab-leader__cert-li" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <div class="ab-leader__cert-info">
                  <strong>内容与创意设计</strong>
                  <span>2024年8月获得</span>
                </div>
              </a>
              <a href="https://verify.skilljar.com/c/owpjectbjz4m" target="_blank" rel="noopener noreferrer" class="ab-leader__cert-card">
                <svg class="ab-leader__cert-li" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <div class="ab-leader__cert-info">
                  <strong>营销策略</strong>
                  <span>2024年8月获得</span>
                </div>
              </a>
              <a href="https://verify.skilljar.com/c/44sf7pp965dk" target="_blank" rel="noopener noreferrer" class="ab-leader__cert-card">
                <svg class="ab-leader__cert-li" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <div class="ab-leader__cert-info">
                  <strong>营销解决方案基础</strong>
                  <span>2024年8月获得</span>
                </div>
              </a>
            </div>
          </div>
        </div>

        <hr class="ab-team__divider" />

        <!-- LiYan Ye -->
        <div class="ab-leader ab-leader--flip reveal">
          <div class="ab-leader__visual">
            <div class="ab-leader__photo-wrap">
              <img src="https://beyondbordergroup.com/wp-content/uploads/elementor/thumbs/Liyan-Ye-rjaieqnzssadxaepw8m116yt79e5qhu51d5tgiyybk.jpg" alt="叶丽燕" class="ab-leader__photo" width="400" height="480" loading="lazy" />
              <div class="ab-leader__photo-ph" aria-hidden="true" style="display:none;">
                <svg width="64" height="64" viewBox="0 0 64 64" fill="none"><circle cx="32" cy="22" r="12" fill="rgba(10,102,194,0.15)"/><ellipse cx="32" cy="52" rx="20" ry="12" fill="rgba(10,102,194,0.10)"/></svg>
                <span>照片即将上线</span>
              </div>
            </div>
          </div>

          <div class="ab-leader__content">
            <h3 class="ab-leader__name">叶丽燕（LiYan Ye）</h3>
            <span class="ab-leader__title">总经理</span>

            <div class="ab-leader__bio">
              <p>拜尔斯道夫、利洁时、百胜中国、蔚优，都是500强，丽燕在这几家前后待了快20年。</p>
              <p>比较有代表性的一段经历是在百胜中国做数字营销总监那会儿。2017年第一季度她带团队把同店销售额重新拉回了正增长 - 之前这个品牌连着跌了11个季度了，内部其实已经没太多人觉得能翻过来。再之前是在蔚优亚太的创始团队，中国区B2B那块的数字化业务基本是她从零开始搭的。</p>
              <p>现在Nuvora的日常运营归她管，内容质量投放数据客户交付这几根线都在她手上。LinkedIn内容策略、社交销售、B2B受众运营这些是她最强的几个方向。</p>
              <p>中英文沟通完全没障碍。</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <FAQ heading="你可能想问的" faqs={faqs} background="var(--off-white)" id="ab-faq" />


    <!-- ── Bottom CTA ──────────────────────────────────────── -->
    <section class="section ab-cta" aria-labelledby="ab-cta-h">
      <div class="ab-cta__orb ab-cta__orb--1" aria-hidden="true"></div>
      <div class="ab-cta__orb ab-cta__orb--2" aria-hidden="true"></div>
      <div class="container">
        <div class="ab-cta__layout">
          <div class="ab-cta__left reveal">
            <p class="eyebrow eyebrow--light">下一步</p>
            <h2 id="ab-cta-h" class="ab-cta__headline">
              你的客户每天都在LinkedIn上。<br />
              <em>但他们未必看得到你。</em>
            </h2>
          </div>
          <div class="ab-cta__right reveal reveal-delay-2">
            <p class="ab-cta__sub">先约个电话也行，我们帮你过一下LinkedIn目前的状况，看看还有哪些机会没抓住。</p>
            <div class="ab-cta__actions">
              <a href="/contact?intent=call" class="btn btn--primary btn--lg">预约通话</a>
            </div>
            <p class="ab-cta__note">半小时左右，不推销，就是聊聊。</p>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>



<style>
  /* ────────────────────────────────────────────────────────────
     HERO
     ──────────────────────────────────────────────────────────── */
  .ab-hero {
    position: relative;
    overflow: hidden;
