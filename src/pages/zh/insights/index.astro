    date: '2026-03-29',
    readTime: '10分钟',
    featured: false,
    image: '/blog/hero-ads-budget.webp',
  },
  // ── 2026年3月23日 ──
  {
    slug: 'your-linkedin-post-is-already-dead',
    category: '内容策略',
    tags: ['内容'],
    title: "发出即沉没:LinkedIn帖子的两小时生死线",
    excerpt: "AI内容泛滥,信息流极度拥挤。一条帖子的有效曝光窗口只剩两小时。在这个环境里存活下来的品牌,做对了三件事。",
    date: '2026-03-23',
    readTime: '5分钟',
    featured: false,
    image: '/blog/hero-post-already-dead.svg',
  },
  {
    slug: 'the-real-linkedin-problem',
    category: '内容策略',
    tags: ['策略'],
    title: "AI解决了怎么写,但写什么才是真问题",
    excerpt: "文笔可以交给AI,选题不行。多数B2B企业的LinkedIn困境不是产能不足,而是方向不清。选题体系才是内容增长的底层基建。",
    date: '2026-03-23',
    readTime: '5分钟',
    featured: false,
    image: '/blog/hero-thinking-not-writing.svg',
  },
];

// Collect all unique tags across posts
const allTags = [...new Set(posts.flatMap(p => p.tags))].sort();
---

<Layout
  lang="zh"
  title="深度洞察 | LinkedIn增长、B2B获客与广告策略 | Nuvora Studio"
  description="LinkedIn增长策略、B2B获客方法论、广告投放实操 - 来自一线操盘手的深度复盘,拒绝空谈。"
  abstract="Nuvora Studio出品 - LinkedIn增长与B2B获客领域的一手洞察与实战方法论。"
>
  <NavBar lang="zh" />
  <main id="main-content">

    <!-- Hero -->
    <section class="insights-hero" aria-labelledby="insights-heading">
      <div class="container">
        <p class="eyebrow eyebrow--light reveal">深度专栏</p>
        <h1 id="insights-heading" class="insights-hero__h1 reveal reveal-delay-1">
          一线操盘手的<br /><em>LinkedIn实战笔记</em>
        </h1>
        <p class="insights-hero__sub reveal reveal-delay-2">
          增长策略、获客方法论、广告实操、平台规则拆解。
          每一篇都来自真实项目。不贩卖焦虑,只提供弹药
        </p>
      </div>
    </section>

    <!-- Posts -->
    <section class="section" style="background: var(--off-white);" aria-label="全部文章">
      <div class="container">

        <!-- Tag filters -->
        <div class="tag-filters" role="group" aria-label="按标签筛选">
          <button class="tag-btn tag-btn--active" data-tag="all">全部</button>
          {allTags.map(tag => (
            <button class="tag-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>

        <!-- Posts grid -->
        <div class="posts-grid" id="posts-grid">
          {posts.map((post, i) => (
            <article
              class="post-card"
              data-tags={post.tags.join(',')}
              style={`transition-delay: ${i * 0.07}s`}
            >
              {post.image ? (
                <div class="post-card__thumb" style={`background-image: url('${post.image}')`}></div>
              ) : (
                <div class="post-card__thumb post-card__thumb--empty">
                  <span>配图即将上线</span>
                </div>
              )}
              <div class="post-card__top">
                <div class="post-card__tags">
                  {post.featured && <span class="post-tag post-tag--featured">置顶</span>}
                  {post.tags.map(tag => (
                    <span class="post-tag">{tag}</span>
                  ))}
                </div>
                <span class="post-card__category">{post.category}</span>
              </div>
              <h2 class="post-card__title">
                <a href={`/zh/insights/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="post-card__excerpt">{post.excerpt}</p>
              <div class="post-card__footer">
                <span class="post-card__read-time">{post.readTime}</span>
                <a href={`/zh/insights/${post.slug}`} class="post-card__cta">阅读全文 →</a>
              </div>
            </article>
          ))}
        </div>

        <!-- Empty state -->
        <p class="posts-empty" id="posts-empty" style="display:none">
          该分类下暂无内容,敬请关注更新。
        </p>

      </div>
    </section>

    <ContactCTA lang="zh" />
  </main>
</Layout>

<style>
  /* ── Hero ── */
  .insights-hero {
    background: var(--deep-navy) url('/blog/hero-insights.svg') center/cover no-repeat;
    padding-block: clamp(3rem, 6vw, 5rem);
    position: relative;
    overflow: hidden;
  }
  .insights-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 70% at 75% 40%, rgba(6,182,212,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .insights-hero .container { position: relative; z-index: 1; }

  .insights-hero__h1 {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.12;
    letter-spacing: -0.015em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .insights-hero__h1 em {
    color: rgba(255,255,255,0.38);
    font-weight: 300;
    font-style: normal;
  }
  .insights-hero__sub {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.58);
    max-width: 540px;
    line-height: 1.7;
  }

  /* ── Tag filters ── */
  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-8);
  }

  .tag-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--white);
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--text-2);
    cursor: pointer;
    transition: all var(--t-base) ease;
    letter-spacing: 0.02em;
  }
  .tag-btn:hover {
    border-color: var(--sky);
    color: var(--sky);
    box-shadow: 0 2px 8px rgba(14,165,233,0.1);
  }
  .tag-btn--active {
    background: var(--deep-navy);
    border-color: var(--deep-navy);
    color: var(--white);
  }

  /* ── Grid ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  /* ── Card ── */
  .post-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-10);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
    transition:
      box-shadow var(--t-base) ease,
      border-color var(--t-base) ease,
      transform var(--t-base) ease,
      opacity var(--t-base) ease;
  }
  .post-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-2);
    transform: translateY(-3px);
  }
  .post-card.is-hidden {
    display: none;
  }

  .post-card__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--r-lg);
    background-color: var(--deep-navy);
    background-size: cover;
    background-position: center;
    margin-bottom: var(--sp-2);
  }

  .post-card__thumb--empty {
    background: linear-gradient(135deg, rgba(14,165,233,0.04) 0%, rgba(6,182,212,0.06) 100%);
    border: 1.5px dashed rgba(14,165,233,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .post-card__thumb--empty span {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(14,165,233,0.2);
  }


  .post-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .post-tag {
    display: inline-block;
    padding: 2px var(--sp-3);
    border-radius: var(--r-sm);
    background: rgba(14,165,233,0.07);
    color: var(--sky);
    font-family: var(--font-body), sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .post-tag--featured {
    background: rgba(234,179,8,0.12);
    color: #b45309;
  }

  .post-card__category {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    color: var(--text-3);
    letter-spacing: 0.04em;
  }

  .post-card__title {
    font-family: var(--font-display), sans-serif;
    font-size: var(--fs-xl);
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .post-card__title a { color: inherit; transition: color var(--t-fast) ease; }
  .post-card__title a:hover { color: var(--sky); }

  .post-card__excerpt {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.8;
    flex: 1;
  }

  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .post-card__read-time {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    color: var(--text-3);
  }

  .post-card__cta {
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sky);
    transition: color var(--t-fast) ease;
  }
  .post-card__cta:hover { color: var(--cyan); }

  .posts-empty {
    text-align: center;
    color: var(--text-3);
    padding-block: var(--sp-20);
    font-family: var(--font-body), sans-serif;
    font-size: var(--fs-md);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
    .post-card { padding: var(--sp-7); }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards   = document.querySelectorAll<HTMLElement>('.post-card');
  const empty   = document.getElementById('posts-empty');

  function filter(tag: string) {
    let visible = 0;

    cards.forEach(card => {
      const tags = (card.dataset.tags ?? '').split(',');
      const show = tag === 'all' || tags.includes(tag);
      card.classList.toggle('is-hidden', !show);
      if (show) visible++;
    });

    if (empty) empty.style.display = visible === 0 ? 'block' : 'none';

    buttons.forEach(btn => {
      btn.classList.toggle('tag-btn--active', btn.dataset.tag === tag);
    });
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => filter(btn.dataset.tag ?? 'all'));
  });
</script>
