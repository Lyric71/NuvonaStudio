---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';
import ContactCTA from '../../../components/ContactCTA.astro';

const posts = [
  // ── 2026年3月29日 ──
  {
    slug: 'why-your-reach-dropped',
    category: '平台动态',
