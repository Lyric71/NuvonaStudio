---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import FAQ from '../../components/FAQ.astro';
import Testimonials from '../../components/Testimonials.astro';

const painPoints = [
  {
    stat: '3%',
    label: '的B2B企业能在LinkedIn上保持稳定发布',
    detail: '另外97%呢？发过一两条就没影了，隔段时间又在问：Linkedin到底有没有用？',
  },
  {
    stat: '0',
    label: '个高管在认真经营自己的LinkedIn',
    detail: '翻一下大多数管理层的页面就知道了，跟招聘网站上的简历差不多。没什么观点输出，信任感就更谈不上了',
  },
  {
    stat: '72%',
    label: '的LinkedIn广告费花得不值',
    detail: '人群没选对，形式也不合适，转化环节是断的。没有做过整体规划的广告账户，预算消耗速度会超出你的想象。',
  },
];

const services = [
  {
    title: '内容运营',
    tag: '自然增长',
    body: '企业主页交给我们打理，Linkedin上能用的内容形式基本都会覆盖到，固定节奏更新。你的品牌一直出现在该出现的地方，团队可以腾出手来专心做业务。',
    href: '/zh/services/content',
    subs: [
      '企业主页全托管',
      '内容策划与生产',
      'LinkedIn Newsletter',
      'LinkedIn线上活动运营',
    ],
  },
  {
    title: '广告投放',
    tag: '付费增长',
    body: '从Sponsored Content到Lead Gen Forms，广告账户的搭建和日常运营都由我们来。预算花在拍板的人身上，展示量变成实打实的业务机会。',
    href: '/zh/services/advertising',
    subs: [
      '广告账户架构设计',
      '受众定向和圈层筛选',
      '素材与文案创作',
      'CRM数据打通、效果归因',
    ],
  },
  {
    title: '策略咨询',
    tag: '顾问服务',
    body: '管理者个人品牌怎么做，员工怎么在LinkedIn上帮公司发声，团队需要什么样的培训——这些我们都能做。说到底就一个目的，让你自己的人变成最好用的获客渠道。',
    href: '/zh/services/consulting',
    subs: [
      '员工社交传播方案',
      '高管个人品牌',
      '企业内训/工作坊',
      'LinkedIn策略评估',
    ],
  },
];

const steps = [
  {
    title: '评估与规划',
    body: '先把你的LinkedIn现状、竞品在干什么、目标受众长什么样弄清楚，然后给你一份标好了优先级的执行方案。这个方案是照着你公司的情况来的，不是套模板。',
    detail: '第1-2周',
  },
  {
    title: '搭建与上线',
    body: '优化主页、把内容生产流程跑起来、广告开户投放，同步推进。上线之前每一步都过你的确认。',
    detail: '第3-4周',
  },
  {
    title: '迭代与增长',
    body: '每月拿事先定好的指标来复盘。跑得好的方向继续加码，转化好的加速推。报告里只放跟业务相关的数据，不凑数。',
    detail: '持续进行',
  },
];

const pillars = [
  {
    title: '这一个领域，我们比谁都熟',
    body: '所有服务都是围绕LinkedIn的，没有别的。算法怎么跑、什么格式管用、广告定向怎么设，哪种内容能带来业务——天天都在研究这些。',
    metric: '100%',
    metricLabel: '专注LinkedIn',
  },
  {
    title: '写给你的客户看的，不是给你审批用的',
    body: '内容是写给你的目标受众读的。B2B的读者很挑的，看完没有想动一下的冲动，这条内容就算白写了。',
    metric: '3.2x',
    metricLabel: '平均互动提升',
  },
  {
    title: '帐怎么算的，随时可以查',
    body: '报告写得清楚，报价没有暗门。做了什么、为什么这么做，你什么时候来问都能给你说明白。',
    metric: '0',
    metricLabel: '隐性收费',
  },
  {
    title: '用AI干活，但人盯着',
    body: 'AI帮我们提速和扩产能，这个我们不回避。但是内容发出去之前必须过团队的审，一条条来。没有例外。',
    metric: '100%',
    metricLabel: '人工终审',
  },
];

const industries = [
  { label: '科技与SaaS' },
  { label: '制造与工业' },
  { label: '专业服务' },
  { label: '医疗健康与生命科学' },
  { label: '金融服务' },
  { label: '物流与供应链' },
];

const posts = [
  {
    category: 'LinkedIn策略',
    tags: ['算法', '触达率'],
    title: '2026年LinkedIn触达率腰斩，跟你的内容没关系',
    excerpt: 'LinkedIn上了一套叫360Brew的新算法。企业自然触达直接掉了一半，公司主页流量更惨，少了六成。你的内容没变差——是平台那边的规则改了。',
    date: '2026-03-29',
    slug: 'why-your-reach-dropped',
    image: '/blog/hero-reach-dropped.svg',
  },
  {
    category: 'LinkedIn策略',
    tags: ['内容', '线索'],
    title: 'LinkedIn内容有了曝光，然后呢？怎么变成客户',
    excerpt: '光有阅读量没人找上门，那内容算是白做了。Inbound的转化率14.6%，主动外呼才1.7%。这中间差了将近10倍，根子上是内容体系搭的问题。',
    date: '2026-03-29',
    slug: 'content-to-inbound-leads',
    image: '/blog/hero-ads-vs-organic.svg',
  },
  {
    category: 'LinkedIn广告',
    tags: ['广告', '归因'],
    title: 'LinkedIn广告ROI难看？可能是你看数据的方式不对',
    excerpt: 'B2B广告在LinkedIn上实际回报率能到121%的。但是买家从第一次接触到最后成交，平均要272天。你要是30天就看ROI，那当然难看。',
    date: '2026-03-29',
    slug: 'linkedin-ad-roi-measurement-problem',
    image: '/blog/hero-ads-cost.svg',
  },
];

const faqs = [
  { q: '你们的客户主要在哪？', a: '全球都有。欧洲、北美、亚太比较集中，但不限地区。LinkedIn本来就没有国界，我们合作也一样。' },
  { q: '真的只做LinkedIn？', a: '对，只做LinkedIn。不接SEO，不碰Instagram，也没有什么全渠道套餐。' },
  { q: '合作起步大概多少钱？', a: 'Foundation方案月费1,800美金起，策略、内容、月度报告都算在里面了。大部分客户先从这个方案开始用，后面看需要再往上加。', link: { text: '完整定价在这里 →', href: '/zh/pricing' } },
  { q: '只适合大公司吗？', a: '不是。1,800美金/月拿到的已经是完整的代运营了，成长期的公司用起来压力也不大。要是觉得暂时不需要全套的，单独做培训或者只管广告也行，这个可以聊。' },
  { q: '广告费包在月费里吗？', a: '不包，广告预算是独立的。有客户只做内容不投广告的，有的反过来只投广告，大部分是两边都做。广告的钱直接进你自己LinkedIn广告账户，不过我们手里。' },
  { q: '效果怎么看？', a: '开始之前先把指标定下来，线索数量、线索质量、粉丝增长、获客成本这些。然后每个月对着这些指标出报告。不会给你一堆曝光量和点赞数凑出来的东西。' },
];

---

<Layout
  lang="zh"
  title="Nuvora Studio | 专注LinkedIn的B2B营销机构"
  description="只给B2B企业做LinkedIn的营销咨询公司。内容运营、广告投放、高管品牌、团队培训，就做这一个平台。"
  abstract="只做LinkedIn的B2B营销公司。策略、内容、广告、培训，全在一个平台上解决。"
  preloadHero="/hero-notification.webp"
>
  <NavBar lang="zh" />
  <main id="main-content">

    <!-- ═══════════════════════════ 1. HERO ═══════════════════════════ -->
    <section class="hero" aria-labelledby="hero-heading">
      <img src="/hero-notification.webp" alt="" aria-hidden="true" class="hero__bg" fetchpriority="high" decoding="async" width="1920" height="1080" />
      <div class="hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="hero__content">
          <p class="eyebrow eyebrow--light hero__anim">专注LinkedIn的B2B营销机构</p>
          <h1 id="hero-heading" class="hero__h1 hero__anim hero__anim--1">
            让LinkedIn成为你<span class="text-gradient">最能带来生意的渠道。</span>
          </h1>
          <p class="hero__sub hero__anim hero__anim--2">
            策略、内容、广告，只围绕LinkedIn一个平台做。
            帮B2B企业在这里站稳脚跟，让对的人看到你，让生意主动找上来。
          </p>
          <div class="hero__actions hero__anim hero__anim--3">
            <a href="/zh/contact?intent=call" class="btn btn--primary btn--lg">预约策略通话</a>
            <a href="/zh/services" class="btn btn--outline-white btn--lg">了解服务内容</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ 2. PROBLEM STATEMENT ═══════════════════════════ -->
    <section class="section problem" aria-labelledby="problem-heading">
      <div class="container">

        <div class="problem__hero reveal">
          <div class="problem__head">
            <p class="eyebrow eyebrow--light">行业现状</p>
            <h2 id="problem-heading">
              大多数B2B企业<br />在LinkedIn上是隐形的。
            </h2>
            <p class="problem__sub">
              内容发了上顿没下顿，公司主页好几年没动过，管理层的个人页面像是注册完就忘了。
              广告投出去也常常打不到做决定的人。Linkedin这个平台是吃持续投入跟专业深度的，
              两样都缺的话，再好的B2B平台也帮不了你。
            </p>
          </div>

          <div class="problem__visual">
            <img
              src="/problem-linkedin.webp"
              alt="两块屏幕对比：左侧是空白的LinkedIn通知、零曝光和平直的数据曲线；右侧是不断涌入的连接请求、新线索和12,400次展示"
              class="problem__img"
              width="1024"
              height="1024"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <div class="problem__grid">
          {painPoints.map((p, i) => (
            <div class="problem__card reveal" style={`transition-delay: ${i * 0.1}s`}>
              <p class="problem__stat">{p.stat}</p>
              <p class="problem__label">{p.label}</p>
              <p class="problem__detail">{p.detail}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════ 3. SERVICES GRID ═══════════════════════════ -->
    <section id="services" class="section" style="background: var(--off-white);" aria-labelledby="services-heading">
      <div class="container">

        <div class="services__head reveal">
          <div>
            <p class="eyebrow">服务范围</p>
            <h2 id="services-heading">LinkedIn运营所需的一切<br />都在这里。</h2>
          </div>
          <p class="services__intro">
            做了什么、花了多少、效果怎样，全部摊开来讲。策略、诊断、报告是每个项目标配，不会额外加钱。
          </p>
        </div>

        <div class="services__grid">
          {services.map((s, i) => (
            <a href={s.href} class="services__card reveal" style={`transition-delay: ${i * 0.08}s`}>
              <div class="services__card-top">
                <span class="tag tag--cyan">{s.tag}</span>
                <span class="services__arrow" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M4.5 15.5L15.5 4.5M15.5 4.5H7.5M15.5 4.5V12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              {s.title === '内容运营' ? (
                <div class="services__vis services__vis--content" aria-hidden="true">
                  <img src="/content-calendar-v2.webp" alt="" width="600" height="338" loading="lazy" />
                </div>
              ) : s.title === '广告投放' ? (
                <div class="services__vis services__vis--content" aria-hidden="true">
                  <img src="/ad-creative-stack.webp" alt="" width="600" height="338" loading="lazy" />
                </div>
              ) : s.title === '策略咨询' ? (
                <div class="services__vis services__vis--content" aria-hidden="true">
                  <img src="/consulting-workshop.webp" alt="" width="600" height="338" loading="lazy" />
                </div>
              ) : (
                <div class="vis-placeholder services__vis" aria-hidden="true">
                  <span>视觉占位</span>
                </div>
              )}
              <h3 class="services__card-title">{s.title}</h3>
              <p class="services__card-desc">{s.body}</p>
              <ul class="services__subs">
                {s.subs.map(sub => (
                  <li class="services__sub">{sub}</li>
                ))}
              </ul>
            </a>
          ))}
        </div>

        <div class="services__foot reveal">
          <a href="/zh/services" class="btn btn--outline btn--lg">查看全部服务</a>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════ 4. HOW WE WORK ═══════════════════════════ -->
    <section class="section" style="background: var(--deep-navy);" aria-labelledby="process-heading">
      <div class="container">

        <div class="process__head reveal">
          <p class="eyebrow eyebrow--light">合作方式</p>
          <h2 id="process-heading" style="color: var(--white);">
            从评估到业务增长<br /><em style="color: rgba(255,255,255,0.35); font-weight: 300;">只需三步。</em>
          </h2>
        </div>

        <div class="process__grid">
          {steps.map((s, i) => (
            <div class="process__step reveal" style={`transition-delay: ${i * 0.1}s`}>
              <div class="process__line-horizontal" aria-hidden="true"></div>
              <div class="process__content">
                <span class="process__detail">{s.detail}</span>
                <h3 class="process__title">{s.title}</h3>
                <p class="process__body">{s.body}</p>
              </div>
              {s.title === '评估与规划' ? (
                <div class="process__vis process__vis--img" aria-hidden="true">
                  <img src="/audit-strategy.webp" alt="" width="600" height="375" loading="lazy" />
                </div>
              ) : s.title === '搭建与上线' ? (
                <div class="process__vis process__vis--img" aria-hidden="true">
                  <img src="/build-launch.webp" alt="" width="600" height="375" loading="lazy" />
                </div>
              ) : s.title === '迭代与增长' ? (
                <div class="process__vis process__vis--img" aria-hidden="true">
                  <img src="/grow-report.webp" alt="" width="600" height="375" loading="lazy" />
                </div>
              ) : (
                <div class="vis-placeholder process__vis" aria-hidden="true">
                  <span>视觉占位</span>
                </div>
              )}
            </div>
          ))}
        </div>

        <div class="process__cta reveal" style="transition-delay: 0.3s">
          <a href="/zh/pricing" class="btn btn--outline-white btn--lg">查看报价</a>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════ 5. WHAT SETS US APART ═══════════════════════════ -->
    <section class="section" aria-labelledby="apart-heading">
      <div class="container">
        <div class="apart__layout">

          <div class="apart__left">
            <div class="apart__head reveal">
              <p class="eyebrow">为什么选择我们</p>
              <h2 id="apart-heading">只做一件事。<br />LinkedIn。</h2>
              <div class="accent-bar"></div>
              <p class="apart__lead">
                不是什么数字营销都接然后顺带管管LinkedIn那种公司。
                LinkedIn就是我们全部业务了，没有别的。做得深和做得浅，区别就在这。
              </p>
            </div>

            <!-- Visual: comparison graphic -->
            <div class="apart__visual reveal reveal-delay-1" aria-hidden="true">
              <div class="apart__visual-inner">
                <div class="apart__vis-compare">
                  <div class="apart__vis-col apart__vis-col--them">
                    <span class="apart__vis-label">综合营销机构</span>
                    <div class="apart__vis-bars">
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 30%"></div></div>
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 25%"></div></div>
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 20%"></div></div>
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 35%"></div></div>
                      <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 15%"></div></div>
                    </div>
                  </div>
                  <div class="apart__vis-divider"></div>
                  <div class="apart__vis-col apart__vis-col--us">
                    <span class="apart__vis-label">Nuvora Studio</span>
                    <div class="apart__vis-bars">
                      <div class="apart__vis-item"><span class="apart__vis-dot"></span><div class="apart__vis-bar" style="width: 100%"></div></div>
                    </div>
                    <span class="apart__vis-tag">只做LinkedIn</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="apart__right">
            <div class="apart__grid">
              {pillars.map((p, i) => (
                <div class="apart__card reveal" style={`transition-delay: ${i * 0.08}s`}>
                  <div class="apart__card-metric">
                    <span class="apart__metric-value">{p.metric}</span>
                    <span class="apart__metric-label">{p.metricLabel}</span>
                  </div>
                  <div class="apart__card-body">
                    <div class="apart__card-header">
                      <h3 class="apart__title">{p.title}</h3>
                    </div>
                    <p class="apart__body">{p.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ 6. TESTIMONIALS ═══════════════════════════ -->
    <Testimonials
      eyebrow="客户说的"
      heading="合作过的人怎么看"
      sub="不同行业的B2B团队，同一个标准：看结果。"
      items={[
        { text: "半年下来40%的线索是从LinkedIn来的。说实话之前这个渠道我们压根就没当回事。", image: "https://randomuser.me/api/portraits/women/32.webp", name: "Sophie Laurent", role: "CMO, SaaS公司" },
        { text: "不是那种随便帮你发发帖子的团队，他们是懂B2B购买逻辑的。几个高管的Linkedin从没人看变成经常有人主动来聊业务了。", image: "https://randomuser.me/api/portraits/men/45.webp", name: "Marcus Webb", role: "销售VP, 工业技术" },
        { text: "说实话最打动我们的就是透明。每个月清清楚楚，什么有用什么没用，钱花在哪了。之前换了好几家都没见过这样做的。", image: "https://randomuser.me/api/portraits/women/28.webp", name: "Priya Sharma", role: "市场负责人, 金融科技" },
        { text: "之前试过三家，效果都一般。Nuvora不一样在哪呢，他们是真吃透了LinkedIn算法和B2B买家的行为习惯的，不是什么社交媒体都接的那种服务商。", image: "https://randomuser.me/api/portraits/men/22.webp", name: "David Chen", role: "CEO, 管理咨询公司" },
        { text: "广告费以前基本就是在打水漂。他们接手之后重新搭了账户结构，线索质量上来了，获客成本差不多降了一半。", image: "https://randomuser.me/api/portraits/women/44.webp", name: "Emma Bergström", role: "数字营销负责人, 制造业" },
        { text: "内容质量是真的好。发出去一看就是我们自己人写的口吻，完全没有外包的那种味道。做B2B内容能做到这样的真的不多见。", image: "https://randomuser.me/api/portraits/men/36.webp", name: "James Okafor", role: "创始人, 专业服务" },
        { text: "策略、内容、投放，全给他们管了。从之前一个月发一条到现在公司页面、高管页面、广告全部跑起来了，变化还是挺大的。", image: "https://randomuser.me/api/portraits/women/51.webp", name: "Ana Rodriguez", role: "市场总监, 医疗行业" },
        { text: "做了一个员工传播项目，销售团队现在在LinkedIn上活跃多了，行业里慢慢有了些认知度。带来的线索是能算出来的。", image: "https://randomuser.me/api/portraits/men/53.webp", name: "Ravi Patel", role: "CRO, 企业软件" },
        { text: "报告给的实在，线索数、质量、成本，有多少说多少。不像以前合作的那几家，给一堆曝光数据就算交差了...", image: "https://randomuser.me/api/portraits/women/19.webp", name: "Laura Koenig", role: "COO, 物流公司" },
      ]}
    />

    <!-- ═══════════════════════════ 7. INDUSTRIES ═══════════════════════════ -->
    <section class="section" aria-labelledby="industries-heading">
      <div class="container">
        <div class="industries__layout">

          <div class="industries__text reveal">
            <p class="eyebrow">服务行业</p>
            <h2 id="industries-heading">面向B2B企业，<br /><em>横跨多个行业。</em></h2>
            <div class="accent-bar"></div>
            <p class="industries__body">
              合作过的有做了很多年的跨国企业，也有正在快速长大的新公司。行业不一样，市场也不一样，共同点是都是做企业客户的。
            </p>
            <p class="industries__body">
              你的客户在LinkedIn上，但你还没找到他们？聊聊看。
            </p>
            <a href="/zh/contact" class="btn btn--primary" style="margin-top: var(--sp-6);">
              联系我们
            </a>
          </div>

          <div class="industries__right reveal reveal-delay-2">
            <div class="industries__visual" aria-hidden="true">
              <img src="/global-connections.webp" alt="" width="600" height="338" loading="lazy" />
            </div>
            <div class="industries__grid" aria-label="服务覆盖行业">
              {industries.map(ind => (
                <div class="industries__item">
                  <span class="industries__dot" aria-hidden="true"></span>
                  <span class="industries__label">{ind.label}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════ 8. INSIGHTS PREVIEW ═══════════════════════════ -->
    <section class="section" style="background: var(--off-white);" aria-labelledby="insights-heading">
      <div class="container">

        <div class="insights__head reveal">
          <div>
            <p class="eyebrow">专栏</p>
            <h2 id="insights-heading">LinkedIn深度观察，<br /><em>来自实战。</em></h2>
          </div>
          <p class="insights__sub">
            LinkedIn策略、B2B内容怎么做、广告打法、平台最新的变动，这些都会写到。
            作者本人天天在做这一行的，不是那种攒稿子的内容团队。
          </p>
        </div>

        <div class="insights__grid">
          {posts.map((post, i) => (
            <article class="insights__card reveal" style={`transition-delay: ${i * 0.08}s`}>
              {post.image ? (
                <div class="insights__thumb insights__thumb--img" style={`background-image: url('${post.image}')`} aria-hidden="true"></div>
              ) : (
                <div class="vis-placeholder insights__thumb" aria-hidden="true">
                  <span>视觉占位</span>
                </div>
              )}
              <div class="insights__card-top">
                <div class="insights__tags">
                  {post.tags.map(t => <span class="insights__tag">{t}</span>)}
                </div>
              </div>
              <h3 class="insights__title">
                <a href={`/insights/${post.slug}`}>{post.title}</a>
              </h3>
              <p class="insights__excerpt">{post.excerpt}</p>
              <a href={`/insights/${post.slug}`} class="insights__read">
                阅读全文
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M3 7h8m0 0L7.5 3.5M11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </article>
          ))}
        </div>

        <div class="text-center reveal" style="margin-top: var(--sp-10);">
          <a href="/zh/insights" class="btn btn--outline btn--lg">查看全部文章</a>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════ 9. FAQ ═══════════════════════════ -->
    <FAQ heading="常见问题" faqs={faqs} footer="还有其他疑问？" footerLink={{ text: '直接联系我们', href: '/zh/contact' }} id="faq-zh" />

    <!-- ═══════════════════════════ 10. CONTACT CTA ═══════════════════════════ -->
    <section class="section cta" aria-labelledby="cta-heading" style="background: var(--deep-navy);">
      <div class="container">
        <div class="cta__layout">

          <div class="cta__left reveal">
            <p class="eyebrow eyebrow--light">现在开始</p>
            <h2 id="cta-heading" class="cta__headline">
              准备好让LinkedIn<br />
              <em>开始产生业务价值了吗？</em>
            </h2>
          </div>

          <div class="cta__right reveal reveal-delay-2">
            <p class="cta__sub">
              说说你们公司现在是什么情况，我们帮你看看Linkedin上有哪些现成的机会。就是聊一下，不会推东西给你。
            </p>
            <div class="cta__actions">
              <a href="/zh/contact?intent=call" class="btn btn--primary btn--lg">预约30分钟通话</a>
              <a href="/zh/contact" class="btn btn--outline-white btn--lg">在线留言</a>
            </div>
            <p class="cta__note">30分钟，不推销，就聊实际的问题。</p>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════════ */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.88) 0%,
      rgba(15,23,42, 0.55) 50%,
      rgba(15,23,42, 0.20) 100%
    );
    z-index: 1;
  }

  .hero__content {
    max-width: 680px;
  }

  .hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__sub {
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.68);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--sp-10);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero__anim { animation: heroFadeUp 0.7s var(--ease, ease) both; }
  .hero__anim--1 { animation-delay: 0.06s; }
  .hero__anim--2 { animation-delay: 0.14s; }
  .hero__anim--3 { animation-delay: 0.22s; }
  @media (prefers-reduced-motion: reduce) {
    .hero__anim { animation: none; opacity: 1; transform: none; }
  }

  @media (max-width: 640px) {
    .hero { padding-block: var(--sp-16) var(--sp-12); }
  }

  /* ═══════════════════════════════════════════════════════════
     PROBLEM STATEMENT
     ═══════════════════════════════════════════════════════════ */
  .problem {
    background: var(--deep-navy);
  }

  /* ── Hero row ── */
  .problem__hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: center;
    margin-bottom: var(--sp-16);
  }

  .problem__head {
    max-width: 540px;
  }

  .problem__head :global(.eyebrow) {
    color: var(--cyan);
  }

  .problem__head :global(h2) {
    color: var(--white);
    margin-bottom: var(--sp-6);
  }

  .problem__sub {
    font-size: var(--fs-md);
    color: var(--navy-text-2);
    line-height: 1.75;
  }

  /* ── Visual ── */
  .problem__visual {
    border-radius: var(--r-xl);
    overflow: hidden;
  }

  .problem__img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Stat cards ── */
  .problem__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  .problem__card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--r-xl);
    padding: var(--sp-8);
    transition: all var(--t-base);
  }

  .problem__card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-3px);
  }

  .problem__stat {
    font-family: var(--font-display);
    font-size: var(--fs-5xl);
    font-weight: 700;
    line-height: 1;
    color: var(--cyan);
    margin-bottom: var(--sp-4);
    letter-spacing: -0.03em;
  }

  .problem__label {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--white);
    line-height: 1.3;
    margin-bottom: var(--sp-4);
    letter-spacing: -0.01em;
  }

  .problem__detail {
    font-size: var(--fs-sm);
    color: var(--navy-text-2);
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .problem__hero {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .problem__head { max-width: 660px; margin-inline: auto; }
    .problem__visual { max-width: 480px; margin-inline: auto; }
    .problem__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .problem__grid { grid-template-columns: 1fr; }
    .problem__stat { font-size: var(--fs-4xl); }
  }

  /* ═══════════════════════════════════════════════════════════
     SERVICES GRID
     ═══════════════════════════════════════════════════════════ */
  .services__head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--sp-12);
    align-items: end;
    margin-bottom: var(--sp-12);
  }

  .services__intro {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.7;
    max-width: 400px;
    align-self: flex-end;
    padding-bottom: 6px;
  }

  /* ── Card grid ── */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
    margin-bottom: var(--sp-12);
  }

  /* ── Card ── */
  .services__card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-8);
    transition: all var(--t-base);
    text-decoration: none;
    color: inherit;
  }

  .services__card:hover {
    border-color: var(--border-2);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .services__card:hover .services__arrow {
    background: var(--deep-navy);
    color: var(--white);
    border-color: var(--deep-navy);
  }

  .services__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
  }

  .services__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 50%;
    color: var(--text-3);
    transition: all var(--t-base);
    flex-shrink: 0;
  }

  /* ── Visual ── */
  .services__vis {
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 120px;
    margin-bottom: var(--sp-6);
    border-radius: var(--r-lg);
    background: var(--off-white);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .services__vis--content {
    background: none;
    border: none;
    padding: 0;
  }

  .services__vis--content img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-lg);
  }

  .services__vis span {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .services__card-title {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: var(--sp-4);
  }

  .services__card-desc {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-6);
  }

  /* ── Sub-services list ── */
  .services__subs {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: auto;
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
  }

  .services__sub {
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--text-2);
    letter-spacing: 0.02em;
    padding-left: var(--sp-4);
    position: relative;
  }

  .services__sub::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--cyan);
  }

  .services__foot { text-align: center; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .services__head { grid-template-columns: 1fr; gap: var(--sp-6); }
    .services__intro { max-width: 100%; }
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services__grid { grid-template-columns: 1fr; }
  }

  /* ═══════════════════════════════════════════════════════════
     HOW WE WORK
     ═══════════════════════════════════════════════════════════ */
  .process__head {
    text-align: center;
    max-width: 580px;
    margin-inline: auto;
    margin-bottom: var(--sp-16);
  }

  .process__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
    margin-bottom: var(--sp-12);
    align-items: start;
  }

  .process__step {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .process__line-horizontal {
    height: 1px;
    background: linear-gradient(to right, rgba(6, 182, 212, 0.25), transparent);
    margin-bottom: var(--sp-2);
  }

  .process__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    flex: 1;
  }

  .process__detail {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cyan);
  }

  .process__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--white);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .process__body {
    font-size: var(--fs-sm);
    color: var(--navy-text-2);
    line-height: 1.75;
  }

  .process__vis {
    width: 100%;
    aspect-ratio: 16 / 10;
    min-height: 100px;
    margin-top: auto;
    border-radius: var(--r-lg);
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .process__vis--img {
    background: none;
    border: none;
    padding: 0;
  }

  .process__vis--img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-lg);
  }

  .process__vis span {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.12);
  }

  .process__cta { text-align: center; }

  @media (max-width: 768px) {
    .process__grid { grid-template-columns: 1fr; gap: var(--sp-10); }
    .process__line-horizontal { display: none; }
  }

  /* ═══════════════════════════════════════════════════════════
     WHAT SETS US APART
     ═══════════════════════════════════════════════════════════ */
  .apart__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: start;
  }

  .apart__left {
    position: sticky;
    top: calc(var(--sp-24));
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }

  .apart__lead {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
  }

  /* ── Comparison visual ── */
  .apart__visual {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
  }

  .apart__visual-inner {
    padding: var(--sp-8);
  }

  .apart__vis-compare {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .apart__vis-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .apart__vis-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .apart__vis-col--us .apart__vis-label {
    color: var(--sky);
  }

  .apart__vis-bars {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .apart__vis-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .apart__vis-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--cyan);
    flex-shrink: 0;
  }
  .apart__vis-dot--muted {
    background: var(--border-2);
  }

  .apart__vis-bar {
    height: 6px;
    background: var(--gradient-accent);
    border-radius: 3px;
  }
  .apart__vis-bar--muted {
    background: var(--border);
    opacity: 0.6;
  }

  .apart__vis-divider {
    height: 1px;
    background: var(--border);
  }

  .apart__vis-tag {
    display: inline-block;
    width: fit-content;
    padding: 3px 10px;
    border-radius: var(--r-full);
    background: rgba(14,165,233,0.08);
    color: var(--sky);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ── Cards grid ── */
  .apart__grid {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .apart__card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
    transition: all var(--t-base);
  }

  .apart__card:hover {
    border-color: var(--border-2);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .apart__card-metric {
    background: var(--off-white);
    padding: var(--sp-5) var(--sp-8);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
  }

  .apart__metric-value {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 700;
    color: var(--sky);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .apart__metric-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
