---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Pricing1 from '../../components/ui/Pricing.astro';
import FAQ from '../../components/FAQ.astro';

/* ── Betreuungspakete ── */
const plans = [
  { name: 'Foundation', popular: false, price: '1.700 €', href: '/de/kontakt?intent=retainer&tier=foundation' },
  { name: 'Growth', popular: true, price: '3.400 €', href: '/de/kontakt?intent=retainer&tier=growth' },
  { name: 'Scale', popular: false, price: '5.900 €', href: '/de/kontakt?intent=retainer&tier=scale' },
];

const features = [
  { label: 'Monatspreis',                       foundation: '1.700 €', growth: '3.400 €', scale: '5.900 €' },
  { label: 'Audit und Einrichtung',             foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Contentstrategie',                  foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Beiträge pro Monat',                foundation: '4', growth: '8', scale: '16' },
  { label: 'KI-generierte Visuals',             foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Community-Betreuung',               foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'LinkedIn-Werbung managen',          foundation: '-', growth: '✓', scale: '✓' },
  { label: 'Zielgruppen und Käuferprofil',      foundation: '-', growth: '✓', scale: '✓' },
  { label: 'Wettbewerbsbeobachtung',            foundation: '-', growth: '✓', scale: '✓' },
  { label: 'Performance-Reporting',             foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Wöchentlicher Strategie-Call',      foundation: '✓', growth: '✓', scale: '✓' },
  { label: 'Dedizierter Ansprechpartner',       foundation: 'Account Manager', growth: 'Account Manager', scale: 'Senior Lead' },
  { label: 'Chat-Support Mo bis Fr',            foundation: '✓', growth: '✓', scale: '✓' },
];

/* ── Ads-Vergleich ── */
const adsFeatures = [
  { label: 'Monatliche Gebühr',                       foundation: '1.500 €/Monat', growth: '6 % bis 10 % des Budgets' },
  { label: 'Vollumfängliche Ads-Strategie',           foundation: '✓', growth: '✓' },
  { label: 'Unbegrenzte Kampagnen und Anzeigen',      foundation: '✓', growth: '✓' },
  { label: 'Unbegrenzte Expertenbetreuung',           foundation: '✓', growth: '✓' },
  { label: 'Maßgeschneiderte Reportings',             foundation: '✓', growth: '✓' },
  { label: 'Empfehlungen zu Anzeigeninhalten',        foundation: '✓', growth: '✓' },
  { label: 'Wöchentliche Abstimmungen',               foundation: '-', growth: '✓' },
  { label: 'Performance-Analyse',                     foundation: '-', growth: '✓' },
  { label: 'Mikrosegmentierungsstrategie',            foundation: '-', growth: '✓' },
  { label: 'Volumenrabatte',                          foundation: '-', growth: '✓' },
];

/* ── Einfache Tabellen ── */
const execServices = [
  { service: 'Profiloptimierung für Geschäftsführung (einmalig)', price: '500 € pro Profil' },
  { service: 'Ghostwriting für Geschäftsführung (4 Beiträge/Monat + Profilpflege)', price: '1.200 €/Monat pro Person' },
];

const contentServices = [
  { service: 'KI-generierte Videos (5 bis 30 Sekunden)', price: '200 € bis 5.000 € pro Video' },
  { service: 'Professioneller Videodreh', price: 'Angebot auf Anfrage' },
  { service: 'Mehrsprachiger Content', price: 'Angebot pro Sprache' },
];

const trainingServices = [
  { service: 'LinkedIn-Workshop (2 Stunden)', price: '2.500 € pro Termin' },
  { service: 'Schulungsprogramm Team (4 Termine)', price: '8.000 € einmalig' },
  { service: 'Employee-Advocacy-Programm', price: '2.500 €/Monat' },
];

const bonusServices = [
  { model: 'Bonus für Lead-Ziele', percent: '+15 %', structure: 'des Monatshonorars, sobald die vereinbarten Lead-Ziele erreicht sind. Aktives LinkedIn-Werbebudget vorausgesetzt.' },
  { model: 'Bonus für Audience-Wachstum', percent: '+10 %', structure: 'des Monatshonorars, sobald die quartalsweisen Wachstumsziele übertroffen werden. Aktives LinkedIn-Werbebudget vorausgesetzt.' },
];

/* ── FAQ ── */
const faqs = [
  {
    q: 'Was ist im Preis enthalten?',
    a: 'Alles, was in Ihrem Paket aufgeführt ist: Strategie, Content, Visuals, Community-Betreuung, Reporting, wöchentlicher Call und ein dedizierter Ansprechpartner. Die einzige separat berechnete Position ist das LinkedIn-Werbebudget, und das läuft direkt über Ihr Konto, nicht über uns.',
  },
  {
    q: 'Warum drei Monate Mindestlaufzeit?',
    a: 'LinkedIn liefert nicht über Nacht. Wir brauchen Zeit, um Ihre Seite zu auditieren, eine Strategie aufzusetzen, regelmäßig zu veröffentlichen und den Algorithmus arbeiten zu lassen. Drei Monate sind das Minimum, um spürbare Bewegung zu sehen.',
  },
  {
    q: 'Können wir das Paket während der Zusammenarbeit wechseln?',
    a: 'Ja, ohne Aufwand. Nach den ersten drei Monaten können Sie zu jedem neuen Abrechnungszyklus hochstufen oder herunterstufen.',
  },
  {
    q: 'Garantieren Sie eine bestimmte Anzahl an Leads?',
    a: 'Nein. Und ehrlich gesagt: Wer Ihnen Lead-Zusagen verspricht, dem sollten Sie misstrauen. Was wir Ihnen zusichern, ist saubere Arbeit Woche für Woche, in Strategie, Content und Targeting. Mit dem optionalen Performance-Bonus verdienen wir nur dann mehr, wenn die gemeinsam definierten Ziele tatsächlich erreicht werden.',
  },
  {
    q: 'Was bedeutet "Zielgruppen und Käuferprofil"?',
    a: 'Im Kern ist das das Profil Ihres idealen Käufers. Wir identifizieren, wer Ihre besten Interessenten sind (nach Position, Branche, Unternehmensgröße, Region) und bauen Content und Kampagnen darauf auf. Enthalten in Growth und Scale.',
  },
  {
    q: 'Wie wird das Werbebudget abgerechnet?',
    a: 'Sie zahlen LinkedIn direkt aus Ihrem eigenen Konto, wir steuern die Kampagnen. Ihr Mediabudget läuft zu keinem Zeitpunkt über unsere Bücher. Damit bleibt die Mittelverwendung jederzeit nachvollziehbar.',
  },
  {
    q: 'Kann ich Ghostwriting für die Geschäftsführung ohne Retainer buchen?',
    a: 'Ja. Wir bieten den Service eigenständig an, in den Varianten Profiloptimierung, Ghostwriting oder beides in Kombination. Ein laufender Retainer ist dafür keine Voraussetzung.',
  },
  {
    q: 'Was kostet der Performance-Bonus, wenn das Ziel verfehlt wird?',
    a: 'Nichts. Der Bonus wird nur dann fällig, wenn wir die gemeinsam definierten Ziele erreichen oder übertreffen. Werden sie verfehlt, zahlen Sie Ihren regulären Retainer, mehr nicht.',
  },
  {
    q: 'Was ist der tatsächliche Unterschied zwischen Foundation und Growth?',
    a: 'Foundation sichert Ihnen Präsenz, also kontinuierlichen Content und eine gepflegte Community. Growth ist die Stufe, auf der die Leadgenerierung tatsächlich anläuft: Werbung, Targeting, Wettbewerbsbeobachtung und doppeltes Contentvolumen kommen hinzu. Wer Leads aus LinkedIn ziehen möchte, beginnt sinnvollerweise mit Growth.',
  },
  {
    q: 'Was passiert nach den ersten drei Monaten?',
    a: 'Ab dem vierten Monat wechseln Sie in den Monatsmodus: bleiben, das Paket anpassen oder mit 30 Tagen Frist kündigen. Strafgebühren oder Restlaufzeiten gibt es nicht.',
  },
];
---

<Layout
  lang="de"
  title="Preise für LinkedIn-Services für B2B-Unternehmen | Nuvora Studio"
  description="Unsere LinkedIn-Preise im Überblick. Drei Betreuungspakete, Werbeschaltung, Executive Branding und Schulungen. Klare Pakete, ausgelegt auf mehr qualifizierte Leads."
  abstract="Preise für LinkedIn-Services für B2B-Unternehmen. Drei Betreuungspakete von 1.700 € bis 5.900 €/Monat. Dazu Werbeschaltung, Executive Branding und Schulungen."
>
  <NavBar lang="de" />
  <main id="main-content">

    <!-- ═══ HERO ═══ -->
    <section class="pricing-hero" aria-labelledby="pricing-heading">
      <div class="pricing-hero__bg" aria-hidden="true"></div>
      <div class="pricing-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="pricing-hero__content">
          <p class="eyebrow eyebrow--light reveal">Preise</p>
          <h1 id="pricing-heading" class="pricing-hero__title reveal reveal-delay-1">
            Ein Ziel: mehr <span class="text-gradient">Leads über LinkedIn.</span>
          </h1>
          <p class="pricing-hero__sub reveal reveal-delay-2">
            Wählen Sie das Paket, das zu Ihrer aktuellen Lage passt. Strategie, Content,
            Reporting und ein dedizierter Ansprechpartner gehören in jeder Stufe zum Lieferumfang. Versteckte Kosten gibt es bei uns nicht, und über die ersten drei Monate hinaus bindet Sie ohnehin nichts an uns.
          </p>
          <div class="pricing-hero__actions reveal reveal-delay-3">
            <a href="#retainer" class="btn btn--primary btn--lg">Pakete ansehen</a>
            <a href="/de/kontakt?intent=call" class="btn btn--outline-white btn--lg">Gespräch vereinbaren</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ BETREUUNGSPAKETE ═══ -->
    <section class="section" id="retainer" aria-labelledby="retainer-heading">
      <div class="container">
        <div class="s-head reveal">
          <p class="eyebrow">Unsere Betreuungspakete</p>
          <h2 id="retainer-heading">Monatliche Betreuung Ihrer LinkedIn-Präsenz</h2>
          <p class="s-head__sub">Alle Pakete setzen eine Mindestlaufzeit von 3 Monaten voraus.</p>
        </div>

        <div class="reveal reveal-delay-1">
          <Pricing1 plans={plans} features={features} ctaLabel="Gespräch vereinbaren" popularLabel="Am häufigsten gewählt" periodLabel="/Monat" />
        </div>

        <div class="tier-cards reveal reveal-delay-2">
          <div class="tier-card">
            Mit <strong>Foundation</strong> legen Sie das Fundament: eine kontinuierliche, sauber aufgebaute LinkedIn-Präsenz, bevor Sie aufdrehen.
          </div>
          <div class="tier-card tier-card--pop">
            <strong>Growth</strong> ist die Stufe, auf der die Leadgenerierung Fahrt aufnimmt: Werbung, Targeting und doppeltes Contentvolumen kommen hinzu. Es ist unser meistgebuchtes Paket, aus guten Gründen.
          </div>
          <div class="tier-card">
            <strong>Scale</strong> richtet sich an Unternehmen, die Vollgas geben: 16 Beiträge im Monat, ein Senior Lead auf Ihrem Konto und alle unsere Disziplinen im orchestrierten Zusammenspiel.
          </div>
        </div>

        <p class="s-footnote reveal">
          Unsicher, welches Paket passt? <a href="/de/kontakt?intent=call">Vereinbaren Sie ein Gespräch</a>, wir gehen es gemeinsam durch.
        </p>
      </div>
    </section>

    <!-- ═══ EXECUTIVE BRANDING ═══ -->
    <section class="section exec-section" aria-labelledby="exec-heading">
      <div class="exec-section__bg" aria-hidden="true"></div>
      <div class="exec-section__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="exec-split">
          <div class="exec-split__text reveal">
            <p class="eyebrow">Ergänzend oder eigenständig</p>
            <h2 id="exec-heading">Sichtbarkeit der Geschäftsführung</h2>
            <p class="s-head__sub">
              Ihre Unternehmensseite erzählt eine Geschichte. Ihre Geschäftsführung erzählt eine andere. Entscheider prüfen beides, bevor sie sich melden.
            </p>
            <p class="s-head__note">
              Ein eigenständiger Service für Führungskräfte, die ihre LinkedIn-Präsenz selbst aufbauen wollen.
              Funktioniert allein oder ergänzend zu jedem Retainer.
            </p>
          </div>
          <div class="exec-split__cards reveal reveal-delay-1">
            {execServices.map(row => (
              <div class="exec-card">
                <p class="exec-card__label">{row.service}</p>
                <p class="exec-card__price">{row.price}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ LINKEDIN-ADS-MANAGEMENT ═══ -->
    <section class="section" aria-labelledby="ads-heading">
      <div class="container">
        <div class="s-head reveal">
          <p class="eyebrow">Eigenständiges Angebot</p>
          <h2 id="ads-heading">LinkedIn-Ads-Management</h2>
          <p class="s-head__sub">
            Für Unternehmen, die professionelles Ads-Management ohne vollständigen Retainer wünschen.
            Das Werbebudget wird separat über Ihr LinkedIn-Konto abgerechnet.
          </p>
          <p class="s-head__note">Beide Stufen setzen einen 3-Monats-Vertrag und eine einmalige Einrichtungsgebühr von 1.500 € voraus.</p>
        </div>

        <div class="ads-table reveal">
          <div class="ads-table__scroll">
            <table aria-label="Preisvergleich LinkedIn-Ads-Management">
              <thead>
                <tr>
                  <th class="ads-table__corner"></th>
                  <th class="ads-table__col-head">Werbebudget &lt; 15.000 €/Monat</th>
                  <th class="ads-table__col-head">Werbebudget &gt; 15.000 €/Monat</th>
                </tr>
              </thead>
              <tbody>
                {adsFeatures.map((row, i) => (
                  <tr class={i === 0 ? 'ads-table__row--price' : ''}>
                    <td class="ads-table__label">{row.label}</td>
                    <td class="ads-table__val">
                      {row.foundation === '✓' ? (
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-label="Enthalten"><path d="M4 9.5l3.5 3.5L14 6" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      ) : row.foundation === '-' ? (
                        <span class="ads-table__dash">-</span>
                      ) : (
                        <strong>{row.foundation}</strong>
                      )}
                    </td>
                    <td class="ads-table__val">
                      {row.growth === '✓' ? (
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-label="Enthalten"><path d="M4 9.5l3.5 3.5L14 6" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      ) : row.growth === '-' ? (
                        <span class="ads-table__dash">-</span>
                      ) : (
                        <strong>{row.growth}</strong>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ KONZERNE / ENTERPRISE ═══ -->
    <section class="section section--dark enterprise" aria-labelledby="enterprise-heading">
      <div class="enterprise__bg" aria-hidden="true"></div>
      <div class="enterprise__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">

        <div class="ent-top reveal">
          <p class="eyebrow eyebrow--light">Maßgeschneidert</p>
          <h2 id="enterprise-heading" class="ent-top__title">Konzerne</h2>
          <p class="ent-top__lead">
            Für international tätige Unternehmen, deren LinkedIn-Präsenz über Märkte, Teams und Sprachen hinweg funktionieren muss.
          </p>
        </div>

        <div class="ent-intro reveal">
          <p>
            Unsere Standardpakete passen für die meisten B2B-Unternehmen. Manche Organisationen brauchen mehr. Mehrere Regionen.
            Dutzende Geschäftsführerprofile. Content in vier Sprachen. Werbekampagnen, die parallel
            über APAC, Europa und Amerika laufen.
          </p>
          <p>Genau dafür ist das Konzern-Angebot da.</p>
          <p>
            Der Leistungsumfang wird entlang Ihrer Organisation konzipiert. Ein Standardpaket mit aufgedrucktem Logo verschicken wir nicht.
            Jedes Mandat beginnt mit einem Gespräch, in dem Ziele, Märkte, Verantwortlichkeiten und interne Abläufe
            aufgenommen werden.
          </p>
        </div>

        <div class="ent-grid">
          <!-- Was Konzernkunden in der Regel benötigen -->
          <div class="ent-block reveal">
            <h3 class="ent-block__title">Was Konzernkunden in der Regel benötigen</h3>
            <ul class="ent-list" role="list">
              <li>LinkedIn-Strategie über mehrere Märkte, Regionen und Sprachen hinweg</li>
              <li>Koordinierte Redaktionspläne für Unternehmensseiten und Geschäftsführerprofile</li>
              <li>Großflächige Employee-Advocacy-Programme</li>
              <li>Ein zentraler Ansprechpartner in Form eines Senior-Strategen, der den Gesamtblick wahrt</li>
              <li>LinkedIn-Ads-Management über mehrere Konten und Währungen</li>
              <li>Mehrsprachige Contentproduktion durch Autoren, die nicht nur die Sprache sicher beherrschen, sondern den jeweiligen Markt aus eigener Anschauung kennen</li>
              <li>Maßgeschneiderte Dashboards, abgestimmt auf Ihre internen Kennzahlen</li>
              <li>Quartalsweise Geschäftsreviews mit der Geschäftsführung</li>
            </ul>
          </div>

          <!-- So funktionieren die Preise + Für wen das Angebot gedacht ist -->
          <div class="ent-block reveal reveal-delay-1">
            <h3 class="ent-block__title">So funktionieren die Preise</h3>
            <div class="ent-block__text">
              <p>
                Konzernmandate werden individuell zugeschnitten und kalkuliert. Es gibt keinen Festpreis, weil kein Programm dem anderen gleicht.
                Der Preis ergibt sich aus Anzahl der Märkte, Profile, Contentvolumen, Werbekonten und Sprachen im Leistungsumfang.
              </p>
              <p class="ent-price-range">
                Die meisten Konzernmandate beginnen zwischen <strong>10.000 € und 25.000 € pro Monat.</strong>
                Manche liegen darüber. In jedem Fall erhalten Sie vor dem Start ein detailliertes, positionsweises Angebot. Überraschungen auf der Rechnung schließen wir damit aus.
              </p>
            </div>

            <h3 class="ent-block__title" style="margin-top: var(--sp-10);">Für wen das Angebot gedacht ist</h3>
            <ul class="ent-list" role="list">
              <li>International tätige Unternehmen mit Teams in mehreren Ländern</li>
              <li>Organisationen, die in neue Märkte expandieren, branchenübergreifend</li>
              <li>Unternehmen, für die LinkedIn strategisch geführt wird und nicht als Nebenkriegsschauplatz behandelt</li>
            </ul>
          </div>
        </div>

        <div class="ent-cta reveal">
          <p class="ent-cta__text">Wenn Sie über das Standardpaket hinausgewachsen sind, ist jetzt der richtige Zeitpunkt für ein Gespräch.</p>
          <a href="/de/kontakt?intent=enterprise" class="btn btn--primary btn--lg">Konzerngespräch vereinbaren</a>
        </div>

      </div>
    </section>

    <!-- ═══ CONTENT + SCHULUNG ═══ -->
    <section class="section" style="background: var(--off-white);" aria-labelledby="addons-heading">
      <div class="container">
        <div class="s-head reveal" style="text-align: center; max-width: 640px; margin-inline: auto;">
          <p class="eyebrow">Ergänzende Leistungen</p>
          <h2 id="addons-heading">Content, Schulung und Mitarbeitermobilisierung</h2>
          <p class="s-head__sub" style="margin-inline: auto;">
            Geschriebene Beiträge, KI-generierte Bilder und visuelle Assets sind in allen Paketen enthalten.
            Diese Leistungen sind auch separat buchbar.
          </p>
        </div>

        <div class="addon-grid">
          <!-- Contentproduktion -->
          <div class="addon-col reveal">
            <h3 class="addon-col__title">Contentproduktion</h3>
            {contentServices.map(row => (
              <div class="addon-item">
                <p class="addon-item__name">{row.service}</p>
                <p class="addon-item__price">{row.price}</p>
              </div>
            ))}
          </div>

          <!-- Trenner -->
          <div class="addon-divider" aria-hidden="true"></div>

          <!-- Schulung -->
          <div class="addon-col reveal reveal-delay-1">
            <h3 class="addon-col__title">Schulung und Employee Advocacy</h3>
            {trainingServices.map(row => (
              <div class="addon-item">
                <p class="addon-item__name">{row.service}</p>
                <p class="addon-item__price">{row.price}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ PERFORMANCE-BONUS ═══ -->
    <section class="section section--dark" aria-labelledby="bonus-heading">
      <div class="container container--md">
        <div class="s-head reveal" style="text-align: center;">
          <p class="eyebrow eyebrow--light">Optional</p>
          <h2 id="bonus-heading" style="color: var(--white);">Performance-Bonus</h2>
          <p class="s-head__sub" style="color: var(--navy-text-2); margin-inline: auto;">
            Verfügbar in Growth und Scale. Wir koppeln einen Teil unseres Honorars an die Ergebnisse.
            Erreichen wir die vereinbarten Ziele, erhalten wir einen Bonus.
            Verfehlen wir sie, zahlen Sie nur Ihren Retainer.
          </p>
        </div>

        <div class="bonus-grid">
          {bonusServices.map((b, i) => (
            <div class={`bonus-card reveal reveal-delay-${i + 1}`}>
              <span class="bonus-card__pct">{b.percent}</span>
              <p class="bonus-card__title">{b.model}</p>
              <p class="bonus-card__desc">{b.structure}</p>
              <span class="bonus-card__tag">Growth & Scale</span>
            </div>
          ))}
        </div>

        <p class="s-footnote reveal" style="color: var(--navy-text-3); text-align: center; margin-top: var(--sp-8);">
          Die Ziele werden gemeinsam zum Mandatsstart festgelegt und quartalsweise überprüft.
        </p>
      </div>
    </section>

    <!-- ═══ RECHTLICHER HINWEIS ═══ -->
    <div style="padding: var(--sp-10) 0; background: var(--off-white);">
      <div class="container">
        <p class="s-disclaimer reveal">
          Alle Preise verstehen sich in Euro, zzgl. gesetzlicher Umsatzsteuer. Das LinkedIn-Werbebudget wird separat über Ihr Konto abgerechnet.
          Maßgeschneiderte Angebote für Konzerne auf Anfrage.
        </p>
      </div>
    </div>

    <FAQ heading="Ihre Fragen zu den Preisen." faqs={faqs} id="pfaq" />

    <ContactCTA lang="de" />

  </main>
</Layout>

<style>
  /* ═══════════ HERO ═══════════ */
  .pricing-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .pricing-hero__bg {
    position: absolute;
    inset: 0;
    background: url('/pricing/hero-pipeline.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .pricing-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15, 23, 42, 0.94) 0%,
      rgba(15, 23, 42, 0.78) 50%,
      rgba(15, 23, 42, 0.50) 100%
    );
    z-index: 1;
  }

  .pricing-hero__content {
    max-width: 680px;
  }

  .pricing-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
