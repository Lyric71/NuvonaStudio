    date: '2026-03-29',
    readTime: '10 Min. Lesezeit',
    featured: false,
    image: '/blog/hero-ads-budget.webp',
  },
  // ── 23. März 2026 ──
  {
    slug: 'ihr-linkedin-beitrag-ist-bereits-tot',
    category: 'LinkedIn-Strategie',
    tags: ['Content'],
    title: "Ihr LinkedIn-Beitrag ist bereits tot. So holen Sie ihn zurück.",
    excerpt: "Der Feed ertrinkt in KI-Content. Ihr Fenster, gesehen zu werden, ist zwei Stunden lang. Wer das überlebt, hat etwas verstanden, das den meisten Marken bis heute entgeht.",
