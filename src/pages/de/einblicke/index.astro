  },
  {
    slug: 'headline-fehler-die-geschaeft-kosten',
    category: 'LinkedIn-Strategie',
    tags: ['Profil'],
    title: "Ihre LinkedIn-Headline kostet Sie Geschäft. So bringen Sie sie in Form.",
    excerpt: "Ihre LinkedIn-Headline taucht überall dort auf, wo Sie auf der Plattform sichtbar werden. Die meisten verschenken sie mit einer Berufsbezeichnung. Es gibt eine bessere Formel.",
    date: '2026-03-29',
    readTime: '7 Min. Lesezeit',
    featured: false,
    image: '/blog/hero-headline-fix.webp',
  },
  {
    slug: 'algorithmus-kleine-vs-grosse-accounts',
    category: 'LinkedIn-Strategie',
    tags: ['Algorithmus'],
    title: "Was die neue LinkedIn-Logik für kleine und große Accounts bedeutet",
    excerpt: "Der neue LinkedIn-Algorithmus belohnt Engagement-Qualität, nicht die Zahl der Follower. Kleine Accounts mit aktiven Netzwerken überholen große Accounts mit passivem Publikum.",
    date: '2026-03-29',
    readTime: '9 Min. Lesezeit',
    featured: false,
    image: '/blog/hero-small-vs-large.svg',
  },
  {
    slug: 'wachstum-auf-linkedin',
    category: 'LinkedIn-Strategie',
    tags: ['Wachstum'],
    title: "Wachsen auf LinkedIn, wenn fünfmal mehr Stimmen um Aufmerksamkeit kämpfen",
    excerpt: "LinkedIn zählt heute fünfmal mehr aktive Creator als 2023. Zwei Millionen Beiträge pro Tag. Aber weniger als 3 % der Mitglieder posten wöchentlich. Wer im Feed durchkommt, hat eines verstanden: Spezifik schlägt Reichweite.",
    date: '2026-03-29',
    readTime: '10 Min. Lesezeit',
    featured: false,
    image: '/blog/hero-grow-linkedin.svg',
  },
  {
    slug: 'warum-linkedin-ads-teurer-werden',
    category: 'LinkedIn-Werbung',
    tags: ['Werbung'],
    title: "Warum LinkedIn-Ads vier- bis sechsmal mehr pro Klick kosten, und wann es sich trotzdem rechnet",
