    padding: var(--sp-1) var(--sp-6);
    font-family: var(--font-body);
    font-size: var(--fs-md);
    font-style: italic;
    color: var(--text-2);
    line-height: 1.75;
  }

  /* ── Inline CTA ── */
  .post-inline-cta {
    margin-top: clamp(2.5rem, 4vw, 3.5rem);
    padding: var(--sp-8) var(--sp-10);
