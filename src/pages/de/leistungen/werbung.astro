---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';
import FAQ from '../../../components/FAQ.astro';

const capabilities = [
  {
    title: 'Kampagnenarchitektur',
    body: 'Wir bauen Ihre Kampagnenstruktur entlang Ihres Funnels. Jedes Format hat seine Aufgabe, jede Zielgruppe ihren Platz, jede Botschaft ihren Zweck. Überschneidungen vermeiden wir, ebenso Streuverluste ins Leere.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
      <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/>
    </svg>`,
  },
  {
    title: 'Zielgruppensteuerung',
    body: 'Wir bauen Zielgruppen nach Funktion, Seniorität, Firmenname, Unternehmensgröße, Branche und Kompetenzen. Account-based Campaigns erreichen genau die Menschen, die Verträge unterschreiben.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.6"/>
      <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
    </svg>`,
  },
  {
    title: 'Creatives und Anzeigentexte',
    body: 'Wir schreiben und gestalten jede Anzeige. Texte, die das Problem Ihres Kunden treffen. Creatives, die im LinkedIn-Feed funktionieren. Tests in einzelnen Segmenten, bevor Budget skaliert wird.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    title: 'Alle Formate aus einer Hand',
    body: 'Wir betreiben jedes LinkedIn-Anzeigenformat als zusammenhängendes System. Keine isolierten Einzelkampagnen, sondern eine durchgehende Funnel-Maschine, die am Ende qualifizierte Leads liefert.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 6h16M4 10h16M4 14h16M4 18h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
  },
  {
    title: 'KI-gestützte Optimierung',
    body: 'KI generiert und testet Anzeigentexte, Varianten und Creatives in unterschiedlichen Zielgruppen. Wir wissen pro Funktion und Seniorität, was zieht, bevor das volle Budget läuft. Kampagnen werden Woche für Woche besser.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    title: 'Reporting mit CRM-Anschluss',
    body: 'Wir berichten gegen Pipeline statt gegen Impressions. Jeder Bericht zeigt Ausgaben, Tests, Conversions und die nächste Anpassung, ohne Fachjargon und ohne Eitelkeitsmetriken.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M7 17V13M12 17V9M17 17V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
  },
];

const adFormats = [
  {
    title: 'Sponsored Content',
    body: 'Das Arbeitspferd der LinkedIn-Werbung. Acht Unterformate: Einzelbild, Karussell, Video, Dokument, Event, Thought Leader, Artikel und Connected-TV-Anzeigen. Wir setzen Sponsored Content ein, um Aufmerksamkeit aufzubauen, Interaktion zu erzeugen und den oberen Funnel mit qualifiziertem Traffic zu versorgen.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
    image: '/images/advertising-sponsored-content.webp',
    imageAlt: 'Visual einer Sponsored-Content-Kampagne',
  },
  {
    title: 'Sponsored Messaging',
    body: 'Message Ads und Conversation Ads, ausgespielt direkt im LinkedIn-Postfach Ihrer Interessenten. Message Ads transportieren genau eine Botschaft mit einer CTA. Conversation Ads bieten dem Empfänger mehrere Pfade zur Wahl. Beide werden in dem Moment ausgeliefert, in dem Ihre Zielgruppe aktiv ist und bereit zu reagieren.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
    image: '/images/advertising-sponsored-messaging.webp',
    imageAlt: 'Visual einer Sponsored-Messaging-Kampagne',
  },
  {
    title: 'Dynamic Ads',
    body: 'Anzeigen, die sich automatisch personalisieren, indem sie die LinkedIn-Profildaten des Empfängers nutzen. Follower Ads vergrößern die Reichweite Ihrer Seite. Spotlight Ads lenken Traffic auf Ihre Website. Content Ads gewinnen Leads beim Download eines Assets. Keine manuelle Anzeigenproduktion für jeden Empfänger nötig.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
    </svg>`,
    image: '/images/advertising-dynamic-ads.webp',
    imageAlt: 'Visual einer Dynamic-Ads-Kampagne',
  },
  {
    title: 'Textanzeigen',
    body: 'Self-Service-PPC in der Desktop-Sidebar. Niedrigste Kosten, niedrigste Einstiegshürde. Keine Verträge. Wir nutzen Textanzeigen als Präzisionswerkzeug innerhalb der Gesamtkampagne, nicht als isolierte Taktik.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 6h16M4 10h16M4 14h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <rect x="16" y="14" width="5" height="7" rx="1" stroke="currentColor" stroke-width="1.6"/>
    </svg>`,
    image: '/images/advertising-text-ads.webp',
    imageAlt: 'Visual einer Textanzeigen-Kampagne',
  },
  {
    title: 'Lead Gen Forms',
    body: 'Vorausgefüllte Formulare innerhalb von LinkedIn. Zwei Klicks und der Lead landet in Ihrem CRM, ganz ohne Landingpage und ohne dass der Interessent etwas doppelt eingeben müsste. Wir kombinieren Lead Gen Forms mit Sponsored Content und Messaging-Kampagnen, um die Conversion in jeder Funnel-Stufe anzuheben.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="5" y="3" width="14" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/>
      <path d="M9 7h6M9 11h6M9 15h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    </svg>`,
    image: '/images/advertising-lead-gen-forms.webp',
    imageAlt: 'Visual zu Lead Gen Forms',
  },
];

const differentiators = [
  {
    title: 'Wir sind LinkedIn-Advertising-zertifiziert.',
    body: 'Das ist kein Logo, das wir aufs Impressum kleben. Zertifizierung heißt, dass unser Team die offizielle LinkedIn-Prüfung zu Kampagnenstrategie, Anzeigenformaten, Targeting, Messung und Optimierung bestanden hat. Sie arbeiten mit einem Team, das auf dem höchsten Standard der Plattform operiert.',
  },
  {
    title: 'Wir denken in Funneln, nicht in einzelnen Formaten.',
    body: 'Bei vielen Agenturen läuft Sponsored Content als Einzeltaktik, daneben ein bisschen Lead Gen Forms. Wir bauen ein Full-Funnel-System, in dem jedes Format seine eigene Rolle übernimmt, von der ersten Aufmerksamkeit bis zur Conversion. So sinken Ihre Cost per Lead, während die Qualität der Leads steigt.',
  },
  {
    title: 'Wir messen Umsatz statt Reichweite.',
    body: 'Impressions bezahlen keine Rechnungen. Wir verbinden Ihre LinkedIn-Kampagnen mit dem CRM, damit Sie sehen, welche Anzeige Pipeline erzeugt. Wöchentlich optimieren wir auf die Kennzahlen, die für den Vertrieb tatsächlich zählen.',
  },
  {
    title: 'Wir testen, bevor wir ausgeben.',
    body: 'KI ermöglicht uns, dutzende Varianten von Anzeigentexten, Headlines und CTAs zu generieren und zu testen, bevor das Budget in die Skalierung geht. Wenn wir hochskalieren, wissen wir bereits, was bei Ihrer Zielgruppe funktioniert.',
  },
  {
    title: 'Wir übernehmen alles.',
    body: 'Strategie, Creatives, Targeting, Launch, Optimierung, Reporting: alles bei uns. Sie brauchen keinen separaten Strategen, keinen externen Designer und keinen zusätzlichen Media-Buyer. Ein Team, ein System, ein Ansprechpartner, der die Verantwortung trägt.',
  },
  {
    title: 'Wir kennen B2B.',
    body: 'E-Commerce-Anzeigen bauen wir nicht nebenher. LinkedIn-Werbung für B2B ist alles, was wir tun. Wir verstehen lange Vertriebszyklen, mehrere Entscheider und warum ein 200-Euro-Lead 200.000 Euro Vertragswert wert sein kann.',
  },
];

const steps = [
  {
    num: '01',
    title: 'Sondierung',
    body: 'Wir lernen Ihr Geschäft, Ihre Kunden und Ihre Pipeline-Ziele kennen. Wir auditieren Ihre aktuelle LinkedIn-Präsenz und Ihren Werbeverlauf. Wir identifizieren, was funktioniert, was nicht und wo die eigentliche Chance liegt.',
  },
  {
    num: '02',
    title: 'Aufbau',
    body: 'Wir entwerfen die Kampagnenarchitektur, bauen die Zielgruppen, schreiben die Anzeigentexte und gestalten die Creatives. Alles strukturiert um Ihren Funnel und Ihren Vertriebszyklus.',
  },
  {
    num: '03',
    title: 'Launch und Test',
    body: 'Wir gehen mit Ihren Kampagnen live und testen vom ersten Tag an. Texte, Creatives, Zielgruppen, Formate, CTAs laufen parallel. KI beschleunigt den Prozess, sodass Gewinner früher sichtbar werden.',
  },
  {
    num: '04',
    title: 'Optimieren und skalieren',
    body: 'Wir optimieren wöchentlich anhand dessen, was Pipeline bringt, nicht nur anhand von Klicks. Mit zunehmender Reife der Kampagnen skalieren wir, was funktioniert, und stoppen, was nicht trägt. Sie erhalten einen Monatsbericht, der Werbeausgaben mit Umsatz verbindet.',
  },
];

const stats = [
  { number: '121 %', label: 'ROAS', note: 'Return on Ad Spend von LinkedIn im B2B, gegenüber 67 % bei Google Search und 51 % bei Meta.', source: 'Quelle: Dreamdata 2026 Benchmarks Report' },
  { number: '6,1 %', label: 'Conversion-Rate', note: 'Durchschnittliche US-LinkedIn-Conversion-Rate, gegenüber 3,75 % bei Google Search und 0,77 % bei Google Display.' },
  { number: '80 %', label: 'B2B-Leads', note: 'Anteil aller B2B-Leads aus sozialen Netzwerken, die von LinkedIn stammen.' },
  { number: '41 %', label: 'Anteil am Werbebudget', note: 'LinkedIns Anteil an den gesamten B2B-Werbebudgets. Die größte Einzelinvestition auf einer Plattform im B2B.' },
  { number: '10–13 %', label: 'CVR Lead Gen Forms', note: 'Conversion-Rate von Lead Gen Forms gegenüber 2,35 % bei klassischen B2B-Landingpages.' },
  { number: '4 von 5', label: 'Entscheidern', note: 'LinkedIn-Mitgliedern, die an geschäftlichen Entscheidungen in ihrem Unternehmen beteiligt sind.' },
  { number: '211', label: 'Tage bis zum Abschluss', note: 'Durchschnittliche Dauer einer B2B-Kaufreise von Erstkontakt bis Vertrag. Genau deshalb braucht es ein Full-Funnel-System.' },
  { number: '33 %', label: 'Kaufabsicht', note: 'Anstieg der Kaufabsicht bei Marken, die auf LinkedIn werben.' },
];

const faqs = [
  {
    q: 'Was bedeutet eigentlich „LinkedIn Advertising Certified"?',
    a: 'Das bedeutet, dass unser Team das offizielle Zertifizierungsprogramm von LinkedIn zu Kampagnenstrategie, Anzeigenformaten, Zielgruppensteuerung, Messung und Optimierung absolviert und bestanden hat. Es ist der eigene Standard von LinkedIn für Werbeexpertise. Nicht jede Agentur hat ihn. Wir schon.',
  },
  {
    q: 'Welche LinkedIn-Anzeigenformate betreuen Sie?',
    a: 'Alle fünf: Sponsored Content (alle acht Unterformate), Sponsored Messaging (Message Ads und Conversation Ads), Dynamic Ads, Textanzeigen und Lead Gen Forms. Wir betreiben sie als ein zusammenhängendes System, nicht als isolierte Kampagnen.',
  },
  {
    q: 'Übernehmen Sie auch Strategie und Creatives oder nur das Mediabuying?',
    a: 'Alles. Wir starten mit Ihrer Zielgruppe, Ihrem Funnel und Ihren Pipeline-Zielen. Daraus bauen wir die Architektur, schreiben die Texte, gestalten die Creatives, launchen, testen und optimieren. Ein Team verantwortet den gesamten Prozess.',
  },
  {
    q: 'Wie sieht Ihr Reporting aus?',
    a: 'Wir berichten gegen Pipeline. Sie erhalten wöchentliche Optimierungs-Updates und einen monatlichen Performance-Report. Jeder Bericht zeigt, was wir ausgegeben und getestet haben, was funktioniert und was wir als Nächstes anpassen. Kein Fachjargon, keine Eitelkeitsmetriken.',
  },
  {
    q: 'Wie setzen Sie KI ein?',
    a: 'KI generiert und testet Anzeigentexte, Varianten und Creatives in unterschiedlichen Zielgruppen. Wir finden heraus, was nach Funktion und Seniorität am besten performt, bevor Ihr volles Budget eingesetzt wird. Das Ergebnis: schnellere Optimierung und niedrigere Kosten pro Lead.',
  },
  {
    q: 'Wie hoch ist Ihr Mindest-Werbebudget?',
    a: 'Wir arbeiten mit B2B-Unternehmen, die LinkedIn als Leadkanal ernst nehmen. Liegt Ihr monatliches Werbebudget unter 5.000 €, ist LinkedIn vermutlich noch nicht das richtige Format. Das sagen wir Ihnen direkt im ersten Gespräch.',
  },
  {
    q: 'Wann sehe ich erste Ergebnisse?',
    a: 'Die meisten Kunden sehen innerhalb der ersten 30 Tage qualifizierte Leads. Aber LinkedIn ist ein Full-Funnel-Kanal. Die durchschnittliche B2B-Kaufreise dauert 211 Tage. Der eigentliche Wert wächst über Monate, je mehr Daten Ihre Kampagnen sammeln, je präziser das Targeting wird und je voller die Pipeline läuft.',
  },
  {
    q: 'Brauche ich eine starke LinkedIn-Unternehmensseite, bevor Anzeigen laufen?',
    a: 'Es hilft, aber es ist kein Ausschlusskriterium. Wer Ihre Anzeige sieht, prüft oft erst Ihre Unternehmensseite, bevor er reagiert. Wir beraten zum Aufbau der Seite oder übernehmen ihn als Teil des Onboardings, damit die Seite vor dem ersten Anzeigenstart bereit ist.',
  },
  {
    q: 'Können Sie bestimmte Unternehmen oder Funktionen gezielt erreichen?',
    a: 'Ja. LinkedIns Targeting ist im B2B das präziseste, das es gibt. Wir steuern nach Funktion, Seniorität, Firmenname, Unternehmensgröße, Branche, Kompetenzen und mehr. Sie erreichen genau die Menschen, die Kaufentscheidungen treffen.',
  },
  {
    q: 'Mit welchen Branchen arbeiten Sie?',
    a: 'B2B-Unternehmen aus Technologie, Industrie, Professional Services, SaaS, Gesundheitswesen und weiteren Bereichen. Wenn Ihre Kunden auf LinkedIn sind und Ihre Abschlüsse mindestens 20.000 € wert sind, lässt sich eine Kampagne aufsetzen, die sich selbst trägt.',
  },
  {
    q: 'Wie steige ich ein?',
    a: 'Vereinbaren Sie ein Gespräch. Wir schauen uns Ihre aktuelle LinkedIn-Präsenz an, sprechen über Ihre Pipeline-Ziele und sagen Ihnen, ob LinkedIn-Werbung für Ihr Geschäft der richtige Kanal ist. Ohne Verkaufsfolien, ohne Drängen.',
  },
];
---

<Layout
  lang="de"
  title="LinkedIn-Werbeleistungen | Mehr B2B-Leads gewinnen"
  description="Wir betreiben jedes LinkedIn-Anzeigenformat als ein System für B2B-Leadgenerierung. Präzises Targeting, KI-gestützte Optimierung und Reporting, das auf Pipeline zielt."
  abstract="Wir betreiben jedes LinkedIn-Anzeigenformat, um Ihre B2B-Leads zu vermehren. Präzises Targeting, Full-Funnel-Kampagnen und Reporting gegen Pipeline, nicht gegen Impressions."
>
  <NavBar lang="de" />
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="ads-hero" aria-labelledby="ads-heading">
      <div class="ads-hero__bg" aria-hidden="true"></div>
      <div class="ads-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="ads-hero__content">
          <p class="eyebrow eyebrow--light reveal">LinkedIn-Werbung</p>
          <h1 id="ads-heading" class="ads-hero__h1 reveal reveal-delay-1">
            LinkedIn-Anzeigen, die aus Klicks <span class="text-gradient">Pipeline machen.</span>
          </h1>
          <p class="ads-hero__sub reveal reveal-delay-2">
            Sie wissen, dass Ihre Kunden auf LinkedIn sind. Wir sorgen dafür, dass Ihre Anzeigen die richtigen erreichen, zur richtigen Zeit, mit der richtigen Botschaft. Und dass daraus Leads werden, die der Vertrieb auch abschließt.
          </p>
          <div class="ads-hero__actions reveal reveal-delay-3">
            <a href="/de/kontakt?intent=call" class="btn btn--primary btn--lg">Gespräch vereinbaren</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── The Problem ─────────────────────────────────────── -->
    <section class="section problem" aria-labelledby="problem-heading">
      <div class="container">
        <div class="problem__inner">
          <div class="problem__text">
            <h2 id="problem-heading" class="problem__h2 reveal">Die meisten B2B-Unternehmen verbrennen ihr Geld auf LinkedIn</h2>
            <div class="problem__body">
              <p class="problem__p reveal">Ein Beitrag wird gepusht. Die Zielgruppe ist breit gewählt. Dann wird auf das Beste gehofft.</p>
              <p class="problem__p reveal">Das Ergebnis: hohe Klickpreise, schlechte Leads, keine klare Verbindung von Werbeausgaben zu Umsatz.</p>
              <p class="problem__p reveal">LinkedIn-Werbung funktioniert. Aber nur, wenn sie als System gebaut ist, nicht als Sammlung unverbundener Kampagnen.</p>
              <p class="problem__p problem__p--highlight reveal">Genau das ist unsere Aufgabe.</p>
            </div>
          </div>
          <div class="problem__visual reveal reveal-delay-2" aria-hidden="true">
            <div class="problem__graphic">
              <div class="problem__bar problem__bar--1"><span>Verbranntes Budget</span></div>
              <div class="problem__bar problem__bar--2"><span>Schwache Leads</span></div>
              <div class="problem__bar problem__bar--3"><span>Keine Attribution</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── What We Do ──────────────────────────────────────── -->
    <section class="section what-we-do" aria-labelledby="wwd-heading">
      <div class="container">
        <div class="wwd__head reveal">
          <p class="eyebrow">Unser Leistungsspektrum</p>
          <h2 id="wwd-heading" class="wwd__h2">Wir bauen und betreiben Ihre gesamte LinkedIn-Werbemaschine</h2>
          <p class="wwd__intro">Wir reichen Ihnen kein Strategiedeck und wünschen viel Erfolg. Wir verantworten den gesamten Prozess, von der Zielgruppe bis zur Pipeline. Unser Team ist LinkedIn Advertising Certified und erfüllt damit den eigenen Standard der Plattform für Strategie, Targeting und Optimierung.</p>
        </div>

        <div class="wwd__grid">
          {capabilities.map((cap, i) => (
            <div class={`wwd-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="wwd-card__top">
                <span class="wwd-card__icon" aria-hidden="true" set:html={cap.icon} />
              </div>
              <strong class="wwd-card__title">{cap.title}</strong>
              <p class="wwd-card__body">{cap.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── Ad Formats We Run ───────────────────────────────── -->
    <section class="section formats-section" aria-labelledby="formats-heading">
      <div class="container">
        <div class="formats__head reveal">
          <p class="eyebrow">Anzeigenformate</p>
          <h2 id="formats-heading" class="formats__h2">Jedes LinkedIn-Anzeigenformat. Ein zertifiziertes Team.</h2>
          <p class="formats__intro">LinkedIn bietet fünf zentrale Anzeigenformate. Jedes erfüllt eine andere Aufgabe im Funnel. Die meisten Agenturen nutzen ein oder zwei. Wir betreiben alle fünf als ein zusammenhängendes System, denn nur so führen Sie Interessenten vom ersten Eindruck bis zum Vertragsabschluss. Unser LinkedIn-Advertising-zertifiziertes Team weiß, wann und wie jedes Format einzusetzen ist.</p>
        </div>

        {adFormats.map((fmt, i) => (
          <div class={`fmt-block${i % 2 === 1 ? ' fmt-block--flip' : ''} reveal`} id={`fmt-${i}`}>
            <div class="fmt-block__text">
              <div class="fmt-block__label">
                <span class="fmt-block__icon" aria-hidden="true" set:html={fmt.icon} />
              </div>
              <h3 class="fmt-block__title">{fmt.title}</h3>
              <p class="fmt-block__body">{fmt.body}</p>
            </div>
            <div class="fmt-block__visual">
              <div class="fmt-block__img-wrap">
                <img
                  src={fmt.image}
                  alt={fmt.imageAlt}
                  class="fmt-block__img"
                  width="560"
                  height="380"
                  loading="lazy"
                />
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── Why Work With Us ────────────────────────────────── -->
    <section class="section why-us" aria-labelledby="why-heading">
      <div class="why-us__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="why__head reveal">
          <p class="eyebrow eyebrow--light">Warum wir</p>
          <h2 id="why-heading" class="why__h2">Was uns unterscheidet</h2>
        </div>

        <div class="why__layout">

          <!-- Left: Visual column -->
          <div class="why__visual reveal">
            <!-- Team photo placeholder -->
            <div class="why__photo-wrap">
              <img
                src="/images/advertising-team.webp"
                alt="Das Team von Nuvora Studio"
                class="why__photo"
                width="480"
                height="560"
                loading="lazy"
              />
            </div>

            <!-- Certification badge -->
            <div class="why__cert">
              <div class="why__cert-badge">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                  <path d="M14 2l3.09 6.26L24 10l-6.91 2.74L14 22l-3.09-9.26L4 10l6.91-1.74L14 2z" fill="var(--cyan)"/>
                  <circle cx="14" cy="12" r="5" fill="var(--deep-navy)" stroke="var(--cyan)" stroke-width="1.5"/>
