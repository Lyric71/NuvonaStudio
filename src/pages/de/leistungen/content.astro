---
import Layout from '../../../layouts/Layout.astro';
import NavBar from '../../../components/NavBar.astro';
import FAQ from '../../../components/FAQ.astro';

/* ── Daten ──────────────────────────────────────────────── */

const overviewCards = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="7" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.6"/><line x1="9" y1="12" x2="15" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="9" y1="16" x2="13" y2="16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>`,
    title: 'Betreuung der Unternehmensseite',
    text: 'Ihr erster Eindruck im Netz, von Grund auf gebaut und im laufenden Betrieb geführt.',
    href: '#svc-company-page',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'Contentproduktion und Redaktion',
    text: 'Alle Formate, jede Woche, in jedem Markt. Inhalte, die Autorität aufbauen.',
    href: '#svc-content-production',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>`,
    title: 'LinkedIn Newsletter',
    text: 'Eine direkte Verbindung zu den Entscheidern, auf die es für Ihr Geschäft ankommt.',
    href: '#svc-newsletter',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.6"/><rect x="7" y="14" width="3" height="3" rx="0.5" fill="currentColor" opacity="0.7"/></svg>`,
    title: 'LinkedIn Events',
    text: 'Das Format mit der höchsten Interaktionsrate auf LinkedIn. Sauber umgesetzt, ohne Risiko.',
    href: '#svc-events',
  },
];

const whatWeDo = [
  { title: 'Wir übernehmen Ihre gesamte Contentproduktion.', body: 'Strategie, Redaktionsplan, Produktion, Veröffentlichung, Reporting. Sie geben frei. Wir machen den Rest. Ihr Team bleibt frei für die eigentliche Arbeit.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/><rect x="14" y="14" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="1.6"/></svg>` },
  { title: 'Wir schreiben in Ihrer Stimme.', body: 'Jede Marke klingt anders. Wir hören Ihrem Team zu, verstehen den Markt und die Zielgruppe, die Sie erreichen wollen. Erst dann setzen wir uns ans Schreiben. Das Ergebnis liest sich, als käme es aus Ihrem Haus. Sonst schreiben wir es neu.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>` },
  { title: 'Wir produzieren Inhalte in jeder Sprache Ihrer Kunden.', body: 'Nicht übersetzt, sondern in der Zielsprache neu verfasst. Wenn Ihre Kunden auf Englisch, Mandarin, Spanisch oder Portugiesisch lesen, schreiben wir für dieses Publikum von Grund auf.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M3.5 9h17M3.5 15h17" stroke="currentColor" stroke-width="1.6"/><ellipse cx="12" cy="12" rx="4" ry="9" stroke="currentColor" stroke-width="1.6"/></svg>` },
  { title: 'KI gibt Tempo. An der Qualität ändert das nichts.', body: 'Künstliche Intelligenz beschleunigt Recherche, Entwürfe, mehrsprachige Produktion, Visuals und Schnitt. Unsere Redaktion prüft jede Ausgabe. Sie geben jedes Stück frei. Mehr Inhalte, schneller produziert, geringere Stückkosten. Die Qualität bleibt, weil die finale Entscheidung der Mensch trifft.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.09 6.26L20 10l-5.91 1.74L12 18l-2.09-6.26L4 10l5.91-1.74L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>` },
  { title: 'Wir berichten, was für Ihr Geschäft zählt.', body: 'Monatliches Reporting, gekoppelt an Ihre kommerziellen Ziele. Was passiert ist, warum, und was wir als Nächstes verändern. Keine Dashboards voller Zahlen, mit denen der Vertrieb nichts anfangen kann.', icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M7 17V13M12 17V9M17 17V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>` },
];

const whyBlocks = [
  { title: 'LinkedIn ist das Einzige, was wir tun.', body: 'Andere Agenturen bedienen LinkedIn als einen von fünfzehn Kanälen mit. Bei uns ist die Plattform alles. Unsere Arbeitsabläufe und Redaktionsprozesse sind dafür aufgesetzt, ebenso unsere Kennzahlen. Sonst nichts.' },
  { title: 'Mehrsprachig vom ersten Tag an.', body: 'Die meisten Agenturen übersetzen englischen Content und nennen das Lokalisierung. Wir schreiben in jeder Sprache nativ. Ihr deutscher Content liest sich so, als hätte ihn jemand verfasst, der auf Deutsch denkt. Weil das tatsächlich so ist.' },
  { title: 'KI-gestützte Produktion, redaktioneller Anspruch.', body: 'Wir nutzen KI-Werkzeuge entlang des gesamten Workflows. Recherche, erste Entwürfe, Visuals, Videoschnitte. Aber jede Ausgabe durchläuft unsere Redaktion, bevor Sie sie zu sehen bekommen. Die KI liefert Tempo. Das Team liefert die Qualität, die Ihre Marke braucht.' },
  { title: 'Alles gehört Ihnen.', body: 'Inhalte, Abonnentenlisten, Anmeldedaten, kreative Vorlagen. Alles in Ihrem Besitz. Gehen Sie morgen, kommt alles mit. Keine Geiselhaft.' },
];

const services = [
  {
    id: 'svc-company-page',
    title: 'Betreuung der Unternehmensseite',
    short: 'Ihr erster globaler Eindruck, von Grund auf gebaut und im laufenden Betrieb geführt.',
    details: [
      'Audit und Neuaufbau (Banner, Über-uns-Bereich, Highlight-Inhalte, Schlagwort-Tags)',
      'Monatliche Contentbetreuung, abgestimmt auf den LinkedIn-Algorithmus und Ihre vertrieblichen Prioritäten',
      'Alle LinkedIn-Formate: Textbeiträge, Karussells, Videos, Dokumente, Umfragen',
      'Follower-Wachstum durch Employee Advocacy, gezielte Kampagnen und Inhalte, die zirkulieren',
      'Monatliches Reporting: was passiert ist, warum, was wir als Nächstes ändern',
    ],
    trust: 'KI-gestützt, redaktionell geführt. Das Tempo kommt aus der Maschine, die Qualität aus dem Team.',
    footnote: 'Nichts geht live ohne Ihre Freigabe. Alles, was wir bauen, gehört Ihnen.',
    stat: null,
    image: '/images/content-company-page.webp',
    imageAlt: 'Dashboard zur Verwaltung der Unternehmensseite',
  },
  {
    id: 'svc-content-production',
    title: 'Contentproduktion und Redaktion',
    short: 'Alle Formate, jede Woche, in jedem Markt.',
    details: [
      'Jedes LinkedIn-Format mit Bedacht gewählt, nicht aus Gewohnheit',
      'Ghostwriting für die Geschäftsführung: Ihre Führungskräfte haben das Fachwissen, wir geben ihm eine Stimme',
      'Mehrsprachige Inhalte, in jeder Sprache nativ verfasst',
      'Redaktionsplan einen Monat im Voraus: geschrieben, lektoriert, freigegeben, pünktlich veröffentlicht',
    ],
    trust: 'KI beschleunigt Recherche, Entwürfe und mehrsprachige Produktion. Unsere Redaktion sichert, dass jede Ausgabe Ihrem Markenanspruch standhält.',
    footnote: 'Sie geben jeden Beitrag frei. Stimmt etwas nicht, schreiben wir neu. Ohne Ausnahme.',
    stat: null,
    image: '/images/content-production.webp',
    imageAlt: 'Ablauf der Contentproduktion',
  },
  {
    id: 'svc-newsletter',
    title: 'LinkedIn Newsletter',
    short: 'Eine direkte Leitung zu den Entscheidern, auf die es für Ihr Geschäft ankommt.',
    details: [
      'Redaktionelles Konzept: wofür Ihr Newsletter steht, wem er dient, warum man abonniert bleibt',
      'Komplette Produktion: Recherche, Text, Lektorat, Betreffzeile, Handlungsaufrufe',
      'Abonnentenwachstum: organische und bezahlte Akquise über Ihre Unternehmensseite, Führungskräfte-Profile und gezielte Kampagnen',
      'Performance-Tracking: Öffnungsraten, Klicks, Abonnentenwachstum, klare Einordnung nach jeder Ausgabe',
    ],
    trust: 'KI beschleunigt Themenrecherche, Zielgruppenanalyse und mehrsprachige Entwürfe. Stimme und finaler Text bleiben menschlich.',
    footnote: 'Die Abonnentenliste gehört ausschließlich Ihnen. Immer.',
    stat: null,
    image: '/images/content-newsletter.webp',
    imageAlt: 'Layout eines LinkedIn-Newsletters',
  },
  {
    id: 'svc-events',
    title: 'LinkedIn Events',
    short: 'Das Format mit der höchsten Interaktionsrate auf LinkedIn. Jede Anmeldung ist ein namentlicher Lead.',
    details: [
      'Konzept und Positionierung: klarer Aufhänger, präzise definierte Zielgruppe, ausgelegt darauf, Plätze zu füllen',
      'Bewerbungskampagne: mehrere Kontaktpunkte, vier Wochen vor dem Termin, organisch und bezahlt',
      'Vorbereitung der Sprecher: jede Person gebrieft, vorbereitet und technisch geprüft',
      'Live-Betreuung: wir steuern die Session, Sie konzentrieren sich auf den Inhalt',
      'Inhalte nach der Veranstaltung: Aufzeichnung, Clips, schriftliche Zusammenfassung, Social-Posts',
      'Follow-up-Playbook: Daten der Angemeldeten plus konkreter Aktionsplan für Ihren Vertrieb',
    ],
    trust: 'KI verarbeitet Aufzeichnungen, erstellt Clips und bringt Schlüsselmomente in alle LinkedIn-Formate.',
    footnote: 'Alle Assets und Anmeldedaten gehören Ihnen. Trägt das Konzept nicht, sagen wir es in Woche eins.',
    stat: '100 % Eigentum an den Anmeldedaten',
    image: '/images/content-events.webp',
    imageAlt: 'Visual zur Bewerbung eines LinkedIn-Events',
  },
];

const cardIcons = overviewCards.map(c => c.icon);

const stats = [
  { value: '80 %', label: 'aller B2B-Leads aus sozialen Netzwerken stammen von LinkedIn.', context: 'Keine andere Plattform kommt auch nur in die Nähe.', source: 'LinkedIn Marketing Solutions / Cognism' },
  { value: '7x', label: 'schnelleres Follower-Wachstum für Seiten, die wöchentlich veröffentlichen.', context: 'Kontinuität ist mit Abstand der wichtigste Hebel für Reichweite.', source: 'LinkedIn' },
  { value: '5x', label: 'mehr Interaktion bei Videoinhalten gegenüber statischen Beiträgen.', context: 'Das Format zählt genauso wie der Inhalt.', source: 'LinkedIn' },
  { value: '59 %', label: 'der B2B-Entscheider halten Fachpublikationen für die vertrauenswürdigste Quelle, um ein Unternehmen einzuschätzen.', context: 'Vertrauenswürdiger als jede andere Werbeform.', source: 'LinkedIn / Edelman' },
  { value: '4 von 5', label: 'LinkedIn-Mitgliedern sind an Kaufentscheidungen ihres Unternehmens beteiligt.', context: 'Ihr Content erreicht Menschen, die tatsächlich kaufen können.', source: 'LinkedIn' },
  { value: '2x', label: 'höhere Conversion-Raten auf LinkedIn gegenüber anderen Netzwerken.', context: 'Das Publikum ist bereits im Arbeitsmodus.', source: 'LinkedIn Marketing Solutions' },
  { value: '277 %', label: 'effektiver in der Leadgenerierung als Facebook und X zusammen.', context: 'LinkedIn konkurriert nicht. LinkedIn spielt in einer anderen Liga.', source: 'HubSpot' },
  { value: '46 %', label: 'des gesamten Social-Traffics auf B2B-Webseiten kommt von LinkedIn.', context: 'Content baut nicht nur Marke auf. Er bringt Besucher auf Ihre Seite.', source: 'LinkedIn' },
  { value: '28 %', label: 'niedrigere Kosten pro Lead auf LinkedIn im Vergleich zu Google Ads.', context: 'Organischer Content senkt diese Kosten zusätzlich.', source: 'HubSpot' },
  { value: '61 %', label: 'höhere Wahrscheinlichkeit einer Paid-Conversion nach vorheriger organischer Interaktion.', context: 'Wer Content und Werbung parallel betreibt, holt aus beiden mehr heraus.', source: 'Interne LinkedIn-Forschung' },
];

const faqs = [
  { q: 'Wie sieht der erste Monat konkret aus?', a: 'Wir starten mit einem Audit Ihrer LinkedIn-Präsenz: Unternehmensseite, Profile der Geschäftsführung, Veröffentlichungshistorie, Abonnentenstamm. Daraus entwickeln wir die redaktionelle Strategie, holen Ihre Freigabe für den ersten Monat Content ein und gehen live. Die meisten Kunden sind innerhalb von zwei bis drei Wochen produktiv.' },
  { q: 'Wie lange laufen Ihre Verträge?', a: 'Drei Monate Mindestlaufzeit, anschließend monatlich kündbar. Das erste Quartal ist der Zeitraum, in dem wir Schwung aufbauen und Ergebnisse messbar machen. Danach bleiben Sie, weil es funktioniert, nicht weil ein Vertrag Sie bindet.' },
  { q: 'Wie setzen Sie KI für Content, Visuals und Videos ein?', a: 'Wir nutzen KI-Werkzeuge entlang des gesamten Produktionsablaufs. Recherche, Entwürfe, mehrsprachiges Schreiben, Bildgenerierung, Videoschnitt. So produzieren wir mehr Content, schneller, zu geringeren Stückkosten. Ohne Abstriche bei der Qualität. Unsere Redaktion prüft jeden Text, unsere Gestalter kontrollieren jedes Visual. Nichts geht ohne menschliche Abnahme und Ihre Freigabe live. KI gibt uns Tempo. Das Team gibt Ihnen den Maßstab, den Ihre Marke braucht.' },
  { q: 'Was passiert, wenn mir der Content nicht gefällt?', a: 'Wir schreiben ihn neu. Ohne Diskussion, ohne Aufpreis. Sie geben jedes Stück frei, bevor es live geht. Lieber schreiben wir einen Beitrag dreimal um, als etwas zu veröffentlichen, das daneben liegt.' },
  { q: 'Brauche ich alle vier Leistungen oder kann ich mit einer starten?', a: 'Starten Sie mit einer. Erweitern Sie, wenn Sie so weit sind.' },
  { q: 'Wie viel Zeit muss mein Team pro Woche investieren?', a: 'Wir planen den Content einen Monat im Voraus. Ihr Team prüft und gibt frei. In der Regel sind das 20 bis 30 Minuten pro Woche. Einige Kunden erledigen das montags früh beim Kaffee.' },
  { q: 'Können Sie mit unseren Markenrichtlinien arbeiten?', a: 'Selbstverständlich. Wir halten uns an Ihre Brand Guidelines, Tonalität, visuelle Identität und Freigabeprozesse. Wenn Sie Vorlagen, vorgegebene Terminologie oder Compliance-Anforderungen haben, arbeiten wir innerhalb dieses Rahmens.' },
  { q: 'Was deckt Ihr Reporting ab?', a: 'Monatsberichte, gekoppelt an Ihre kommerziellen Ziele. Follower-Wachstum, Interaktion, Performance einzelner Beiträge, Lead-Indikatoren. Wir zeigen, was funktioniert hat, was nicht, und was wir verändern. Keine Füllseiten, keine Eitelkeitsmetriken.' },
  { q: 'Wie lange dauert es bis zu ersten Ergebnissen?', a: 'Die meisten Kunden sehen innerhalb von 60 Tagen Zuwächse bei Profilaufrufen, Followern und Interaktion. Die Leadgenerierung baut sich über 90 Tage auf, weil sich Content verdichtet und die Reichweite wächst. Wir versprechen keine Wunder über Nacht. LinkedIn belohnt Beständigkeit über die Zeit.' },
  { q: 'Was, wenn ich aufhören möchte?', a: 'Nach den ersten drei Monaten beträgt die Kündigungsfrist 30 Tage. Inhalte, Abonnenten, Assets bleiben Ihr Eigentum. Sie gehen mit allem, was wir gemeinsam aufgebaut haben.' },
];
---

<Layout
  lang="de"
  title="LinkedIn-Content-Leistungen | Mehr B2B-Leads gewinnen"
  description="Wir produzieren jeden Beitrag, den Ihre LinkedIn-Präsenz benötigt. Strategie, Produktion, Veröffentlichung, Reporting. Für B2B konzipiert, auf Leadgenerierung ausgelegt."
  abstract="Wir führen Ihre LinkedIn-Contentproduktion durchgehend. Strategie, Produktion, Veröffentlichung, Reporting. Vier Leistungen, ein Ziel: mehr Leads über LinkedIn."
>
  <NavBar lang="de" />
  <main id="main-content">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="c-hero" aria-labelledby="hero-h">
      <div class="c-hero__bg" aria-hidden="true"></div>
      <div class="c-hero__overlay" aria-hidden="true"></div>
      <div class="container" style="position: relative; z-index: 2;">
        <div class="c-hero__content">
          <p class="eyebrow eyebrow--light reveal">LinkedIn-Content-Leistungen</p>
          <h1 id="hero-h" class="c-hero__h1 reveal reveal-delay-1">
            LinkedIn-Content, der Aufmerksamkeit gewinnt und <span class="text-gradient">Leads bringt.</span>
          </h1>
          <p class="c-hero__sub reveal reveal-delay-2">
            Wir produzieren jeden Beitrag, den Ihre LinkedIn-Präsenz braucht. Strategie, Produktion, Veröffentlichung, Reporting. Alles abgedeckt.
          </p>
          <div class="c-hero__actions reveal reveal-delay-3">
            <a href="/de/kontakt" class="btn btn--primary btn--lg">Gespräch vereinbaren</a>
          </div>
        </div>
      </div>
    </section>


    <!-- ── Service Overview Cards ──────────────────────────── -->
    <section class="section c-overview" aria-label="Übersicht der Leistungen">
      <div class="container">
        <div class="c-ov__grid">
          {overviewCards.map((card, i) => (
            <a href={card.href} class={`c-ov-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="c-ov-card__top">
                <span class="c-ov-card__icon" set:html={card.icon} />
              </div>
              <strong class="c-ov-card__title">{card.title}</strong>
              <p class="c-ov-card__text">{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- ── What We Do ──────────────────────────────────────── -->
    <section class="section c-wwd" aria-labelledby="wwd-h">
      <div class="container">
        <div class="c-wwd__head reveal">
          <p class="eyebrow">Unser Ansatz</p>
          <h2 id="wwd-h" class="c-wwd__h2">Wir machen Ihre LinkedIn-Präsenz zum Vertriebskanal.</h2>
          <p class="c-wwd__intro">Ihr Team hat die Expertise. Ihr Unternehmen hat eine Geschichte. Solange dieses Wissen jedoch in den Büros bleibt, füllt es keine Pipeline.</p>
          <p class="c-wwd__intro">Wir nehmen das, was Ihre Marke glaubwürdig macht, und übersetzen es in eine redaktionelle Mechanik, die auf LinkedIn jede Woche läuft. Beiträge, Artikel, Newsletter, Events. Alles geschnitten auf die Menschen, die kaufen, was Sie verkaufen.</p>
        </div>

        <div class="c-wwd__grid">
          {whatWeDo.map((item, i) => (
            <div class={`c-wwd-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
              <div class="c-wwd-card__top">
                <span class="c-wwd-card__icon" aria-hidden="true" set:html={item.icon} />
              </div>
              <strong class="c-wwd-card__title">{item.title}</strong>
              <p class="c-wwd-card__body">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ── Why Brands Work With Us ─────────────────────────── -->
    <section class="section c-why" aria-labelledby="why-h">
      <div class="c-why__bg" aria-hidden="true"></div>
      <div class="container">
        <div class="c-why__head reveal">
          <p class="eyebrow eyebrow--light">Warum wir</p>
          <h2 id="why-h" class="c-why__h2">Für B2B gemacht. Für internationale Märkte aufgestellt.</h2>
        </div>

        <div class="c-why__layout">
          <!-- Left: visual column -->
          <div class="c-why__visual reveal">
            <div class="c-why__photo-wrap">
              <img src="/images/content-team.webp" alt="Das Team von Nuvora Studio" class="c-why__photo" width="480" height="560" loading="lazy" />
            </div>
            <div class="c-why__trust-row">
              <div class="c-why__trust-item">
                <span class="c-why__trust-num">100 %</span>
                <span class="c-why__trust-label">LinkedIn-Fokus</span>
              </div>
              <div class="c-why__trust-divider"></div>
              <div class="c-why__trust-item">
                <span class="c-why__trust-num">B2B</span>
                <span class="c-why__trust-label">Ausschließlich</span>
              </div>
              <div class="c-why__trust-divider"></div>
              <div class="c-why__trust-item">
                <span class="c-why__trust-num">Global</span>
                <span class="c-why__trust-label">Mehrsprachig</span>
              </div>
            </div>
          </div>

          <!-- Right: differentiator cards -->
          <div class="c-why__cards">
            {whyBlocks.map((b, i) => (
              <div class={`c-why-card reveal${i > 0 ? ` reveal-delay-${Math.min(i, 3)}` : ''}`}>
                <div class="c-why-card__content">
                  <strong class="c-why-card__title">{b.title}</strong>
                  <p class="c-why-card__body">{b.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ── Our LinkedIn Content Services ───────────────────── -->
    <section class="section c-svc" aria-labelledby="svc-h">
      <div class="container">
        <div class="c-svc__head reveal">
          <p class="eyebrow">Unsere Leistungen</p>
          <h2 id="svc-h" class="c-svc__h2">Vier Leistungen, ein gemeinsames Ziel: mehr Leads über LinkedIn.</h2>
          <p class="c-svc__intro">Jede Leistung steht für sich. Zusammen machen sie aus Ihrer LinkedIn-Präsenz ein Leadgenerierungssystem, auf das sich der Vertrieb verlassen kann.</p>
        </div>

        {services.map((s, i) => (
          <div class={`c-svc-block${i % 2 === 1 ? ' c-svc-block--flip' : ''} reveal`} id={s.id}>
            <div class="c-svc-block__text">
              <div class="c-svc-block__label">
                <span class="c-svc-block__icon" set:html={cardIcons[i]} />
              </div>
              <h3 class="c-svc-block__title">{s.title}</h3>
              <p class="c-svc-block__short">{s.short}</p>

              <ul class="c-svc-block__details" role="list">
                {s.details.map(d => (
                  <li>
