---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import HowWeWork from '../components/HowWeWork.astro';
import WhatSetsUsApart from '../components/WhatSetsUsApart.astro';
import Testimonials from '../components/Testimonials.astro';
import IndustriesWeServe from '../components/IndustriesWeServe.astro';
import InsightsPreview from '../components/InsightsPreview.astro';
import FAQ from '../components/FAQ.astro';
import ContactCTA from '../components/ContactCTA.astro';

const faqs = [
  {
    q: 'Where are your clients based?',
    a: 'Everywhere. We work with B2B companies in Europe, North America, Asia, and elsewhere. LinkedIn is global. So are we.',
  },
  {
    q: 'Do you only do LinkedIn?',
    a: 'Yes. No SEO, no Instagram, no "full-service" packages. LinkedIn only. That is the whole point.',
  },
  {
    q: 'What does it cost to get started?',
    a: 'Our Foundation retainer starts at $1,800/month. That covers strategy, content, and reporting. Most clients start there and scale up.',
    link: { text: 'See full pricing →', href: '/pricing' },
  },
  {
    q: 'Is this only for large companies?',
    a: 'No. Our packages cover different stages. $1,800/month gets you LinkedIn handled end to end. We also do standalone training and ad management for teams that are not ready for a full retainer.',
  },
  {
    q: 'Is advertising included?',
    a: 'Ads are a separate line. Some clients run organic only. Others run paid only. Most do both. Ad spend always goes directly to your LinkedIn account, never through us.',
  },
  {
    q: 'How do you measure results?',
    a: 'We agree on KPIs at the start: leads, pipeline, follower growth, cost per lead. Every month you get a report against those numbers. Not a deck full of impressions.',
  },
];
---

<Layout
  title="LinkedIn Agency for B2B | Nuvora Studio"
  description="LinkedIn-only B2B agency. Strategy, content, ads, all built for the channel that matters most for B2B. We work for pipeline, not vanity numbers."
  abstract="The LinkedIn-only B2B agency. We make LinkedIn the channel that pays back. Strategy, content, ads. Built for B2B teams who want pipeline."
  preloadHero="/hero-notification.webp"
>
  <NavBar />
  <main id="main-content">
    <Hero />
    <ProblemStatement />
    <ServicesGrid />
    <HowWeWork />
    <WhatSetsUsApart />
    <Testimonials />
    <IndustriesWeServe />
    <InsightsPreview />
    <FAQ heading="The things people usually ask." faqs={faqs} footer="Still have questions?" footerLink={{ text: 'Get in touch', href: '/contact' }} />
    <ContactCTA />
  </main>
</Layout>
