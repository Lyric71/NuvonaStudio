---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import WhatSetsUsApart from '../components/WhatSetsUsApart.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import HowWeWork from '../components/HowWeWork.astro';
import ClientResults from '../components/ClientResults.astro';
import InsightsPreview from '../components/InsightsPreview.astro';
import IndustriesWeServe from '../components/IndustriesWeServe.astro';
import FAQ from '../components/FAQ.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <NavBar />
  <main id="main-content">
    <Hero />
    <ProblemStatement />
    <WhatSetsUsApart />
    <ServicesGrid />
    <HowWeWork />
    <ClientResults />
    <InsightsPreview />
    <IndustriesWeServe />
    <FAQ />
    <ContactCTA />
  </main>
  <Footer />
</Layout>
