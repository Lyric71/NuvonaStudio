---
const testimonials = [
  {
    text: "Nuvora transformed our LinkedIn presence from an afterthought into our top lead channel. Within six months, we were generating 40% of pipeline from LinkedIn alone.",
    image: "https://randomuser.me/api/portraits/women/32.jpg",
    name: "Sophie Laurent",
    role: "CMO, SaaS Platform",
  },
  {
    text: "They don't just post content. They understand B2B buying cycles. Our executive team's profiles went from dormant to actively generating inbound conversations.",
    image: "https://randomuser.me/api/portraits/men/45.jpg",
    name: "Marcus Webb",
    role: "VP Sales, Industrial Tech",
  },
  {
    text: "The transparency is refreshing. Every month we see exactly what's working, what's not, and where the budget goes. No other agency has given us that.",
    image: "https://randomuser.me/api/portraits/women/28.jpg",
    name: "Priya Sharma",
    role: "Head of Marketing, Fintech",
  },
  {
    text: "We tried three agencies before Nuvora. The difference? They actually understand LinkedIn's algorithm and how B2B decision-makers behave on the platform.",
    image: "https://randomuser.me/api/portraits/men/22.jpg",
    name: "David Chen",
    role: "CEO, Consulting Firm",
  },
  {
    text: "Our LinkedIn ad spend went from burning cash to delivering qualified leads at half the cost. The campaign structure they built is incredibly efficient.",
    image: "https://randomuser.me/api/portraits/women/44.jpg",
    name: "Emma Bergström",
    role: "Digital Lead, Manufacturing",
  },
  {
    text: "The content quality sets them apart. Every post sounds like us, not like an agency. That's rare in B2B content outsourcing.",
    image: "https://randomuser.me/api/portraits/men/36.jpg",
    name: "James Okafor",
    role: "Founder, Professional Services",
  },
  {
    text: "From strategy to execution, everything is handled. We went from posting once a month to a full presence. Company page, executive profiles, and ads. All performing.",
    image: "https://randomuser.me/api/portraits/women/51.jpg",
    name: "Ana Rodriguez",
    role: "Marketing Director, Healthcare",
  },
  {
    text: "Nuvora helped us build an employee advocacy programme that turned our sales team into thought leaders. The pipeline impact has been measurable and significant.",
    image: "https://randomuser.me/api/portraits/men/53.jpg",
    name: "Ravi Patel",
    role: "CRO, Enterprise Software",
  },
  {
    text: "What impressed me most is the reporting. Real KPIs, real pipeline numbers. Not impressions and likes. We finally know what LinkedIn is actually doing for our business.",
    image: "https://randomuser.me/api/portraits/women/19.jpg",
    name: "Laura Koenig",
    role: "COO, Logistics Company",
  },
];

const firstColumn = testimonials.slice(0, 3);
const secondColumn = testimonials.slice(3, 6);
const thirdColumn = testimonials.slice(6, 9);
---

<section class="testimonials section" aria-labelledby="testimonials-heading">
  <div class="container">
    <div class="testimonials__head reveal">
      <p class="eyebrow">Social proof</p>
      <h2 id="testimonials-heading" class="testimonials__title">What our clients say</h2>
      <p class="testimonials__sub">Results-driven partnerships with B2B teams across industries.</p>
    </div>

    <div class="testimonials__columns">
      {[
        { items: firstColumn, speed: 'slow' },
        { items: secondColumn, speed: 'mid' },
        { items: thirdColumn, speed: 'fast' },
      ].map(({ items, speed }, colIdx) => (
        <div class={`testimonials__col testimonials__col--${speed} ${colIdx === 1 ? 'testimonials__col--md' : ''} ${colIdx === 2 ? 'testimonials__col--lg' : ''}`}>
          <div class="testimonials__track">
            {[0, 1].map(() =>
              items.map((t, i) => (
                <div class="testimonials__card">
                  <div class="testimonials__quote" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M10 8H6C4.9 8 4 8.9 4 10V14C4 15.1 4.9 16 6 16H8L6 20H8.5L10.5 16H10C11.1 16 12 15.1 12 14V10C12 8.9 11.1 8 10 8Z" fill="currentColor"/>
                      <path d="M20 8H16C14.9 8 14 8.9 14 10V14C14 15.1 14.9 16 16 16H18L16 20H18.5L20.5 16H20C21.1 16 22 15.1 22 14V10C22 8.9 21.1 8 20 8Z" fill="currentColor"/>
                    </svg>
                  </div>
                  <p class="testimonials__text">{t.text}</p>
                  <div class="testimonials__author">
                    <img
                      width="40"
                      height="40"
                      src={t.image}
                      alt={t.name}
                      class="testimonials__avatar"
                      loading="lazy"
                    />
                    <div>
                      <p class="testimonials__name">{t.name}</p>
                      <p class="testimonials__role">{t.role}</p>
                    </div>
                  </div>
                </div>
              ))
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 540px;
    margin-inline: auto;
    margin-bottom: var(--sp-10);
    text-align: center;
  }

  .testimonials__title {
    letter-spacing: -0.03em;
  }

  .testimonials__sub {
    margin-top: var(--sp-4);
    color: var(--text-2);
  }

  /* ── Columns grid ── */
  .testimonials__columns {
    display: flex;
    justify-content: center;
    gap: var(--sp-6);
    max-height: 740px;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, transparent, black 25%, black 75%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 25%, black 75%, transparent);
  }

  .testimonials__col {
    flex: 0 0 auto;
    width: 100%;
    max-width: 320px;
  }

  .testimonials__col--md { display: none; }
  .testimonials__col--lg { display: none; }

  /* ── Infinite scroll track ── */
  .testimonials__track {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
    animation: scroll-up 15s linear infinite;
  }

  .testimonials__col--mid .testimonials__track { animation-duration: 19s; }
  .testimonials__col--fast .testimonials__track { animation-duration: 17s; }

  @keyframes scroll-up {
    0%   { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  /* ── Card ── */
  .testimonials__card {
    padding: var(--sp-8);
    border-radius: var(--r-2xl);
    border: 1px solid var(--border);
    box-shadow: 0 4px 24px rgba(10, 102, 194, 0.07);
    background: var(--white);
  }

  .testimonials__quote {
    color: var(--cyan);
    opacity: 0.35;
    margin-bottom: var(--sp-4);
  }

  .testimonials__text {
    font-size: var(--fs-sm);
    line-height: 1.7;
    color: var(--text);
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
  }

  .testimonials__avatar {
    width: 40px;
    height: 40px;
    border-radius: var(--r-full);
    object-fit: cover;
  }

  .testimonials__name {
    font-weight: 500;
    font-size: var(--fs-sm);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .testimonials__role {
    font-size: var(--fs-xs);
    line-height: 1.3;
    color: var(--text-3);
    letter-spacing: -0.01em;
  }

  /* ── Responsive ── */
  @media (min-width: 768px) {
    .testimonials__col--md { display: block; }
  }

  @media (min-width: 1024px) {
    .testimonials__col--lg { display: block; }
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials__track { animation: none; }
  }
</style>
