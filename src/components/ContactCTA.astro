---
import { useTranslations, localizedPath, type Lang } from '../i18n/index.ts';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const contactHref = `${localizedPath('contact', lang)}?intent=call`;
const pricingHref = localizedPath('pricing', lang);
---

<section class="section cta" aria-labelledby="cta-heading" style="background: var(--deep-navy);">
  <div class="container">
    <div class="cta__layout">

      <div class="cta__left reveal">
        <p class="eyebrow eyebrow--light">{t('cta.eyebrow')}</p>
        <h2 id="cta-heading" class="cta__headline">
          {t('cta.headline')}<br />
          <em>{t('cta.headline2')}</em>
        </h2>
      </div>

      <div class="cta__right reveal reveal-delay-2">
        <p class="cta__sub">
          {t('cta.sub')}
        </p>
        <div class="cta__actions">
          <a href={contactHref} class="btn btn--primary btn--lg">{t('cta.book')}</a>
          <a href={pricingHref} class="btn btn--outline-white btn--lg">{t('cta.pricing')}</a>
        </div>
        <p class="cta__note">{t('cta.note')}</p>
      </div>

    </div>
  </div>
</section>

<style>
  .cta { position: relative; overflow: hidden; }
  .cta::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 55% 75% at 100% 50%, rgba(14,165,233,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .cta__layout {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
  }

  .cta__headline {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.025em;
  }
  .cta__headline em { color: rgba(255,255,255,0.35); font-weight: 300; }

  .cta__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.55);
    line-height: 1.75;
    margin-bottom: var(--sp-8);
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    align-items: center;
    margin-bottom: var(--sp-5);
  }

  .cta__note {
    font-size: var(--fs-sm);
    color: rgba(255,255,255,0.30);
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .cta__layout { grid-template-columns: 1fr; gap: var(--sp-10); }
  }
  @media (max-width: 640px) {
    .cta__actions { flex-direction: column; align-items: stretch; }
    .cta__actions .btn { justify-content: center; }
  }
</style>
