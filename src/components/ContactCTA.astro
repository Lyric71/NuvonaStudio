---
---

<section class="section cta" aria-labelledby="cta-heading" style="background: var(--deep-navy);">
  <div class="container">
    <div class="cta__layout">

      <div class="cta__left reveal">
        <p class="eyebrow eyebrow--light">Start here</p>
        <h2 id="cta-heading" class="cta__headline">
          Ready to make LinkedIn<br />
          <em>work for your business?</em>
        </h2>
      </div>

      <div class="cta__right reveal reveal-delay-2">
        <p class="cta__sub">
          Tell us about your company. We'll show you exactly where the opportunity is.
        </p>
        <div class="cta__actions">
          <a href="/contact?intent=call" class="btn btn--primary btn--lg">Book a call</a>
          <a href="/pricing" class="btn btn--outline-white btn--lg">View pricing</a>
        </div>
        <p class="cta__note">30 minutes. No pitch. Straight answers.</p>
      </div>

    </div>
  </div>
</section>

<style>
  .cta { position: relative; overflow: hidden; }
  .cta::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 80% at 100% 50%, rgba(0,168,220,0.10) 0%, transparent 60%);
    pointer-events: none;
  }

  .cta__layout {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    align-items: center;
  }

  .cta__headline {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
  }
  .cta__headline em { color: rgba(255,255,255,0.45); font-weight: 300; }

  .cta__visual {
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 160px;
    border-radius: var(--r-xl);
    background: rgba(255,255,255,0.03);
    border: 1.5px dashed rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--sp-8);
  }

  .cta__visual span {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.18);
  }

  .cta__sub {
    font-size: var(--fs-md);
    color: rgba(255,255,255,0.60);
    line-height: 1.75;
    margin-bottom: var(--sp-8);
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    align-items: center;
    margin-bottom: var(--sp-5);
  }

  .cta__note {
    font-size: var(--fs-sm);
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.02em;
  }

  @media (max-width: 1024px) {
    .cta__layout { grid-template-columns: 1fr; gap: var(--sp-10); }
  }
  @media (max-width: 640px) {
    .cta__actions { flex-direction: column; align-items: stretch; }
    .cta__actions .btn { justify-content: center; }
  }
</style>
