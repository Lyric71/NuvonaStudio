---
const caseStudies = [
  {
    industry: 'Technology & SaaS',
    challenge: 'PLACEHOLDER — describe the challenge in one sentence',
    result: 'PLACEHOLDER — quantified outcome (e.g. +240% pipeline from LinkedIn in 6 months)',
    tag: 'Case Study',
  },
  {
    industry: 'Manufacturing & Industrial',
    challenge: 'PLACEHOLDER — describe the challenge in one sentence',
    result: 'PLACEHOLDER — quantified outcome',
    tag: 'Case Study',
  },
  {
    industry: 'Professional Services',
    challenge: 'PLACEHOLDER — describe the challenge in one sentence',
    result: 'PLACEHOLDER — quantified outcome',
    tag: 'Case Study',
  },
];

const testimonials = [
  {
    quote: 'PLACEHOLDER — client quote here.',
    name: 'PLACEHOLDER Name',
    title: 'PLACEHOLDER Title',
    company: 'PLACEHOLDER Company',
  },
];
---

<section class="section" aria-labelledby="results-heading">
  <div class="container">

    <div class="results__head reveal">
      <div>
        <p class="eyebrow">Proof</p>
        <h2 id="results-heading">LinkedIn that generates pipeline.</h2>
      </div>
      <a href="/work" class="btn btn--outline">View all case studies →</a>
    </div>

    <div class="results__cases">
      {caseStudies.map((cs, i) => (
        <article class="results__card reveal" style={`transition-delay: ${i * 0.08}s`}>
          <span class="tag tag--blue" style="margin-bottom: var(--sp-5); display: inline-flex;">{cs.tag}</span>
          <p class="results__industry">{cs.industry}</p>
          <p class="results__challenge">{cs.challenge}</p>
          <hr class="results__rule" />
          <p class="results__result">{cs.result}</p>
        </article>
      ))}
    </div>

    <div class="results__quotes">
      {testimonials.map((t, i) => (
        <blockquote class="results__quote reveal" style={`transition-delay: ${i * 0.10}s`}>
          <p class="results__quote-mark" aria-hidden="true">"</p>
          <p class="results__quote-text">{t.quote}"</p>
          <footer class="results__quote-footer">
            <p class="results__quote-name">{t.name}</p>
            <p class="results__quote-meta">{t.title}, {t.company}</p>
          </footer>
        </blockquote>
      ))}
    </div>

  </div>
</section>

<style>
  .results__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--sp-8);
    margin-bottom: var(--sp-12);
    flex-wrap: wrap;
  }

  .results__cases {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
    margin-bottom: var(--sp-10);
  }

  .results__card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-7);
    display: flex;
    flex-direction: column;
    transition: all var(--t-base);
  }
  .results__card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--mid-blue);
    transform: translateY(-2px);
  }

  .results__industry {
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: var(--sp-2);
  }

  .results__challenge {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.7;
    flex: 1;
    margin-bottom: var(--sp-4);
  }

  .results__rule { height: 1px; background: var(--border); border: none; margin-bottom: var(--sp-4); }

  .results__result {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .results__quotes {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6);
    margin-bottom: var(--sp-4);
  }

  .results__quote {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-left: 4px solid var(--blue);
    border-radius: 0 var(--r-xl) var(--r-xl) 0;
    padding: var(--sp-8);
    display: flex;
    flex-direction: column;
  }

  .results__quote-mark {
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--blue);
    opacity: 0.25;
    line-height: 0.8;
    margin-bottom: var(--sp-3);
    font-weight: 700;
  }

  .results__quote-text {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-style: italic;
    color: var(--text);
    line-height: 1.6;
    flex: 1;
    margin-bottom: var(--sp-6);
    letter-spacing: -0.01em;
  }

  .results__quote-name { font-size: var(--fs-sm); font-weight: 600; color: var(--text); }
  .results__quote-meta { font-size: var(--fs-xs); color: var(--text-3); margin-top: 2px; letter-spacing: 0.02em; }

  @media (max-width: 1024px) { .results__cases { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .results__head { flex-direction: column; align-items: flex-start; }
    .results__cases { grid-template-columns: 1fr; }
    .results__quotes { grid-template-columns: 1fr; }
  }
</style>
