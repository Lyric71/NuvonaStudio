---
const steps = [
  {
    title: 'Audit & Strategy',
    body: 'We review your LinkedIn presence, competitors, and audience. You get a clear roadmap with specific actions — not a generic playbook.',
    detail: 'Week 1–2',
  },
  {
    title: 'Build & Launch',
    body: 'We optimise profiles, set up your content engine, and launch campaigns. Everything goes live with your sign-off.',
    detail: 'Week 3–4',
  },
  {
    title: 'Grow & Report',
    body: 'Monthly reporting against agreed KPIs. We iterate on what works and scale what converts. No vanity metrics.',
    detail: 'Ongoing',
  },
];
---

<section class="section" style="background: var(--deep-navy);" aria-labelledby="process-heading">
  <div class="container">

    <div class="process__head reveal">
      <p class="eyebrow eyebrow--light">How it works</p>
      <h2 id="process-heading" style="color: var(--white);">
        From audit to pipeline<br /><em style="color: rgba(255,255,255,0.40); font-weight: 300;">in three steps.</em>
      </h2>
    </div>

    <div class="process__grid">
      {steps.map((s, i) => (
        <div class="process__step reveal" style={`transition-delay: ${i * 0.1}s`}>
          {i < steps.length - 1 && <div class="process__line-horizontal" aria-hidden="true"></div>}
          <div class="process__content">
            <span class="process__detail">{s.detail}</span>
            <h3 class="process__title">{s.title}</h3>
            <p class="process__body">{s.body}</p>
          </div>
          {s.title === 'Audit & Strategy' ? (
            <div class="process__vis process__vis--img" aria-hidden="true">
              <img src="/audit-strategy.png" alt="" width="600" height="375" loading="lazy" />
            </div>
          ) : s.title === 'Build & Launch' ? (
            <div class="process__vis process__vis--img" aria-hidden="true">
              <img src="/build-launch.png" alt="" width="600" height="375" loading="lazy" />
            </div>
          ) : s.title === 'Grow & Report' ? (
            <div class="process__vis process__vis--img" aria-hidden="true">
              <img src="/grow-report.png" alt="" width="600" height="375" loading="lazy" />
            </div>
          ) : (
            <div class="vis-placeholder process__vis" aria-hidden="true">
              <span>Visual placeholder</span>
            </div>
          )}
        </div>
      ))}
    </div>

    <div class="process__cta reveal" style="transition-delay: 0.3s">
      <a href="/pricing" class="btn btn--outline-white btn--lg">See pricing</a>
    </div>

  </div>
</section>

<style>
  .process__head {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--sp-16);
  }

  .process__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
    margin-bottom: var(--sp-12);
  }

  .process__step {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .process__line-horizontal {
    height: 1px;
    background: linear-gradient(to right, rgba(0, 168, 220, 0.30), transparent);
    margin-bottom: var(--sp-2);
  }

  .process__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .process__detail {
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cyan);
  }

  .process__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--white);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .process__body {
    font-size: var(--fs-sm);
    color: var(--navy-text-2);
    line-height: 1.75;
  }

  .process__vis {
    width: 100%;
    aspect-ratio: 16 / 10;
    min-height: 100px;
    margin-top: var(--sp-2);
    border-radius: var(--r-lg);
    background: rgba(255,255,255,0.03);
    border: 1.5px dashed rgba(255,255,255,0.10);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .process__vis--img {
    background: none;
    border: none;
    padding: 0;
    overflow: hidden;
  }

  .process__vis--img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-lg);
  }

  .process__vis span {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.15);
  }

  .process__cta { text-align: center; }

  @media (max-width: 768px) {
    .process__grid { grid-template-columns: 1fr; gap: var(--sp-10); }
    .process__line-horizontal { display: none; }
  }
</style>
