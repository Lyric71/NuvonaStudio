---
const services = [
  {
    title: 'Content',
    tag: 'Organic',
    body: 'We manage your company page, produce every format LinkedIn offers, and publish consistently so your brand stays visible while your team stays focused.',
    href: '/services/content',
    subs: [
      'Company page management',
      'Content production & editorial',
      'LinkedIn newsletter',
      'LinkedIn events',
    ],
  },
  {
    title: 'Advertising',
    tag: 'Paid',
    body: 'From Sponsored Content to Lead Gen Forms, we build and run campaigns that reach the right decision-makers and convert them into leads.',
    href: '/services/advertising',
    subs: [
      'Campaign architecture',
      'Audience targeting',
      'Ad creative & copy',
      'CRM-connected reporting',
    ],
  },
  {
    title: 'Consulting',
    tag: 'Strategy',
    body: 'Training, personal branding, and employee advocacy programs that turn your people into your strongest channel on LinkedIn.',
    href: '/services/consulting',
    subs: [
      'Employee advocacy',
      'Executive personal branding',
      'Training workshops',
      'LinkedIn strategy audit',
    ],
  },
];
---

<section id="services" class="section" style="background: var(--off-white);" aria-labelledby="services-heading">
  <div class="container">

    <div class="services__head reveal">
      <div>
        <p class="eyebrow">What we do</p>
        <h2 id="services-heading">Everything your LinkedIn<br />presence needs.</h2>
      </div>
      <p class="services__intro">
        Delivered with full transparency. Strategy, audit, and reporting included in every engagement.
      </p>
    </div>

    <div class="services__grid">
      {services.map((s, i) => (
        <a href={s.href} class="services__card reveal" style={`transition-delay: ${i * 0.08}s`}>
          <div class="services__card-top">
            <span class="tag tag--cyan">{s.tag}</span>
            <span class="services__arrow" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4.5 15.5L15.5 4.5M15.5 4.5H7.5M15.5 4.5V12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
          {s.title === 'Content' ? (
            <div class="services__vis services__vis--content" aria-hidden="true">
              <img src="/content-calendar-v2.png" alt="" width="600" height="338" loading="lazy" />
            </div>
          ) : s.title === 'Advertising' ? (
            <div class="services__vis services__vis--content" aria-hidden="true">
              <img src="/ad-creative-stack.png" alt="" width="600" height="338" loading="lazy" />
            </div>
          ) : s.title === 'Consulting' ? (
            <div class="services__vis services__vis--content" aria-hidden="true">
              <img src="/consulting-workshop.png" alt="" width="600" height="338" loading="lazy" />
            </div>
          ) : (
            <div class="vis-placeholder services__vis" aria-hidden="true">
              <span>Visual placeholder</span>
            </div>
          )}
          <h3 class="services__card-title">{s.title}</h3>
          <p class="services__card-desc">{s.body}</p>
          <ul class="services__subs">
            {s.subs.map(sub => (
              <li class="services__sub">{sub}</li>
            ))}
          </ul>
        </a>
      ))}
    </div>

    <div class="services__foot reveal">
      <a href="/services" class="btn btn--outline btn--lg">See all services</a>
    </div>

  </div>
</section>

<style>
  .services__head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--sp-12);
    align-items: end;
    margin-bottom: var(--sp-12);
  }

  .services__intro {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.7;
    max-width: 400px;
    align-self: flex-end;
    padding-bottom: 6px;
  }

  /* ── Card grid ── */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
    margin-bottom: var(--sp-12);
  }

  /* ── Card ── */
  .services__card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-8);
    transition: all var(--t-base);
    text-decoration: none;
    color: inherit;
  }

  .services__card:hover {
    border-color: var(--border-2);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .services__card:hover .services__arrow {
    background: var(--deep-navy);
    color: var(--white);
    border-color: var(--deep-navy);
  }

  .services__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-6);
  }

  .services__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 50%;
    color: var(--text-3);
    transition: all var(--t-base);
    flex-shrink: 0;
  }

  /* ── Visual ── */
  .services__vis {
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 120px;
    margin-bottom: var(--sp-6);
    border-radius: var(--r-lg);
    background: var(--off-white);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .services__vis--content {
    background: none;
    border: none;
    padding: 0;
  }

  .services__vis--content img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-lg);
  }

  .services__vis span {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .services__card-title {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: var(--sp-4);
  }

  .services__card-desc {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: var(--sp-6);
  }

  /* ── Sub-services list ── */
  .services__subs {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: auto;
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
  }

  .services__sub {
    font-size: var(--fs-xs);
    font-weight: 500;
    color: var(--text-2);
    letter-spacing: 0.02em;
    padding-left: var(--sp-4);
    position: relative;
  }

  .services__sub::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--cyan);
  }

  .services__foot { text-align: center; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .services__head { grid-template-columns: 1fr; gap: var(--sp-6); }
    .services__intro { max-width: 100%; }
    .services__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .services__grid { grid-template-columns: 1fr; }
  }
</style>
