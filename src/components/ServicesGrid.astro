---
const services = [
  {
    num: '01',
    title: 'Content',
    tag: 'Organic',
    body: 'We manage your company page, produce every format LinkedIn offers, and publish consistently — so your brand stays visible while your team stays focused.',
  },
  {
    num: '02',
    title: 'Advertising',
    tag: 'Paid',
    body: 'From Sponsored Content to Lead Gen Forms, we build and run campaigns that reach the right decision-makers and convert them into leads.',
  },
  {
    num: '03',
    title: 'Personal Branding',
    tag: 'Executive',
    body: 'We build executive profiles that open doors. Thought leadership content that earns trust before the first conversation.',
  },
  {
    num: '04',
    title: 'Employee Advocacy',
    tag: 'Amplification',
    body: "Your team's networks are your biggest untapped channel. We help you activate them at scale.",
  },
  {
    num: '05',
    title: 'Training',
    tag: 'Knowledge',
    body: 'LinkedIn fundamentals, content strategy, ads, and personal branding — workshops built for teams that want to perform, not just participate.',
  },
];
---

<section id="services" class="section" aria-labelledby="services-heading">
  <div class="container">

    <div class="services__head reveal">
      <div>
        <p class="eyebrow">What we do</p>
        <h2 id="services-heading">Everything your LinkedIn<br />presence needs.</h2>
      </div>
      <p class="services__intro">
        Delivered with full transparency — strategy, audit, and reporting included in every engagement.
      </p>
    </div>

    <div class="services__list">
      {services.map((s, i) => (
        <article class="services__item reveal" style={`transition-delay: ${i * 0.07}s`}>
          <span class="services__num">{s.num}</span>
          <div class="services__body">
            <div class="services__title-row">
              <h3 class="services__title">{s.title}</h3>
              <span class="tag tag--cyan">{s.tag}</span>
            </div>
            <p class="services__desc">{s.body}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="services__foot reveal">
      <a href="/services" class="btn btn--outline btn--lg">See all services →</a>
    </div>

  </div>
</section>

<style>
  .services__head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--sp-12);
    align-items: end;
    margin-bottom: var(--sp-12);
  }

  .services__intro {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.7;
    max-width: 400px;
    align-self: flex-end;
    padding-bottom: 6px;
  }

  .services__list {
    border-top: 1px solid var(--border);
    margin-bottom: var(--sp-12);
  }

  .services__item {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: var(--sp-6);
    padding: var(--sp-7) 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
    transition: background var(--t-base);
  }
  .services__item:hover { background: linear-gradient(90deg, rgba(10,102,194,0.02) 0%, transparent 100%); }

  .services__num {
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--blue);
    letter-spacing: 0.08em;
    padding-top: 6px;
    display: block;
  }

  .services__title-row {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-3);
    flex-wrap: wrap;
  }

  .services__title {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .services__desc {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.75;
    max-width: 700px;
  }

  .services__foot { text-align: center; }

  @media (max-width: 1024px) {
    .services__head { grid-template-columns: 1fr; gap: var(--sp-6); }
    .services__intro { max-width: 100%; }
  }

  @media (max-width: 640px) {
    .services__item { grid-template-columns: 36px 1fr; }
  }
</style>
