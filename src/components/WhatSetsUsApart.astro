---
const pillars = [
  {
    title: 'Specialists, not generalists',
    body: 'Every service we offer is built around LinkedIn. We know the algorithm, the formats, the targeting, and the content that drives results.',
    metric: '100%',
    metricLabel: 'LinkedIn focus',
  },
  {
    title: 'Content that earns attention',
    body: 'We write for your audience, not your approval. Clear, direct B2B content that gets read and acted on.',
    metric: '3.2x',
    metricLabel: 'avg. engagement lift',
  },
  {
    title: 'Transparent by default',
    body: 'No vague reports. No hidden markups. You always know what we are doing and why.',
    metric: '0',
    metricLabel: 'hidden fees',
  },
  {
    title: 'AI-assisted. Human-led.',
    body: 'We use AI to move faster and scale content production. Every output is reviewed and shaped by our team before it touches your brand.',
    metric: '100%',
    metricLabel: 'human-reviewed',
  },
];
---

<section class="section" aria-labelledby="apart-heading">
  <div class="container">
    <div class="apart__layout">

      <div class="apart__left">
        <div class="apart__head reveal">
          <p class="eyebrow">Why us</p>
          <h2 id="apart-heading">We do one thing.<br />LinkedIn.</h2>
          <div class="accent-bar"></div>
          <p class="apart__lead">
            We are not a full-service digital agency with a LinkedIn practice.
            LinkedIn is all we do. That focus is the difference.
          </p>
        </div>

        <!-- Visual: comparison graphic -->
        <div class="apart__visual reveal reveal-delay-1" aria-hidden="true">
          <div class="apart__visual-inner">
            <div class="apart__vis-compare">
              <div class="apart__vis-col apart__vis-col--them">
                <span class="apart__vis-label">Generalist agencies</span>
                <div class="apart__vis-bars">
                  <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 30%"></div></div>
                  <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 25%"></div></div>
                  <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 20%"></div></div>
                  <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 35%"></div></div>
                  <div class="apart__vis-item"><span class="apart__vis-dot apart__vis-dot--muted"></span><div class="apart__vis-bar apart__vis-bar--muted" style="width: 15%"></div></div>
                </div>
              </div>
              <div class="apart__vis-divider"></div>
              <div class="apart__vis-col apart__vis-col--us">
                <span class="apart__vis-label">Nuvora Studio</span>
                <div class="apart__vis-bars">
                  <div class="apart__vis-item"><span class="apart__vis-dot"></span><div class="apart__vis-bar" style="width: 100%"></div></div>
                </div>
                <span class="apart__vis-tag">LinkedIn only</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="apart__right">
        <div class="apart__grid">
          {pillars.map((p, i) => (
            <div class="apart__card reveal" style={`transition-delay: ${i * 0.08}s`}>
              <div class="apart__card-metric">
                <span class="apart__metric-value">{p.metric}</span>
                <span class="apart__metric-label">{p.metricLabel}</span>
              </div>
              <div class="apart__card-body">
                <div class="apart__card-header">
                  <h3 class="apart__title">{p.title}</h3>
                </div>
                <p class="apart__body">{p.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .apart__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: start;
  }

  .apart__left {
    position: sticky;
    top: calc(var(--sp-24));
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }

  .apart__lead {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.75;
  }

  /* ── Comparison visual ── */
  .apart__visual {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
  }

  .apart__visual-inner {
    padding: var(--sp-8);
  }

  .apart__vis-compare {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .apart__vis-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .apart__vis-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .apart__vis-col--us .apart__vis-label {
    color: var(--sky);
  }

  .apart__vis-bars {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .apart__vis-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .apart__vis-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--cyan);
    flex-shrink: 0;
  }
  .apart__vis-dot--muted {
    background: var(--border-2);
  }

  .apart__vis-bar {
    height: 6px;
    background: var(--gradient-accent);
    border-radius: 3px;
  }
  .apart__vis-bar--muted {
    background: var(--border);
    opacity: 0.6;
  }

  .apart__vis-divider {
    height: 1px;
    background: var(--border);
  }

  .apart__vis-tag {
    display: inline-block;
    width: fit-content;
    padding: 3px 10px;
    border-radius: var(--r-full);
    background: rgba(14,165,233,0.08);
    color: var(--sky);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ── Cards grid ── */
  .apart__grid {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
  }

  .apart__card {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
    transition: all var(--t-base);
  }

  .apart__card:hover {
    border-color: var(--border-2);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .apart__card-metric {
    background: var(--off-white);
    padding: var(--sp-5) var(--sp-8);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
  }

  .apart__metric-value {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 700;
    color: var(--sky);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .apart__metric-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .apart__card-body {
    padding: var(--sp-5) var(--sp-8) var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .apart__card-header {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  .apart__title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .apart__body {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.75;
  }

  @media (max-width: 1024px) {
    .apart__layout { grid-template-columns: 1fr; }
    .apart__left { position: static; }
  }
</style>
