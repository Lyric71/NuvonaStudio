---
import { useTranslations, getAlternateUrl, localizedPath, type Lang } from '../i18n/index.ts';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

const langOptions = [
  { code: 'en' as Lang, label: 'English',  flag: '/flags/gb.svg' },
  { code: 'fr' as Lang, label: 'Français', flag: '/flags/fr.svg' },
  { code: 'zh' as Lang, label: '中文',     flag: '/flags/cn.svg' },
  { code: 'es' as Lang, label: 'Español',  flag: '/flags/es.svg' },
  { code: 'de' as Lang, label: 'Deutsch',  flag: '/flags/de.svg' },
].filter(l => l.code !== lang);


const links = [
  {
    label: t('nav.services'),
    href: localizedPath('services', lang),
    children: [
      { label: t('nav.content'),     href: localizedPath('services/content', lang) },
      { label: t('nav.advertising'), href: localizedPath('services/advertising', lang) },
      { label: t('nav.consulting'),  href: localizedPath('services/consulting', lang) },
    ],
  },
  { label: t('nav.pricing'),  href: localizedPath('pricing', lang) },
  { label: t('nav.work'),     href: localizedPath('work', lang) },
  { label: t('nav.insights'), href: localizedPath('insights', lang) },
  { label: t('nav.about'),    href: localizedPath('about', lang) },
];

const optimizerHref = localizedPath('linkedin-optimizer', lang);

const homeHref = lang === 'en' ? '/' : `/${lang}/`;
const contactHref = `${localizedPath('contact', lang)}?intent=call`;
---

<nav class="nav" aria-label="Main navigation">
  <div class="nav__inner">

    <a href={homeHref} class="nav__logo" aria-label="Nuvora Studio, home">
      <img src="/nuvora-logo.webp" alt="Nuvora Studio" class="nav__logo-img" width="220" height="86" />
    </a>

    <ul class="nav__links" role="list">
      {links.map(link => (
        <li class={link.children ? 'nav__item nav__item--has-dropdown' : 'nav__item'}>
          {link.children ? (
            <>
              <a
                href={link.href}
                class={`nav__link nav__link--dropdown${currentPath.startsWith(link.href) ? ' nav__link--active' : ''}`}
                aria-haspopup="true" aria-expanded="false"
              >
                {link.label}
                <svg class="nav__chevron" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
                  <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                </svg>
              </a>
              <ul class="nav__dropdown" role="list">
                {link.children.map(child => (
                  <li>
                    <a href={child.href} class={`nav__dropdown-link${currentPath === child.href ? ' nav__dropdown-link--active' : ''}`}>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a href={link.href} class={`nav__link${currentPath === link.href ? ' nav__link--active' : ''}`}>
              {link.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <div class="nav__actions">
      <a href={optimizerHref} class="nav__optimizer-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        {t('nav.optimizer')}
      </a>

      <!-- Language switcher -->
      <div class="nav__lang-group">
        {langOptions.map(opt => (
          <a
            href={getAlternateUrl(currentPath, opt.code)}
            class="nav__lang"
            aria-label={`Switch to ${opt.label}`}
            title={opt.label}
          >
            <img src={opt.flag} alt="" width="22" height="22" class="nav__lang-flag" loading="lazy" />
          </a>
        ))}
      </div>

      <a href={contactHref} class="btn btn--primary btn--sm">{t('nav.book_call')}</a>
    </div>

    <button class="nav__burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      {links.map(link => (
        <>
          <li><a href={link.href} class="nav__mobile-link">{link.label}</a></li>
          {link.children?.map(child => (
            <li><a href={child.href} class="nav__mobile-link nav__mobile-link--child">↳ {child.label}</a></li>
          ))}
        </>
      ))}
      <li>
        <a href={optimizerHref} class="nav__mobile-link" style="color:var(--sky);font-weight:600;">
          {t('nav.optimizer')}
        </a>
      </li>
    </ul>
    <div class="nav__mobile-langs" role="list" aria-label="Language">
      {langOptions.map(opt => (
        <a
          href={getAlternateUrl(currentPath, opt.code)}
          class="nav__mobile-lang-pill"
          aria-label={`Switch to ${opt.label}`}
          title={opt.label}
        >
          <img src={opt.flag} alt="" width="20" height="20" class="nav__mobile-lang-flag" loading="lazy" />
        </a>
      ))}
    </div>
    <a href={contactHref} class="btn btn--primary w-full" style="justify-content:center; margin-top: var(--sp-3);">
      {t('nav.book_call')}
    </a>
  </div>
</nav>

<style>
  .nav__logo-img {
    height: 40px;
    width: auto;
    display: block;
  }

  /* Items */
  .nav__item { position: relative; }

  .nav__link--dropdown {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--text-2);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color var(--t-fast);
  }
  .nav__link--dropdown:hover,
  .nav__link--dropdown.nav__link--active { color: var(--text); }

  .nav__chevron { transition: transform var(--t-fast); }
  .nav__item--has-dropdown:hover .nav__chevron,
  .nav__item--has-dropdown.is-open .nav__chevron { transform: rotate(180deg); }

  /* Dropdown */
  .nav__dropdown {
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 200px;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lg);
    padding: var(--sp-2);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--t-fast), transform var(--t-fast), visibility var(--t-fast);
    z-index: var(--z-dropdown);
  }
  .nav__item--has-dropdown:hover .nav__dropdown,
  .nav__item--has-dropdown.is-open .nav__dropdown {
    opacity: 1; visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav__dropdown-link {
    display: block;
    padding: 0.625rem 1rem;
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--text-2);
    border-radius: var(--r-md);
    transition: background var(--t-fast), color var(--t-fast);
    white-space: nowrap;
  }
  .nav__dropdown-link:hover,
  .nav__dropdown-link--active { background: var(--off-white); color: var(--text); }


  /* Optimizer link */
  .nav__optimizer-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--sky);
    padding: var(--sp-1) var(--sp-3);
    border: 1.5px solid var(--sky);
    border-radius: var(--r-full);
    white-space: nowrap;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .nav__optimizer-link:hover {
    background: var(--sky);
    color: var(--white);
  }

  /* Language switcher */
  .nav__lang-group {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .nav__lang {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--white);
    transition: transform var(--t-fast), border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .nav__lang:hover {
    transform: translateY(-1px);
    border-color: var(--text-3);
    box-shadow: 0 2px 6px rgba(0,0,0,.08);
  }
  .nav__lang-flag {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .nav__mobile-lang-flag {
    width: 20px;
    height: 20px;
    object-fit: cover;
    border-radius: 50%;
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  /* Burger */
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--sp-2);
  }
  .nav__burger span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text);
    border-radius: 2px;
    transition: all var(--t-base);
  }

  /* Mobile menu */
  .nav__mobile {
    display: none;
    flex-direction: column;
    padding: var(--sp-2) var(--gutter) var(--sp-4);
    border-top: 1px solid var(--border);
    background: var(--white);
  }
  .nav__mobile-link {
    display: block;
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--text-2);
    padding-block: var(--sp-2);
    border-bottom: 1px solid var(--border);
    transition: color var(--t-fast);
  }
  .nav__mobile-link:hover { color: var(--text); }
  .nav__mobile-link--child { font-size: var(--fs-sm); font-weight: 400; color: var(--text-3); padding-left: var(--sp-4); padding-block: var(--sp-1); }

  .nav__mobile-langs {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding-top: var(--sp-3);
    flex-wrap: wrap;
  }
  .nav__mobile-lang-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--white);
    transition: transform var(--t-fast), border-color var(--t-fast);
  }
  .nav__mobile-lang-pill:hover { transform: translateY(-1px); border-color: var(--text-3); }

  @media (max-width: 768px) {
    .nav__links, .nav__actions { display: none; }
    .nav__burger { display: flex; }
    .nav__mobile.is-open { display: flex; }
  }
</style>

<script>
  const burger = document.querySelector('.nav__burger') as HTMLButtonElement | null;
  const menu   = document.getElementById('mobile-menu');

  burger?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });

  document.querySelectorAll('.nav__link--dropdown').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.nav__item--has-dropdown');
      item?.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(item?.classList.contains('is-open') ?? false));
    });
  });

  document.addEventListener('click', (e) => {
    document.querySelectorAll('.nav__item--has-dropdown.is-open').forEach(item => {
      if (!item.contains(e.target as Node)) {
        item.classList.remove('is-open');
        item.querySelector('.nav__link--dropdown')?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
