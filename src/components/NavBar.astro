---
const links = [
  {
    label: 'Services',
    href: '/services',
    children: [
      { label: 'Training', href: '/services/training' },
    ],
  },
  { label: 'Pricing',  href: '/pricing' },
  { label: 'Work',     href: '/work' },
  { label: 'Insights', href: '/insights' },
  { label: 'About',    href: '/about' },
];
// Note: Contact removed from links — handled by dedicated CTA button only

const currentPath = Astro.url.pathname;
---

<nav class="nav" aria-label="Main navigation">
  <div class="nav__inner">

    <a href="/" class="nav__logo" aria-label="Nuvora Studio — home">
      <img src="/nuvora-logo.png" alt="Nuvora Studio" class="nav__logo-img" width="220" height="86" />
    </a>

    <ul class="nav__links" role="list">
      {links.map(link => (
        <li class={link.children ? 'nav__item nav__item--has-dropdown' : 'nav__item'}>
          {link.children ? (
            <>
              <button
                class={`nav__link nav__link--dropdown${currentPath.startsWith(link.href) ? ' nav__link--active' : ''}`}
                aria-haspopup="true" aria-expanded="false"
              >
                {link.label}
                <svg class="nav__chevron" width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
                  <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                </svg>
              </button>
              <ul class="nav__dropdown" role="list">
                <li>
                  <a href={link.href} class={`nav__dropdown-link${currentPath === link.href ? ' nav__dropdown-link--active' : ''}`}>
                    All Services
                  </a>
                </li>
                {link.children.map(child => (
                  <li>
                    <a href={child.href} class={`nav__dropdown-link${currentPath === child.href ? ' nav__dropdown-link--active' : ''}`}>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a href={link.href} class={`nav__link${currentPath === link.href ? ' nav__link--active' : ''}`}>
              {link.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <div class="nav__actions">
      <a href="/contact?intent=call" class="btn btn--primary btn--sm">Book a call</a>
    </div>

    <button class="nav__burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      {links.map(link => (
        <>
          <li><a href={link.href} class="nav__mobile-link">{link.label}</a></li>
          {link.children?.map(child => (
            <li><a href={child.href} class="nav__mobile-link nav__mobile-link--child">↳ {child.label}</a></li>
          ))}
        </>
      ))}
    </ul>
    <a href="/contact?intent=call" class="btn btn--primary w-full" style="justify-content:center; margin-top: 1.25rem;">Book a call</a>
  </div>
</nav>

<style>
  .nav__logo-img {
    height: 44px;
    width: auto;
    display: block;
  }

  /* Items */
  .nav__item { position: relative; }

  .nav__link--dropdown {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--fs-sm);
    font-weight: 400;
    color: var(--text-2);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color var(--t-fast);
  }
  .nav__link--dropdown:hover,
  .nav__link--dropdown.nav__link--active { color: var(--blue); }

  .nav__chevron { transition: transform var(--t-fast); }
  .nav__item--has-dropdown:hover .nav__chevron,
  .nav__item--has-dropdown.is-open .nav__chevron { transform: rotate(180deg); }

  /* Dropdown */
  .nav__dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 180px;
    background: var(--white);
    border: 1px solid var(--border-2);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lg);
    padding: var(--sp-2);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--t-fast), transform var(--t-fast), visibility var(--t-fast);
    z-index: 100;
  }
  .nav__item--has-dropdown:hover .nav__dropdown,
  .nav__item--has-dropdown.is-open .nav__dropdown {
    opacity: 1; visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav__dropdown-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: var(--fs-sm);
    color: var(--text-2);
    border-radius: var(--r-md);
    transition: background var(--t-fast), color var(--t-fast);
    white-space: nowrap;
  }
  .nav__dropdown-link:hover,
  .nav__dropdown-link--active { background: #EEF4FB; color: var(--blue); }

  /* Burger */
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--sp-2);
  }
  .nav__burger span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text);
    border-radius: 2px;
    transition: all var(--t-base);
  }

  /* Mobile menu */
  .nav__mobile {
    display: none;
    flex-direction: column;
    padding: var(--sp-4) var(--gutter) var(--sp-6);
    border-top: 1px solid var(--border);
    background: var(--white);
  }
  .nav__mobile-link {
    display: block;
    font-size: var(--fs-base);
    color: var(--text-2);
    padding-block: var(--sp-3);
    border-bottom: 1px solid var(--border);
    transition: color var(--t-fast);
  }
  .nav__mobile-link:hover { color: var(--blue); }
  .nav__mobile-link--child { font-size: var(--fs-sm); color: var(--text-3); padding-left: var(--sp-4); }

  @media (max-width: 768px) {
    .nav__links, .nav__actions { display: none; }
    .nav__burger { display: flex; }
    .nav__mobile.is-open { display: flex; }
  }
</style>

<script>
  const burger = document.querySelector('.nav__burger') as HTMLButtonElement | null;
  const menu   = document.getElementById('mobile-menu');

  burger?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });

  document.querySelectorAll('.nav__link--dropdown').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.nav__item--has-dropdown');
      item?.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(item?.classList.contains('is-open') ?? false));
    });
  });

  document.addEventListener('click', (e) => {
    document.querySelectorAll('.nav__item--has-dropdown.is-open').forEach(item => {
      if (!item.contains(e.target as Node)) {
        item.classList.remove('is-open');
        item.querySelector('.nav__link--dropdown')?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
