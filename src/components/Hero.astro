---
---

<section class="hero" aria-labelledby="hero-heading">
  <canvas class="hero__canvas" aria-hidden="true"></canvas>
  <div class="hero__gradient-1" aria-hidden="true"></div>
  <div class="hero__gradient-2" aria-hidden="true"></div>

  <div class="container hero__container">
    <div class="hero__grid">

      <div class="hero__copy">
        <h1 id="hero-heading" class="hero__headline">
          We grow LinkedIn presence.<br />
          <span class="hero__headline-sub">You get more leads.</span>
        </h1>

        <p class="hero__hook">
          LinkedIn is where B2B decisions are made.
        </p>

        <p class="hero__sub">
          We help you show up, build authority, and turn that into pipeline.
        </p>

        <div class="hero__actions">
          <a href="/contact?intent=call" class="btn btn--primary btn--lg hero__btn-primary">Start generating leads</a>
          <a href="/work" class="btn btn--outline-white btn--lg">View client results</a>
        </div>
      </div>

      <div class="hero__image-col">
        <div class="hero__image-wrap">
          <div class="hero__image-glow" aria-hidden="true"></div>
          <picture>
            <source srcset="/hero-network.webp" type="image/webp" />
            <img
              src="/Hero1.png"
              alt="65 million B2B decision-makers connected on LinkedIn"
              class="hero__img"
              width="900"
              height="900"
              loading="eager"
              decoding="async"
            />
          </picture>
        </div>
      </div>

    </div>

    <div class="hero__stats" aria-label="Key LinkedIn statistics">
      <div class="hero__stat">
        <span class="hero__stat-num" data-count="65" data-suffix="M+">65M+</span>
        <span class="hero__stat-label">Decision-makers on LinkedIn</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <span class="hero__stat-num">4 in 5</span>
        <span class="hero__stat-label">Members drive business decisions</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <span class="hero__stat-num">#1</span>
        <span class="hero__stat-label">B2B lead generation channel</span>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--deep-navy);
    padding-top: clamp(2rem, 4vw, 3.5rem);
    padding-bottom: 0;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__canvas { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.45; }

  .hero__gradient-1 {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 70% 30%, rgba(0,168,220,0.14) 0%, transparent 60%),
      radial-gradient(ellipse 50% 70% at 10% 80%, rgba(0,65,130,0.35) 0%, transparent 55%);
    z-index: 0; pointer-events: none;
  }

  .hero__gradient-2 {
    position: absolute; bottom: 0; left: 0; right: 0; height: 40%;
    background: linear-gradient(to top, rgba(0,24,64,0.6) 0%, transparent 100%);
    z-index: 0; pointer-events: none;
  }

  .hero__container { position: relative; z-index: 1; }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hero__headline {
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.01em;
    color: var(--white);
    margin-bottom: var(--sp-6);
    opacity: 0;
    animation: heroFadeUp 0.75s 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__headline-sub {
    display: block;
    background: linear-gradient(90deg, rgba(255,255,255,0.85) 0%, rgba(0,168,220,0.85) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 600;
  }

  .hero__hook {
    font-size: var(--fs-xl);
    font-weight: 500;
    color: rgba(255,255,255,0.80);
    line-height: 1.5;
    margin-bottom: var(--sp-4);
    opacity: 0;
    animation: heroFadeUp 0.75s 0.38s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__sub {
    font-size: var(--fs-md);
    line-height: 1.75;
    color: rgba(255,255,255,0.55);
    margin-bottom: var(--sp-8);
    max-width: 520px;
    opacity: 0;
    animation: heroFadeUp 0.75s 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    opacity: 0;
    animation: heroFadeUp 0.75s 0.55s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__btn-primary {
    box-shadow: 0 0 32px rgba(10,102,194,0.45);
    transition: box-shadow var(--t-base), transform var(--t-fast);
  }
  .hero__btn-primary:hover {
    box-shadow: 0 0 48px rgba(0,168,220,0.55);
    transform: translateY(-1px);
  }

  .hero__image-col {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    opacity: 0;
    animation: heroFadeUp 0.85s 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__image-wrap { position: relative; width: 100%; max-width: 500px; }

  .hero__image-glow {
    position: absolute; inset: -20px;
    background: radial-gradient(ellipse 70% 60% at 50% 60%, rgba(0,168,220,0.22) 0%, transparent 70%);
    z-index: 0; filter: blur(20px); pointer-events: none;
  }

  .hero__img {
    position: relative; z-index: 1; width: 100%; height: auto;
    border-radius: var(--r-2xl) var(--r-2xl) 0 0;
    display: block; margin-inline: auto;
    box-shadow: 0 -12px 80px rgba(0,168,220,0.18), 0 0 0 1px rgba(255,255,255,0.06);
    animation: float 6s ease-in-out infinite;
  }

  .hero__stats {
    display: flex; align-items: stretch; gap: 0;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.08); border-bottom: none;
    border-radius: var(--r-xl) var(--r-xl) 0 0;
    padding: var(--sp-5) var(--sp-6);
    opacity: 0;
    animation: heroFadeUp 0.75s 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__stat { flex: 1; display: flex; flex-direction: column; gap: 5px; padding-inline: var(--sp-6); }
  .hero__stat:first-child { padding-left: 0; }
  .hero__stat-num { font-size: var(--fs-2xl); font-weight: 700; color: var(--white); line-height: 1; letter-spacing: -0.02em; }
  .hero__stat-label { font-size: 0.68rem; font-weight: 400; color: var(--cyan); text-transform: uppercase; letter-spacing: 0.07em; line-height: 1.4; }
  .hero__stat-sep { width: 1px; background: rgba(255,255,255,0.10); flex-shrink: 0; margin-block: var(--sp-1); }

  @keyframes heroFadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes float { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-10px); } }

  @media (max-width: 900px) {
    .hero__grid { grid-template-columns: 1fr; gap: var(--sp-10); padding-bottom: var(--sp-8); }
    .hero__image-col { order: -1; }
    .hero__img { max-width: 360px; border-radius: var(--r-2xl); animation: none; }
  }

  @media (max-width: 640px) {
    .hero__stats { flex-direction: column; gap: var(--sp-5); padding: var(--sp-5); }
    .hero__stat { padding-inline: 0; }
    .hero__stat-sep { width: 100%; height: 1px; margin-block: 0; }
    .hero__img { max-width: 100%; }
  }
</style>

<script>
  const canvas = document.querySelector('.hero__canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const c = canvas;
    const ctx = c.getContext('2d')!;
    let nodes: Array<{ x: number; y: number; vx: number; vy: number; r: number }> = [];
    let W = 0, H = 0;
    const COUNT = 55;
    const MAX_DIST = 160;

    function resize() {
      W = c.offsetWidth; H = c.offsetHeight;
      c.width = W * devicePixelRatio; c.height = H * devicePixelRatio;
      ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    }
    function init() {
      nodes = Array.from({ length: COUNT }, () => ({
        x: Math.random() * W, y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.35, vy: (Math.random() - 0.5) * 0.35,
        r: Math.random() * 1.5 + 1,
      }));
    }
    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x; const dy = nodes[i].y - nodes[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MAX_DIST) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(0,168,220,${(1 - dist / MAX_DIST) * 0.25})`;
            ctx.lineWidth = 0.8;
            ctx.moveTo(nodes[i].x, nodes[i].y); ctx.lineTo(nodes[j].x, nodes[j].y); ctx.stroke();
          }
        }
      }
      nodes.forEach(n => { ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2); ctx.fillStyle = 'rgba(0,168,220,0.55)'; ctx.fill(); });
    }
    function update() {
      nodes.forEach(n => {
        n.x += n.vx; n.y += n.vy;
        if (n.x < 0 || n.x > W) n.vx *= -1;
        if (n.y < 0 || n.y > H) n.vy *= -1;
      });
    }
    function loop() { update(); draw(); requestAnimationFrame(loop); }
    resize(); init(); loop();
    new ResizeObserver(() => { resize(); init(); }).observe(c);
  }

  const statNums = document.querySelectorAll<HTMLElement>('.hero__stat-num[data-count]');
  const counterObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.count!);
      const suffix = el.dataset.suffix ?? '';
      const duration = 1400;
      const startTime = performance.now();
      function tick(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        el.textContent = Math.round(target * (1 - Math.pow(1 - progress, 3))) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
      counterObs.unobserve(el);
    });
  }, { threshold: 0.5 });
  statNums.forEach(el => counterObs.observe(el));
</script>
