---
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="container" style="position: relative; z-index: 2;">
    <div class="hero__content">
      <p class="eyebrow eyebrow--light reveal">The LinkedIn-only B2B agency</p>
      <h1 id="hero-heading" class="hero__h1 reveal reveal-delay-1">
        We turn LinkedIn into your <span class="text-gradient">best revenue channel.</span>
      </h1>
      <p class="hero__sub reveal reveal-delay-2">
        Strategy, content, and advertising. Built exclusively for LinkedIn.
        We help B2B companies show up, build authority, and generate pipeline.
      </p>
      <div class="hero__actions reveal reveal-delay-3">
        <a href="/contact?intent=call" class="btn btn--primary btn--lg">Book a strategy call</a>
        <a href="/services" class="btn btn--outline-white btn--lg">Explore services</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--sp-32) var(--sp-24);
    min-height: 520px;
    display: flex;
    align-items: center;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: url('/hero-notification.webp') center center / cover no-repeat;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(15,23,42, 0.88) 0%,
      rgba(15,23,42, 0.55) 50%,
      rgba(15,23,42, 0.20) 100%
    );
    z-index: 1;
  }

  .hero__content {
    max-width: 680px;
  }

  .hero__h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    color: var(--white);
    line-height: 1.10;
    letter-spacing: -0.02em;
    margin-block: var(--sp-5) var(--sp-6);
  }
  .hero__h1 .text-gradient {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--sky) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__sub {
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.68);
    max-width: 520px;
    line-height: 1.75;
    margin-bottom: var(--sp-10);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  @media (max-width: 640px) {
    .hero { padding-block: var(--sp-16) var(--sp-12); }
  }
</style>
