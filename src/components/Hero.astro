---
---

<section class="hero" aria-labelledby="hero-heading">
  <canvas class="hero__canvas" aria-hidden="true"></canvas>
  <div class="hero__gradient-1" aria-hidden="true"></div>
  <div class="hero__gradient-2" aria-hidden="true"></div>

  <div class="hero__bg-image" aria-hidden="true"></div>

  <div class="container hero__container">
    <div class="hero__center">

      <div class="hero__copy">
        <p class="hero__eyebrow">
          <span class="hero__eyebrow-dot" aria-hidden="true"></span>
          The LinkedIn-only B2B agency
        </p>

        <h1 id="hero-heading" class="hero__headline">
          We turn LinkedIn into your<br />
          <span class="hero__headline-accent">best revenue channel.</span>
        </h1>

        <p class="hero__sub">
          Strategy, content, and advertising. Built exclusively for LinkedIn.
          We help B2B companies show up, build authority, and generate pipeline.
        </p>

        <div class="hero__actions">
          <a href="/contact?intent=call" class="btn btn--primary btn--lg hero__btn-primary">Book a strategy call</a>
          <a href="/services" class="btn btn--outline-white btn--lg">Explore services</a>
        </div>
      </div>

    </div>

    <div class="hero__stats" aria-label="Key LinkedIn statistics">
      <div class="hero__stat">
        <span class="hero__stat-num" data-count="65" data-suffix="M+">65M+</span>
        <span class="hero__stat-label">Decision-makers on LinkedIn</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <span class="hero__stat-num">4 in 5</span>
        <span class="hero__stat-label">Members drive business decisions</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <span class="hero__stat-num">#1</span>
        <span class="hero__stat-label">B2B lead generation channel</span>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--deep-navy);
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: 0;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__canvas { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.35; }

  .hero__gradient-1 {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 70% 30%, rgba(0,168,220,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 50% 70% at 10% 80%, rgba(0,65,130,0.30) 0%, transparent 55%);
    z-index: 0; pointer-events: none;
  }

  .hero__gradient-2 {
    position: absolute; bottom: 0; left: 0; right: 0; height: 40%;
    background: linear-gradient(to top, rgba(0,24,64,0.6) 0%, transparent 100%);
    z-index: 0; pointer-events: none;
  }

  .hero__bg-image {
    position: absolute;
    inset: 0;
    background-image: url('/hero-network.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.15;
    z-index: 0;
    pointer-events: none;
  }

  .hero__container { position: relative; z-index: 1; }

  .hero__center {
    display: flex;
    justify-content: center;
    text-align: center;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  /* ── Copy ── */
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: var(--sp-6);
    opacity: 0;
    animation: heroFadeUp 0.75s 0.15s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__eyebrow-dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--cyan);
    animation: pulse 2s ease-in-out infinite;
  }

  .hero__headline {
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    font-weight: 700;
    line-height: 1.10;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-bottom: var(--sp-6);
    opacity: 0;
    animation: heroFadeUp 0.75s 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__headline-accent {
    display: block;
    background: linear-gradient(90deg, rgba(255,255,255,0.90) 0%, var(--cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__sub {
    font-size: var(--fs-md);
    line-height: 1.75;
    color: rgba(255,255,255,0.55);
    margin-bottom: var(--sp-8);
    max-width: 580px;
    margin-inline: auto;
    opacity: 0;
    animation: heroFadeUp 0.75s 0.38s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    justify-content: center;
    opacity: 0;
    animation: heroFadeUp 0.75s 0.50s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__btn-primary {
    box-shadow: 0 0 32px rgba(10,102,194,0.45);
    transition: box-shadow var(--t-base), transform var(--t-fast);
  }
  .hero__btn-primary:hover {
    box-shadow: 0 0 48px rgba(0,168,220,0.55);
    transform: translateY(-1px);
  }

  /* ── Stats bar ── */
  .hero__stats {
    display: flex; align-items: stretch; gap: 0;
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.08); border-bottom: none;
    border-radius: var(--r-xl) var(--r-xl) 0 0;
    padding: var(--sp-5) var(--sp-6);
    opacity: 0;
    animation: heroFadeUp 0.75s 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero__stat { flex: 1; display: flex; flex-direction: column; gap: 5px; padding-inline: var(--sp-6); text-align: center; }
  .hero__stat:first-child { padding-left: 0; }
  .hero__stat-num { font-size: var(--fs-2xl); font-weight: 700; color: var(--white); line-height: 1; letter-spacing: -0.02em; }
  .hero__stat-label { font-size: 0.68rem; font-weight: 400; color: var(--cyan); text-transform: uppercase; letter-spacing: 0.07em; line-height: 1.4; }
  .hero__stat-sep { width: 1px; background: rgba(255,255,255,0.10); flex-shrink: 0; margin-block: var(--sp-1); }

  /* ── Keyframes ── */
  @keyframes heroFadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  /* ── Responsive ── */

  @media (max-width: 640px) {
    .hero__stats { flex-direction: column; gap: var(--sp-5); padding: var(--sp-5); }
    .hero__stat { padding-inline: 0; }
    .hero__stat-sep { width: 100%; height: 1px; margin-block: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__eyebrow-dot { animation: none; }
    .hero__eyebrow, .hero__headline, .hero__sub, .hero__actions, .hero__stats {
      opacity: 1; animation: none;
    }
  }
</style>

<script>
  const canvas = document.querySelector('.hero__canvas') as HTMLCanvasElement | null;
  if (canvas) {
    const c = canvas;
    const ctx = c.getContext('2d')!;
    let nodes: Array<{ x: number; y: number; vx: number; vy: number; r: number }> = [];
    let W = 0, H = 0;
    const COUNT = 55;
    const MAX_DIST = 160;

    function resize() {
      W = c.offsetWidth; H = c.offsetHeight;
      c.width = W * devicePixelRatio; c.height = H * devicePixelRatio;
      ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    }
    function init() {
      nodes = Array.from({ length: COUNT }, () => ({
        x: Math.random() * W, y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.35, vy: (Math.random() - 0.5) * 0.35,
        r: Math.random() * 1.5 + 1,
      }));
    }
    function draw() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x; const dy = nodes[i].y - nodes[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MAX_DIST) {
            ctx.beginPath();
            ctx.strokeStyle = `rgba(0,168,220,${(1 - dist / MAX_DIST) * 0.25})`;
            ctx.lineWidth = 0.8;
            ctx.moveTo(nodes[i].x, nodes[i].y); ctx.lineTo(nodes[j].x, nodes[j].y); ctx.stroke();
          }
        }
      }
      nodes.forEach(n => { ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2); ctx.fillStyle = 'rgba(0,168,220,0.55)'; ctx.fill(); });
    }
    function update() {
      nodes.forEach(n => {
        n.x += n.vx; n.y += n.vy;
        if (n.x < 0 || n.x > W) n.vx *= -1;
        if (n.y < 0 || n.y > H) n.vy *= -1;
      });
    }
    function loop() { update(); draw(); requestAnimationFrame(loop); }
    resize(); init(); loop();
    new ResizeObserver(() => { resize(); init(); }).observe(c);
  }

  const statNums = document.querySelectorAll<HTMLElement>('.hero__stat-num[data-count]');
  const counterObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.count!);
      const suffix = el.dataset.suffix ?? '';
      const duration = 1400;
      const startTime = performance.now();
      function tick(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        el.textContent = Math.round(target * (1 - Math.pow(1 - progress, 3))) + suffix;
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
      counterObs.unobserve(el);
    });
  }, { threshold: 0.5 });
  statNums.forEach(el => counterObs.observe(el));
</script>
