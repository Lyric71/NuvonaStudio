  }
  .priority-card__impact {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    border-radius: var(--r-full);
    display: inline-block;
    margin-bottom: var(--sp-2);
  }
  .priority-card__impact--critical { background: #fef2f2; color: #dc2626; }
  .priority-card__impact--high { background: #fff7ed; color: #ea580c; }
  .priority-card__impact--medium { background: #f0f9ff; color: #0284c7; }
  .priority-card__tip {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.6;
    margin: 0;
