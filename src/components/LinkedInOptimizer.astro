    margin-bottom: var(--sp-10);
  }
  .results__details-toggle {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--sky);
    cursor: pointer;
    padding: var(--sp-1) 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    width: 100%;
  }
  .results__details-toggle::-webkit-details-marker { display: none; }
  .results__all-checks { padding-top: var(--sp-4); }
  .check-group-title {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: 600;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: var(--sp-6) 0 var(--sp-3);
  }
  .check-group-title:first-child { margin-top: 0; }
  .check-row {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) 0;
    font-size: var(--fs-sm);
    border-bottom: 1px solid var(--border);
  }
  .check-row:last-child { border-bottom: none; }
  .check-row__status {
    width: 20px;
    height: 20px;
    border-radius: var(--r-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .check-row__status--pass { background: #dcfce7; color: #16a34a; }
  .check-row__status--partial { background: #fef3c7; color: #d97706; }
  .check-row__status--fail { background: #fee2e2; color: #dc2626; }
  .check-row__status--na { background: var(--off-white); color: var(--text-3); }
  .check-row__label { flex: 1; color: var(--text-2); }

  /* ── CTA Card ── */
  .results__cta-card {
    background: var(--off-white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-8);
    display: flex;
    align-items: center;
    gap: var(--sp-8);
  }
  .results__cta-content { flex: 1; }
  .results__cta-content h3 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 var(--sp-2);
  }
  .results__cta-content p {
    font-size: var(--fs-sm);
    color: var(--text-2);
    margin: 0;
    line-height: 1.6;
  }
  .results__cta-actions {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    flex-shrink: 0;
  }
  .results__cta-actions .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .results__grid { grid-template-columns: 1fr; }
    .results__cta-card { flex-direction: column; text-align: center; }
    .results__cta-actions { width: 100%; }
    .score-hero { padding: var(--sp-8) var(--sp-6); }
  }
  @media (max-width: 640px) {
    .optimizer { padding: var(--sp-8) var(--sp-4) var(--sp-16); }
    .optimizer__title { font-size: var(--fs-2xl); }
    .optimizer__trust { flex-direction: column; align-items: center; gap: var(--sp-3); }
    .cat-bar__name { min-width: 100px; font-size: var(--fs-xs); }
    .cat-bar { padding: var(--sp-2) var(--sp-3); }
    .score-hero__ring { width: 120px; height: 120px; }
    .score-ring__number { font-size: 40px; }
  }
</style>

<script>
  // ══════════════════════════════════════════════════════════
  // DOM REFS
  // ══════════════════════════════════════════════════════════
  const viewInput   = document.getElementById('view-input') as HTMLElement;
  const viewLoading = document.getElementById('view-loading') as HTMLElement;
  const viewResults = document.getElementById('view-results') as HTMLElement;
  const form        = document.getElementById('analyze-form') as HTMLFormElement;
  const fileInput   = document.getElementById('screenshot-input') as HTMLInputElement;
  const uploadZone  = document.getElementById('upload-zone') as HTMLElement;
  const placeholder = document.getElementById('upload-placeholder') as HTMLElement;
  const previewWrap = document.getElementById('upload-preview') as HTMLElement;
  const previewImg  = document.getElementById('preview-image') as HTMLImageElement;
  const removeBtn   = document.getElementById('remove-image') as HTMLButtonElement;
  const analyzeBtn  = document.getElementById('analyze-btn') as HTMLButtonElement;
  const btnLabel    = analyzeBtn.querySelector('.btn__label') as HTMLElement;
  const btnLoading  = analyzeBtn.querySelector('.btn__loading') as HTMLElement;
  const errorBox    = document.getElementById('analyze-error') as HTMLElement;

  let selectedFile: File | null = null;

  function showView(view: HTMLElement) {
    [viewInput, viewLoading, viewResults].forEach(v => {
      v.hidden = true;
      v.classList.remove('optimizer__view--active');
    });
    view.hidden = false;
    view.classList.add('optimizer__view--active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ══════════════════════════════════════════════════════════
  // FILE UPLOAD HANDLING
  // ══════════════════════════════════════════════════════════
  function showPreview(file: File) {
    selectedFile = file;
    const reader = new FileReader();
    reader.onload = (e) => {
      previewImg.src = e.target?.result as string;
      placeholder.hidden = true;
      previewWrap.hidden = false;
      uploadZone.classList.add('has-file');
    };
    reader.readAsDataURL(file);
  }

  function clearFile() {
    selectedFile = null;
    fileInput.value = '';
    placeholder.hidden = false;
    previewWrap.hidden = true;
    uploadZone.classList.remove('has-file');
    previewImg.src = '';
  }

  fileInput.addEventListener('change', () => {
    if (fileInput.files && fileInput.files[0]) {
      const file = fileInput.files[0];
      if (file.size > 10 * 1024 * 1024) {
        errorBox.textContent = 'File is too large. Maximum size is 10 MB.';
        errorBox.hidden = false;
        return;
      }
      errorBox.hidden = true;
      showPreview(file);
    }
  });

  removeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    clearFile();
  });

  // Drag & drop
  uploadZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadZone.classList.add('is-dragover');
  });
  uploadZone.addEventListener('dragleave', () => {
    uploadZone.classList.remove('is-dragover');
  });
  uploadZone.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('is-dragover');
    const file = e.dataTransfer?.files?.[0];
    if (file && file.type.startsWith('image/')) {
      showPreview(file);
    }
  });

  // ══════════════════════════════════════════════════════════
  // GRADE HELPERS
  // ══════════════════════════════════════════════════════════
  function getVerdict(grade: string): string {
    const v: Record<string, string> = {
      S:'Elite \u2014 Top 1%. Your profile is world-class.',
      A:'Excellent \u2014 Top 10%. A few tweaks away from perfection.',
      B:'Good \u2014 Above average with room to grow.',
      C:'Average \u2014 Several opportunities for improvement.',
      D:'Below Average \u2014 Significant gaps costing you visibility.',
      F:'Major Overhaul Needed \u2014 Time for a fresh start.'
    };
    return v[grade] || '';
  }
  function getBarColor(score: number): string {
    if (score >= 85) return '#22c55e';
    if (score >= 70) return '#0ea5e9';
    if (score >= 55) return '#f59e0b';
    return '#ef4444';
  }
  function gradeColor(grade: string): string {
    if (grade === 'S' || grade === 'A') return '#22c55e';
    if (grade === 'B') return '#0ea5e9';
    if (grade === 'C') return '#f59e0b';
    return '#ef4444';
  }

  // ══════════════════════════════════════════════════════════
  // LOADING ANIMATION
  // ══════════════════════════════════════════════════════════
  let loadingTimers: number[] = [];
  function startLoadingAnimation() {
    const steps = [
      document.getElementById('loading-step-1')!,
      document.getElementById('loading-step-2')!,
      document.getElementById('loading-step-3')!,
    ];
    steps.forEach(s => { s.classList.remove('is-active', 'is-done'); });
    steps[0].classList.add('is-active');
    loadingTimers.push(window.setTimeout(() => {
      steps[0].classList.remove('is-active'); steps[0].classList.add('is-done');
      steps[1].classList.add('is-active');
    }, 3000));
    loadingTimers.push(window.setTimeout(() => {
      steps[1].classList.remove('is-active'); steps[1].classList.add('is-done');
      steps[2].classList.add('is-active');
    }, 8000));
  }
  function stopLoadingAnimation() {
    loadingTimers.forEach(t => clearTimeout(t));
    loadingTimers = [];
  }

  // ══════════════════════════════════════════════════════════
  // RENDER RESULTS
  // ══════════════════════════════════════════════════════════
  function renderResults(data: any) {
    // Type label
    document.getElementById('results-type-label')!.textContent =
      data.profile_type === 'company' ? 'Company Page Analysis' : 'Personal Profile Analysis';

    // Score ring
    const circle = document.getElementById('score-circle') as unknown as (HTMLElement & { style: CSSStyleDeclaration });
    const circumference = 2 * Math.PI * 52;
    const offset = circumference - (data.overall_score / 100) * circumference;
    circle.style.transition = 'none';
    circle.style.strokeDashoffset = String(circumference);
    requestAnimationFrame(() => {
      circle.style.transition = 'stroke-dashoffset 1.2s cubic-bezier(0.16, 1, 0.3, 1)';
      circle.style.strokeDashoffset = String(offset);
    });

    // Animate number
    const numEl = document.getElementById('score-number')!;
    const gradeEl = document.getElementById('score-grade')!;
    let current = 0;
    const target = data.overall_score;
    const step = Math.max(1, Math.floor(target / 40));
    const timer = setInterval(() => {
      current = Math.min(current + step, target);
      numEl.textContent = String(current);
      if (current >= target) clearInterval(timer);
    }, 25);
    gradeEl.textContent = data.overall_grade;
    // Style grade badge on dark background
    const gc = gradeColor(data.overall_grade);
    gradeEl.style.color = gc;
    gradeEl.style.background = gc + '20'; // 12% opacity
    gradeEl.style.border = `1px solid ${gc}40`;
    document.getElementById('results-verdict')!.textContent = getVerdict(data.overall_grade);

    // Category bars with score color
    const catContainer = document.getElementById('results-categories')!;
    catContainer.innerHTML = data.categories.map((cr: any) => {
      const barColor = getBarColor(cr.score);
      return `
      <div class="cat-bar">
        <div class="cat-bar__icon" style="background:${barColor}15;color:${barColor};">${cr.score >= 80 ? '\u2713' : cr.score >= 55 ? '\u2022' : '!'}</div>
        <span class="cat-bar__name">${cr.name}</span>
        <div class="cat-bar__track">
          <div class="cat-bar__fill" style="width:0;background:${barColor};" data-target="${cr.score}"></div>
        </div>
        <span class="cat-bar__score" style="color:${barColor};">${cr.score}%</span>
      </div>`;
    }).join('');
    setTimeout(() => {
      catContainer.querySelectorAll<HTMLElement>('.cat-bar__fill').forEach(el => {
        el.style.width = el.dataset.target + '%';
      });
    }, 200);

    // Priorities
    const priContainer = document.getElementById('results-priorities')!;
    if (!data.top_priorities?.length) {
      priContainer.innerHTML = '<p style="color:var(--text-2);font-size:var(--fs-sm);">No critical issues found!</p>';
    } else {
      priContainer.innerHTML = data.top_priorities.map((p: any, i: number) => {
        const cls = p.impact === 'CRITICAL' ? 'critical' : p.impact === 'HIGH' ? 'high' : 'medium';
        return `
        <div class="priority-card">
          <span class="priority-card__rank">${i + 1}</span>
          <div class="priority-card__content">
            <span class="priority-card__impact priority-card__impact--${cls}">${p.impact}</span>
            <p class="priority-card__label">${p.label}</p>
            <p class="priority-card__tip">${p.recommendation}</p>
          </div>
        </div>`;
      }).join('');
    }

    // Quick wins
    const qwContainer = document.getElementById('results-quick-wins')!;
    if (!data.quick_wins?.length) {
      qwContainer.innerHTML = '<p style="color:var(--text-2);font-size:var(--fs-sm);">No quick wins remaining!</p>';
    } else {
      qwContainer.innerHTML = data.quick_wins.map((q: string) => `
        <div class="quick-win">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          ${q}
        </div>`).join('');
    }

    // Strengths
    const strContainer = document.getElementById('results-strengths')!;
    if (!data.strengths?.length) {
      strContainer.innerHTML = '<p style="color:var(--text-2);font-size:var(--fs-sm);">Keep improving!</p>';
    } else {
      strContainer.innerHTML = data.strengths.map((s: string) => `
        <div class="strength-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ${s}
        </div>`).join('');
    }

    // Detailed checks
    const allChecksContainer = document.getElementById('results-all-checks')!;
    const statusIcons: Record<string, string> = {
      pass: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>',
      partial: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14"/></svg>',
      fail: '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6L6 18M6 6l12 12"/></svg>',
      na: '<span style="font-size:9px;font-weight:700;">N/A</span>',
    };
    let checksHtml = '';
    (data.categories || []).forEach((cat: any) => {
      checksHtml += `<div class="check-group-title">${cat.name}</div>`;
      (cat.checks || []).forEach((c: any) => {
        checksHtml += `
          <div class="check-row">
            <span class="check-row__status check-row__status--${c.status}">${statusIcons[c.status] || statusIcons.na}</span>
            <span class="check-row__label">${c.label}</span>
          </div>`;
      });
    });
    allChecksContainer.innerHTML = checksHtml;

    showView(viewResults);
  }

  // ══════════════════════════════════════════════════════════
  // UPLOAD PROGRESS
  // ══════════════════════════════════════════════════════════
  const progressWrap   = document.getElementById('upload-progress') as HTMLElement;
  const progressName   = document.getElementById('upload-progress-name') as HTMLElement;
  const progressPct    = document.getElementById('upload-progress-pct') as HTMLElement;
  const progressFill   = document.getElementById('upload-progress-fill') as HTMLElement;
  const progressStatus = document.getElementById('upload-progress-status') as HTMLElement;

  function showProgress(fileName: string) {
    progressName.textContent = fileName;
    progressPct.textContent = '0%';
    progressFill.style.width = '0%';
    progressStatus.textContent = 'Uploading screenshot...';
    progressStatus.classList.remove('is-done');
    progressWrap.hidden = false;
  }
  function updateProgress(pct: number) {
    const p = Math.min(100, Math.round(pct));
    progressPct.textContent = p + '%';
    progressFill.style.width = p + '%';
    if (p >= 100) {
      progressStatus.textContent = 'Upload complete — analyzing...';
      progressStatus.classList.add('is-done');
    }
  }
  function hideProgress() {
    progressWrap.hidden = true;
  }

  // ══════════════════════════════════════════════════════════
  // FORM SUBMIT (XHR for upload progress)
  // ══════════════════════════════════════════════════════════
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!selectedFile) {
      errorBox.textContent = 'Please upload a screenshot of your LinkedIn profile.';
      errorBox.hidden = false;
      return;
    }

    // UI: loading state
    analyzeBtn.disabled = true;
    btnLabel.hidden = true;
    btnLoading.hidden = false;
    errorBox.hidden = true;

    // Show progress bar in upload zone
    showProgress(selectedFile.name);

    try {
      // Convert file to base64
      const base64 = await new Promise<string>((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve((reader.result as string).split(',')[1]);
        reader.onerror = reject;
        reader.readAsDataURL(selectedFile!);
      });

      const mediaType = selectedFile.type || 'image/png';
      const payload = JSON.stringify({ image: base64, media_type: mediaType });

      // Use XHR for upload progress tracking
      const data = await new Promise<any>((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/api/analyze-linkedin');
        xhr.setRequestHeader('Content-Type', 'application/json');

        xhr.upload.addEventListener('progress', (evt) => {
          if (evt.lengthComputable) {
            updateProgress((evt.loaded / evt.total) * 100);
          }
        });

        xhr.upload.addEventListener('loadend', () => {
          updateProgress(100);
          // Switch to analyzing view after upload completes
          setTimeout(() => {
            hideProgress();
            showView(viewLoading);
            startLoadingAnimation();
          }, 400);
        });

        xhr.addEventListener('load', () => {
          try {
            const result = JSON.parse(xhr.responseText);
            if (xhr.status >= 200 && xhr.status < 300 && result.success) {
              resolve(result);
            } else {
              reject(new Error(result.error || 'Analysis failed. Please try again.'));
            }
          } catch {
            reject(new Error('Failed to parse response.'));
          }
        });

        xhr.addEventListener('error', () => reject(new Error('Network error. Please try again.')));
        xhr.addEventListener('timeout', () => reject(new Error('Request timed out. Please try again.')));
        xhr.timeout = 120000; // 2 min timeout for AI analysis

        xhr.send(payload);
      });

      stopLoadingAnimation();
      renderResults(data.analysis);

    } catch (err: any) {
      stopLoadingAnimation();
      hideProgress();
      showView(viewInput);
      errorBox.textContent = err.message || 'Something went wrong. Please try again.';
      errorBox.hidden = false;
    } finally {
      analyzeBtn.disabled = false;
      btnLabel.hidden = false;
      btnLoading.hidden = true;
    }
  });

  // Restart
  document.getElementById('btn-restart')!.addEventListener('click', () => {
    clearFile();
    showView(viewInput);
  });
</script>
