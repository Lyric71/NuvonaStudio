    transition: box-shadow var(--t-fast), transform 200ms ease;
  }
  .priority-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }
  .priority-card__rank {
    width: 32px;
    height: 32px;
    border-radius: var(--r-full);
    background: linear-gradient(135deg, var(--sky), var(--cyan));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 700;
    flex-shrink: 0;
  }
  .priority-card__content { flex: 1; }
  .priority-card__label {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text);
