---
/**
 * Pricing comparison table — clean card-wrapped design
 * Matches Nuvora design system v2.
 */

interface PricingFeature {
  label: string;
  foundation: string;
  growth: string;
  scale: string;
}

interface PricingPlan {
  name: string;
  popular: boolean;
  price: string;
  href: string;
}

interface Props {
  plans: PricingPlan[];
  features: PricingFeature[];
}

const { plans, features } = Astro.props;
---

<div class="ptable">
  <div class="ptable__scroll">
    <table class="ptable__table" aria-label="Core retainer tier comparison">
      <thead>
        <tr>
          <th class="ptable__corner"></th>
          {plans.map(plan => (
            <th class={`ptable__plan ${plan.popular ? 'ptable__plan--pop' : ''}`}>
              {plan.popular && <span class="ptable__pop-badge">Most popular</span>}
              <span class="ptable__plan-name">{plan.name}</span>
              <span class="ptable__plan-price">{plan.price}<span class="ptable__plan-period">/mo</span></span>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {features.map((f, i) => (
          <tr class={i === 0 ? 'ptable__row--price' : ''}>
            <td class="ptable__label">{f.label}</td>
            {[f.foundation, f.growth, f.scale].map((val, ci) => (
              <td class={`ptable__val ${plans[ci].popular ? 'ptable__val--pop' : ''}`}>
                {val === '✓' ? (
                  <svg class="ptable__check" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-label="Included">
                    <path d="M4 9.5l3.5 3.5L14 6" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                ) : val === '—' ? (
                  <span class="ptable__dash">—</span>
                ) : (
                  <span class="ptable__text">{val}</span>
                )}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
      <tfoot>
        <tr>
          <td></td>
          {plans.map(plan => (
            <td class="ptable__cta">
              <a href={plan.href} class={`btn ${plan.popular ? 'btn--primary' : 'btn--outline'}`}>
                Book a call
              </a>
            </td>
          ))}
        </tr>
      </tfoot>
    </table>
  </div>
</div>

<style>
  .ptable {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .ptable__scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ptable__table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
  }

  /* ── Header ── */
  .ptable__corner {
    background: var(--white);
    width: 30%;
  }

  .ptable__plan {
    background: var(--white);
    padding: var(--sp-6) var(--sp-5);
    text-align: center;
    vertical-align: bottom;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .ptable__plan--pop {
    background: rgba(10, 102, 194, 0.03);
  }

  .ptable__pop-badge {
    display: inline-block;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--gradient-button);
    padding: 3px var(--sp-3);
    border-radius: var(--r-full);
    margin-bottom: var(--sp-3);
  }

  .ptable__plan-name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--sp-2);
  }

  .ptable__plan-price {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 700;
    color: var(--deep-navy);
    line-height: 1;
  }

  .ptable__plan-period {
    font-size: var(--fs-sm);
    font-weight: 400;
    color: var(--text-2);
  }

  /* ── Body rows ── */
  .ptable__table tbody tr {
    transition: background var(--t-fast);
  }

  .ptable__table tbody tr:hover {
    background: var(--off-white);
  }

  .ptable__label {
    padding: var(--sp-3) var(--sp-6);
    font-size: var(--fs-sm);
    font-weight: 400;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .ptable__val {
    padding: var(--sp-3) var(--sp-5);
    text-align: center;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .ptable__val--pop {
    background: rgba(10, 102, 194, 0.03);
  }

  .ptable__table tbody tr:hover .ptable__val--pop {
    background: rgba(10, 102, 194, 0.05);
  }

  .ptable__check {
    display: inline-block;
    vertical-align: middle;
  }

  .ptable__dash {
    color: var(--text-3);
    font-size: var(--fs-sm);
  }

  .ptable__text {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text);
  }

  /* hide price row since prices are in header */
  .ptable__row--price {
    display: none;
  }

  /* ── Footer CTA ── */
  .ptable__cta {
    padding: var(--sp-6) var(--sp-5);
    text-align: center;
    vertical-align: middle;
  }

  .ptable__cta .btn {
    font-size: var(--fs-sm);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .ptable__label {
      padding: var(--sp-3) var(--sp-4);
      font-size: var(--fs-xs);
    }

    .ptable__val {
      padding: var(--sp-3);
    }

    .ptable__plan {
      padding: var(--sp-4) var(--sp-3);
    }

    .ptable__plan-price {
      font-size: var(--fs-xl);
    }
  }
</style>
