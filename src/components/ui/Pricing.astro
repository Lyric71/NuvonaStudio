---
/**
 * Pricing comparison table — clean card-wrapped design
 * Matches Nuvora design system v2.
 */

interface PricingFeature {
  label: string;
  foundation: string;
  growth: string;
  scale: string;
}

interface PricingPlan {
  name: string;
  popular: boolean;
  price: string;
  href: string;
}

interface Props {
  plans: PricingPlan[];
  features: PricingFeature[];
  ctaLabel?: string;
  popularLabel?: string;
  periodLabel?: string;
}

const { plans, features, ctaLabel = 'Book a call', popularLabel = 'Most popular', periodLabel = '/mo' } = Astro.props;
---

<!-- Desktop table -->
<div class="ptable ptable--desktop">
  <div class="ptable__scroll">
    <table class="ptable__table" aria-label="Core retainer tier comparison">
      <thead>
        <tr>
          <th class="ptable__corner"></th>
          {plans.map(plan => (
            <th class={`ptable__plan ${plan.popular ? 'ptable__plan--pop' : ''}`}>
              {plan.popular && <span class="ptable__pop-badge">{popularLabel}</span>}
              <span class="ptable__plan-name">{plan.name}</span>
              <span class="ptable__plan-price">{plan.price}<span class="ptable__plan-period">{periodLabel}</span></span>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {features.map((f, i) => (
          <tr class={i === 0 ? 'ptable__row--price' : ''}>
            <td class="ptable__label">{f.label}</td>
            {[f.foundation, f.growth, f.scale].map((val, ci) => (
              <td class={`ptable__val ${plans[ci].popular ? 'ptable__val--pop' : ''}`}>
                {val === '✓' ? (
                  <svg class="ptable__check" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-label="Included">
                    <path d="M4 9.5l3.5 3.5L14 6" stroke="var(--blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                ) : val === '—' ? (
                  <span class="ptable__dash">—</span>
                ) : (
                  <span class="ptable__text">{val}</span>
                )}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
      <tfoot>
        <tr>
          <td></td>
          {plans.map(plan => (
            <td class="ptable__cta">
              <a href={plan.href} class={`btn ${plan.popular ? 'btn--primary' : 'btn--outline'}`}>
                {ctaLabel}
              </a>
            </td>
          ))}
        </tr>
      </tfoot>
    </table>
  </div>
</div>

<!-- Mobile cards -->
<div class="ptable-mobile">
  {plans.map((plan, pi) => (
    <div class={`pm-card ${plan.popular ? 'pm-card--pop' : ''}`}>
      {plan.popular && <span class="pm-card__badge">{popularLabel}</span>}
      <h3 class="pm-card__name">{plan.name}</h3>
      <p class="pm-card__price">{plan.price}<span class="pm-card__period">{periodLabel}</span></p>
      <ul class="pm-card__features" role="list">
        {features.slice(1).map(f => {
          const val = [f.foundation, f.growth, f.scale][pi];
          return val !== '—' ? (
            <li class="pm-card__feat">
              <svg class="pm-card__check-icon" width="16" height="16" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M4 9.5l3.5 3.5L14 6" stroke="var(--sky)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>
                {f.label}{val !== '✓' ? <strong class="pm-card__feat-val"> - {val}</strong> : null}
              </span>
            </li>
          ) : null;
        })}
      </ul>
      <a href={plan.href} class={`btn ${plan.popular ? 'btn--primary' : 'btn--outline'} pm-card__cta`}>
        {ctaLabel}
      </a>
    </div>
  ))}
</div>

<style>
  .ptable {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .ptable__scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ptable__table {
    width: 100%;
    min-width: 640px;
    border-collapse: collapse;
  }

  /* ── Header ── */
  .ptable__corner {
    background: var(--white);
    width: 30%;
  }

  .ptable__plan {
    background: var(--white);
    padding: var(--sp-8) var(--sp-5);
    text-align: center;
    vertical-align: bottom;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .ptable__plan--pop {
    background: rgba(14, 165, 233, 0.03);
    border-bottom: 2px solid var(--sky);
  }

  .ptable__pop-badge {
    display: inline-block;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--gradient-button);
    padding: 4px var(--sp-3);
    border-radius: var(--r-full);
    margin-bottom: var(--sp-3);
  }

  .ptable__plan-name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--sp-2);
  }

  .ptable__plan-price {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 700;
    color: var(--deep-navy);
    line-height: 1;
  }

  .ptable__plan-period {
    font-size: var(--fs-sm);
    font-weight: 400;
    color: var(--text-3);
  }

  /* ── Body rows ── */
  .ptable__table tbody tr {
    transition: background var(--t-fast);
  }

  .ptable__table tbody tr:hover {
    background: var(--off-white);
  }

  .ptable__label {
    padding: var(--sp-3) var(--sp-6);
    font-size: var(--fs-sm);
    font-weight: 400;
    color: var(--text);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .ptable__val {
    padding: var(--sp-3) var(--sp-5);
    text-align: center;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .ptable__val--pop {
    background: rgba(14, 165, 233, 0.03);
  }

  .ptable__table tbody tr:hover .ptable__val--pop {
    background: rgba(14, 165, 233, 0.06);
  }

  .ptable__check {
    display: inline-block;
    vertical-align: middle;
  }

  .ptable__dash {
    color: var(--text-3);
    font-size: var(--fs-sm);
  }

  .ptable__text {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text);
  }

  /* hide price row since prices are in header */
  .ptable__row--price {
    display: none;
  }

  /* ── Footer CTA ── */
  .ptable__cta {
    padding: var(--sp-8) var(--sp-5);
    text-align: center;
    vertical-align: middle;
  }

  .ptable__cta .btn {
    font-size: var(--fs-sm);
  }

  /* ── Mobile cards (hidden on desktop) ── */
  .ptable-mobile {
    display: none;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .ptable--desktop {
      display: none;
    }

    .ptable-mobile {
      display: flex;
      flex-direction: column;
      gap: var(--sp-5);
    }

    .pm-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--r-xl);
      padding: var(--sp-6);
      display: flex;
      flex-direction: column;
      gap: var(--sp-1);
    }

    .pm-card--pop {
      border-color: var(--sky);
      background: rgba(14, 165, 233, 0.02);
      box-shadow: 0 0 0 1px rgba(14, 165, 233, 0.12), var(--shadow-md);
    }

    .pm-card__badge {
      display: inline-flex;
      align-self: flex-start;
      font-size: var(--fs-xs);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--white);
      background: var(--gradient-button);
      padding: 3px var(--sp-3);
      border-radius: var(--r-full);
      margin-bottom: var(--sp-1);
    }

    .pm-card__name {
      font-family: var(--font-display);
      font-size: var(--fs-lg);
      font-weight: 600;
      color: var(--text);
    }

    .pm-card__price {
      font-family: var(--font-display);
      font-size: var(--fs-2xl);
      font-weight: 700;
      color: var(--deep-navy);
      line-height: 1;
      margin-top: var(--sp-1);
      margin-bottom: var(--sp-4);
    }

    .pm-card__period {
      font-size: var(--fs-sm);
      font-weight: 400;
      color: var(--text-3);
    }

    .pm-card__features {
      display: flex;
      flex-direction: column;
      gap: var(--sp-2);
      padding: var(--sp-4) 0;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      margin-bottom: var(--sp-5);
    }

    .pm-card__feat {
      display: flex;
      align-items: flex-start;
      gap: var(--sp-2);
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--text-2);
      line-height: 1.5;
    }

    .pm-card__check-icon {
      flex-shrink: 0;
      margin-top: 2px;
    }

    .pm-card__feat-val {
      color: var(--text);
      font-weight: 600;
    }

    .pm-card__cta {
      width: 100%;
      justify-content: center;
      min-height: 44px;
    }
  }
</style>
