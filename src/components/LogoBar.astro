---
const logos = ['Siemens', 'Deloitte', 'SAP', 'HubSpot', 'Salesforce', 'McKinsey'];
---

<section class="logobar" aria-label="Trusted by leading B2B companies">
  <div class="container">
    <p class="logobar__label">Trusted by B2B teams at</p>
    <div class="logobar__track">
      <div class="logobar__logos">
        {Array.from({ length: 2 }).map(() => (
          <div class="logobar__set" aria-hidden="true">
            {logos.map(name => (
              <div class="logobar__logo-placeholder">
                <span>{name}</span>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .logobar {
    background: var(--off-white);
    padding-block: var(--sp-10);
    border-bottom: 1px solid var(--border);
  }

  .logobar__label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
    text-align: center;
    margin-bottom: var(--sp-6);
  }

  .logobar__track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .logobar__logos {
    display: flex;
    width: max-content;
    animation: logoScroll 28s linear infinite;
  }

  .logobar__set {
    display: flex;
    align-items: center;
    gap: var(--sp-8);
    padding-right: var(--sp-8);
    flex-shrink: 0;
  }

  .logobar__logo-placeholder {
    width: 120px;
    height: 44px;
    border-radius: var(--r-md);
    background: var(--white);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logobar__logo-placeholder span {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-3);
    user-select: none;
  }

  @keyframes logoScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .logobar__logos { animation: none; }
  }
</style>
