---
const faqs = [
  {
    q: 'Do you work with companies outside Europe?',
    a: 'Yes. We work with B2B companies globally. LinkedIn is a global platform and our team operates across time zones.',
  },
  {
    q: 'Do you manage LinkedIn only, or other channels too?',
    a: 'LinkedIn only. That is a deliberate choice — it allows us to go deeper on the platform than any generalist agency can.',
  },
  {
    q: 'Is advertising included in your services?',
    a: 'LinkedIn advertising is a dedicated service line. Some clients engage us for organic content only, others for paid only, and many for both. We scope each engagement around your objectives.',
  },
  {
    q: 'How do you report on results?',
    a: 'Every client receives a performance dashboard aligned to agreed KPIs. We report against outcomes — reach, engagement, leads, pipeline — not just activity.',
  },
  {
    q: 'Do smaller companies work with you?',
    a: 'Yes. Our training and standalone advisory services are designed for teams that are not yet ready for a full retainer but want to build genuine LinkedIn capability.',
  },
];
---

<section class="section" aria-labelledby="faq-heading" style="background: var(--off-white);">
  <div class="container container--lg">

    <div class="faq__head reveal">
      <div>
        <p class="eyebrow">Common questions</p>
        <h2 id="faq-heading">The things people usually ask.</h2>
      </div>
      <p class="faq__sub">
        Still have questions? <a href="/contact" class="faq__link">Get in touch</a> and we'll reply within one business day.
      </p>
    </div>

    <dl class="faq__list reveal reveal-delay-1">
      {faqs.map((faq, i) => (
        <div class="faq__item">
          <dt>
            <button
              class="faq__question"
              aria-expanded="false"
              aria-controls={`faq-answer-${i}`}
              id={`faq-q-${i}`}
            >
              <span>{faq.q}</span>
              <span class="faq__icon" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd class="faq__answer" id={`faq-answer-${i}`} role="region" aria-labelledby={`faq-q-${i}`} hidden>
            <p>{faq.a}</p>
          </dd>
        </div>
      ))}
    </dl>

  </div>
</section>

<style>
  .faq__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: end;
    margin-bottom: var(--sp-12);
  }

  .faq__sub {
    font-size: var(--fs-md);
    color: var(--text-2);
    line-height: 1.7;
    align-self: flex-end;
  }
  .faq__link { color: var(--blue); transition: color var(--t-fast); }
  .faq__link:hover { color: var(--mid-blue); }

  .faq__list {
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
    background: var(--white);
  }

  .faq__item { border-bottom: 1px solid var(--border); }
  .faq__item:last-child { border-bottom: none; }

  .faq__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    padding: var(--sp-5) var(--sp-7);
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    text-align: left;
    background: var(--white);
    transition: background var(--t-fast), color var(--t-fast);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .faq__question:hover { background: #EEF4FB; }
  .faq__question[aria-expanded="true"] { background: #EEF4FB; color: var(--blue); }

  .faq__icon { flex-shrink: 0; color: var(--text-3); transition: transform var(--t-base), color var(--t-base); }
  .faq__question[aria-expanded="true"] .faq__icon { transform: rotate(180deg); color: var(--blue); }

  .faq__answer { padding: 0 var(--sp-7) var(--sp-5); background: #EEF4FB; }
  .faq__answer p { font-size: var(--fs-sm); color: var(--text-2); line-height: 1.75; }

  @media (max-width: 768px) {
    .faq__head { grid-template-columns: 1fr; gap: var(--sp-6); }
    .faq__question { padding: var(--sp-5); font-size: var(--fs-base); }
    .faq__answer { padding: 0 var(--sp-5) var(--sp-5); }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answer = document.getElementById(btn.getAttribute('aria-controls')!) as HTMLElement | null;
      btn.setAttribute('aria-expanded', String(!expanded));
      if (answer) answer.hidden = expanded;
    });
  });
</script>
