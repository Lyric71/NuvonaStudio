---
interface FaqItem {
  q: string;
  a: string;
  link?: { text: string; href: string };
}

interface Props {
  eyebrow?: string;
  heading: string;
  faqs: FaqItem[];
  footer?: string;
  footerLink?: { text: string; href: string };
  cta?: { text: string; href: string };
  background?: string;
  id?: string;
}

const {
  eyebrow = 'FAQ',
  heading,
  faqs,
  footer,
  footerLink,
  cta,
  background,
  id = 'faq',
} = Astro.props;
---

<section class="section" aria-labelledby={`${id}-heading`} style={background ? `background: ${background};` : undefined}>
  <div class="container container--md">

    <div class="faq__head reveal">
      <p class="eyebrow">{eyebrow}</p>
      <h2 id={`${id}-heading`}>{heading}</h2>
    </div>

    <dl class="faq__list reveal reveal-delay-1">
      {faqs.map((faq, i) => (
        <div class="faq__item">
          <dt>
            <button
              class="faq__question"
              aria-expanded="false"
              aria-controls={`${id}-answer-${i}`}
              id={`${id}-q-${i}`}
            >
              <span>{faq.q}</span>
              <span class="faq__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path d="M4.5 6.75l4.5 4.5 4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd class="faq__answer" id={`${id}-answer-${i}`} role="region" aria-labelledby={`${id}-q-${i}`} hidden>
            <p>{faq.a}{faq.link && <> <a href={faq.link.href} class="faq__answer-link">{faq.link.text}</a></>}</p>
          </dd>
        </div>
      ))}
    </dl>

    {footer && footerLink && (
      <p class="faq__footer reveal">
        {footer} <a href={footerLink.href} class="faq__link">{footerLink.text}</a>
      </p>
    )}

    {cta && (
      <div class="faq__cta reveal">
        <a href={cta.href} class="btn btn--primary btn--lg">{cta.text}</a>
      </div>
    )}

  </div>
</section>

<style>
  .faq__head {
    margin-bottom: var(--sp-10);
  }

  .faq__head h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    max-width: 520px;
  }

  .faq__list {
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
    background: var(--white);
    margin-bottom: var(--sp-8);
  }

  .faq__item { border-bottom: 1px solid var(--border); }
  .faq__item:last-child { border-bottom: none; }

  .faq__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    padding: 1.5rem var(--sp-8);
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    text-align: left;
    background: var(--white);
    transition: background var(--t-fast), color var(--t-fast);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .faq__question:hover { background: #EEF4FB; }
  .faq__question[aria-expanded="true"] { background: #EEF4FB; color: var(--blue); }

  .faq__icon {
    flex-shrink: 0;
    color: var(--text-3);
    transition: transform var(--t-base), color var(--t-base);
    width: 28px;
    height: 28px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--white);
  }
  .faq__question[aria-expanded="true"] .faq__icon {
    transform: rotate(180deg);
    color: var(--blue);
    border-color: var(--blue);
    background: rgba(10,102,194,0.06);
  }

  .faq__answer { padding: 0 var(--sp-8) 1.5rem; background: #EEF4FB; }
  .faq__answer p {
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.75;
    max-width: 640px;
  }

  .faq__footer {
    font-size: var(--fs-md);
    color: var(--text-2);
    text-align: center;
  }
  .faq__link { color: var(--blue); font-weight: 500; transition: color var(--t-fast); }
  .faq__link:hover { color: var(--mid-blue); }

  .faq__answer-link { color: var(--blue); font-weight: 500; transition: color var(--t-fast); }
  .faq__answer-link:hover { color: var(--mid-blue); }

  .faq__cta {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .faq__question { padding: var(--sp-6) var(--sp-6); font-size: var(--fs-base); }
    .faq__answer { padding: 0 var(--sp-6) var(--sp-6); }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answer = document.getElementById(btn.getAttribute('aria-controls')!) as HTMLElement | null;
      btn.setAttribute('aria-expanded', String(!expanded));
      if (answer) answer.hidden = expanded;
    });
  });
</script>
