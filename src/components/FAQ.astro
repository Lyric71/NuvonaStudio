---
const faqs = [
  {
    q: 'Where are your clients based?',
    a: 'Everywhere. We work with B2B companies across Europe, North America, Asia, and beyond. LinkedIn is a global platform. So are we.',
  },
  {
    q: 'Do you only do LinkedIn?',
    a: 'Yes. No SEO, no Instagram, no "full-service" packages. LinkedIn only. That focus is why we\'re good at it.',
  },
  {
    q: 'What does it cost to get started?',
    a: 'Our Foundation retainer starts at $1,800/month. That includes strategy, content, and reporting. Most clients start there and scale up.',
    link: { text: 'See full pricing →', href: '/pricing' },
  },
  {
    q: 'Is this only for large companies?',
    a: 'No. Our packages are built for companies at different stages. $1,800/month gets you a fully managed LinkedIn presence. We also offer standalone training and ad management if a full retainer isn\'t the right fit yet.',
  },
  {
    q: 'Is advertising included?',
    a: 'Ads are a separate line. Some clients run organic only. Others run paid only. Most do both. Ad spend always goes directly to your LinkedIn account — never through us.',
  },
  {
    q: 'How do you measure results?',
    a: 'We agree on KPIs at the start — leads, pipeline, follower growth, cost per lead. Every month you get a report against those numbers. Not a deck full of impressions.',
  },
];
---

<section class="section" aria-labelledby="faq-heading">
  <div class="container container--md">

    <div class="faq__head reveal">
      <p class="eyebrow">FAQ</p>
      <h2 id="faq-heading">The things people<br />usually ask.</h2>
    </div>

    <dl class="faq__list reveal reveal-delay-1">
      {faqs.map((faq, i) => (
        <div class="faq__item">
          <dt>
            <button
              class="faq__question"
              aria-expanded="false"
              aria-controls={`faq-answer-${i}`}
              id={`faq-q-${i}`}
            >
              <span>{faq.q}</span>
              <span class="faq__icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path d="M4.5 6.75l4.5 4.5 4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
          </dt>
          <dd class="faq__answer" id={`faq-answer-${i}`} role="region" aria-labelledby={`faq-q-${i}`} hidden>
            <p>{faq.a}{faq.link && <> <a href={faq.link.href} class="faq__answer-link">{faq.link.text}</a></>}</p>
          </dd>
        </div>
      ))}
    </dl>

    <p class="faq__footer reveal">
      Still have questions? <a href="/contact" class="faq__link">Get in touch</a> — we reply within one business day.
    </p>

  </div>
</section>

<style>
  .faq__head {
    margin-bottom: var(--sp-10);
  }

  .faq__head h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    max-width: 520px;
  }

  .faq__list {
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    overflow: hidden;
    background: var(--white);
    margin-bottom: var(--sp-8);
  }

  .faq__item { border-bottom: 1px solid var(--border); }
  .faq__item:last-child { border-bottom: none; }

  .faq__question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    padding: 1.5rem var(--sp-8);
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    text-align: left;
    background: var(--white);
    transition: background var(--t-fast), color var(--t-fast);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }
  .faq__question:hover { background: #EEF4FB; }
  .faq__question[aria-expanded="true"] { background: #EEF4FB; color: var(--blue); }

  .faq__icon {
    flex-shrink: 0;
    color: var(--text-3);
    transition: transform var(--t-base), color var(--t-base);
    width: 28px;
    height: 28px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--white);
  }
  .faq__question[aria-expanded="true"] .faq__icon {
    transform: rotate(180deg);
    color: var(--blue);
    border-color: var(--blue);
    background: rgba(10,102,194,0.06);
  }

  .faq__answer { padding: 0 var(--sp-8) 1.5rem; background: #EEF4FB; }
  .faq__answer p {
    font-size: var(--fs-base);
    color: var(--text-2);
    line-height: 1.75;
    max-width: 640px;
  }

  .faq__footer {
    font-size: var(--fs-md);
    color: var(--text-2);
    text-align: center;
  }
  .faq__link { color: var(--blue); font-weight: 500; transition: color var(--t-fast); }
  .faq__link:hover { color: var(--mid-blue); }

  .faq__answer-link { color: var(--blue); font-weight: 500; transition: color var(--t-fast); }
  .faq__answer-link:hover { color: var(--mid-blue); }

  @media (max-width: 768px) {
    .faq__question { padding: var(--sp-6) var(--sp-6); font-size: var(--fs-base); }
    .faq__answer { padding: 0 var(--sp-6) var(--sp-6); }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answer = document.getElementById(btn.getAttribute('aria-controls')!) as HTMLElement | null;
      btn.setAttribute('aria-expanded', String(!expanded));
      if (answer) answer.hidden = expanded;
    });
  });
</script>
