---
import { useTranslations, localizedPath, type Lang } from '../i18n/index.ts';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const servicesLinks = [
  { label: t('footer.content'),      href: localizedPath('services/content', lang) },
  { label: t('footer.advertising'),  href: localizedPath('services/advertising', lang) },
  { label: t('footer.consulting'),   href: localizedPath('services/consulting', lang) },
];

const companyLinks = [
  { label: t('footer.about'),    href: localizedPath('about', lang) },
  { label: t('footer.work'),     href: localizedPath('work', lang) },
  { label: t('footer.insights'), href: localizedPath('insights', lang) },
  { label: t('footer.pricing'),  href: localizedPath('pricing', lang) },
  { label: t('footer.contact'),  href: localizedPath('contact', lang) },
];

const legalLinks = [
  { label: t('footer.privacy'), href: localizedPath('privacy', lang) },
  { label: t('footer.terms'),   href: localizedPath('terms', lang) },
  { label: t('footer.cookies'), href: localizedPath('cookies', lang) },
];

const networkLinks = [
  {
    label: 'BeyondBorderGroup.com',
    href: 'https://beyondbordergroup.com',
    logo: '/AgencyLogos/BBG%20PNG.webp',
    description: 'Market entry consulting for Western brands growing in China.',
  },
  {
    label: 'ChinaWebFoundry.com',
    href: 'https://www.chinawebfoundry.com',
    logo: '/AgencyLogos/Logo-ChinaWebFoundry-transparent.webp',
    description: 'Websites built for the Chinese internet — ICP, Baidu SEO, hosting.',
  },
  {
    label: 'BeyondCompass.com',
    href: 'https://beyondcompass.com',
    logo: '/AgencyLogos/BeyondCompass%20-%20Transparent%20-%204K.webp',
    description: 'Vetted distributor and Tmall partner introductions in China.',
  },
  {
    label: 'TheRedScroll.com',
    href: 'https://theredscroll.com',
    logo: '/AgencyLogos/TheredScroll%20PNG.webp',
    description: 'Daily WeChat, Douyin, RedNote and Weibo operations from the ground.',
  },
];

const groupLink = {
  label: 'BeyondBorderGroup.org',
  href: 'https://www.beyondbordergroup.org',
  logo: '/AgencyLogos/BBG%20PNG.webp',
  description: 'The umbrella group connecting our specialised China agencies.',
};

const homeHref = lang === 'en' ? '/' : `/${lang}/`;
const year = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container">

    <div class="footer__main">

      <!-- Brand -->
      <div class="footer__brand">
        <a href={homeHref} class="footer__logo-link" aria-label="Nuvora Studio, home">
          <img
            src="/nuvora-logo.webp"
            alt="Nuvora Studio"
            class="footer__logo"
            width="200"
            height="78"
          />
        </a>
        <p class="footer__tagline">{t('footer.tagline')}</p>
      </div>

      <!-- Services -->
      <nav class="footer__col" aria-label={t('footer.services')}>
        <p class="footer__col-label">{t('footer.services')}</p>
        <ul role="list" class="footer__links">
          {servicesLinks.map(l => (
            <li><a href={l.href} class="footer__link">{l.label}</a></li>
          ))}
        </ul>
        <a href={localizedPath('services', lang)} class="footer__see-all">{t('footer.see_all')}</a>
      </nav>

      <!-- Company -->
      <nav class="footer__col" aria-label={t('footer.company')}>
        <p class="footer__col-label">{t('footer.company')}</p>
        <ul role="list" class="footer__links">
          {companyLinks.map(l => (
            <li><a href={l.href} class="footer__link">{l.label}</a></li>
          ))}
        </ul>
      </nav>


    </div>

    <div class="footer__rule"></div>

    <section class="footer__network" aria-label="Our network">
      <p class="footer__col-label">Our network</p>
      <ul class="footer__network-list" role="list">
        {networkLinks.map(l => (
          <li class="footer__network-item">
            <a href={l.href} class="footer__network-logo-link" target="_blank" rel="noopener noreferrer" aria-label={l.label}>
              <img src={l.logo} alt={`${l.label} logo`} class="footer__network-logo" loading="lazy" />
            </a>
            <a href={l.href} class="footer__network-link" target="_blank" rel="noopener noreferrer">{l.label}</a>
            <p class="footer__network-desc">{l.description}</p>
          </li>
        ))}
      </ul>

      <a
        href={groupLink.href}
        class="footer__group"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${groupLink.label} — parent group`}
      >
        <span class="footer__group-logo-wrap">
          <img src={groupLink.logo} alt={`${groupLink.label} logo`} class="footer__group-logo" loading="lazy" />
        </span>
        <span class="footer__group-text">
          <span class="footer__group-eyebrow">Parent group</span>
          <span class="footer__group-name">{groupLink.label}</span>
          <span class="footer__group-desc">{groupLink.description}</span>
        </span>
        <span class="footer__group-cta" aria-hidden="true">
          Visit
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </span>
      </a>
    </section>

    <div class="footer__rule"></div>

    <div class="footer__bottom">
      <p class="footer__badges">{t('footer.badges')}</p>
      <p class="footer__copy">&copy; {year} Nuvora Studio. {t('footer.rights')}</p>
      <ul class="footer__legal" role="list">
        {legalLinks.map(l => (
          <li><a href={l.href} class="footer__legal-link">{l.label}</a></li>
        ))}
      </ul>
    </div>

  </div>
</footer>

<style is:global>
  .footer {
    background: var(--deep-navy);
    padding-block: var(--sp-16) var(--sp-8);
  }

  .footer__main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--sp-12);
    align-items: start;
    padding-bottom: var(--sp-12);
  }

  /* Brand */
  .footer__logo-link { display: inline-block; margin-bottom: var(--sp-4); }
  .footer__logo {
    height: 36px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
    opacity: 0.85;
  }
  .footer__tagline {
    font-size: var(--fs-sm);
    color: var(--navy-text-2);
    line-height: 1.65;
    max-width: 260px;
  }

  /* Columns */
  .footer__col-label {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--navy-text-3);
    margin-bottom: var(--sp-5);
  }
  .footer__links { display: flex; flex-direction: column; gap: var(--sp-3); }
  .footer__link {
    font-size: var(--fs-sm);
    color: var(--navy-text-2);
    transition: color var(--t-fast);
  }
  .footer__link:hover { color: var(--white); }

  .footer__see-all {
    display: inline-block;
    margin-top: var(--sp-4);
    font-size: var(--fs-xs);
    color: var(--cyan);
    font-weight: 500;
    transition: opacity var(--t-fast);
  }
  .footer__see-all:hover { opacity: 0.75; }

  /* Network */
  .footer__network { padding-block: var(--sp-8); }
  .footer__network-list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-6);
  }
  .footer__network-item { display: flex; flex-direction: column; gap: var(--sp-2); min-width: 0; }
  .footer__network-logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    border-radius: 10px;
    padding: var(--sp-3) var(--sp-4);
    height: 72px;
    width: 100%;
    margin-bottom: var(--sp-2);
    transition: transform var(--t-fast), box-shadow var(--t-fast);
  }
  .footer__network-logo-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.25);
  }
  .footer__network-logo {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }
  .footer__network-link {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--white);
    transition: color var(--t-fast);
  }
  .footer__network-link:hover { color: var(--cyan); }
  .footer__network-desc {
    font-size: var(--fs-xs);
    color: var(--navy-text-3);
    line-height: 1.55;
  }

  /* Parent group card */
  .footer__group {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-6);
    margin-top: var(--sp-8);
    padding: var(--sp-5) var(--sp-6);
    background:
      linear-gradient(135deg, rgba(0, 200, 220, 0.08), rgba(255, 255, 255, 0.02)) padding-box,
      linear-gradient(135deg, rgba(0, 200, 220, 0.5), rgba(255, 255, 255, 0.08)) border-box;
    border: 1px solid transparent;
    border-radius: 14px;
    transition: transform var(--t-fast), box-shadow var(--t-fast), border-color var(--t-fast);
  }
  .footer__group:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.3);
  }
  .footer__group-logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    border-radius: 10px;
    padding: var(--sp-3) var(--sp-4);
    height: 64px;
    width: 140px;
    flex-shrink: 0;
  }
  .footer__group-logo {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }
  .footer__group-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .footer__group-eyebrow {
    font-family: var(--font-body);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cyan);
  }
  .footer__group-name {
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--white);
  }
  .footer__group-desc {
    font-size: var(--fs-sm);
    color: var(--navy-text-2);
    line-height: 1.55;
  }
  .footer__group-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: var(--sp-2) var(--sp-4);
    border-radius: 999px;
    background: rgba(0, 200, 220, 0.12);
    color: var(--cyan);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .footer__group:hover .footer__group-cta {
    background: var(--cyan);
    color: var(--deep-navy);
  }

  /* Bottom bar */
  .footer__rule { height: 1px; background: rgba(255,255,255,0.06); }
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    padding-top: var(--sp-6);
    flex-wrap: wrap;
  }
  .footer__badges {
    font-size: var(--fs-xs);
    color: var(--navy-text-3);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .footer__copy {
    font-size: var(--fs-xs);
    color: var(--navy-text-3);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .footer__legal { display: flex; gap: var(--sp-5); flex-wrap: wrap; }
  .footer__legal-link {
    font-size: var(--fs-xs);
    color: var(--navy-text-3);
    transition: color var(--t-fast);
    letter-spacing: 0.02em;
  }
  .footer__legal-link:hover { color: var(--navy-text-2); }

  @media (max-width: 1024px) {
    .footer__network-list { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .footer__main { grid-template-columns: 1fr 1fr; gap: var(--sp-8); padding-bottom: var(--sp-8); }
    .footer__brand { grid-column: 1 / -1; }
    .footer__network-list { grid-template-columns: 1fr; gap: var(--sp-5); }
    .footer__group {
      grid-template-columns: 1fr;
      text-align: left;
      gap: var(--sp-4);
    }
    .footer__group-logo-wrap { width: 100%; }
    .footer__group-cta { justify-self: start; }
    .footer__bottom { flex-direction: column; align-items: flex-start; gap: var(--sp-4); }
    .footer__badges { white-space: normal; }
    .footer__legal { gap: var(--sp-4); }
  }
</style>
