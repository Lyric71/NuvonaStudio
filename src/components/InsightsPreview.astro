---
const posts = [
  {
    category: 'LinkedIn Strategy',
    tags: ['Algorithm', 'Reach'],
    title: "Why Your Reach Dropped 50%+ in 2026 (And It's Not Your Content)",
    excerpt: "LinkedIn replaced its entire algorithm with 360Brew. Reach dropped 50%, company pages lost 60%. Your content isn't the problem. The system changed.",
    date: '2026-03-29',
    slug: 'why-your-reach-dropped',
    image: '/blog/hero-reach-dropped.svg',
  },
  {
    category: 'LinkedIn Advertising',
    tags: ['Ads', 'Budget'],
    title: "Why LinkedIn Ads Cost 4 to 6x More Per Click (And When It's Still Worth It)",
    excerpt: "LinkedIn charges $5 to $12 per click. Meta charges $0.50. But clicks don't close deals. LinkedIn leads convert at 2 to 3x the rate of other platforms.",
    date: '2026-03-29',
    slug: 'why-linkedin-ads-cost-more',
    image: '/blog/hero-ads-cost.svg',
  },
  {
    category: 'LinkedIn Strategy',
    tags: ['Ads', 'Organic', 'Budget'],
    title: "LinkedIn Ads vs. Organic Content: Where to Put Your Budget in 2026",
    excerpt: "Organic LinkedIn content generates leads at half the cost of ads. But ads close gaps fast. The right split depends on your stage and deal size.",
    date: '2026-03-29',
    slug: 'linkedin-ads-vs-organic-content',
    image: '/blog/hero-ads-vs-organic.svg',
  },
];
---

<section class="section" aria-labelledby="insights-heading">
  <div class="container">

    <div class="insights__head reveal">
      <div>
        <p class="eyebrow">From the blog</p>
        <h2 id="insights-heading">LinkedIn intelligence,<br /><em>in writing.</em></h2>
      </div>
      <p class="insights__sub">
        Sharp thinking on LinkedIn strategy, B2B content, advertising, and platform updates —
        written by practitioners, not content mills.
      </p>
    </div>

    <div class="insights__grid">
      {posts.map((post, i) => (
        <article class="insights__card reveal" style={`transition-delay: ${i * 0.08}s`}>
          {post.image ? (
            <div class="insights__thumb insights__thumb--img" style={`background-image: url('${post.image}')`} aria-hidden="true"></div>
          ) : (
            <div class="vis-placeholder insights__thumb" aria-hidden="true">
              <span>Visual placeholder</span>
            </div>
          )}
          <div class="insights__card-top">
            <div class="insights__tags">
              {post.tags.map(t => <span class="insights__tag">{t}</span>)}
            </div>
          </div>
          <h3 class="insights__title">
            <a href={`/insights/${post.slug}`}>{post.title}</a>
          </h3>
          <p class="insights__excerpt">{post.excerpt}</p>
          <a href={`/insights/${post.slug}`} class="insights__read">
            Read article
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7h8m0 0L7.5 3.5M11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

    <div class="text-center reveal" style="margin-top: var(--sp-10);">
      <a href="/insights" class="btn btn--outline btn--lg">Read all articles</a>
    </div>

  </div>
</section>

<style>
  .insights__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: end;
    margin-bottom: var(--sp-12);
  }

  .insights__sub {
    font-size: var(--fs-md);
    color: var(--text-2);
    max-width: 400px;
    line-height: 1.75;
    align-self: flex-end;
  }

  .insights__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  .insights__card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-8);
    display: flex;
    flex-direction: column;
    transition: all var(--t-base);
  }
  .insights__card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  /* ── Thumbnail placeholder ── */
  .insights__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 160px;
    margin-bottom: var(--sp-6);
    border-radius: var(--r-lg);
    background: linear-gradient(135deg, rgba(10,102,194,0.04) 0%, rgba(0,168,220,0.07) 100%);
    border: 1.5px dashed rgba(10,102,194,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .insights__thumb span {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: rgba(10,102,194,0.25);
  }

  .insights__thumb--img {
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 160px;
    margin-bottom: var(--sp-6);
    border-radius: var(--r-lg);
    background-color: var(--deep-navy);
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  .insights__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-5);
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .insights__tags {
    display: flex;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }

  .insights__tag {
    display: inline-block;
    padding: 2px var(--sp-3);
    border-radius: 999px;
    background: rgba(10,102,194,0.08);
    color: var(--blue);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .insights__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--sp-3);
    line-height: 1.25;
    letter-spacing: -0.01em;
    flex: 1;
  }
  .insights__title a { color: inherit; transition: color var(--t-fast); }
  .insights__title a:hover { color: var(--blue); }

  .insights__excerpt {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.75;
    flex: 1;
    margin-bottom: var(--sp-6);
  }

  .insights__read {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue);
    margin-top: auto;
    transition: color var(--t-fast), gap var(--t-fast);
  }
  .insights__read:hover { color: var(--mid-blue); gap: var(--sp-3); }

  @media (max-width: 1024px) {
    .insights__head { grid-template-columns: 1fr; gap: var(--sp-6); }
  }
  @media (max-width: 1024px) {
    .insights__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .insights__grid { grid-template-columns: 1fr; }
  }
</style>
