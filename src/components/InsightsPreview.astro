---
const posts = [
  {
    category: 'LinkedIn Strategy',
    title: "The Real LinkedIn Problem Isn't Writing. It's Thinking.",
    excerpt: "AI can clean up your sentences. It cannot tell you what to say. That gap is where most B2B companies quietly fail.",
    date: '2026-03-23',
    slug: 'the-real-linkedin-problem',
  },
];

---

<section class="section" aria-labelledby="insights-heading" style="background: var(--off-white);">
  <div class="container">

    <div class="insights__head reveal">
      <div>
        <p class="eyebrow">From the blog</p>
        <h2 id="insights-heading">LinkedIn intelligence,<br /><em>in writing.</em></h2>
      </div>
      <p class="insights__sub">
        Sharp thinking on LinkedIn strategy, B2B content, advertising, and platform updates —
        written by practitioners, not content mills.
      </p>
    </div>

    <div class="insights__grid">
      {posts.map((post, i) => (
        <article class="insights__card reveal" style={`transition-delay: ${i * 0.08}s`}>
          <div class="insights__card-top">
            <span class="tag tag--blue">{post.category}</span>
          </div>
          <h3 class="insights__title">
            <a href={`/insights/${post.slug}`}>{post.title}</a>
          </h3>
          <p class="insights__excerpt">{post.excerpt}</p>
          <a href={`/insights/${post.slug}`} class="insights__read">Read article →</a>
        </article>
      ))}
    </div>

    <div class="text-center reveal" style="margin-top: var(--sp-10);">
      <a href="/insights" class="btn btn--outline btn--lg">Read all articles</a>
    </div>

  </div>
</section>

<style>
  .insights__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: end;
    margin-bottom: var(--sp-12);
  }

  .insights__sub {
    font-size: var(--fs-md);
    color: var(--text-2);
    max-width: 400px;
    line-height: 1.75;
    align-self: flex-end;
  }

  .insights__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  .insights__card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: var(--sp-10);
    display: flex;
    flex-direction: column;
    transition: all var(--t-base);
  }
  .insights__card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--border-2);
    transform: translateY(-2px);
  }

  .insights__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--sp-5);
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .insights__date {
    font-size: var(--fs-xs);
    color: var(--text-3);
    letter-spacing: 0.03em;
  }

  .insights__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--text);
    margin-bottom: var(--sp-3);
    line-height: 1.25;
    letter-spacing: -0.01em;
    flex: 1;
  }
  .insights__title a { color: inherit; transition: color var(--t-fast); }
  .insights__title a:hover { color: var(--blue); }

  .insights__excerpt {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.75;
    flex: 1;
    margin-bottom: var(--sp-6);
  }

  .insights__read {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue);
    margin-top: auto;
    transition: color var(--t-fast);
  }
  .insights__read:hover { color: var(--mid-blue); }

  @media (max-width: 1024px) {
    .insights__head { grid-template-columns: 1fr; gap: var(--sp-6); }
    .insights__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .insights__grid { grid-template-columns: 1fr; }
  }
</style>
