---
const painPoints = [
  {
    stat: '3%',
    label: 'of B2B companies post consistently on LinkedIn',
    detail: 'The rest post once, disappear, and wonder why nothing works.',
  },
  {
    stat: '0',
    label: 'executives with a real presence',
    detail: 'Most C-suite profiles read like CVs, not trust signals.',
  },
  {
    stat: '72%',
    label: 'of LinkedIn ad spend is wasted',
    detail: 'Wrong audience, wrong format, wrong funnel. Budget burns fast without structure.',
  },
];
---

<section class="section problem" aria-labelledby="problem-heading">
  <div class="container">

    <div class="problem__hero reveal">
      <div class="problem__head">
        <p class="eyebrow eyebrow--light">The problem</p>
        <h2 id="problem-heading">
          Most B2B companies are<br />invisible on LinkedIn.
        </h2>
        <p class="problem__sub">
          They post sporadically. Their company page is outdated. Their executives have no presence.
          Their ads reach the wrong people. LinkedIn rewards consistency and expertise. Without both,
          you are wasting the best B2B channel available.
        </p>
      </div>

      <div class="problem__visual">
        <img
          src="/problem-linkedin.png"
          alt="Split-screen comparison of two laptops: left shows empty LinkedIn notifications with zero impressions and flat analytics, right shows a flood of connection requests, new leads, and 12,400 reach"
          class="problem__img"
          width="1024"
          height="1024"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <div class="problem__grid">
      {painPoints.map((p, i) => (
        <div class="problem__card reveal" style={`transition-delay: ${i * 0.1}s`}>
          <p class="problem__stat">{p.stat}</p>
          <p class="problem__label">{p.label}</p>
          <p class="problem__detail">{p.detail}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .problem {
    background: var(--deep-navy);
  }

  /* ── Hero row ── */
  .problem__hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: center;
    margin-bottom: var(--sp-16);
  }

  .problem__head {
    max-width: 540px;
  }

  .problem__head :global(.eyebrow) {
    color: var(--cyan);
  }

  .problem__head :global(h2) {
    color: var(--white);
    margin-bottom: var(--sp-6);
  }

  .problem__sub {
    font-size: var(--fs-md);
    color: var(--navy-text-2);
    line-height: 1.75;
  }

  /* ── Visual ── */
  .problem__visual {
    border-radius: var(--r-xl);
    overflow: hidden;
  }

  .problem__img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Stat cards ── */
  .problem__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  .problem__card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--r-xl);
    padding: var(--sp-8);
    transition: all var(--t-base);
  }

  .problem__card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-3px);
  }

  .problem__stat {
    font-family: var(--font-display);
    font-size: var(--fs-5xl);
    font-weight: 700;
    line-height: 1;
    color: var(--cyan);
    margin-bottom: var(--sp-4);
    letter-spacing: -0.03em;
  }

  .problem__label {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--white);
    line-height: 1.3;
    margin-bottom: var(--sp-4);
    letter-spacing: -0.01em;
  }

  .problem__detail {
    font-size: var(--fs-sm);
    color: var(--navy-text-2);
    line-height: 1.7;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .problem__hero {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .problem__head { max-width: 660px; margin-inline: auto; }
    .problem__visual { max-width: 480px; margin-inline: auto; }
    .problem__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .problem__grid { grid-template-columns: 1fr; }
    .problem__stat { font-size: var(--fs-4xl); }
  }
</style>
